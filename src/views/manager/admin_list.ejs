<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 gap-3">
    <div>
        <span class="badge bg-danger-subtle text-danger px-3 py-2 rounded-pill fw-bold mb-2 tracking-widest x-small text-uppercase"><i class="bi bi-shield-lock-fill me-1"></i>System Admin</span>
        <h2 class="fw-black mb-1 text-dark" style="font-family: 'Outfit', sans-serif;">Tất cả Địa điểm</h2>
        <p class="text-muted mb-0 small">Quản lý tổng thể hệ thống, theo dõi và chỉnh sửa mọi điểm đến.</p>
    </div>
</div>

<div class="row g-4">
    <% allDests.forEach(dest => { %>
        <div class="col-md-6 col-xl-4">
            <div class="card-bl border-0 shadow-sm rounded-4 overflow-hidden h-100 bg-white group-hover transition-hover">
                <div class="position-relative ratio ratio-21x9">
                    <img src="<%= typeof fixImg === 'function' ? fixImg(dest.cover_image) : dest.cover_image %>" class="w-100 h-100 object-fit-cover transition-transform duration-500 group-hover-scale" alt="<%= dest.name %>">
                    <div class="position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 100%);"></div>
                    <div class="position-absolute top-0 end-0 m-3">
                        <span class="badge <%= dest.is_active ? 'bg-success' : 'bg-secondary' %> bg-opacity-75 rounded-pill shadow-sm"><%= dest.is_active ? 'Đang hoạt động' : 'Tạm dừng' %></span>
                    </div>
                </div>
                <div class="p-4 d-flex flex-column" style="flex-grow: 1;">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h5 class="fw-bold mb-0 text-dark text-truncate pe-2"><%= dest.name %></h5>
                    </div>
                    <p class="small text-muted mb-4 line-clamp-2 flex-grow-1"><%= dest.short_desc || dest.highlight || 'Chưa có mô tả' %></p>
                    
                    <div class="d-flex align-items-center gap-2 mt-auto border-top pt-3">
                        <a href="/manager?dest_id=<%= dest.id %>" class="btn btn-primary-bl flex-grow-1 rounded-pill fw-bold shadow-sm">
                            <i class="bi bi-gear-fill me-2"></i>Quản lý Không gian
                        </a>
                        <a href="/explore/<%= dest.slug %>" target="_blank" class="btn btn-outline-secondary rounded-circle" style="width: 45px; height: 45px; padding: 0; line-height: 43px; text-align: center;" title="Xem thực tế">
                            <i class="bi bi-eye text-muted"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    <% }) %>
</div>

<style>
    .transition-hover { transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), box-shadow 0.4s ease; }
    .transition-hover:hover { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(0,0,0,0.1) !important; }
    .group-hover-scale { transition: transform 0.5s ease; }
    .group-hover:hover .group-hover-scale { transform: scale(1.05); }
    .tracking-widest { letter-spacing: 1px; }
    .x-small { font-size: 0.75rem; }
</style>
