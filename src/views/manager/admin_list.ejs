<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-black mb-1">Tất cả địa điểm</h2>
        <p class="text-muted mb-0">Chọn một địa điểm để xem thống kê và cập nhật nội dung.</p>
    </div>
    <div>
        <span class="badge bg-primary text-white px-3 py-2 rounded-pill">Quản trị viên Hệ thống</span>
    </div>
</div>

<div class="row g-4">
    <% allDests.forEach(dest => { %>
        <div class="col-md-6 col-xl-4">
            <div class="admin-card h-100 position-relative">
                <div class="ratio ratio-21x9">
                    <img src="<%= typeof fixImg === 'function' ? fixImg(dest.cover_image) : dest.cover_image %>" class="w-100 h-100 object-fit-cover" alt="<%= dest.name %>">
                </div>
                <div class="p-4">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h5 class="fw-bold mb-0 text-truncate pe-2"><%= dest.name %></h5>
                        <span class="badge <%= dest.is_active ? 'bg-success' : 'bg-secondary' %>"><%= dest.is_active ? 'Hoạt động' : 'Tạm ẩn' %></span>
                    </div>
                    <p class="small text-muted mb-4 line-clamp-2" style="height: 40px;"><%= dest.short_desc || dest.highlight || 'Chưa có mô tả' %></p>
                    
                    <div class="d-flex align-items-center gap-2">
                        <a href="/manager?dest_id=<%= dest.id %>" class="btn btn-primary-bl flex-grow-1 rounded-pill">
                            Quản lý nội dung
                        </a>
                        <a href="/explore/<%= dest.slug %>" target="_blank" class="btn btn-light border rounded-circle" style="width: 40px; height: 40px; padding: 0; line-height: 38px; text-align: center;">
                            <i class="bi bi-box-arrow-up-right text-muted"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    <% }) %>
</div>
