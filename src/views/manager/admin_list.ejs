<!-- Admin-level Destination List (Manager Panel) -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1" style="color: var(--admin-text); font-family: 'Inter', sans-serif;">Chọn địa điểm quản lý</h4>
        <p class="mb-0" style="color: var(--admin-muted); font-size: 0.85rem;">Với quyền Admin, bạn có thể chỉnh sửa nội dung bất kỳ địa điểm nào</p>
    </div>
</div>

<div class="row g-3">
    <% allDests.forEach(d => { %>
    <div class="col-md-6 col-xl-4">
        <a href="/manager?dest_id=<%= d.id %>" class="text-decoration-none">
            <div class="chart-card h-100 p-3 hover-lift border border-opacity-10" style="border-color: var(--admin-accent) !important; transition: transform 0.2s;">
                <div class="d-flex align-items-center gap-3">
                    <img src="<%= fixImg(d.cover_image) %>" class="rounded-3" style="width: 80px; height: 60px; object-fit: cover;">
                    <div class="overflow-hidden">
                        <h6 class="fw-bold mb-1 text-truncate" style="color: var(--admin-text);"><%= d.name %></h6>
                        <span class="badge rounded-pill" style="background: rgba(240,165,0,0.1); color: var(--admin-accent); font-size: 0.65rem;">
                            <i class="bi bi-gear-fill me-1"></i>Chỉnh sửa ngay
                        </span>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <% }) %>
</div>

<style>
.hover-lift:hover {
    transform: translateY(-5px);
    background: rgba(0,0,0,0.02);
}
</style>
