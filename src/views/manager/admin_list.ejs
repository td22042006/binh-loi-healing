<section class="site-section bg-light min-vh-100">
    <div class="container-site">
        <div class="d-flex justify-content-between align-items-end mb-5">
            <div>
                <h1 class="display-text mb-0">Quản trị Hệ thống</h1>
                <p class="text-muted">Chọn một địa điểm để bắt đầu quản lý nội dung.</p>
            </div>
            <div class="badge bg-primary px-3 py-2 rounded-pill">ADMIN</div>
        </div>

        <div class="row g-4">
            <% allDests.forEach(dest => { %>
                <div class="col-md-4">
                    <div class="card-bl h-100 shadow-sm border-0">
                        <div class="p-4">
                            <h5 class="fw-black mb-1"><%= dest.name %></h5>
                            <p class="small text-muted mb-4"><i class="bi bi-geo-alt me-1"></i> <%= dest.short_desc %></p>
                            <a href="/manager?dest_id=<%= dest.id %>" class="btn btn-primary-bl btn-sm w-100 rounded-pill py-2">
                                Quản lý địa điểm này <i class="bi bi-arrow-right ms-2"></i>
                            </a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</section>
