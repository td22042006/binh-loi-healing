<!-- Premium Manager Dashboard -->
<div class="container-fluid p-0 animate__animated animate__fadeIn">
    <!-- Header banner -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1 font-display" style="color: var(--admin-text); font-family: 'Inter', sans-serif;">
                🏛️ <%= dest.name %> - Bảng điều khiển
            </h3>
            <p class="mb-0 text-muted small">
                Theo dõi thời gian thực lượt truy cập, check-in, doanh thu tại địa điểm của bạn.
            </p>
        </div>
        <div>
            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-20 rounded-pill px-3 py-2 fw-semibold">
                <i class="bi bi-shield-check me-1"></i>Trạng thái hoạt động
            </span>
        </div>
    </div>

    <!-- Manager Tab Navigation -->
    <div class="d-flex gap-2 mb-4 border-bottom border-secondary border-opacity-10 pb-3">
        <a href="/manager<%= (typeof dest !== 'undefined' && user.role === 'admin') ? '?dest_id=' + dest.id : '' %>" class="btn btn-primary btn-sm rounded-pill px-3">
            <i class="bi bi-grid-1x2-fill me-1"></i> Bảng điều khiển
        </a>
        <a href="/manager/chat<%= (typeof dest !== 'undefined' && user.role === 'admin') ? '?dest_id=' + dest.id : '' %>" class="btn btn-outline-secondary btn-sm rounded-pill px-3 border-opacity-25">
            <i class="bi bi-chat-dots-fill me-1"></i> Hộp thư Hỗ trợ
        </a>
        <a href="/manager/destination<%= (typeof dest !== 'undefined' && user.role === 'admin') ? '?dest_id=' + dest.id : '' %>" class="btn btn-outline-secondary btn-sm rounded-pill px-3 border-opacity-25">
            <i class="bi bi-geo-alt-fill me-1"></i> Quản lý Địa điểm
        </a>
        <% if (user.role === 'admin') { %>
            <a href="/manager" class="btn btn-outline-warning btn-sm rounded-pill px-3 ms-auto text-warning border-opacity-25">
                <i class="bi bi-arrow-left-short me-1"></i> Chọn địa điểm khác
            </a>
        <% } %>
    </div>

    <!-- Stats and Timeline Grid -->
    <div class="row g-4">
        <!-- Stats Panel -->
        <div class="col-xl-6 col-lg-6">
            <div class="d-flex flex-column gap-4">
                
                <% if (typeof success !== 'undefined' && success) { %>
                    <div class="alert alert-success alert-dismissible fade show rounded-3 border-0 shadow-sm" role="alert" style="background: rgba(16,185,129,0.15); color: #86efac;">
                        <i class="bi bi-check-circle-fill me-2 text-success"></i><%= success %>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger alert-dismissible fade show rounded-3 border-0 shadow-sm" role="alert" style="background: rgba(239,68,68,0.15); color: #fca5a5;">
                        <i class="bi bi-exclamation-triangle-fill me-2 text-danger"></i><%= error %>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>

                <!-- 2x2 Stats Dashboard Grid -->
                <div class="row g-3">
                    <!-- Workshop Bookings -->
                    <div class="col-6">
                        <div class="stat-card position-relative overflow-hidden">
                            <div class="stat-icon mb-3" style="background: rgba(240,165,0,0.12); color: #f0a500;">
                                <i class="bi bi-ticket-perforated-fill"></i>
                            </div>
                            <small class="text-uppercase tracking-wider text-muted fw-bold" style="font-size: 0.68rem; letter-spacing: 0.5px;">Lượt đặt Workshop</small>
                            <h3 class="fw-black mt-1 mb-0 font-display" style="color: var(--admin-text);"><%= stats.workshopBookings.toLocaleString() %></h3>
                            <div class="stat-bg-glow" style="background: radial-gradient(circle, rgba(240,165,0,0.08) 0%, transparent 70%);"></div>
                        </div>
                    </div>

                    <!-- Revenue -->
                    <div class="col-6">
                        <div class="stat-card position-relative overflow-hidden">
                            <div class="stat-icon mb-3" style="background: rgba(16,185,129,0.12); color: #10b981;">
                                <i class="bi bi-cash-stack"></i>
                            </div>
                            <small class="text-uppercase tracking-wider text-muted fw-bold" style="font-size: 0.68rem; letter-spacing: 0.5px;">Doanh thu (Workshop)</small>
                            <h3 class="fw-black mt-1 mb-0 font-display text-truncate" style="color: var(--admin-text); font-size: 1.45rem;"><%= stats.revenue.toLocaleString('vi-VN') %>đ</h3>
                            <div class="stat-bg-glow" style="background: radial-gradient(circle, rgba(16,185,129,0.08) 0%, transparent 70%);"></div>
                        </div>
                    </div>
                    <!-- Total Check-ins -->
                    <div class="col-6">
                        <div class="stat-card position-relative overflow-hidden">
                            <div class="stat-icon mb-3" style="background: rgba(59,130,246,0.12); color: #3b82f6;">
                                <i class="bi bi-qr-code-scan"></i>
                            </div>
                            <small class="text-uppercase tracking-wider text-muted fw-bold" style="font-size: 0.68rem; letter-spacing: 0.5px;">Lượt Check-in</small>
                            <h3 class="fw-black mt-1 mb-0 font-display" style="color: var(--admin-text);"><%= stats.checkins %></h3>
                            <div class="stat-bg-glow" style="background: radial-gradient(circle, rgba(59,130,246,0.08) 0%, transparent 70%);"></div>
                        </div>
                    </div>
                    <!-- Average Rating -->
                    <div class="col-6">
                        <div class="stat-card position-relative overflow-hidden">
                            <div class="stat-icon mb-3" style="background: rgba(139,92,246,0.12); color: #8b5cf6;">
                                <i class="bi bi-star-fill"></i>
                            </div>
                            <small class="text-uppercase tracking-wider text-muted fw-bold" style="font-size: 0.68rem; letter-spacing: 0.5px;">Đánh giá địa điểm</small>
                            <h3 class="fw-black mt-1 mb-0 font-display" style="color: var(--admin-text);"><%= stats.avgRating %> <span class="fs-6 text-muted">/ 5.0</span></h3>
                            <div class="stat-bg-glow" style="background: radial-gradient(circle, rgba(139,92,246,0.08) 0%, transparent 70%);"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 2nd Column: Timeline and Reviews -->
        <div class="col-xl-6 col-lg-6">
            <div class="d-flex flex-column gap-4">
                <!-- Live Check-in Timeline -->
                <div class="chart-card">
                    <h6 class="fw-bold text-uppercase tracking-widest small mb-4" style="color: var(--admin-primary); font-size: 0.72rem; letter-spacing: 1px;">
                        👣 Lượt Check-in thời gian thực (Real-time Log)
                    </h6>
                    
                    <div class="checkin-timeline overflow-y-auto custom-scrollbar" style="max-height: 250px; padding-right: 5px;">
                        <% if (recentCheckins && recentCheckins.length > 0) { %>
                            <% recentCheckins.forEach((check, index) => { %>
                                <div class="d-flex align-items-start gap-3 mb-3 pb-3 border-bottom border-secondary border-opacity-10 timeline-item">
                                    <div class="position-relative">
                                        <img src="<%= check.avatar || '/images/default-avatar.png' %>" class="rounded-circle" style="width: 38px; height: 38px; object-fit: cover; border: 2px solid rgba(16,185,129,0.3);">
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <h6 class="fw-bold mb-0 small" style="color: var(--admin-text); font-size: 0.8rem;"><%= check.full_name || 'Du khách ẩn danh' %></h6>
                                            <small class="text-muted" style="font-size: 0.65rem;">
                                                <%= new Date(check.created_at).toLocaleTimeString('vi-VN', {hour: '2-digit', minute: '2-digit'}) %>
                                            </small>
                                        </div>
                                        <p class="text-muted x-small mb-0" style="line-height: 1.4; font-size: 0.72rem;">
                                            Đã xác thực check-in thành công qua <span class="text-success fw-semibold"><%= check.checkin_method === 'qr' ? 'Mã QR tại điểm' : 'Bản đồ GPS' %></span>.
                                            Nhận <strong class="text-warning">+<%= check.points_earned %> điểm</strong>.
                                        </p>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="text-center py-5 opacity-25">
                                <i class="bi bi-qr-code-scan display-6 mb-3 d-block text-muted"></i>
                                <h6 class="fw-bold mb-1 small">Chưa có lượt check-in nào</h6>
                            </div>
                        <% } %>
                    </div>
                </div>

                <!-- Recent User Reviews -->
                <div class="chart-card">
                    <h6 class="fw-bold text-uppercase tracking-widest small mb-4" style="color: #8b5cf6; font-size: 0.72rem; letter-spacing: 1px;">
                        ⭐ Ý kiến đóng góp từ Du khách
                    </h6>

                    <div class="reviews-list overflow-y-auto custom-scrollbar" style="max-height: 250px; padding-right: 5px;">
                        <% if (recentReviews && recentReviews.length > 0) { %>
                            <% recentReviews.forEach(r => { %>
                                <div class="review-item p-3 rounded-3 mb-2 border border-secondary border-opacity-10" style="background: rgba(0,0,0,0.02);">
                                    <div class="d-flex align-items-center justify-content-between mb-2">
                                        <div class="d-flex align-items-center gap-2">
                                            <img src="<%= r.avatar || '/images/default-avatar.png' %>" class="rounded-circle" style="width: 28px; height: 28px; object-fit: cover;">
                                            <div>
                                                <h6 class="fw-bold mb-0" style="color: var(--admin-text); font-size: 0.75rem;"><%= r.full_name || 'Du khách ẩn danh' %></h6>
                                                <small class="text-muted" style="font-size: 0.6rem;"><%= new Date(r.created_at).toLocaleDateString('vi-VN') %></small>
                                            </div>
                                        </div>
                                        <div class="rating-stars text-warning" style="font-size: 0.7rem;">
                                            <% for(let i=1; i<=5; i++) { %>
                                                <i class="bi <%= i <= r.rating ? 'bi-star-fill' : 'bi-star' %>"></i>
                                            <% } %>
                                        </div>
                                    </div>
                                    <p class="text-muted mb-0 x-small italic" style="line-height: 1.5; font-size: 0.72rem;">
                                        "<%= r.content %>"
                                    </p>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="text-center py-5 opacity-25">
                                <i class="bi bi-chat-heart display-6 mb-3 d-block text-muted"></i>
                                <h6 class="fw-bold mb-1 small">Chưa có đánh giá nào</h6>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Manager Charts Row -->
    <div class="row g-4 mt-2 mb-4">
        <div class="col-lg-6">
            <div class="chart-card">
                <h6 class="fw-bold mb-3" style="font-family: 'Inter', sans-serif; color: var(--admin-primary);">Lượt Check-in (7 ngày gần nhất)</h6>
                <div style="position: relative; height: 220px;">
                    <canvas id="managerCheckinChart"></canvas>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="chart-card">
                <h6 class="fw-bold mb-3" style="font-family: 'Inter', sans-serif; color: #8b5cf6;">Xu hướng Đánh giá (7 ngày gần nhất)</h6>
                <div style="position: relative; height: 220px;">
                    <canvas id="managerRatingChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    // Check-in Chart
    const checkinData = <%- JSON.stringify(chartData.dailyCheckins) %>;
    new Chart(document.getElementById('managerCheckinChart'), {
        type: 'line',
        data: {
            labels: checkinData.map(d => { const date = new Date(d.day); return date.getDate() + '/' + (date.getMonth()+1); }),
            datasets: [{
                label: 'Lượt Check-in',
                data: checkinData.map(d => d.count),
                borderColor: '#1e5a3e',
                backgroundColor: 'rgba(30, 90, 62, 0.1)',
                fill: true,
                tension: 0.4,
                borderWidth: 2,
                pointRadius: 3,
                pointBackgroundColor: '#1e5a3e'
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { color: 'rgba(0,0,0,0.03)' }, ticks: { color: '#71717a', font: { size: 10 } } },
                y: { grid: { color: 'rgba(0,0,0,0.03)' }, ticks: { color: '#71717a', font: { size: 10 } }, beginAtZero: true }
            }
        }
    });

    // Rating Chart
    const ratingData = <%- JSON.stringify(chartData.dailyRatings) %>;
    new Chart(document.getElementById('managerRatingChart'), {
        type: 'line',
        data: {
            labels: ratingData.map(d => { const date = new Date(d.day); return date.getDate() + '/' + (date.getMonth()+1); }),
            datasets: [{
                label: 'Điểm Đánh giá',
                data: ratingData.map(d => d.rating),
                borderColor: '#8b5cf6',
                backgroundColor: 'rgba(139, 92, 246, 0.1)',
                fill: true,
                tension: 0.4,
                borderWidth: 2,
                pointRadius: 3,
                pointBackgroundColor: '#8b5cf6'
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { color: 'rgba(0,0,0,0.03)' }, ticks: { color: '#71717a', font: { size: 10 } } },
                y: { grid: { color: 'rgba(0,0,0,0.03)' }, ticks: { color: '#71717a', font: { size: 10 } }, min: 1, max: 5 }
            }
        }
    });
});
</script>

<style>
    /* Stat Cards */
    .stat-card {

        background: var(--admin-surface);
        border: 1px solid var(--admin-border);
        border-radius: 16px;
        padding: 24px;
        transition: all 0.3s ease;
    }
    .stat-card:hover {
        transform: translateY(-2px);
        border-color: rgba(255, 255, 255, 0.12);
        box-shadow: 0 8px 16px rgba(0,0,0,0.15);
    }
    .stat-card .stat-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
    }
    .stat-bg-glow {
        position: absolute;
        width: 100px;
        height: 100px;
        bottom: -20px;
        right: -20px;
        z-index: 0;
        pointer-events: none;
    }
    .timeline-item:last-child {
        border-bottom: none !important;
        margin-bottom: 0 !important;
        padding-bottom: 0 !important;
    }
    .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(0,0,0,0.1);
        border-radius: 10px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: rgba(0,0,0,0.2);
    }
</style>
