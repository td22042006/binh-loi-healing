<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-black mb-1 text-primary">Quản lý: <%= dest.name %></h2>
        <p class="text-muted mb-0">Cập nhật nội dung hiển thị và phản hồi du khách.</p>
    </div>
</div>

<% if (typeof req !== 'undefined' && req.query.success) { %>
    <div class="alert alert-success rounded-4 border-0 shadow-sm mb-4"><i class="bi bi-check-circle-fill me-2"></i> <%= req.query.success %></div>
<% } %>
<% if (typeof req !== 'undefined' && req.query.error) { %>
    <div class="alert alert-danger rounded-4 border-0 shadow-sm mb-4"><i class="bi bi-exclamation-triangle-fill me-2"></i> <%= req.query.error %></div>
<% } %>

<div class="row g-4">
    <!-- Stats Column -->
    <div class="col-lg-3">
        <div class="admin-card p-4 text-center mb-4 h-100 d-flex flex-column justify-content-center">
            <div class="display-3 text-primary fw-black mb-2"><%= stats.checkins %></div>
            <p class="text-muted small text-uppercase fw-bold mb-0">Lượt Check-in</p>
        </div>
    </div>

    <!-- Update Content Column -->
    <div class="col-lg-5">
        <div class="admin-card p-4 h-100">
            <h5 class="fw-bold mb-4"><i class="bi bi-pencil-square me-2 text-primary"></i> Thông tin địa điểm</h5>
            <form action="/manager/update" method="POST">
                <input type="hidden" name="dest_id" value="<%= dest.id %>">
                <div class="row g-3">
                    <div class="col-md-6 mb-3">
                        <label class="form-label small fw-bold text-muted">Giờ mở cửa</label>
                        <input type="text" name="open_hours" class="form-control admin-input" value="<%= dest.open_hours %>">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label small fw-bold text-muted">Chi phí dự kiến</label>
                        <input type="text" name="cost" class="form-control admin-input" value="<%= dest.cost %>">
                    </div>
                </div>
                <div class="row g-3">
                    <div class="col-md-6 mb-3">
                        <label class="form-label small fw-bold text-muted">Thời điểm đẹp</label>
                        <input type="text" name="best_time" class="form-control admin-input" value="<%= dest.best_time %>">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label small fw-bold text-muted">Mô tả ngắn</label>
                        <input type="text" name="short_desc" class="form-control admin-input" value="<%= dest.short_desc %>">
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold text-muted">Ảnh Cover (URL)</label>
                    <input type="text" name="cover_image" class="form-control admin-input" value="<%= dest.cover_image %>">
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold text-muted">Điểm nhấn (Highlight)</label>
                    <input type="text" name="highlight" class="form-control admin-input" value="<%= dest.highlight %>">
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold text-muted">Mẹo check-in (Tip)</label>
                    <input type="text" name="checkin_tip" class="form-control admin-input" value="<%= dest.checkin_tip %>">
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold text-muted">Mô tả Zen Walk</label>
                    <input type="text" name="zen_walk_desc" class="form-control admin-input" value="<%= dest.zen_walk_desc %>">
                </div>
                <div class="mb-4">
                    <label class="form-label small fw-bold text-muted">Câu chuyện (Story)</label>
                    <textarea name="story" class="form-control admin-input" rows="5"><%= dest.story %></textarea>
                </div>
                <button type="submit" class="btn btn-primary-bl w-100 rounded-pill py-3 fw-bold shadow-sm">LƯU THAY ĐỔI</button>
            </form>
        </div>
    </div>

    <!-- Messages Column -->
    <div class="col-lg-4">
        <div class="admin-card p-4 h-100 d-flex flex-column">
            <h5 class="fw-bold mb-4"><i class="bi bi-chat-left-text me-2 text-primary"></i> Tin nhắn du khách</h5>
            <div class="message-list flex-grow-1 overflow-auto pe-2" style="max-height: 600px;">
                <% if (messages && messages.length > 0) { %>
                    <% messages.forEach(msg => { %>
                        <div class="p-3 rounded-4 bg-light border mb-3">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="small fw-bold text-primary">
                                    <% if (msg.sender_uuid) { %>
                                        <i class="bi bi-person-circle me-1"></i> Khách #<%= msg.sender_uuid.substring(0, 8) %>
                                    <% } else { %>
                                        <i class="bi bi-shield-check me-1"></i> Bạn
                                    <% } %>
                                </span>
                                <span class="x-small text-muted"><%= new Date(msg.created_at).toLocaleDateString('vi-VN') %></span>
                            </div>
                            <p class="small mb-0 text-dark"><%= msg.message %></p>
                            <% if (msg.sender_uuid) { %>
                                <div class="mt-2 text-end">
                                    <button class="btn btn-sm btn-outline-secondary rounded-pill px-3 py-1 x-small" onclick="openReplyModal('<%= msg.id %>', '<%= msg.sender_uuid.substring(0, 8) %>')">Phản hồi</button>
                                </div>
                            <% } %>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="text-center py-5 h-100 d-flex flex-column justify-content-center align-items-center opacity-50">
                        <i class="bi bi-chat-dots display-3 mb-3"></i>
                        <p class="small mb-0">Chưa có tin nhắn nào</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- Reply Modal -->
<div class="modal fade" id="replyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header bg-primary text-white border-0 py-3">
                <h5 class="modal-title fw-bold">Phản hồi Khách #<span id="reply-to-id"></span></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-modal="hide" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="reply-msg-id">
                <div class="mb-3">
                    <textarea id="reply-text" class="form-control admin-input" rows="4" placeholder="Nhập nội dung phản hồi..."></textarea>
                </div>
                <button class="btn btn-primary-bl w-100 rounded-pill py-2 fw-bold" onclick="sendReply()">GỬI PHẢN HỒI</button>
            </div>
        </div>
    </div>
</div>

<script>
function openReplyModal(msgId, guestId) {
    document.getElementById('reply-msg-id').value = msgId;
    document.getElementById('reply-to-id').innerText = guestId;
    new bootstrap.Modal(document.getElementById('replyModal')).show();
}

function sendReply() {
    const msgId = document.getElementById('reply-msg-id').value;
    const text = document.getElementById('reply-text').value;
    if (!text) return alert('Vui lòng nhập nội dung');

    axios.post('/api/reply-message', {
        messageId: msgId,
        replyText: text
    }).then(res => {
        if (res.data.success) {
            location.reload();
        }
    }).catch(err => {
        alert('Lỗi: ' + (err.response?.data?.message || err.message));
    });
}
</script>

<style>
.x-small { font-size: 0.75rem; }
.message-list::-webkit-scrollbar { width: 6px; }
.message-list::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.1); border-radius: 10px; }
.message-list::-webkit-scrollbar-track { background: transparent; }
</style>
