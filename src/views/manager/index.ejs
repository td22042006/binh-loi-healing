<!-- Premium Manager Dashboard & Side-by-Side Fanpage Chat Panel -->
<div class="container-fluid p-0 animate__animated animate__fadeIn">
    <!-- Header banner -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1 font-display text-white" style="font-family: 'Outfit', sans-serif;">
                🏛️ <%= dest.name %> – Quản lý Panel
            </h3>
            <p class="mb-0 text-muted small">
                Theo dõi thời gian thực lượt truy cập, check-in, doanh thu và hỗ trợ trực tuyến du khách.
            </p>
        </div>
        <div>
            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-20 rounded-pill px-3 py-2 fw-semibold">
                <i class="bi bi-shield-check me-1"></i>Manager Mode Active
            </span>
        </div>
    </div>

    <!-- MAIN GRID LAYOUT -->
    <div class="row g-4">
        <!-- 1. LEFT COLUMN: REAL-TIME ANALYTICS DASHBOARD -->
        <div class="col-xl-5 col-lg-6">
            <div class="d-flex flex-column gap-4">
                
                <% if (typeof success !== 'undefined' && success) { %>
                    <div class="alert alert-success alert-dismissible fade show rounded-3 border-0 shadow-sm" role="alert" style="background: rgba(16,185,129,0.15); color: #86efac;">
                        <i class="bi bi-check-circle-fill me-2 text-success"></i><%= success %>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger alert-dismissible fade show rounded-3 border-0 shadow-sm" role="alert" style="background: rgba(239,68,68,0.15); color: #fca5a5;">
                        <i class="bi bi-exclamation-triangle-fill me-2 text-danger"></i><%= error %>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>

                <!-- 2x2 Stats Dashboard Grid -->
                <div class="row g-3">
                    <!-- Page Views -->
                    <div class="col-6">
                        <div class="stat-card position-relative overflow-hidden">
                            <div class="stat-icon mb-3" style="background: rgba(240,165,0,0.12); color: #f0a500;">
                                <i class="bi bi-eye-fill"></i>
                            </div>
                            <small class="text-uppercase tracking-wider text-muted fw-bold" style="font-size: 0.68rem; letter-spacing: 0.5px;">Lượt truy cập thực</small>
                            <h3 class="fw-black text-white mt-1 mb-0 font-display"><%= stats.pageViews.toLocaleString() %></h3>
                            <div class="stat-bg-glow" style="background: radial-gradient(circle, rgba(240,165,0,0.08) 0%, transparent 70%);"></div>
                        </div>
                    </div>
                    <!-- Revenue -->
                    <div class="col-6">
                        <div class="stat-card position-relative overflow-hidden">
                            <div class="stat-icon mb-3" style="background: rgba(16,185,129,0.12); color: #10b981;">
                                <i class="bi bi-cash-stack"></i>
                            </div>
                            <small class="text-uppercase tracking-wider text-muted fw-bold" style="font-size: 0.68rem; letter-spacing: 0.5px;">Doanh thu (Workshop)</small>
                            <h3 class="fw-black text-white mt-1 mb-0 font-display text-truncate" style="font-size: 1.45rem;"><%= stats.revenue.toLocaleString('vi-VN') %>đ</h3>
                            <div class="stat-bg-glow" style="background: radial-gradient(circle, rgba(16,185,129,0.08) 0%, transparent 70%);"></div>
                        </div>
                    </div>
                    <!-- Total Check-ins -->
                    <div class="col-6">
                        <div class="stat-card position-relative overflow-hidden">
                            <div class="stat-icon mb-3" style="background: rgba(59,130,246,0.12); color: #3b82f6;">
                                <i class="bi bi-qr-code-scan"></i>
                            </div>
                            <small class="text-uppercase tracking-wider text-muted fw-bold" style="font-size: 0.68rem; letter-spacing: 0.5px;">Lượt Check-in</small>
                            <h3 class="fw-black text-white mt-1 mb-0 font-display"><%= stats.checkins %></h3>
                            <div class="stat-bg-glow" style="background: radial-gradient(circle, rgba(59,130,246,0.08) 0%, transparent 70%);"></div>
                        </div>
                    </div>
                    <!-- Average Rating -->
                    <div class="col-6">
                        <div class="stat-card position-relative overflow-hidden">
                            <div class="stat-icon mb-3" style="background: rgba(139,92,246,0.12); color: #8b5cf6;">
                                <i class="bi bi-star-fill"></i>
                            </div>
                            <small class="text-uppercase tracking-wider text-muted fw-bold" style="font-size: 0.68rem; letter-spacing: 0.5px;">Đánh giá địa điểm</small>
                            <h3 class="fw-black text-white mt-1 mb-0 font-display"><%= stats.avgRating %> <span class="fs-6 text-muted">/ 5.0</span></h3>
                            <div class="stat-bg-glow" style="background: radial-gradient(circle, rgba(139,92,246,0.08) 0%, transparent 70%);"></div>
                        </div>
                    </div>
                </div>

                <!-- Config Destination Info Form -->
                <div class="chart-card">
                    <h6 class="fw-bold text-uppercase tracking-widest small mb-3" style="color: var(--admin-accent); font-size: 0.72rem; letter-spacing: 1px;">
                        ⚙️ Cấu hình thông tin địa điểm (Destination Profile)
                    </h6>
                    <form action="/manager/update" method="POST" id="dest-update-form" class="mt-3">
                        <input type="hidden" name="dest_id" value="<%= dest.id %>">
                        
                        <div class="row g-3">
                            <!-- Open Hours -->
                            <div class="col-md-6">
                                <label class="text-muted small fw-bold mb-1 d-block" style="font-size: 0.7rem;">⏰ Giờ mở cửa</label>
                                <input type="text" name="open_hours" value="<%= dest.open_hours %>" class="form-control bg-dark border-secondary border-opacity-20 text-white rounded-3 small py-2" placeholder="Ví dụ: 08:00 - 17:00" style="font-size: 0.75rem;">
                            </div>
                            
                            <!-- Expected Cost -->
                            <div class="col-md-6">
                                <label class="text-muted small fw-bold mb-1 d-block" style="font-size: 0.7rem;">💵 Chi phí dự kiến</label>
                                <input type="text" name="cost" value="<%= dest.cost %>" class="form-control bg-dark border-secondary border-opacity-20 text-white rounded-3 small py-2" placeholder="Ví dụ: Miễn phí / 50.000đ" style="font-size: 0.75rem;">
                            </div>

                            <!-- Cover Image Uploader -->
                            <div class="col-12">
                                <label class="text-muted small fw-bold mb-1 d-block" style="font-size: 0.7rem;">🖼️ Ảnh bìa địa điểm</label>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="position-relative overflow-hidden rounded-3 border border-secondary border-opacity-15 bg-dark bg-opacity-20 d-flex align-items-center justify-content-center" style="width: 120px; height: 80px; min-width: 120px;">
                                        <img id="cover-preview" src="<%= fixImg(dest.cover_image) %>" class="w-100 h-100 object-fit-cover">
                                    </div>
                                    <div class="flex-grow-1">
                                        <input type="file" id="cover-file-input" class="form-control form-control-sm bg-dark border-secondary border-opacity-20 text-white rounded-3 mb-1" accept="image/*" style="font-size: 0.7rem;">
                                        <input type="hidden" name="cover_image" id="cover-image-path" value="<%= dest.cover_image %>">
                                        <span id="upload-status" class="text-muted small" style="font-size: 0.65rem;">Hỗ trợ định dạng JPG, PNG, WEBP.</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Highlights -->
                            <div class="col-12">
                                <label class="text-muted small fw-bold mb-1 d-block" style="font-size: 0.7rem;">✨ Hoạt động nổi bật / Đặc sản trải nghiệm</label>
                                <textarea name="highlight" class="form-control bg-dark border-secondary border-opacity-20 text-white rounded-3 small" rows="2" placeholder="Nhập các hoạt động nổi bật..." style="font-size: 0.75rem; line-height: 1.4;"><%= dest.highlight %></textarea>
                            </div>

                            <!-- Description -->
                            <div class="col-12">
                                <label class="text-muted small fw-bold mb-1 d-block" style="font-size: 0.7rem;">📖 Nội dung giới thiệu / Mô tả địa điểm</label>
                                <textarea name="description" class="form-control bg-dark border-secondary border-opacity-20 text-white rounded-3 small" rows="3" placeholder="Nhập mô tả chi tiết địa điểm..." style="font-size: 0.75rem; line-height: 1.4;"><%= dest.description %></textarea>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary btn-sm rounded-pill mt-3 w-100 fw-bold py-2 shadow-sm" style="background: var(--admin-accent); border: none; font-size: 0.78rem;">
                            <i class="bi bi-save2-fill me-1"></i> LƯU THAY ĐỔI CẤU HÌNH
                        </button>
                    </form>
                </div>

                <!-- Live Check-in Timeline -->
                <div class="chart-card">
                    <h6 class="fw-bold text-uppercase tracking-widest small mb-4" style="color: var(--admin-primary); font-size: 0.72rem; letter-spacing: 1px;">
                        👣 Lượt Check-in thời gian thực (Real-time Log)
                    </h6>
                    
                    <div class="checkin-timeline overflow-y-auto custom-scrollbar" style="max-height: 250px; padding-right: 5px;">
                        <% if (recentCheckins && recentCheckins.length > 0) { %>
                            <% recentCheckins.forEach((check, index) => { %>
                                <div class="d-flex align-items-start gap-3 mb-3 pb-3 border-bottom border-secondary border-opacity-10 timeline-item">
                                    <div class="position-relative">
                                        <img src="<%= check.avatar || '/images/default-avatar.png' %>" class="rounded-circle" style="width: 38px; height: 38px; object-fit: cover; border: 2px solid rgba(16,185,129,0.3);">
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <h6 class="fw-bold text-white mb-0 small" style="font-size: 0.8rem;"><%= check.full_name || 'Du khách ẩn danh' %></h6>
                                            <small class="text-muted" style="font-size: 0.65rem;">
                                                <%= new Date(check.created_at).toLocaleTimeString('vi-VN', {hour: '2-digit', minute: '2-digit'}) %>
                                            </small>
                                        </div>
                                        <p class="text-muted x-small mb-0" style="line-height: 1.4; font-size: 0.72rem;">
                                            Đã xác thực check-in thành công qua <span class="text-success fw-semibold"><%= check.checkin_method === 'qr' ? 'Mã QR tại điểm' : 'Bản đồ GPS' %></span>.
                                            Nhận <strong class="text-warning">+<%= check.points_earned %> điểm</strong>.
                                        </p>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="text-center py-5 opacity-25">
                                <i class="bi bi-qr-code-scan display-6 mb-3 d-block text-muted"></i>
                                <h6 class="fw-bold mb-1 small">Chưa có lượt check-in nào</h6>
                            </div>
                        <% } %>
                    </div>
                </div>

                <!-- Recent User Reviews -->
                <div class="chart-card">
                    <h6 class="fw-bold text-uppercase tracking-widest small mb-4" style="color: #8b5cf6; font-size: 0.72rem; letter-spacing: 1px;">
                        ⭐ Ý kiến đóng góp từ Du khách
                    </h6>

                    <div class="reviews-list overflow-y-auto custom-scrollbar" style="max-height: 250px; padding-right: 5px;">
                        <% if (recentReviews && recentReviews.length > 0) { %>
                            <% recentReviews.forEach(r => { %>
                                <div class="review-item p-3 rounded-3 mb-2 border border-secondary border-opacity-10" style="background: rgba(255,255,255,0.01);">
                                    <div class="d-flex align-items-center justify-content-between mb-2">
                                        <div class="d-flex align-items-center gap-2">
                                            <img src="<%= r.avatar || '/images/default-avatar.png' %>" class="rounded-circle" style="width: 28px; height: 28px; object-fit: cover;">
                                            <div>
                                                <h6 class="fw-bold text-white mb-0" style="font-size: 0.75rem;"><%= r.full_name || 'Du khách ẩn danh' %></h6>
                                                <small class="text-muted" style="font-size: 0.6rem;"><%= new Date(r.created_at).toLocaleDateString('vi-VN') %></small>
                                            </div>
                                        </div>
                                        <div class="rating-stars text-warning" style="font-size: 0.7rem;">
                                            <% for(let i=1; i<=5; i++) { %>
                                                <i class="bi <%= i <= r.rating ? 'bi-star-fill' : 'bi-star' %>"></i>
                                            <% } %>
                                        </div>
                                    </div>
                                    <p class="text-muted mb-0 x-small italic" style="line-height: 1.5; font-size: 0.72rem;">
                                        "<%= r.content %>"
                                    </p>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="text-center py-5 opacity-25">
                                <i class="bi bi-chat-heart display-6 mb-3 d-block text-muted"></i>
                                <h6 class="fw-bold mb-1 small">Chưa có đánh giá nào</h6>
                            </div>
                        <% } %>
                    </div>
                </div>

            </div>
        </div>

        <!-- 2. RIGHT COLUMN: FACEBOOK FANPAGE BUSINESS CHAT WORKSPACE -->
        <div class="col-xl-7 col-lg-6">
            <div class="chat-container-card" style="height: calc(100vh - 150px); min-height: 650px;">
                <div class="row g-0 h-100">
                    
                    <!-- Chat Sidebar (Active Conversations list) -->
                    <div class="col-md-5 col-xl-4 border-end border-secondary border-opacity-10 d-flex flex-column h-100" style="background: rgba(0,0,0,0.15);">
                        <div class="p-3 border-bottom border-secondary border-opacity-10">
                            <h6 class="fw-bold text-white small mb-3"><i class="bi bi-messenger text-primary me-2"></i>HỘP THƯ HỖ TRỢ TRỰC TUYẾN</h6>
                            <div class="input-group">
                                <span class="input-group-text bg-dark border-secondary border-opacity-20 text-muted"><i class="bi bi-search"></i></span>
                                <input type="text" class="form-control admin-input border-secondary border-opacity-20 ps-2" placeholder="Tìm du khách..." id="chat-search" oninput="filterConversations()">
                            </div>
                        </div>
                        
                        <!-- Conversations List -->
                        <div class="flex-grow-1 overflow-y-auto custom-scrollbar" id="convo-list">
                            <% if (conversations && conversations.length > 0) { %>
                                <% conversations.forEach((convo, index) => { %>
                                    <div class="convo-item-card p-3 border-bottom border-secondary border-opacity-5 d-flex gap-3 position-relative cursor-pointer transition-all" 
                                         id="convo-<%= convo.session_id %>"
                                         onclick="loadConversation('<%= convo.session_id %>')">
                                        
                                        <!-- Avatar -->
                                        <div class="position-relative flex-shrink-0">
                                            <div class="convo-avatar rounded-circle d-flex align-items-center justify-content-center fw-bold text-white shadow-sm"
                                                 style="width: 40px; height: 40px; background: <%= ['#4f46e5', '#0891b2', '#0d9488', '#059669', '#ca8a04', '#dc2626'][convo.session_id % 6] %>; object-fit: cover; font-size: 0.8rem;">
                                                <% if (convo.user_avatar) { %>
                                                    <img src="<%= convo.user_avatar %>" class="w-100 h-100 rounded-circle object-fit-cover">
                                                <% } else { %>
                                                    <%= (convo.user_name || 'KH').split(' ').pop().slice(0,2).toUpperCase() %>
                                                <% } %>
                                            </div>
                                            <span class="position-absolute bottom-0 end-0 bg-success border border-dark border-2 rounded-circle" style="width: 10px; height: 10px;"></span>
                                        </div>
                                        
                                        <!-- Body -->
                                        <div class="flex-grow-1 overflow-hidden">
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <h6 class="fw-bold mb-0 text-white text-truncate small" style="max-width: 110px; font-size: 0.78rem;">
                                                    <%= convo.user_name || 'Du khách #' + convo.session_uuid.slice(0,4).toUpperCase() %>
                                                </h6>
                                                <small class="text-muted" style="font-size: 0.6rem;">
                                                    <%= convo.last_message_time ? new Date(convo.last_message_time).toLocaleTimeString('vi-VN', {hour: '2-digit', minute: '2-digit'}) : '' %>
                                                </small>
                                            </div>
                                            <p class="text-muted text-truncate mb-0 x-small" style="line-height: 1.4; font-size: 0.7rem;">
                                                <%= convo.last_message || 'Bắt đầu cuộc hội thoại...' %>
                                            </p>
                                        </div>
                                        
                                        <div class="active-indicator"></div>
                                    </div>
                                <% }) %>
                            <% } else { %>
                                <div class="text-center py-5 opacity-25">
                                    <i class="bi bi-chat-square-quote display-6 mb-3 d-block"></i>
                                    <small class="fw-bold">Chưa có hội thoại nào</small>
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <!-- Chat Feed Widget -->
                    <div class="col-md-7 col-xl-8 d-flex flex-column h-100" style="background: var(--admin-bg);">
                        <!-- Header -->
                        <div class="p-3 border-bottom border-secondary border-opacity-10 d-flex justify-content-between align-items-center" id="chat-header" style="height: 68px;">
                            <div class="d-flex align-items-center gap-3">
                                <div class="rounded-circle text-white d-flex align-items-center justify-content-center fw-bold" id="active-chat-avatar" style="width: 38px; height: 38px; background: #555; font-size: 0.85rem;">
                                    ?
                                </div>
                                <div>
                                    <h6 class="fw-bold text-white mb-0 small" id="active-chat-name" style="font-size: 0.85rem;">Vui lòng chọn hội thoại</h6>
                                    <small class="text-muted" style="font-size: 0.65rem;" id="active-chat-status">Ngoại tuyến</small>
                                </div>
                            </div>
                        </div>

                        <!-- Chat Messages Container -->
                        <div class="flex-grow-1 p-4 overflow-y-auto custom-scrollbar d-flex flex-column gap-3" id="chat-messages-stream" style="background: rgba(0,0,0,0.05); height: 0;">
                            <div class="h-100 d-flex flex-column justify-content-center align-items-center text-center opacity-30 my-auto">
                                <i class="bi bi-messenger display-4 mb-3 text-primary animate-pulse"></i>
                                <h6 class="fw-bold">Hộp thư Hỗ trợ Hướng dẫn</h6>
                                <p class="small text-muted px-4" style="max-width: 320px; font-size: 0.72rem;">Chọn một cuộc hội thoại từ danh sách bên trái để phản hồi, giải đáp thắc mắc của du khách về địa điểm.</p>
                            </div>
                        </div>

                        <!-- Chat Input and Canned Answers -->
                        <div class="border-top border-secondary border-opacity-10" id="chat-controls-area" style="display: none; background: var(--admin-surface);">
                            
                            <!-- Quick answers row -->
                            <div class="p-2 border-bottom border-secondary border-opacity-5 d-flex gap-2 overflow-x-auto custom-scrollbar whitespace-nowrap bg-dark bg-opacity-20" style="padding-left: 15px !important; padding-right: 15px !important;">
                                <button class="btn btn-outline-secondary btn-sm rounded-pill x-small px-3 text-white border-opacity-25" style="font-size: 0.68rem;" onclick="insertCannedResponse('road')">
                                    🗺️ Vị trí & Bản đồ
                                </button>
                                <button class="btn btn-outline-secondary btn-sm rounded-pill x-small px-3 text-white border-opacity-25" style="font-size: 0.68rem;" onclick="insertCannedResponse('hours')">
                                    ⏰ Giờ & Giá vé
                                </button>
                                <button class="btn btn-outline-secondary btn-sm rounded-pill x-small px-3 text-white border-opacity-25" style="font-size: 0.68rem;" onclick="insertCannedResponse('highlight')">
                                    ✨ Đặc sản văn hóa
                                </button>
                                <button class="btn btn-outline-secondary btn-sm rounded-pill x-small px-3 text-white border-opacity-25" style="font-size: 0.68rem;" onclick="insertCannedResponse('thanks')">
                                    🙏 Cảm ơn du khách
                                </button>
                            </div>

                            <!-- Input control -->
                            <div class="p-3">
                                <div class="input-group">
                                    <input type="text" id="manager-chat-input" class="form-control border-secondary border-opacity-20 rounded-pill ps-4 py-2 bg-dark text-white" placeholder="Nhập tin nhắn hỗ trợ du khách..." style="font-size: 0.8rem;" onkeypress="if(event.key === 'Enter') sendLiveReply()">
                                    <button class="btn btn-primary rounded-circle ms-2 shadow d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; background: var(--admin-primary); border: none;" onclick="sendLiveReply()">
                                        <i class="bi bi-send-fill text-white" style="font-size: 0.9rem;"></i>
                                    </button>
                                </div>
                            </div>
                        </div>

                    </div>
                    
                </div>
            </div>
        </div>
    </div>
</div>

<!-- STYLING INJECTIONS -->
<style>
    /* Stat Cards */
    .stat-card {
        background: var(--admin-surface);
        border: 1px solid var(--admin-border);
        border-radius: 16px;
        padding: 20px;
        transition: all 0.3s ease;
    }
    .stat-card:hover {
        transform: translateY(-2px);
        border-color: rgba(255, 255, 255, 0.12);
        box-shadow: 0 8px 16px rgba(0,0,0,0.15);
    }
    .stat-card .stat-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.15rem;
    }
    .stat-bg-glow {
        position: absolute;
        width: 100px;
        height: 100px;
        bottom: -20px;
        right: -20px;
        z-index: 0;
        pointer-events: none;
    }

    /* Chat Container card */
    .chat-container-card {
        background: var(--admin-surface);
        border: 1px solid var(--admin-border);
        border-radius: 16px;
        overflow: hidden;
    }

    /* Conversation Items */
    .convo-item-card {
        transition: all 0.2s ease;
        border-left: 3px solid transparent;
    }
    .convo-item-card:hover {
        background: rgba(255, 255, 255, 0.02) !important;
    }
    .convo-item-card.active {
        background: rgba(59, 130, 246, 0.08) !important;
        border-left-color: var(--admin-primary);
    }
    .convo-item-card .active-indicator {
        position: absolute;
        width: 6px;
        height: 6px;
        right: 16px;
        top: 50%;
        transform: translateY(-50%);
        border-radius: 50%;
        background: var(--admin-primary);
        opacity: 0;
    }
    .convo-item-card.active .active-indicator {
        opacity: 1;
    }

    /* Timeline and lists */
    .timeline-item:last-child {
        border-bottom: none !important;
        margin-bottom: 0 !important;
        padding-bottom: 0 !important;
    }

    /* Speech bubbles */
    .chat-bubble-received {
        background: rgba(255,255,255,0.06);
        border: 1px solid var(--admin-border);
        color: var(--admin-text);
        max-width: 80%;
        word-wrap: break-word;
    }
    .chat-bubble-sent {
        background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
        color: #ffffff;
        max-width: 80%;
        word-wrap: break-word;
        box-shadow: 0 3px 10px rgba(29, 78, 216, 0.2);
    }
    .chat-bubble-ai {
        background: rgba(16, 185, 129, 0.08);
        border: 1px solid rgba(16, 185, 129, 0.2);
        color: #34d399;
        max-width: 80%;
        word-wrap: break-word;
    }

    /* Scrollbars */
    .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
        height: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(255,255,255,0.08);
        border-radius: 10px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: rgba(255,255,255,0.15);
    }

    .whitespace-nowrap {
        white-space: nowrap;
    }
</style>

<!-- CONTROLLER INTERACTION SCRIPTS -->
<script>
    let activeSessionId = null;
    let autoRefreshInterval = null;

    // Filter conversations in sidebar
    function filterConversations() {
        const query = document.getElementById('chat-search').value.toLowerCase();
        document.querySelectorAll('.convo-item-card').forEach(item => {
            const name = item.querySelector('h6').innerText.toLowerCase();
            const lastMsg = item.querySelector('p').innerText.toLowerCase();
            if (name.includes(query) || lastMsg.includes(query)) {
                item.style.display = 'flex';
            } else {
                item.style.display = 'none';
            }
        });
    }

    // Load selected conversation
    function loadConversation(sessionId) {
        activeSessionId = sessionId;

        // Toggle active styling
        document.querySelectorAll('.convo-item-card').forEach(c => c.classList.remove('active'));
        const activeCard = document.getElementById('convo-' + sessionId);
        if (activeCard) activeCard.classList.add('active');

        // Fetch messages via API
        axios.get('/api/manager/chat-history?sessionId=' + sessionId + '&dest_id=<%= dest.id %>')
            .then(res => {
                if (res.data.success) {
                    renderChatMessages(res.data.messages, res.data.visitor);
                }
            })
            .catch(err => {
                console.error("Lỗi lấy lịch sử chat:", err);
            });
    }

    // Render loaded messages and visitor metadata
    function renderChatMessages(messages, visitor) {
        const stream = document.getElementById('chat-messages-stream');
        const headerName = document.getElementById('active-chat-name');
        const headerStatus = document.getElementById('active-chat-status');
        const avatarBox = document.getElementById('active-chat-avatar');
        
        // Show/hide elements
        document.getElementById('chat-controls-area').style.display = 'block';

        // 1. Populate header
        const vName = visitor.full_name || 'Khách vãng lai #' + visitor.uuid.slice(0,4).toUpperCase();
        headerName.innerText = vName;
        headerStatus.innerHTML = visitor.is_checked_in > 0 
            ? '<span class="text-success fw-bold">• ĐÃ CHECK-IN TẠI ĐIỂM</span>' 
            : '<span class="text-muted">• TOURIST</span>';
        
        avatarBox.innerText = vName.split(' ').pop().slice(0,2).toUpperCase();
        avatarBox.style.background = ['#4f46e5', '#0891b2', '#0d9488', '#059669', '#ca8a04', '#dc2626'][visitor.id % 6];

        // 2. Render bubbles
        stream.innerHTML = '';
        if (messages && messages.length > 0) {
            messages.forEach(msg => {
                const isReply = msg.sender_id !== null && !msg.is_ai; // Manager's manual reply
                const isAI = msg.is_ai === 1;

                const wrapper = document.createElement('div');
                wrapper.className = `d-flex flex-column mb-3 ${isReply ? 'align-items-end' : 'align-items-start'}`;

                let bubbleClass = 'chat-bubble-received';
                let senderLabel = vName;
                if (isReply) {
                    bubbleClass = 'chat-bubble-sent';
                    senderLabel = msg.manager_name || 'Bạn (Quản lý)';
                } else if (isAI) {
                    bubbleClass = 'chat-bubble-ai';
                    senderLabel = '🤖 AI Assistant';
                }

                wrapper.innerHTML = `
                    <div class="x-small text-muted mb-1 px-2" style="font-size: 0.6rem; font-weight: 600;">
                        ${senderLabel.toUpperCase()}
                    </div>
                    <div class="p-3 rounded-4 shadow-sm ${bubbleClass} text-start" style="font-size: 0.8rem; line-height: 1.4;">
                        ${msg.message}
                        <div class="x-small mt-1 text-end opacity-50" style="font-size: 0.58rem;">
                            ${new Date(msg.created_at).toLocaleTimeString('vi-VN', {hour: '2-digit', minute:'2-digit'})}
                        </div>
                    </div>
                `;
                stream.appendChild(wrapper);
            });
        } else {
            stream.innerHTML = `
                <div class="text-center my-auto opacity-30 py-5">
                    <i class="bi bi-chat-dots-fill display-5 mb-2"></i>
                    <p class="small">Bắt đầu cuộc trò chuyện với du khách tại đây</p>
                </div>
            `;
        }

        // Scroll chat stream to bottom
        stream.scrollTop = stream.scrollHeight;
    }

    // Send Live Reply from Facebook Fanpage chat input
    function sendLiveReply() {
        const input = document.getElementById('manager-chat-input');
        const text = input.value.trim();
        if (!text || !activeSessionId) return;

        input.disabled = true;

        axios.post('/api/reply-message', {
            sessionId: activeSessionId,
            replyText: text,
            destinationId: '<%= dest.id %>'
        })
        .then(res => {
            if (res.data.success) {
                input.value = '';
                // Reload active conversation history
                loadConversation(activeSessionId);
            }
        })
        .catch(err => {
            alert('Lỗi khi gửi phản hồi: ' + (err.response?.data?.message || err.message));
        })
        .finally(() => {
            input.disabled = false;
            input.focus();
        });
    }

    // Insert canned response into input
    function insertCannedResponse(type) {
        const input = document.getElementById('manager-chat-input');
        let response = '';

        if (type === 'road') {
            response = 'Xin chào bạn, để di chuyển đến địa điểm <%= dest.name %>, bạn đi thẳng theo đường chính của xã Bình Lợi, sau đó rẽ theo biển chỉ dẫn hoặc theo định vị Google Maps này nhé: https://www.google.com/maps/dir/?api=1&destination=<%= dest.lat %>,<%= dest.lng %>';
        } else if (type === 'hours') {
            response = 'Chào bạn! Địa điểm <%= dest.name %> mở cửa phục vụ du khách từ <%= dest.open_hours || "8:00 - 17:00" %>. Chi phí dự kiến tham quan trải nghiệm khoảng <%= dest.cost || "miễn phí" %>. Rất vui lòng được tiếp đón bạn!';
        } else if (type === 'highlight') {
            response = 'Chào bạn, trải nghiệm văn hóa nổi bật nhất tại <%= dest.name %> của chúng tôi là: "<%= dest.highlight %>". Mời bạn ghé qua để thực tế cảm nhận nhé!';
        } else if (type === 'thanks') {
            response = 'Cảm ơn bạn rất nhiều vì đã chia sẻ và đặt câu hỏi. Chúc bạn có một hành trình chữa lành thật bình an, trọn vẹn tại Bình Lợi!';
        }

        input.value = response;
        input.focus();
    }

    // Start auto-refresh for conversations list
    function startAutoRefresh() {
        stopAutoRefresh();
        autoRefreshInterval = setInterval(() => {
            if (activeSessionId) {
                // Refresh history for active chat
                axios.get('/api/manager/chat-history?sessionId=' + activeSessionId + '&dest_id=<%= dest.id %>')
                    .then(res => {
                        if (res.data.success) {
                            // Only update if number of messages has changed to prevent resetting view
                            const stream = document.getElementById('chat-messages-stream');
                            const currentBubbles = stream.querySelectorAll('.rounded-4').length;
                            if (res.data.messages.length !== currentBubbles) {
                                renderChatMessages(res.data.messages, res.data.visitor);
                            }
                        }
                    }).catch(err => console.log(err));
            }
        }, 5000); // Check every 5 seconds
    }

    function stopAutoRefresh() {
        if (autoRefreshInterval) {
            clearInterval(autoRefreshInterval);
            autoRefreshInterval = null;
        }
    }

    // Initialize on document ready
    document.addEventListener('DOMContentLoaded', () => {
        startAutoRefresh();

        // Image uploader change event listener
        const coverInput = document.getElementById('cover-file-input');
        if (coverInput) {
            coverInput.addEventListener('change', async (e) => {
                const file = e.target.files[0];
                if (!file) return;

                const formData = new FormData();
                formData.append('image', file);

                const statusSpan = document.getElementById('upload-status');
                statusSpan.innerText = '⏳ Đang tải ảnh...';
                statusSpan.className = 'text-warning small d-block mt-1';

                try {
                    const response = await fetch('/api/upload', {
                        method: 'POST',
                        body: formData
                    });
                    const result = await response.json();
                    if (result.success && result.url) {
                        document.getElementById('cover-image-path').value = result.url;
                        document.getElementById('cover-preview').src = result.url;
                        statusSpan.innerText = '✅ Tải ảnh thành công!';
                        statusSpan.className = 'text-success small d-block mt-1';
                    } else {
                        statusSpan.innerText = '❌ Lỗi: ' + (result.message || 'Không thể tải');
                        statusSpan.className = 'text-danger small d-block mt-1';
                    }
                } catch (err) {
                    console.error(err);
                    statusSpan.innerText = '❌ Lỗi kết nối';
                    statusSpan.className = 'text-danger small d-block mt-1';
                }
            });
        }

        // If there are conversations, load the first one by default
        <% if (conversations && conversations.length > 0) { %>
            const firstSession = '<%= conversations[0].session_id %>';
            loadConversation(firstSession);
        <% } %>
    });
</script>
