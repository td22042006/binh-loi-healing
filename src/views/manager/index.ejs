<section class="site-section bg-light min-vh-100">
    <div class="container-site">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <span class="badge bg-primary rounded-pill mb-2">Location Manager</span>
                <h2 class="display-text mb-0"><%= dest.name %></h2>
            </div>
            <div class="text-end">
                <a href="/explore/<%= dest.slug %>" class="btn btn-outline-bl rounded-pill me-2" target="_blank">Xem trang công khai</a>
                <a href="/auth/logout" class="btn btn-danger btn-sm rounded-pill">Đăng xuất</a>
            </div>
        </div>

        <% if (typeof req !== 'undefined' && req.query.success) { %>
            <div class="alert alert-success rounded-4 border-0 shadow-sm mb-4"><%= req.query.success %></div>
        <% } %>

        <div class="row g-4">
            <!-- Stats Column -->
            <div class="col-lg-3">
                <div class="card-bl p-4 text-center shadow-sm border-0 mb-4 h-100">
                    <div class="display-4 text-primary fw-black mb-1"><%= stats.checkins %></div>
                    <p class="text-muted small text-uppercase fw-bold">Tổng lượt Check-in</p>
                    <hr>
                    <div class="small text-muted">Mảnh ghép di sản đã được du khách thu thập tại địa điểm này.</div>
                </div>
            </div>

            <!-- Update Content Column -->
            <div class="col-lg-5">
                <div class="card-bl p-4 shadow-sm border-0 h-100">
                    <h5 class="fw-bold mb-4"><i class="bi bi-pencil-square me-2 text-primary"></i> Cập nhật nội dung</h5>
                    <form action="/manager/update" method="POST">
                        <input type="hidden" name="dest_id" value="<%= dest.id %>">
                        <div class="row g-3">
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold">Giờ mở cửa</label>
                                <input type="text" name="open_hours" class="form-control bg-light border-0 rounded-3" value="<%= dest.open_hours %>">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold">Chi phí dự kiến</label>
                                <input type="text" name="cost" class="form-control bg-light border-0 rounded-3" value="<%= dest.cost %>">
                            </div>
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold">Thời điểm đẹp</label>
                                <input type="text" name="best_time" class="form-control bg-light border-0 rounded-3" value="<%= dest.best_time %>">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold">Mô tả ngắn</label>
                                <input type="text" name="short_desc" class="form-control bg-light border-0 rounded-3" value="<%= dest.short_desc %>">
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Đường dẫn hình ảnh (Cover Image)</label>
                            <input type="text" name="cover_image" class="form-control bg-light border-0 rounded-3" value="<%= dest.cover_image %>">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Điểm nhấn trải nghiệm (Highlight)</label>
                            <input type="text" name="highlight" class="form-control bg-light border-0 rounded-3" value="<%= dest.highlight %>">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Mẹo check-in (Tip)</label>
                            <input type="text" name="checkin_tip" class="form-control bg-light border-0 rounded-3" value="<%= dest.checkin_tip %>">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Nội dung Zen Walk</label>
                            <input type="text" name="zen_walk_desc" class="form-control bg-light border-0 rounded-3" value="<%= dest.zen_walk_desc %>">
                        </div>
                        <div class="mb-4">
                            <label class="form-label small fw-bold">Câu chuyện di sản (Story)</label>
                            <textarea name="story" class="form-control bg-light border-0 rounded-3" rows="6"><%= dest.story %></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary-bl w-100 rounded-pill py-3 fw-bold">LƯU TẤT CẢ THAY ĐỔI</button>
                    </form>
                </div>
            </div>

            <!-- Messages Column -->
            <div class="col-lg-4">
                <div class="card-bl p-4 shadow-sm border-0 h-100">
                    <h5 class="fw-bold mb-4"><i class="bi bi-chat-left-text me-2 text-primary"></i> Tin nhắn từ du khách</h5>
                    <div class="message-list overflow-auto" style="max-height: 500px;">
                        <% if (messages && messages.length > 0) { %>
                            <% messages.forEach(msg => { %>
                                <div class="message-item p-3 rounded-4 bg-white border mb-3">
                                    <div class="d-flex justify-content-between mb-2">
                                        <span class="small fw-bold text-primary">
                                            <% if (msg.sender_uuid) { %>
                                                Khách #<%= msg.sender_uuid.substring(0, 8) %>
                                            <% } else { %>
                                                Phản hồi của bạn
                                            <% } %>
                                        </span>
                                        <span class="x-small text-muted"><%= new Date(msg.created_at).toLocaleDateString('vi-VN') %></span>
                                    </div>
                                    <p class="small mb-0 text-dark"><%= msg.message %></p>
                                    <% if (msg.sender_uuid) { %>
                                        <div class="mt-2 text-end">
                                            <button class="btn btn-link btn-sm p-0 x-small text-decoration-none" onclick="openReplyModal('<%= msg.id %>', '<%= msg.sender_uuid.substring(0, 8) %>')">Phản hồi</button>
                                        </div>
                                    <% } %>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="text-center py-5">
                                <i class="bi bi-chat-dots display-1 opacity-10"></i>
                                <p class="text-muted small mt-3">Chưa có tin nhắn nào</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Reply Modal -->
<div class="modal fade" id="replyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header bg-primary text-white border-0 py-3">
                <h5 class="modal-title fw-bold">Phản hồi Khách #<span id="reply-to-id"></span></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-modal="hide" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="reply-msg-id">
                <div class="mb-3">
                    <textarea id="reply-text" class="form-control bg-light border-0 rounded-3" rows="4" placeholder="Nhập nội dung phản hồi..."></textarea>
                </div>
                <button class="btn btn-primary-bl w-100 rounded-pill py-2 fw-bold" onclick="sendReply()">GỬI PHẢN HỒI</button>
            </div>
        </div>
    </div>
</div>

<script>
function openReplyModal(msgId, guestId) {
    document.getElementById('reply-msg-id').value = msgId;
    document.getElementById('reply-to-id').innerText = guestId;
    new bootstrap.Modal(document.getElementById('replyModal')).show();
}

function sendReply() {
    const msgId = document.getElementById('reply-msg-id').value;
    const text = document.getElementById('reply-text').value;
    if (!text) return alert('Vui lòng nhập nội dung');

    axios.post('/api/reply-message', {
        messageId: msgId,
        replyText: text
    }).then(res => {
        if (res.data.success) {
            alert('Đã gửi phản hồi thành công');
            location.reload();
        }
    }).catch(err => {
        alert('Lỗi: ' + (err.response?.data?.message || err.message));
    });
}
</script>

<style>
.x-small { font-size: 0.75rem; }
.message-list::-webkit-scrollbar { width: 4px; }
.message-list::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.1); border-radius: 10px; }
</style>
