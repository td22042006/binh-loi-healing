<!-- Manager Chat Panel -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1" style="font-family: 'Outfit', sans-serif;"><%= user.role === 'admin' ? 'Chỉnh sửa & Hỗ trợ: ' + dest.name : 'Hộp thư Hỗ trợ: ' + dest.name %></h4>
        <p class="mb-0" style="color: var(--admin-muted); font-size: 0.85rem;"><%= user.role === 'admin' ? 'Quản lý thông tin và giải đáp thắc mắc du khách' : 'Giải đáp thắc mắc và tương tác trực tiếp với du khách tại địa điểm' %></p>
    </div>
    <a href="/explore/<%= dest.slug %>" target="_blank" class="btn btn-sm rounded-pill px-3" style="background: rgba(255,255,255,0.05); color: var(--admin-muted);">
        <i class="bi bi-eye me-1"></i>Xem địa điểm
    </a>
</div>

<% if (user.role === 'admin') { %>
<div class="row g-3 mb-4">
    <div class="col-xl-12">
        <div class="chart-card">
            <h6 class="fw-bold mb-4 text-uppercase tracking-widest small" style="color: var(--admin-primary);">Chỉnh sửa Thông tin (Chỉ dành cho Admin)</h6>
            
            <form action="/manager/update" method="POST" id="updateForm">
                <input type="hidden" name="dest_id" value="<%= dest.id %>">
                
                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label class="form-label small fw-bold" style="color: var(--admin-muted);">Giờ hoạt động</label>
                        <input type="text" name="open_hours" class="form-control admin-input" value="<%= dest.open_hours %>">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-bold" style="color: var(--admin-muted);">Chi phí dự kiến</label>
                        <input type="text" name="cost" class="form-control admin-input" value="<%= dest.cost %>">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-bold" style="color: var(--admin-muted);">Ảnh Đại diện (Cover)</label>
                        <div class="d-flex align-items-center gap-3">
                            <img id="cover_preview" src="<%= fixImg(dest.cover_image) %>" class="rounded-3" style="width: 60px; height: 40px; object-fit: cover; border: 1px solid var(--admin-border);">
                            <button type="button" class="btn btn-sm btn-outline-light rounded-pill" onclick="document.getElementById('cover_file').click()">
                                <i class="bi bi-upload"></i>
                            </button>
                            <input type="file" id="cover_file" class="d-none" accept="image/*" onchange="uploadFile(this, 'cover_image', 'cover_preview')">
                        </div>
                        <input type="hidden" name="cover_image" id="cover_image" value="<%= dest.cover_image %>">
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label small fw-bold" style="color: var(--admin-muted);">Mô tả ngắn</label>
                    <input type="text" name="short_desc" class="form-control admin-input" value="<%= dest.short_desc %>">
                </div>

                <div class="mb-3">
                    <label class="form-label small fw-bold" style="color: var(--admin-muted);">Nội dung Câu chuyện (Story)</label>
                    <textarea name="story" class="form-control admin-input" rows="4"><%= dest.story %></textarea>
                </div>

                <div class="text-end">
                    <button type="submit" class="btn btn-primary px-5 py-2 rounded-pill fw-bold">
                        <i class="bi bi-check-circle me-2"></i>CẬP NHẬT TRANG WEB
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
<% } %>

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-md-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon mb-2" style="background: rgba(59,130,246,0.15); color: #3b82f6;"><i class="bi bi-chat-dots-fill"></i></div>
            <h3><%= messages ? messages.filter(m => m.sender_uuid).length : 0 %></h3>
            <small>Tin nhắn du khách</small>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon mb-2" style="background: rgba(16,185,129,0.15); color: #10b981;"><i class="bi bi-qr-code-scan"></i></div>
            <h3><%= stats.checkins %></h3>
            <small>Lượt Check-in</small>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="chart-card d-flex flex-column" style="min-height: 600px;">
            <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3" style="border-color: var(--admin-border) !important;">
                <h6 class="fw-bold mb-0 text-uppercase tracking-widest small" style="color: var(--admin-accent);">Luồng hội thoại trực tuyến</h6>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge rounded-pill bg-success p-1"><i class="bi bi-dot"></i> Trực tuyến</span>
                </div>
            </div>
            
            <div class="flex-grow-1 overflow-auto pe-2 mb-4" id="chat-box" style="max-height: 500px;">
                <% if (messages && messages.length > 0) { %>
                    <% messages.forEach(msg => { %>
                        <% const isReply = !msg.sender_uuid; %>
                        <div class="mb-4 <%= isReply ? 'text-end' : '' %>">
                            <div class="d-inline-block p-3 rounded-4 <%= isReply ? 'bg-primary text-white shadow-sm' : 'bg-dark' %>" 
                                 style="max-width: 80%; border: <%= isReply ? 'none' : '1px solid var(--admin-border)' %>; text-align: left;">
                                <div class="d-flex justify-content-between align-items-center mb-1 gap-4">
                                    <span class="fw-bold" style="font-size: 0.65rem; color: <%= isReply ? 'rgba(255,255,255,0.7)' : 'var(--admin-muted)' %>;">
                                        <%= isReply ? 'PHẢN HỒI TỪ BẠN' : 'KHÁCH #' + msg.sender_uuid.slice(0,6).toUpperCase() %>
                                    </span>
                                    <span style="font-size: 0.6rem; color: <%= isReply ? 'rgba(255,255,255,0.5)' : 'var(--admin-muted)' %>;">
                                        <%= new Date(msg.created_at).toLocaleTimeString('vi-VN', {hour:'2-digit', minute:'2-digit', day:'2-digit', month:'2-digit'}) %>
                                    </span>
                                </div>
                                <p class="mb-0 small" style="line-height: 1.5;"><%= msg.message %></p>
                                <% if (!isReply) { %>
                                    <button class="btn btn-link btn-sm p-0 mt-2 text-primary text-decoration-none fw-bold" 
                                            style="font-size: 0.7rem; border-top: 1px solid rgba(59,130,246,0.1); width: 100%; text-align: left; padding-top: 8px !important;" 
                                            onclick="openReplyModal('<%= msg.id %>', '<%= msg.sender_uuid.slice(0,6) %>')">
                                        <i class="bi bi-reply-fill me-1"></i>TRẢ LỜI NGAY
                                    </button>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="h-100 d-flex flex-column justify-content-center align-items-center opacity-25">
                        <i class="bi bi-chat-square-quote display-1 mb-3"></i>
                        <h5 class="fw-bold">Chưa có hội thoại nào</h5>
                        <p class="small">Khi du khách đặt câu hỏi tại địa điểm, tin nhắn sẽ xuất hiện ở đây.</p>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<!-- Reply Modal -->
<div class="modal fade" id="replyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4" style="background: var(--admin-surface); border: 1px solid var(--admin-border) !important;">
            <div class="modal-header border-bottom p-4" style="border-color: var(--admin-border) !important;">
                <h5 class="modal-title fw-bold" style="color: var(--admin-text);"><i class="bi bi-reply-fill me-2 text-primary"></i>Phản hồi Khách #<span id="reply-to-id"></span></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="reply-msg-id">
                <div class="mb-4">
                    <label class="form-label small fw-bold text-muted text-uppercase mb-2">Nội dung giải đáp</label>
                    <textarea id="reply-text" class="form-control admin-input" style="height: 150px" placeholder="Nhập thông tin hỗ trợ du khách..."></textarea>
                </div>
                <button class="btn btn-primary w-100 rounded-pill py-3 fw-bold shadow-sm" onclick="sendReply()">
                    GỬI PHẢN HỒI <i class="bi bi-send ms-2"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
async function uploadFile(input, targetId, previewId) {
    if (!input.files || !input.files[0]) return;
    
    const formData = new FormData();
    formData.append('image', input.files[0]);
    
    const btn = input.previousElementSibling;
    const oldHtml = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
    
    try {
        const res = await axios.post('/api/upload', formData, {
            headers: { 'Content-Type': 'multipart/form-data' }
        });
        
        if (res.data.success) {
            document.getElementById(targetId).value = res.data.path; 
            if (previewId) document.getElementById(previewId).src = res.data.url;
            btn.innerHTML = '<i class="bi bi-check-circle-fill text-success"></i>';
        }
    } catch (err) {
        alert('Lỗi tải ảnh: ' + (err.response?.data?.message || err.message));
        btn.innerHTML = oldHtml;
    } finally {
        btn.disabled = false;
        setTimeout(() => { btn.innerHTML = oldHtml; }, 2000);
    }
}

function openReplyModal(msgId, guestId) {
    document.getElementById('reply-msg-id').value = msgId;
    document.getElementById('reply-to-id').innerText = guestId.toUpperCase();
    new bootstrap.Modal(document.getElementById('replyModal')).show();
}

function sendReply() {
    const msgId = document.getElementById('reply-msg-id').value;
    const text = document.getElementById('reply-text').value;
    if (!text) return alert('Vui lòng nhập nội dung');

    axios.post('/api/reply-message', {
        messageId: msgId,
        replyText: text
    }).then(res => {
        if (res.data.success) {
            location.reload();
        }
    }).catch(err => {
        alert('Lỗi: ' + (err.response?.data?.message || err.message));
    });
}

// Auto scroll to bottom of chat
document.addEventListener('DOMContentLoaded', () => {
    const chatBox = document.getElementById('chat-box');
    if (chatBox) chatBox.scrollTop = chatBox.scrollHeight;
});
</script>
