<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= typeof title !=='undefined' ? title + " | Manager" : "Manager Dashboard" %>
    </title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style-v5.css?v=<%= assetV %>">
    
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8f9fa; overflow-x: hidden; }
        
        /* Sidebar Styles (Right Side) */
        .manager-sidebar {
            width: 280px;
            position: fixed;
            top: 0;
            right: 0;
            height: 100vh;
            background: #fff;
            border-left: 1px solid #e9ecef;
            z-index: 1040;
            transition: transform 0.3s ease-in-out;
            display: flex;
            flex-direction: column;
        }
        
        .manager-main {
            margin-right: 280px;
            transition: margin-right 0.3s ease-in-out;
            min-height: 100vh;
            padding: 2rem;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            padding: 12px 20px;
            color: #495057;
            text-decoration: none;
            border-radius: 8px;
            margin: 4px 16px;
            transition: all 0.2s;
            font-weight: 500;
        }

        .sidebar-link:hover, .sidebar-link.active {
            background-color: rgba(92, 138, 94, 0.1);
            color: var(--v5-primary);
        }

        .sidebar-link i {
            width: 24px;
            font-size: 1.2rem;
            margin-right: 12px;
        }

        /* Mobile Adjustments */
        @media (max-width: 991.98px) {
            .manager-sidebar { transform: translateX(100%); }
            .manager-sidebar.show { transform: translateX(0); box-shadow: -5px 0 25px rgba(0,0,0,0.1); }
            .manager-main { margin-right: 0; padding: 1rem; }
        }
        
        .card-stat { border: 0; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.03); transition: transform 0.2s; }
        .card-stat:hover { transform: translateY(-5px); }
    </style>
</head>

<body>
    <!-- Mobile Navbar (Top) -->
    <nav class="navbar navbar-light bg-white border-bottom d-lg-none sticky-top px-3">
        <a class="navbar-brand fw-bold text-primary" href="/manager">
            <i class="bi bi-shield-lock me-2"></i>Bình Lợi Manager
        </a>
        <button class="btn btn-light rounded-circle p-2" id="sidebarToggle">
            <i class="bi bi-list fs-4"></i>
        </button>
    </nav>

    <!-- Right Sidebar -->
    <aside class="manager-sidebar shadow-sm" id="managerSidebar">
        <div class="p-4 border-bottom text-center">
            <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex p-3 mb-2">
                <i class="bi bi-person-workspace fs-2 text-primary"></i>
            </div>
            <h6 class="fw-bold mb-0"><%= user.name %></h6>
            <span class="badge bg-primary-subtle text-primary rounded-pill mt-2">Quản lý Cấp cao</span>
        </div>
        
        <div class="flex-grow-1 overflow-auto py-3">
            <small class="text-muted text-uppercase tracking-widest px-4 mb-2 d-block" style="font-size: 10px;">Bảng điều khiển</small>
            <a href="/manager" class="sidebar-link active"><i class="bi bi-grid-1x2"></i> Tổng quan</a>
            
            <small class="text-muted text-uppercase tracking-widest px-4 mt-4 mb-2 d-block" style="font-size: 10px;">Quản lý Điểm đến</small>
            <a href="#destinations" class="sidebar-link"><i class="bi bi-map"></i> Địa điểm của tôi</a>
            <a href="#media" class="sidebar-link"><i class="bi bi-images"></i> Thư viện Ảnh/Video</a>
            
            <small class="text-muted text-uppercase tracking-widest px-4 mt-4 mb-2 d-block" style="font-size: 10px;">Tương tác Khách hàng</small>
            <a href="#inbox" class="sidebar-link d-flex justify-content-between align-items-center">
                <span><i class="bi bi-chat-dots"></i> Tin nhắn</span>
                <span class="badge bg-danger rounded-pill">3</span>
            </a>
            <a href="#reviews" class="sidebar-link"><i class="bi bi-star"></i> Đánh giá</a>
        </div>
        
        <div class="p-3 border-top">
            <a href="/" class="btn btn-outline-secondary w-100 rounded-pill mb-2"><i class="bi bi-house me-2"></i>Xem Trang Chủ</a>
            <a href="/auth/logout" class="btn btn-danger w-100 rounded-pill"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a>
        </div>
    </aside>

    <!-- Mobile Overlay -->
    <div class="position-fixed top-0 start-0 w-100 h-100 bg-dark bg-opacity-50 d-none" id="sidebarOverlay" style="z-index: 1030;"></div>

    <!-- Main Content Area -->
    <main class="manager-main">
        <%- body %>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const sidebar = document.getElementById('managerSidebar');
        const toggleBtn = document.getElementById('sidebarToggle');
        const overlay = document.getElementById('sidebarOverlay');

        if(toggleBtn) {
            toggleBtn.addEventListener('click', () => {
                sidebar.classList.toggle('show');
                overlay.classList.toggle('d-none');
                document.body.style.overflow = sidebar.classList.contains('show') ? 'hidden' : '';
            });
        }

        if(overlay) {
            overlay.addEventListener('click', () => {
                sidebar.classList.remove('show');
                overlay.classList.add('d-none');
                document.body.style.overflow = '';
            });
        }
    </script>
</body>
</html>
