<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !=='undefined' ? title + " | " + (user.role === 'manager' ? "Quản lý Panel" : "Admin Panel") : (user.role === 'manager' ? "Quản lý Panel" : "Admin Panel") %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root {
            --sb-width: 260px;
            <% if (user.role === 'manager') { %>
                /* Manager Panel: Healing Green Brand Theme */
                --admin-bg: #f3f7f5;
                --admin-surface: #ffffff;
                --admin-border: rgba(30,90,62,0.15);
                --admin-text: #0b1c12;
                --admin-muted: #496354;
                --admin-accent: #d97706;
                --admin-primary: #1e5a3e;
            <% } else { %>
                /* Admin Panel: Maroon Red Brand Theme */
                --admin-bg: #fcf7f7;
                --admin-surface: #ffffff;
                --admin-border: rgba(146,39,36,0.15);
                --admin-text: #1c0b0a;
                --admin-muted: #634948;
                --admin-accent: #d97706;
                --admin-primary: #922724;
            <% } %>
        }
        * { box-sizing: border-box; font-family: 'Inter', sans-serif !important; }
        body { background: var(--admin-bg); color: var(--admin-text); margin: 0; }
        .admin-wrap { display: flex; min-height: 100vh; }
        
        /* Sidebar */
        .admin-sb { width: var(--sb-width); background: var(--admin-surface); border-right: 1px solid var(--admin-border); display: flex; flex-direction: column; position: fixed; top: 0; left: 0; height: 100vh; z-index: 100; }
        .sb-brand { padding: 24px 20px; border-bottom: 1px solid var(--admin-border); }
        .sb-brand h5 { font-family: 'Inter', sans-serif; font-weight: 800; font-size: 1.15rem; color: var(--admin-primary); margin: 0; letter-spacing: 1px; }
        .sb-brand small { color: var(--admin-muted); font-size: 0.72rem; }
        .sb-nav { padding: 16px 12px; flex-grow: 1; overflow-y: auto; }
        .sb-label { font-size: 0.65rem; font-weight: 700; color: var(--admin-muted); text-transform: uppercase; letter-spacing: 2px; padding: 8px 12px; margin-top: 16px; }
        .sb-link { display: flex; align-items: center; gap: 10px; padding: 10px 14px; border-radius: 10px; color: var(--admin-muted); text-decoration: none; font-size: 0.85rem; font-weight: 500; transition: all 0.2s; margin-bottom: 2px; }
        .sb-link:hover { background: rgba(0,0,0,0.04); color: var(--admin-text); }
        .sb-link.active { background: var(--admin-primary); color: #fff; font-weight: 600; }
        .sb-link i { font-size: 1.1rem; width: 20px; text-align: center; }
        .sb-footer { padding: 16px; border-top: 1px solid var(--admin-border); }
        
        /* Main content */
        .admin-main { margin-left: var(--sb-width); flex-grow: 1; padding: 32px; min-height: 100vh; }
        
        /* Stat cards */
        .stat-card { background: var(--admin-surface); border: 1px solid var(--admin-border); border-radius: 16px; padding: 20px; }
        .stat-card .stat-icon { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }
        .stat-card h3 { font-family: 'Inter', sans-serif; font-weight: 800; font-size: 1.8rem; margin: 0; }
        .stat-card small { color: var(--admin-muted); font-size: 0.78rem; }
        
        /* Tables */
        .admin-table { background: var(--admin-surface); border: 1px solid var(--admin-border); border-radius: 16px; overflow: hidden; }
        .admin-table th { background: rgba(0,0,0,0.02); color: var(--admin-muted); font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; padding: 14px 16px; border-bottom: 1px solid var(--admin-border); }
        .admin-table td { padding: 12px 16px; border-bottom: 1px solid var(--admin-border); font-size: 0.88rem; vertical-align: middle; }
        .admin-table tr:last-child td { border-bottom: none; }
        .admin-table tr:hover td { background: rgba(0,0,0,0.015); }
        
        /* Charts */
        .chart-card { background: var(--admin-surface); border: 1px solid var(--admin-border); border-radius: 16px; padding: 24px; }
        
        /* Badges */
        .role-badge { padding: 4px 10px; border-radius: 20px; font-size: 0.72rem; font-weight: 600; }
        .role-admin { background: rgba(239,68,68,0.15); color: #ef4444; }
        .role-manager { background: rgba(240,165,0,0.15); color: #f0a500; }
        .role-user { background: rgba(59,130,246,0.15); color: #3b82f6; }
        
        .admin-input { background: #ffffff; border: 1px solid #cbd5e1; color: var(--admin-text); border-radius: 10px; padding: 10px 14px; }
        .admin-input:focus { background: #ffffff; border-color: var(--admin-primary); color: var(--admin-text); box-shadow: 0 0 0 3px rgba(26, 77, 46, 0.1); outline: none; }
        
        @media (max-width: 991px) {
            .admin-sb { display: none; }
            .admin-main { margin-left: 0; padding: 16px; }
        }
    </style>
</head>
<body>
    <div class="admin-wrap">
        <!-- Sidebar -->
        <aside class="admin-sb">
            <div class="sb-brand">
                <% if (user.role === 'manager') { %>
                    <h5>🏛️ QUẢN LÝ PANEL</h5>
                    <small>Hệ thống Quản lý Địa điểm</small>
                <% } else { %>
                    <h5>🏛️ BÌNH LỢI ADMIN</h5>
                    <small>Hệ thống Quản trị cấp Xã</small>
                <% } %>
            </div>
            <nav class="sb-nav">
                <% if (user.role === 'admin') { %>
                    <div class="sb-label">Tổng quan</div>
                    <a href="/admin" class="sb-link <%= typeof adminPage !== 'undefined' && adminPage === 'dashboard' ? 'active' : '' %>">
                        <i class="bi bi-grid-1x2-fill"></i> Dashboard
                    </a>
                    
                    <div class="sb-label">Quản lý</div>
                    <a href="/admin/users" class="sb-link <%= typeof adminPage !== 'undefined' && adminPage === 'users' ? 'active' : '' %>">
                        <i class="bi bi-people-fill"></i> Người dùng
                    </a>
                    <a href="/admin/destinations" class="sb-link <%= typeof adminPage !== 'undefined' && adminPage === 'destinations' ? 'active' : '' %>">
                        <i class="bi bi-geo-alt-fill"></i> Địa điểm
                    </a>
                    <a href="/admin/workshops" class="sb-link <%= typeof adminPage !== 'undefined' && adminPage === 'workshops' ? 'active' : '' %>">
                        <i class="bi bi-palette-fill"></i> Workshop
                    </a>
                    <a href="/admin/reviews" class="sb-link <%= typeof adminPage !== 'undefined' && adminPage === 'reviews' ? 'active' : '' %>">
                        <i class="bi bi-people-fill"></i> Cộng đồng
                    </a>
                    <a href="/admin/chat" class="sb-link <%= typeof adminPage !== 'undefined' && adminPage === 'chat' ? 'active' : '' %>">
                        <i class="bi bi-chat-dots-fill"></i> Hộp thư Hỗ trợ
                    </a>
                    <a href="/admin/events" class="sb-link <%= typeof adminPage !== 'undefined' && adminPage === 'events' ? 'active' : '' %>">
                        <i class="bi bi-calendar-event-fill"></i> Sự kiện
                    </a>
                    <a href="/admin/journey-templates" class="sb-link <%= typeof adminPage !== 'undefined' && adminPage === 'journey-templates' ? 'active' : '' %>">
                        <i class="bi bi-signpost-2-fill"></i> Hành trình mẫu
                    </a>
                    
                    <div class="sb-label">Cài đặt</div>
                    <a href="/admin/settings" class="sb-link <%= typeof adminPage !== 'undefined' && adminPage === 'settings' ? 'active' : '' %>">
                        <i class="bi bi-gear-fill"></i> Cài đặt Web
                    </a>
                <% } else if (user.role === 'manager') { %>
                    <div class="sb-label">QUẢN LÝ ĐỊA ĐIỂM</div>
                    <a href="/manager" class="sb-link <%= typeof managerPage !== 'undefined' && managerPage === 'dashboard' ? 'active' : '' %>">
                        <i class="bi bi-grid-1x2-fill"></i> Bảng điều khiển
                    </a>
                    <a href="/manager/chat" class="sb-link <%= typeof managerPage !== 'undefined' && managerPage === 'chat' ? 'active' : '' %>">
                        <i class="bi bi-chat-dots-fill"></i> Hộp thư Hỗ trợ
                    </a>
                    <a href="/manager/destination" class="sb-link <%= typeof managerPage !== 'undefined' && managerPage === 'destination' ? 'active' : '' %>">
                        <i class="bi bi-geo-alt-fill"></i> Quản lý Địa điểm
                    </a>
                    <a href="/manager/workshops" class="sb-link <%= typeof managerPage !== 'undefined' && managerPage === 'workshops' ? 'active' : '' %>">
                        <i class="bi bi-palette-fill"></i> Quản lý Workshop
                    </a>
                <% } %>
            </nav>
            <div class="sb-footer">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <img src="<%= user.avatar || '/images/default-avatar.png' %>" class="rounded-circle" style="width: 36px; height: 36px; object-fit: cover;">
                    <div>
                        <div class="fw-bold" style="font-size: 0.82rem;"><%= user.full_name %></div>
                        <div style="font-size: 0.7rem; color: var(--admin-muted);"><%= user.email %></div>
                    </div>
                </div>
                <a href="/auth/logout" class="btn btn-outline-danger w-100 rounded-pill btn-sm fw-bold">
                    <i class="bi bi-box-arrow-right me-1"></i>Đăng xuất
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="admin-main">
            <%- body %>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.js"></script>
    <%- typeof scripts !=='undefined' ? scripts : '' %>
</body>
</html>
