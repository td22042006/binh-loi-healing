<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !=='undefined' ? title + " | Admin Panel" : "Admin Panel" %></title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Outfit:wght@300;400;600;800&family=Montserrat:wght@400;700;900&family=Inter:wght@400;500&display=swap" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- Custom CSS (Reusing existing utility classes) -->
    <link rel="stylesheet" href="/css/style-v5.css?v=<%= assetV %>">

    <style>
        :root {
            --sidebar-width: 280px;
            --admin-bg: #f4f6f9;
        }
        
        body {
            background-color: var(--admin-bg);
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
        }

        .admin-layout {
            display: flex;
            min-height: 100vh;
            /* Reverse row to put sidebar on the right */
            flex-direction: row-reverse; 
        }

        /* Right Sidebar Styling */
        .admin-sidebar {
            width: var(--sidebar-width);
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(20px);
            border-left: 1px solid rgba(0,0,0,0.05);
            box-shadow: -5px 0 25px rgba(0,0,0,0.03);
            display: flex;
            flex-direction: column;
            position: fixed;
            right: 0;
            top: 0;
            height: 100vh;
            z-index: 1000;
        }

        /* Main Content Area */
        .admin-main {
            flex-grow: 1;
            padding: 2rem;
            margin-right: var(--sidebar-width); /* Leave space for right sidebar */
            min-height: 100vh;
        }

        .sidebar-brand {
            padding: 2rem 1.5rem;
            text-align: center;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

        .sidebar-nav {
            padding: 1.5rem 1rem;
            flex-grow: 1;
            overflow-y: auto;
        }

        .sidebar-nav .nav-link {
            color: #495057;
            border-radius: 12px;
            padding: 12px 20px;
            margin-bottom: 8px;
            font-weight: 600;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .sidebar-nav .nav-link:hover, .sidebar-nav .nav-link.active {
            background: var(--v5-primary);
            color: white !important;
            box-shadow: 0 4px 15px rgba(var(--v5-primary-rgb), 0.3);
            transform: translateX(-5px);
        }
        
        .sidebar-nav .nav-link i {
            font-size: 1.2rem;
        }

        .sidebar-footer {
            padding: 1.5rem;
            border-top: 1px solid rgba(0,0,0,0.05);
        }

        /* Mobile adjustments */
        @media (max-width: 991.98px) {
            .admin-layout {
                flex-direction: column;
            }
            .admin-sidebar {
                position: static;
                width: 100%;
                height: auto;
                border-left: none;
                border-bottom: 1px solid rgba(0,0,0,0.05);
                box-shadow: 0 5px 25px rgba(0,0,0,0.03);
            }
            .admin-main {
                margin-right: 0;
                padding: 1rem;
            }
        }
        
        /* Form & Card overrides for Admin */
        .admin-card {
            background: white;
            border-radius: 20px;
            border: 1px solid rgba(0,0,0,0.03);
            box-shadow: 0 10px 30px rgba(0,0,0,0.02);
            overflow: hidden;
        }
        .admin-input {
            background: #f8f9fa;
            border: 1px solid transparent;
            border-radius: 12px;
            padding: 12px 15px;
            transition: all 0.3s;
        }
        .admin-input:focus {
            background: white;
            border-color: var(--v5-primary);
            box-shadow: 0 0 0 4px rgba(var(--v5-primary-rgb), 0.1);
        }
    </style>
</head>

<body>
    <div class="admin-layout">
        <!-- Right Sidebar -->
        <aside class="admin-sidebar">
            <div class="sidebar-brand">
                <img src="/images/logo.png" alt="Logo" style="height: 50px; margin-bottom: 15px;">
                <h5 class="fw-black text-primary mb-0" style="letter-spacing: 1px;">HEALING ADMIN</h5>
                <span class="badge bg-dark rounded-pill mt-2 px-3 py-1 fw-normal"><%= user && user.role === 'admin' ? 'Quản trị viên' : 'Quản lý điểm đến' %></span>
            </div>

            <div class="sidebar-nav">
                <% if (user && user.role === 'admin') { %>
                    <a href="/manager" class="nav-link <%= typeof dest === 'undefined' ? 'active' : '' %>">
                        <i class="bi bi-grid-1x2-fill"></i> TẤT CẢ ĐỊA ĐIỂM
                    </a>
                <% } %>
                
                <% if (typeof dest !== 'undefined' && dest) { %>
                    <div class="text-uppercase text-muted small fw-bold px-3 mb-2 mt-3" style="letter-spacing: 2px;">Đang quản lý</div>
                    <div class="px-3 mb-4 text-primary fw-bold"><%= dest.name %></div>
                    
                    <a href="/manager<%= user.role === 'admin' ? '?dest_id=' + dest.id : '' %>" class="nav-link active">
                        <i class="bi bi-pencil-square"></i> Cập nhật thông tin
                    </a>
                    <a href="/explore/<%= dest.slug %>" target="_blank" class="nav-link">
                        <i class="bi bi-box-arrow-up-right"></i> Xem trang hiển thị
                    </a>
                <% } %>
            </div>

            <div class="sidebar-footer">
                <div class="d-flex align-items-center gap-3 mb-3">
                    <img src="<%= user.avatar || '/images/default-avatar.png' %>" class="rounded-circle" style="width: 40px; height: 40px; object-fit: cover;">
                    <div>
                        <div class="fw-bold text-dark small"><%= user.full_name %></div>
                        <div class="text-muted x-small"><%= user.email %></div>
                    </div>
                </div>
                <a href="/auth/logout" class="btn btn-outline-danger w-100 rounded-pill fw-bold">
                    <i class="bi bi-box-arrow-right me-2"></i>ĐĂNG XUẤT
                </a>
                <a href="/" class="btn btn-link text-muted w-100 text-decoration-none mt-2 small">
                    <i class="bi bi-house-door me-1"></i> Trở về trang chủ
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="admin-main">
            <%- body %>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <%- typeof scripts !=='undefined' ? scripts : '' %>
</body>

</html>
