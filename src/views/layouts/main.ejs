<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= typeof title !=='undefined' ? title + " | " + appName : appName %>
    </title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Outfit:wght@300;400;600;800&family=Montserrat:wght@400;700;900&family=Inter:wght@400;500&display=swap" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- Animate.css -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <!-- Custom CSS -->
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style-v5.css?v=<%= assetV %>">
    <!-- GSAP for Cinematic Animations -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

    <script>
        window.APP_CONFIG = {
            baseUrl: '<%= baseUrl %>',
            apiUrl: '<%= baseUrl %>/api'
        };
    </script>
</head>

<body>
    <!-- Page Loader -->
    <div id="page-loader">
        <div class="text-center">
            <div class="loader-spinner mb-3 mx-auto"></div>
            <div class="text-white fw-bold small text-uppercase tracking-widest animate__animated animate__pulse animate__infinite" style="letter-spacing: 3px;">Bình Lợi Healing</div>
        </div>
    </div>

    <!-- Navbar -->
    <%- include('../partials/navbar') %>

    <!-- Floating QR Scan Button -->
    <a href="/checkin" class="fab-qr" title="Quét mã QR">
        <i class="bi bi-qr-code-scan"></i>
    </a>

    <!-- Main Content -->
    <main>
        <%- body %>
    </main>

    <!-- Footer -->
    <%- include('../partials/footer') %>

    <!-- Back to Top -->
    <div id="back-to-top">
        <i class="bi bi-arrow-up"></i>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://unpkg.com/html5-qrcode"></script>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"></script>

    <script>
        gsap.registerPlugin(ScrollTrigger);

        // Global Reveal Animation
        const reveal = () => {
            const items = document.querySelectorAll('.reveal-up');
            items.forEach(item => {
                gsap.fromTo(item, 
                    { opacity: 0, y: 50 },
                    { 
                        opacity: 1, 
                        y: 0, 
                        duration: 1, 
                        ease: "power3.out",
                        scrollTrigger: {
                            trigger: item,
                            start: "top 85%",
                            toggleActions: "play none none none"
                        }
                    }
                );
            });
        };

        // Page Loader
        window.addEventListener('load', () => {
            const loader = document.getElementById('page-loader');
            gsap.to(loader, {
                opacity: 0,
                duration: 0.8,
                onComplete: () => {
                    loader.style.display = 'none';
                    reveal(); // Trigger reveal animations after loader is gone
                }
            });
        });

        // Navbar Scroll Effect
        const nav = document.querySelector('.navbar-premium');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 50) {
                nav.classList.add('scrolled', 'shadow-premium');
                nav.querySelector('.container').style.marginTop = '0';
            } else {
                nav.classList.remove('scrolled', 'shadow-premium');
                nav.querySelector('.container').style.marginTop = '15px';
            }
        });

        // Back to Top
        const btt = document.getElementById('back-to-top');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 300) {
                btt.classList.add('show');
            } else {
                btt.classList.remove('show');
            }
        });
        btt.addEventListener('click', () => {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });
    </script>
    <script src="/js/app.js?v=<%= assetV %>"></script>

    <%- typeof scripts !=='undefined' ? scripts : '' %>

</body>

</html>