<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !=='undefined' ? title + " | " + appName : appName %></title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Inter:wght@400;600;800&family=Outfit:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style-v5.css?v=<%= assetV %>">
    
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
</head>
<body>

    <!-- Platform Sidebar (Desktop Only) -->
    <%- include('../partials/sidebar') %>

    <!-- Top Header -->
    <%- include('../partials/header_platform') %>

    <!-- Main Content Wrapper -->
    <main class="content-wrapper">
        <%- body %>
    </main>

    <!-- Mobile Bottom Navigation (Always Visible on Mobile) -->
    <nav class="d-lg-none position-fixed bottom-0 start-0 w-100 bg-white border-top shadow-lg" style="z-index: 1050; padding-bottom: env(safe-area-inset-bottom, 0);">
        <div class="d-flex justify-content-around align-items-center py-2">
            <a href="/" class="text-center text-decoration-none text-muted px-2">
                <i class="bi bi-house-door d-block fs-5"></i>
                <span style="font-size: 0.65rem;">Home</span>
            </a>
            <a href="/explore" class="text-center text-decoration-none text-muted px-2">
                <i class="bi bi-compass d-block fs-5"></i>
                <span style="font-size: 0.65rem;">Khám phá</span>
            </a>
            <a href="/checkin" class="text-center text-decoration-none px-2" style="margin-top: -20px;">
                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center shadow" style="width: 50px; height: 50px; margin: 0 auto;">
                    <i class="bi bi-qr-code-scan fs-4"></i>
                </div>
            </a>
            <a href="/market" class="text-center text-decoration-none text-muted px-2">
                <i class="bi bi-bag d-block fs-5"></i>
                <span style="font-size: 0.65rem;">Chợ</span>
            </a>
            <a href="<%= user ? '/profile' : '/auth/login' %>" class="text-center text-decoration-none text-muted px-2">
                <i class="bi bi-person d-block fs-5"></i>
                <span style="font-size: 0.65rem;">Tôi</span>
            </a>
        </div>
    </nav>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Set Active Nav Link
        const currentPath = window.location.pathname;
        document.querySelectorAll('.nav-item-platform').forEach(link => {
            if (link.getAttribute('href') === currentPath) {
                link.classList.add('active');
            } else {
                link.classList.remove('active');
            }
        });

        // Dynamic Title
        const pageTitle = document.querySelector('h1')?.textContent || document.title.split('|')[0];
        const platformTitle = document.getElementById('platform-page-title');
        if (platformTitle && pageTitle) platformTitle.textContent = pageTitle;

        // Initialize AOS
        AOS.init({
            duration: 1000,
            once: true,
            offset: 100
        });
    </script>
</body>
</html>