<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= typeof title !=='undefined' ? title + " | " + appName : appName %>
    </title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Montserrat:wght@400;500;600;700;800;900&family=Dancing+Script:wght@500;600;700&family=Playfair+Display:wght@700;800;900&display=swap" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- Animate.css -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <!-- Custom CSS -->
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style-v5.css?v=<%= assetV %>">
    
    <!-- PWA Meta Tags & iOS Compatibility -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#922724">
    <link rel="apple-touch-icon" href="<%= fixImg(settings.brand_logo, '/images/logo.png') %>">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content="Bình Lợi">

    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

    <script>
        window.APP_CONFIG = {
            baseUrl: '<%= baseUrl %>',
            apiUrl: '<%= baseUrl %>/api'
        };
        window.CURRENT_SESSION_ID = '<%= typeof sessionDbId !== "undefined" && sessionDbId ? sessionDbId : "" %>';
    </script>
</head>

<body>
    <!-- No Page Loader to prevent infinite spinning delays -->

    <!-- Navbar -->
    <%- include('../partials/navbar') %>

    <!-- Floating QR Scan Button -->
    <a href="/checkin" class="fab-qr d-none d-lg-flex" title="Quét mã QR">
        <i class="bi bi-qr-code-scan"></i>
    </a>



    <!-- Main Content -->
    <main>
        <%- body %>
    </main>

    <!-- Footer -->
    <%- include('../partials/footer') %>

    <!-- Floating Mobile Simulator Toggle (Desktop / Laptop only) -->
    <button type="button" id="btnToggleMobileFrame" class="btn btn-dark position-fixed bottom-0 end-0 m-4 rounded-pill shadow-lg d-none d-lg-flex align-items-center gap-2 px-3 py-2 z-3 border border-secondary" style="font-size: 0.8rem; background: #0f172a;" onclick="toggleMobileFrameMode()">
        <i class="bi bi-phone fs-6 text-warning"></i>
        <span>Xem giao diện Mobile</span>
    </button>



    <!-- Mobile Bottom: Only QR Scan Button (centered for mobile & PWA) -->
    <div class="mobile-bottom-qr-container d-lg-none position-fixed bottom-0 start-50 translate-middle-x" style="z-index: 1030; margin-bottom: 20px; padding-bottom: env(safe-area-inset-bottom, 0);">
        <a href="/checkin" class="mobile-qr-fab d-flex align-items-center justify-content-center text-white text-decoration-none rounded-circle shadow-lg">
            <i class="bi bi-qr-code-scan fs-4"></i>
        </a>
    </div>

    <!-- Custom PWA Install Banner (Android/Chrome) -->
    <div id="pwaInstallBanner" class="pwa-install-banner d-none animate__animated animate__slideInUp">
        <div class="d-flex align-items-center justify-content-between w-100 p-3">
            <div class="d-flex align-items-center gap-2">
                <img src="/images/logo.png" alt="Logo" class="rounded-3" style="width: 40px; height: 40px; border: 1px solid rgba(0,0,0,0.1);" onerror="this.src='/images/logo.png'">
                <div>
                    <div class="fw-bold text-dark" style="font-size: 0.85rem; line-height: 1.2;">Ứng dụng Bình Lợi</div>
                    <div class="text-muted" style="font-size: 0.72rem;">Thêm vào màn hình chính để sử dụng mượt mà hơn</div>
                </div>
            </div>
            <div class="d-flex align-items-center gap-2">
                <button id="btnPwaClose" class="btn btn-sm btn-link text-muted text-decoration-none px-2 py-1" style="font-size: 0.75rem;">Đóng</button>
                <button id="btnPwaInstall" class="btn btn-sm btn-premium rounded-pill px-3 py-1 fw-bold" style="font-size: 0.75rem; background: var(--primary); color: white; border: none;">Cài đặt</button>
            </div>
        </div>
    </div>

    <!-- Custom PWA iOS Instructions Toast -->
    <div id="pwaIosInstructions" class="pwa-ios-instructions d-none animate__animated animate__fadeIn">
        <div class="p-3 text-center">
            <div class="fw-bold mb-1" style="font-size: 0.88rem;">Cài đặt Ứng dụng Bình Lợi</div>
            <div style="font-size: 0.75rem; line-height: 1.5; color: #475569;">
                Để cài đặt, chạm vào biểu tượng Chia sẻ <i class="bi bi-box-arrow-up mx-1 text-primary"></i> bên dưới trình duyệt Safari, sau đó cuộn xuống và chọn <strong>"Thêm vào MH chính"</strong> <i class="bi bi-plus-square mx-1"></i>.
            </div>
            <button id="btnPwaIosClose" class="btn btn-sm btn-link text-muted text-decoration-none mt-2 w-100 fw-semibold" style="font-size: 0.75rem; border: none; background: none;">Tôi đã hiểu</button>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://unpkg.com/html5-qrcode"></script>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"></script>

    <script>
        gsap.registerPlugin(ScrollTrigger);

        // Global Reveal Animation
        const reveal = () => {
            const items = document.querySelectorAll('.reveal-up');
            items.forEach(item => {
                gsap.fromTo(item, 
                    { opacity: 0, y: 50 },
                    { 
                        opacity: 1, 
                        y: 0, 
                        duration: 1, 
                        ease: "power3.out",
                        scrollTrigger: {
                            trigger: item,
                            start: "top 85%",
                            toggleActions: "play none none none"
                        }
                    }
                );
            });
        };

        function toggleMobileFrameMode() {
            document.body.classList.toggle('mobile-frame-active');
            const isActive = document.body.classList.contains('mobile-frame-active');
            const btn = document.getElementById('btnToggleMobileFrame');
            if (btn) {
                if (isActive) {
                    btn.innerHTML = '<i class="bi bi-laptop fs-6 text-success"></i><span>Về màn hình Laptop</span>';
                } else {
                    btn.innerHTML = '<i class="bi bi-phone fs-6 text-warning"></i><span>Xem giao diện Mobile</span>';
                }
            }
        }

        // Run reveal immediately on DOMContentLoaded
        document.addEventListener('DOMContentLoaded', () => {
            setTimeout(reveal, 100);
        });

        // Navbar Scroll Effect (Fixed top without detached spacing)
        // Navbar always white - shadow only on scroll
        const nav = document.querySelector('.navbar-premium');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 50) {
                nav.classList.add('scrolled', 'shadow-premium');
            } else {
                nav.classList.remove('scrolled', 'shadow-premium');
            }
        });


    </script>
    <script src="/js/app.js?v=<%= assetV %>"></script>



    <!-- Floating Buttons Alignment -->
    <style>
        /* Mobile QR Floating Button */
        .mobile-qr-fab {
            width: 56px;
            height: 56px;
            background: linear-gradient(135deg, var(--primary) 0%, #15803d 100%);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .mobile-qr-fab:hover {
            transform: scale(1.1);
            box-shadow: 0 6px 20px rgba(15, 118, 110, 0.4) !important;
        }

        /* Uniform size and styles for desktop floating action buttons */
        .fab-qr, 
        #floatingChatFabContainer button {
            width: 60px !important;
            height: 60px !important;
            border-radius: 50% !important;
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
            border: 3px solid white !important;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15) !important;
            transition: all 0.4s ease !important;
            padding: 0 !important;
        }

        /* Hover animations */
        .fab-qr:hover, 
        #floatingChatFabContainer button:hover {
            transform: scale(1.1) !important;
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.25) !important;
        }

        /* Desktop position alignment (centers them horizontally since they all have width 60px) */
        .fab-qr {
            position: fixed !important;
            bottom: 32px !important;
            right: 32px !important;
            z-index: 1040;
            background: var(--grad-nature) !important;
            color: white !important;
            font-size: 1.5rem !important;
            text-decoration: none !important;
        }
        #floatingChatFabContainer {
            position: fixed !important;
            bottom: 112px !important;
            right: 32px !important;
            z-index: 1040;
        }
        #floatingChatFabContainer button {
            background-color: var(--primary) !important;
            color: white !important;
            font-size: 1.5rem !important;
        }

        /* Mobile alignment & responsive adjustments */
        @media (max-width: 991.98px) {
            body { 
                padding-bottom: calc(90px + env(safe-area-inset-bottom, 0px)) !important; 
            }
            .fab-qr { display: none !important; }
            /* Hide floating chat on mobile - use sidebar link instead */
            #floatingChatFabContainer { display: none !important; }
            #floatingChatWidget { display: none !important; }
            
            /* Responsive offcanvas sidebar for small phones */
            #mobileMenu {
                max-width: 85% !important;
            }
        }

        /* Optimize branding on smaller screens (SE sizes) */
        @media (max-width: 375px) {
            .navbar-brand img {
                height: 34px !important;
            }
            .navbar-brand span:first-child {
                font-size: 1.1rem !important;
            }
            .navbar-brand span:last-child {
                font-size: 0.95rem !important;
            }
        }

        @media (max-width: 575.98px) {
            #floatingChatWidget {
                right: 10px !important;
                left: 10px !important;
                bottom: 80px !important;
                width: auto !important;
                height: 450px !important;
            }
        }

        /* PWA Install Banner & iOS Instructions CSS */
        .pwa-install-banner {
            position: fixed;
            bottom: calc(90px + env(safe-area-inset-bottom, 0px));
            left: 20px;
            right: 20px;
            background: #ffffff;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
            z-index: 1060;
            border: 1px solid rgba(226, 232, 240, 0.8);
            max-width: 500px;
            margin: 0 auto;
        }

        .pwa-ios-instructions {
            position: fixed;
            bottom: calc(90px + env(safe-area-inset-bottom, 0px));
            left: 20px;
            right: 20px;
            background: #ffffff;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
            z-index: 1060;
            border: 1px solid rgba(226, 232, 240, 0.8);
            max-width: 450px;
            margin: 0 auto;
        }

        /* Standalone PWA UI overrides (keeps hamburger button visible) */
        @media (display-mode: standalone) {
            .footer-main {
                display: none !important;
            }
        }

        /* JS-detected PWA UI overrides (keeps hamburger button visible) */
        body.is-pwa .footer-main {
            display: none !important;
        }
    </style>

    <!-- Floating Chat FAB -->
    <% if (locals.user) { %>
    <div id="floatingChatFabContainer">
        <button class="btn btn-danger rounded-circle shadow-lg d-flex align-items-center justify-content-center" style="background-color: var(--primary) !important; border: none;" onclick="toggleFloatingChat()">
            <i class="bi bi-chat-dots-fill"></i>
        </button>
    </div>

    <!-- Floating Chat Widget -->
    <div id="floatingChatWidget" class="d-none position-fixed shadow-premium border-0 rounded-4 overflow-hidden" 
         style="bottom: 90px; right: 32px; width: 360px; height: 500px; z-index: 1050; background: #ffffff; border: 1px solid rgba(0,0,0,0.08);">
        <!-- Header -->
        <div class="p-3 text-white border-0 d-flex justify-content-between align-items-center" style="background: linear-gradient(135deg, #922724 0%, #b83330 100%);">
            <div class="d-flex align-items-center gap-2">
                <img src="<%= fixImg(settings.brand_logo, '/images/logo.png') %>" height="30" style="filter: brightness(0) invert(1);" onerror="this.src='/images/logo.png'">
                <div>
                    <h6 class="fw-bold mb-0" style="font-size: 0.9rem;">Hỗ trợ Bình Lợi Healing</h6>
                    <small class="opacity-60" style="font-size: 0.65rem; text-transform: uppercase;">Ban Quản Trị</small>
                </div>
            </div>
            <button class="btn-close btn-close-white p-1" onclick="toggleFloatingChat()" style="font-size: 0.8rem; border:none; background:none; color:white;"><i class="bi bi-x-lg"></i></button>
        </div>
        <!-- Body -->
        <div class="d-flex flex-column h-100" style="padding-bottom: 60px;">
            <div class="flex-grow-1 p-3 overflow-auto" id="floatingChatMessages" style="height: calc(100% - 60px);">
                <div class="text-center mb-3"><span class="badge bg-light text-muted px-2 py-1 rounded-pill small">Hỗ trợ trực tuyến</span></div>
                
                <div class="message-received mb-3 d-flex gap-2">
                    <img src="<%= fixImg(settings.brand_logo, '/images/logo.png') %>" class="rounded-circle mt-auto" style="width: 28px; height: 28px;" onerror="this.src='/images/logo.png'">
                    <div class="p-2 px-3 rounded-4 bg-light text-dark small" style="max-width: 75%; font-size: 0.85rem; line-height: 1.5;">
                        Xin chào! Chúng tôi có thể giúp gì cho bạn? Hãy gửi tin nhắn tại đây nhé.
                    </div>
                </div>
            </div>
            <!-- Input -->
            <div class="p-2 px-3 border-top position-absolute bottom-0 start-0 w-100 bg-white" style="height: 60px;">
                <form id="floatingChatForm" class="d-flex gap-2 align-items-center h-100" onsubmit="sendFloatingMessage(event)">
                    <input type="text" class="form-control rounded-pill border-0 bg-light px-3" style="font-size: 0.85rem; height: 38px;" placeholder="Nhập tin nhắn..." id="floatingChatInput" required>
                    <button type="submit" class="btn btn-danger rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 38px; height: 38px; background-color: var(--primary) !important; border: none;">
                        <i class="bi bi-send-fill text-white" style="font-size: 0.85rem;"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>

    <script>
        let floatingChatInterval = null;
        let lastMessageCount = -1;

        function toggleFloatingChat() {
            const widget = document.getElementById('floatingChatWidget');
            widget.classList.toggle('d-none');
            
            if (!widget.classList.contains('d-none')) {
                loadFloatingChatMessages();
                setTimeout(() => {
                    const container = document.getElementById('floatingChatMessages');
                    container.scrollTop = container.scrollHeight;
                }, 150);
                floatingChatInterval = setInterval(loadFloatingChatMessages, 4000);
            } else {
                if (floatingChatInterval) {
                    clearInterval(floatingChatInterval);
                    floatingChatInterval = null;
                }
            }
        }

        async function loadFloatingChatMessages() {
            try {
                const res = await axios.get('/api/get-messages');
                if (res.data.success) {
                    const messages = res.data.data;
                    if (messages.length === lastMessageCount) return;
                    lastMessageCount = messages.length;

                    const container = document.getElementById('floatingChatMessages');
                    let html = `<div class="text-center mb-3"><span class="badge bg-light text-muted px-2 py-1 rounded-pill small">Hỗ trợ trực tuyến</span></div>
                                <div class="message-received mb-3 d-flex gap-2">
                                    <img src="<%= fixImg(settings.brand_logo, '/images/logo.png') %>" class="rounded-circle mt-auto" style="width: 28px; height: 28px;" onerror="this.src='/images/logo.png'">
                                    <div class="p-2 px-3 rounded-4 bg-light text-dark small" style="max-width: 75%; font-size: 0.85rem; line-height: 1.5;">
                                        Xin chào! Chúng tôi có thể giúp gì cho bạn? Hãy gửi tin nhắn tại đây nhé.
                                    </div>
                                </div>`;
                    
                    const currentSessionId = window.CURRENT_SESSION_ID;
                    
                    messages.forEach(msg => {
                        const isMe = msg.sender_uuid && String(msg.sender_uuid) === String(currentSessionId);
                        if (isMe) {
                            html += `
                                <div class="message-sent mb-3 d-flex justify-content-end">
                                    <div class="p-2 px-3 rounded-4 bg-primary text-white small" style="max-width: 75%; font-size: 0.85rem; line-height: 1.5; background-color: var(--primary) !important;">
                                        ${msg.message}
                                    </div>
                                </div>
                            `;
                        } else {
                            html += `
                                <div class="message-received mb-3 d-flex gap-2">
                                    <img src="<%= fixImg(settings.brand_logo, '/images/logo.png') %>" class="rounded-circle mt-auto" style="width: 28px; height: 28px;" onerror="this.src='/images/logo.png'">
                                    <div class="p-2 px-3 rounded-4 bg-light text-dark small" style="max-width: 75%; font-size: 0.85rem; line-height: 1.5;">
                                        ${msg.message}
                                    </div>
                                </div>
                            `;
                        }
                    });
                    
                    container.innerHTML = html;
                    container.scrollTop = container.scrollHeight;
                }
            } catch (e) {
                console.error('Error loading chat messages:', e);
            }
        }

        async function sendFloatingMessage(e) {
            e.preventDefault();
            const input = document.getElementById('floatingChatInput');
            const msg = input.value.trim();
            if (!msg) return;

            input.value = '';
            
            try {
                const res = await axios.post('/api/send-message', { message: msg });
                if (res.data.success) {
                    loadFloatingChatMessages();
                }
            } catch (e) {
                console.error('Error sending message:', e);
            }
        }
    </script>
    <% } %>

    <%- typeof scripts !=='undefined' ? scripts : '' %>

    <!-- PWA Service Worker & App Mode Handler -->
    <script>
        // Service Worker Registration
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js')
                    .then((registration) => {
                        console.log('ServiceWorker registration successful with scope: ', registration.scope);
                    })
                    .catch((err) => {
                        console.log('ServiceWorker registration failed: ', err);
                    });
            });
        }

        // PWA Mode Detection & Navigation Highlight
        document.addEventListener('DOMContentLoaded', () => {
            const isStandalone = window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone || document.referrer.includes('android-app://');
            if (isStandalone) {
                document.body.classList.add('is-pwa');
            }
            
            // PWA Standalone Back Button visibility (only shown in standalone mode when not on home page)
            const pwaBackBtn = document.getElementById('pwaBackButton');
            const path = window.location.pathname;
            if (pwaBackBtn && isStandalone && path !== '/') {
                pwaBackBtn.classList.remove('d-none');
                pwaBackBtn.classList.add('d-flex');
            }
            


            // In-App Install Prompt Banner (Android/Chrome)
            let deferredPrompt;
            window.addEventListener('beforeinstallprompt', (e) => {
                e.preventDefault();
                deferredPrompt = e;
                
                const isDismissed = localStorage.getItem('pwa_install_dismissed');
                if (!isDismissed && !isStandalone) {
                    const banner = document.getElementById('pwaInstallBanner');
                    if (banner) {
                        banner.classList.remove('d-none');
                    }
                }
            });

            const btnPwaInstall = document.getElementById('btnPwaInstall');
            if (btnPwaInstall) {
                btnPwaInstall.addEventListener('click', async () => {
                    if (!deferredPrompt) return;
                    deferredPrompt.prompt();
                    const { outcome } = await deferredPrompt.userChoice;
                    console.log(`PWA install prompt outcome: ${outcome}`);
                    deferredPrompt = null;
                    const banner = document.getElementById('pwaInstallBanner');
                    if (banner) {
                        banner.classList.add('d-none');
                    }
                });
            }

            const btnPwaClose = document.getElementById('btnPwaClose');
            if (btnPwaClose) {
                btnPwaClose.addEventListener('click', () => {
                    const banner = document.getElementById('pwaInstallBanner');
                    if (banner) {
                        banner.classList.add('d-none');
                    }
                    localStorage.setItem('pwa_install_dismissed', 'true');
                });
            }

            // iOS PWA support instructions popup
            const isIos = /iphone|ipad|ipod/.test(window.navigator.userAgent.toLowerCase());
            const isInStandaloneMode = window.navigator.standalone === true;

            if (isIos && !isInStandaloneMode && !isStandalone) {
                const isDismissedIos = localStorage.getItem('pwa_ios_dismissed');
                if (!isDismissedIos) {
                    const iosBanner = document.getElementById('pwaIosInstructions');
                    if (iosBanner) {
                        setTimeout(() => {
                            iosBanner.classList.remove('d-none');
                        }, 2500);
                    }
                }
            }

            const btnPwaIosClose = document.getElementById('btnPwaIosClose');
            if (btnPwaIosClose) {
                btnPwaIosClose.addEventListener('click', () => {
                    const iosBanner = document.getElementById('pwaIosInstructions');
                    if (iosBanner) {
                        iosBanner.classList.add('d-none');
                    }
                    localStorage.setItem('pwa_ios_dismissed', 'true');
                });
            }
        });
    </script>
</body>

</html>