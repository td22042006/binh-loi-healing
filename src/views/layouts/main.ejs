<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= typeof title !=='undefined' ? title + " | " + appName : appName %>
    </title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Montserrat:wght@400;500;600;700;800;900&family=Dancing+Script:wght@500;600;700&family=Playfair+Display:wght@700;800;900&display=swap" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- Animate.css -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <!-- Custom CSS -->
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style-v5.css?v=<%= assetV %>">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

    <script>
        window.APP_CONFIG = {
            baseUrl: '<%= baseUrl %>',
            apiUrl: '<%= baseUrl %>/api'
        };
        window.CURRENT_SESSION_ID = '<%= typeof sessionDbId !== "undefined" && sessionDbId ? sessionDbId : "" %>';
    </script>
</head>

<body>
    <!-- No Page Loader to prevent infinite spinning delays -->

    <!-- Navbar -->
    <%- include('../partials/navbar') %>

    <!-- Floating QR Scan Button -->
    <a href="/checkin" class="fab-qr d-none d-lg-flex" title="Quét mã QR">
        <i class="bi bi-qr-code-scan"></i>
    </a>



    <!-- Main Content -->
    <main>
        <%- body %>
    </main>

    <!-- Footer -->
    <%- include('../partials/footer') %>



    <!-- Mobile Bottom: Only QR Scan Button (centered) -->
    <div class="d-lg-none position-fixed bottom-0 start-50 translate-middle-x" style="z-index: 1050; margin-bottom: 20px; padding-bottom: env(safe-area-inset-bottom, 0);">
        <a href="/checkin" class="mobile-qr-fab d-flex align-items-center justify-content-center text-white text-decoration-none rounded-circle shadow-lg">
            <i class="bi bi-qr-code-scan fs-4"></i>
        </a>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="https://unpkg.com/html5-qrcode"></script>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"></script>

    <script>
        gsap.registerPlugin(ScrollTrigger);

        // Global Reveal Animation
        const reveal = () => {
            const items = document.querySelectorAll('.reveal-up');
            items.forEach(item => {
                gsap.fromTo(item, 
                    { opacity: 0, y: 50 },
                    { 
                        opacity: 1, 
                        y: 0, 
                        duration: 1, 
                        ease: "power3.out",
                        scrollTrigger: {
                            trigger: item,
                            start: "top 85%",
                            toggleActions: "play none none none"
                        }
                    }
                );
            });
        };

        // Run reveal immediately on DOMContentLoaded
        document.addEventListener('DOMContentLoaded', () => {
            setTimeout(reveal, 100);
        });

        // Navbar Scroll Effect (Fixed top without detached spacing)
        // Navbar always white - shadow only on scroll
        const nav = document.querySelector('.navbar-premium');
        window.addEventListener('scroll', () => {
            if (window.scrollY > 50) {
                nav.classList.add('scrolled', 'shadow-premium');
            } else {
                nav.classList.remove('scrolled', 'shadow-premium');
            }
        });


    </script>
    <script src="/js/app.js?v=<%= assetV %>"></script>



    <!-- Floating Buttons Alignment -->
    <style>
        /* Mobile QR Floating Button */
        .mobile-qr-fab {
            width: 56px;
            height: 56px;
            background: linear-gradient(135deg, var(--primary) 0%, #15803d 100%);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .mobile-qr-fab:hover {
            transform: scale(1.1);
            box-shadow: 0 6px 20px rgba(15, 118, 110, 0.4) !important;
        }

        /* Uniform size and styles for desktop floating action buttons */
        .fab-qr, 
        #floatingChatFabContainer button {
            width: 60px !important;
            height: 60px !important;
            border-radius: 50% !important;
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
            border: 3px solid white !important;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15) !important;
            transition: all 0.4s ease !important;
            padding: 0 !important;
        }

        /* Hover animations */
        .fab-qr:hover, 
        #floatingChatFabContainer button:hover {
            transform: scale(1.1) !important;
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.25) !important;
        }

        /* Desktop position alignment (centers them horizontally since they all have width 60px) */
        .fab-qr {
            position: fixed !important;
            bottom: 32px !important;
            right: 32px !important;
            z-index: 1040;
            background: var(--grad-nature) !important;
            color: white !important;
            font-size: 1.5rem !important;
            text-decoration: none !important;
        }
        #floatingChatFabContainer {
            position: fixed !important;
            bottom: 112px !important;
            right: 32px !important;
            z-index: 1040;
        }
        #floatingChatFabContainer button {
            background-color: var(--primary) !important;
            color: white !important;
            font-size: 1.5rem !important;
        }

        /* Mobile alignment */
        @media (max-width: 991.98px) {
            body { padding-bottom: 80px; }
            .fab-qr { display: none !important; }
            #floatingChatFabContainer {
                position: fixed !important;
                bottom: 20px !important;
                right: 20px !important;
                z-index: 1040;
            }
            #floatingChatFabContainer button {
                width: 50px !important;
                height: 50px !important;
                font-size: 1.25rem !important;
            }
        }

        @media (max-width: 575.98px) {
            #floatingChatWidget {
                right: 10px !important;
                left: 10px !important;
                bottom: 80px !important;
                width: auto !important;
                height: 450px !important;
            }
        }
    </style>

    <!-- Floating Chat FAB -->
    <div id="floatingChatFabContainer">
        <button class="btn btn-danger rounded-circle shadow-lg d-flex align-items-center justify-content-center" style="background-color: var(--primary) !important; border: none;" onclick="toggleFloatingChat()">
            <i class="bi bi-chat-dots-fill"></i>
        </button>
    </div>

    <!-- Floating Chat Widget -->
    <div id="floatingChatWidget" class="d-none position-fixed shadow-premium border-0 rounded-4 overflow-hidden" 
         style="bottom: 90px; right: 32px; width: 360px; height: 500px; z-index: 1050; background: #ffffff; border: 1px solid rgba(0,0,0,0.08);">
        <!-- Header -->
        <div class="p-3 bg-dark text-white border-0 d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2">
                <img src="<%= fixImg(settings.brand_logo, '/images/logo.png') %>" height="30" onerror="this.src='/images/logo.png'">
                <div>
                    <h6 class="fw-bold mb-0" style="font-size: 0.9rem;">Hỗ trợ Bình Lợi Healing</h6>
                    <small class="opacity-60" style="font-size: 0.65rem; text-transform: uppercase;">Ban Quản Trị</small>
                </div>
            </div>
            <button class="btn-close btn-close-white p-1" onclick="toggleFloatingChat()" style="font-size: 0.8rem; border:none; background:none; color:white;"><i class="bi bi-x-lg"></i></button>
        </div>
        <!-- Body -->
        <div class="d-flex flex-column h-100" style="padding-bottom: 60px;">
            <div class="flex-grow-1 p-3 overflow-auto" id="floatingChatMessages" style="height: calc(100% - 60px);">
                <div class="text-center mb-3"><span class="badge bg-light text-muted px-2 py-1 rounded-pill small">Hỗ trợ trực tuyến</span></div>
                
                <div class="message-received mb-3 d-flex gap-2">
                    <img src="<%= fixImg(settings.brand_logo, '/images/logo.png') %>" class="rounded-circle mt-auto" style="width: 28px; height: 28px;" onerror="this.src='/images/logo.png'">
                    <div class="p-2 px-3 rounded-4 bg-light text-dark small" style="max-width: 75%; font-size: 0.85rem; line-height: 1.5;">
                        Xin chào! Chúng tôi có thể giúp gì cho bạn? Hãy gửi tin nhắn tại đây nhé.
                    </div>
                </div>
            </div>
            <!-- Input -->
            <div class="p-2 px-3 border-top position-absolute bottom-0 start-0 w-100 bg-white" style="height: 60px;">
                <form id="floatingChatForm" class="d-flex gap-2 align-items-center h-100" onsubmit="sendFloatingMessage(event)">
                    <input type="text" class="form-control rounded-pill border-0 bg-light px-3" style="font-size: 0.85rem; height: 38px;" placeholder="Nhập tin nhắn..." id="floatingChatInput" required>
                    <button type="submit" class="btn btn-danger rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 38px; height: 38px; background-color: var(--primary) !important; border: none;">
                        <i class="bi bi-send-fill text-white" style="font-size: 0.85rem;"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>

    <script>
        let floatingChatInterval = null;
        let lastMessageCount = -1;

        function toggleFloatingChat() {
            const widget = document.getElementById('floatingChatWidget');
            widget.classList.toggle('d-none');
            
            if (!widget.classList.contains('d-none')) {
                loadFloatingChatMessages();
                setTimeout(() => {
                    const container = document.getElementById('floatingChatMessages');
                    container.scrollTop = container.scrollHeight;
                }, 150);
                floatingChatInterval = setInterval(loadFloatingChatMessages, 4000);
            } else {
                if (floatingChatInterval) {
                    clearInterval(floatingChatInterval);
                    floatingChatInterval = null;
                }
            }
        }

        async function loadFloatingChatMessages() {
            try {
                const res = await axios.get('/api/get-messages');
                if (res.data.success) {
                    const messages = res.data.data;
                    if (messages.length === lastMessageCount) return;
                    lastMessageCount = messages.length;

                    const container = document.getElementById('floatingChatMessages');
                    let html = `<div class="text-center mb-3"><span class="badge bg-light text-muted px-2 py-1 rounded-pill small">Hỗ trợ trực tuyến</span></div>
                                <div class="message-received mb-3 d-flex gap-2">
                                    <img src="<%= fixImg(settings.brand_logo, '/images/logo.png') %>" class="rounded-circle mt-auto" style="width: 28px; height: 28px;" onerror="this.src='/images/logo.png'">
                                    <div class="p-2 px-3 rounded-4 bg-light text-dark small" style="max-width: 75%; font-size: 0.85rem; line-height: 1.5;">
                                        Xin chào! Chúng tôi có thể giúp gì cho bạn? Hãy gửi tin nhắn tại đây nhé.
                                    </div>
                                </div>`;
                    
                    const currentSessionId = window.CURRENT_SESSION_ID;
                    
                    messages.forEach(msg => {
                        const isMe = msg.sender_uuid && String(msg.sender_uuid) === String(currentSessionId);
                        if (isMe) {
                            html += `
                                <div class="message-sent mb-3 d-flex justify-content-end">
                                    <div class="p-2 px-3 rounded-4 bg-primary text-white small" style="max-width: 75%; font-size: 0.85rem; line-height: 1.5; background-color: var(--primary) !important;">
                                        ${msg.message}
                                    </div>
                                </div>
                            `;
                        } else {
                            html += `
                                <div class="message-received mb-3 d-flex gap-2">
                                    <img src="<%= fixImg(settings.brand_logo, '/images/logo.png') %>" class="rounded-circle mt-auto" style="width: 28px; height: 28px;" onerror="this.src='/images/logo.png'">
                                    <div class="p-2 px-3 rounded-4 bg-light text-dark small" style="max-width: 75%; font-size: 0.85rem; line-height: 1.5;">
                                        ${msg.message}
                                    </div>
                                </div>
                            `;
                        }
                    });
                    
                    container.innerHTML = html;
                    container.scrollTop = container.scrollHeight;
                }
            } catch (e) {
                console.error('Error loading chat messages:', e);
            }
        }

        async function sendFloatingMessage(e) {
            e.preventDefault();
            const input = document.getElementById('floatingChatInput');
            const msg = input.value.trim();
            if (!msg) return;

            input.value = '';
            
            try {
                const res = await axios.post('/api/send-message', { message: msg });
                if (res.data.success) {
                    loadFloatingChatMessages();
                }
            } catch (e) {
                console.error('Error sending message:', e);
            }
        }
    </script>

    <%- typeof scripts !=='undefined' ? scripts : '' %>

</body>

</html>