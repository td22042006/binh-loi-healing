<!-- Checkout Dashboard — Show All Features -->
<div class="row g-4">
    <!-- Items & Payment -->
    <div class="col-lg-8">
        <div class="widget-card mb-4">
            <h5 class="fw-bold mb-4">Giỏ hàng của bạn</h5>
            <div id="cart-table-wrapper" class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr class="x-small fw-bold text-muted text-uppercase">
                            <th>Sản phẩm</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-end">Đơn giá</th>
                            <th class="text-end">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody id="checkout-list">
                        <!-- JS Rendered -->
                    </tbody>
                </table>
                <div id="checkout-empty" class="text-center py-5 d-none">
                    <p class="text-muted">Giỏ hàng đang trống.</p>
                    <a href="/market" class="btn btn-primary-bl rounded-pill px-4">Đi mua sắm ngay</a>
                </div>
            </div>
        </div>

        <div class="widget-card">
            <h5 class="fw-bold mb-4">Thông tin nhận hàng</h5>
            <form id="checkoutForm">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label x-small fw-bold">HỌ TÊN</label>
                        <input type="text" class="form-control rounded-pill bg-light border-0 px-3" value="<%= user ? user.full_name : '' %>" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label x-small fw-bold">SỐ ĐIỆN THOẠI</label>
                        <input type="tel" class="form-control rounded-pill bg-light border-0 px-3" value="<%= user ? user.phone : '' %>" required>
                    </div>
                    <div class="col-12">
                        <label class="form-label x-small fw-bold">ĐỊA CHỈ NHẬN HÀNG (HOẶC ĐIỂM HẸN TẠI BÌNH LỢI)</label>
                        <textarea class="form-control rounded-4 bg-light border-0 px-3 py-2" rows="2" placeholder="Ví dụ: Vườn Mai 1, Bình Lợi..."></textarea>
                    </div>
                    <div class="col-12">
                        <label class="form-label x-small fw-bold">PHƯƠNG THỨC THANH TOÁN</label>
                        <div class="d-flex gap-3">
                            <label class="flex-grow-1 cursor-pointer">
                                <input type="radio" name="payment" value="cod" class="d-none peer" checked>
                                <div class="p-3 rounded-4 border text-center peer-checked-primary">
                                    <i class="bi bi-cash-coin d-block fs-4 mb-1"></i>
                                    <span class="x-small fw-bold">Tiền mặt (COD)</span>
                                </div>
                            </label>
                            <label class="flex-grow-1 cursor-pointer">
                                <input type="radio" name="payment" value="momo" class="d-none peer">
                                <div class="p-3 rounded-4 border text-center peer-checked-primary">
                                    <i class="bi bi-qr-code d-block fs-4 mb-1"></i>
                                    <span class="x-small fw-bold">Chuyển khoản / MoMo</span>
                                </div>
                            </label>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Summary Sidebar -->
    <div class="col-lg-4">
        <div class="widget-card sticky-top" style="top: 100px;">
            <h6 class="fw-bold mb-4">Tóm tắt đơn hàng</h6>
            <div class="d-flex flex-column gap-3 mb-4">
                <div class="d-flex justify-content-between small">
                    <span class="text-muted">Tạm tính</span>
                    <span class="fw-bold" id="checkout-subtotal">0đ</span>
                </div>
                <div class="d-flex justify-content-between small">
                    <span class="text-muted">Phí giao hàng</span>
                    <span class="text-success fw-bold">Miễn phí</span>
                </div>
                <div class="d-flex justify-content-between small">
                    <span class="text-muted">Giảm giá</span>
                    <span class="text-danger fw-bold">-0đ</span>
                </div>
                <hr class="my-0 opacity-10">
                <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-bold">TỔNG CỘNG</span>
                    <span class="fw-black font-display text-primary fs-3" id="checkout-total">0đ</span>
                </div>
            </div>
            
            <div class="p-3 rounded-4 mb-4" style="background: var(--primary-50); border: 1px dashed var(--primary);">
                <div class="d-flex align-items-center gap-2 small text-primary fw-bold">
                    <i class="bi bi-star-fill"></i>
                    Tích lũy <span id="checkout-points">0</span> điểm Healing
                </div>
            </div>

            <button class="btn btn-premium w-100 rounded-pill py-3 fw-bold shadow-lg" onclick="placeOrder()">ĐẶT HÀNG NGAY</button>
            <p class="text-center x-small text-muted mt-3 mb-0"><i class="bi bi-shield-check me-1"></i> Giao dịch bảo mật & an toàn</p>
        </div>
    </div>
</div>

<style>
    .peer-checked-primary { border-color: var(--border); transition: all 0.2s; }
    input:checked + .peer-checked-primary { border-color: var(--primary); background: var(--primary-50); color: var(--primary); }
    .cursor-pointer { cursor: pointer; }
</style>

<script>
    let cart = JSON.parse(localStorage.getItem('bl_cart') || '[]');
    
    function renderCheckout() {
        const list = document.getElementById('checkout-list');
        const empty = document.getElementById('checkout-empty');
        const subtotalEl = document.getElementById('checkout-subtotal');
        const totalEl = document.getElementById('checkout-total');
        const pointsEl = document.getElementById('checkout-points');
        
        if (cart.length === 0) {
            document.getElementById('cart-table-wrapper').classList.add('d-none');
            empty.classList.remove('d-none');
            return;
        }

        let total = 0;
        list.innerHTML = cart.map(item => {
            total += item.price * item.qty;
            return `
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-3">
                            <img src="${item.img}" class="rounded-3" style="width: 48px; height: 48px; object-fit: cover;">
                            <span class="fw-bold small">${item.name}</span>
                        </div>
                    </td>
                    <td class="text-center small">${item.qty}</td>
                    <td class="text-end small">${item.price.toLocaleString()}đ</td>
                    <td class="text-end fw-bold text-primary">${(item.price * item.qty).toLocaleString()}đ</td>
                </tr>
            `;
        }).join('');

        subtotalEl.innerText = total.toLocaleString() + 'đ';
        totalEl.innerText = total.toLocaleString() + 'đ';
        pointsEl.innerText = Math.floor(total / 10000);
    }

    async function placeOrder() {
        if(cart.length === 0) return alert('Giỏ hàng trống!');
        // Logic đặt hàng...
        alert('Cảm ơn bạn! Đơn hàng đã được ghi nhận. Chúng tôi sẽ liên hệ sớm nhất.');
        localStorage.removeItem('bl_cart');
        window.location.href = '/cart/orders';
    }

    document.addEventListener('DOMContentLoaded', renderCheckout);
</script>
