<!-- Cart Page — Chương 5.12 -->
<section class="py-5" style="margin-top: 80px;">
    <div class="container py-4" style="max-width: 960px;">
        <div class="mb-5 reveal-up">
            <span class="section-label">GIỎ HÀNG</span>
            <h2 class="section-title">Sản phẩm OCOP đã chọn</h2>
        </div>

        <% if (items.length === 0) { %>
            <div class="text-center py-5 reveal-up">
                <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-4" style="width: 80px; height: 80px; background: var(--surface-alt);">
                    <i class="bi bi-bag" style="font-size: 2rem; color: var(--text-muted);"></i>
                </div>
                <p class="text-muted mb-4">Giỏ hàng trống</p>
                <a href="/market" class="btn btn-premium rounded-pill px-5">Mua sắm OCOP</a>
            </div>
        <% } else { %>
        <div class="row g-4">
            <!-- Items -->
            <div class="col-lg-7">
                <div class="d-flex flex-column gap-3">
                    <% items.forEach(item => { %>
                    <div class="d-flex gap-3 p-3 rounded-xl align-items-center reveal-up" id="item-<%= item.id %>" style="background: var(--surface); border: 1px solid var(--border-light);">
                        <img src="<%= fixImg(item.image) %>" class="rounded-lg flex-shrink-0" style="width: 72px; height: 72px; object-fit: cover;">
                        <div class="flex-grow-1">
                            <h6 class="fw-bold mb-1" style="font-size: 0.9rem;"><%= item.name %></h6>
                            <span class="text-muted" style="font-size: 0.78rem;"><%= item.origin || item.category || '' %></span>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <button class="btn btn-sm rounded-circle d-flex align-items-center justify-content-center" style="width: 30px; height: 30px; background: var(--surface-alt); border: 1px solid var(--border);" onclick="updateQty('<%= item.id %>', <%= item.quantity - 1 %>)">
                                <i class="bi bi-dash" style="font-size: 0.8rem;"></i>
                            </button>
                            <span class="fw-bold" style="min-width: 24px; text-align: center;"><%= item.quantity %></span>
                            <button class="btn btn-sm rounded-circle d-flex align-items-center justify-content-center" style="width: 30px; height: 30px; background: var(--surface-alt); border: 1px solid var(--border);" onclick="updateQty('<%= item.id %>', <%= item.quantity + 1 %>)">
                                <i class="bi bi-plus" style="font-size: 0.8rem;"></i>
                            </button>
                        </div>
                        <div class="text-end" style="min-width: 90px;">
                            <span class="fw-black d-block" style="color: var(--primary);"><%= new Intl.NumberFormat('vi-VN').format(item.price * item.quantity) %>đ</span>
                            <button class="btn btn-sm p-0 border-0 bg-transparent" style="color: var(--text-muted); font-size: 0.75rem;" onclick="removeItem('<%= item.id %>')"><i class="bi bi-trash3 me-1"></i>Xóa</button>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>

            <!-- Checkout Sidebar -->
            <div class="col-lg-5">
                <div class="p-4 rounded-2xl reveal-up" style="background: var(--surface); border: 1px solid var(--border-light); position: sticky; top: 100px;">
                    <h5 class="fw-bold mb-4">Thông tin đặt hàng</h5>
                    <form id="checkoutForm">
                        <div class="mb-3">
                            <label class="form-label fw-bold" style="font-size: 0.82rem; color: var(--text-secondary);">Nơi nhận hàng</label>
                            <select class="form-select rounded-lg border-0" name="pickup_location" style="background: var(--surface-alt); padding: 12px;">
                                <option value="Chợ OCOP Bình Lợi">Chợ OCOP Bình Lợi</option>
                                <option value="Vườn Mai Bình Lợi">Vườn Mai Bình Lợi</option>
                                <option value="Xưởng Nhang Minh">Xưởng Nhang Minh</option>
                                <option value="Chùa Thanh Tâm">Chùa Thanh Tâm</option>
                            </select>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold" style="font-size: 0.82rem; color: var(--text-secondary);">Ghi chú</label>
                            <textarea class="form-control rounded-lg border-0" name="note" rows="2" placeholder="Yêu cầu đặc biệt..." style="background: var(--surface-alt); padding: 12px; resize: none;"></textarea>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-4 pb-3" style="border-bottom: 1px solid var(--border-light);">
                            <span class="text-muted">Tổng cộng</span>
                            <span class="fw-black font-display" style="font-size: 1.5rem; color: var(--primary);"><%= new Intl.NumberFormat('vi-VN').format(total) %>đ</span>
                        </div>
                        <button type="submit" class="btn btn-premium w-100 py-3" id="btnCheckout">
                            <i class="bi bi-bag-check me-2"></i>Đặt hàng
                        </button>
                    </form>
                    <div id="checkoutResult" class="mt-3 d-none"></div>
                    <p class="text-center text-muted mt-3 mb-0" style="font-size: 0.75rem;"><i class="bi bi-shield-check me-1"></i>Thanh toán tại điểm nhận hàng · +30 điểm thưởng</p>
                </div>
            </div>
        </div>
        <% } %>
    </div>
</section>

<script>
async function updateQty(itemId, qty) {
    await axios.post('/api/cart/update', { item_id: itemId, quantity: qty });
    location.reload();
}
async function removeItem(itemId) {
    await axios.post('/api/cart/remove', { item_id: itemId });
    location.reload();
}
document.getElementById('checkoutForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('btnCheckout');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang xử lý...';
    try {
        const formData = new FormData(e.target);
        const res = await axios.post('/api/cart/checkout', Object.fromEntries(formData));
        const el = document.getElementById('checkoutResult');
        el.classList.remove('d-none');
        if (res.data.success) {
            el.innerHTML = `<div class="alert border-0 rounded-xl p-3 text-center" style="background: var(--primary-50); color: var(--primary);"><i class="bi bi-check-circle-fill me-2"></i>${res.data.message}</div>`;
            btn.innerHTML = '<i class="bi bi-check-circle me-2"></i>Đã đặt!';
        }
    } catch(err) {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-bag-check me-2"></i>Đặt hàng';
    }
});
</script>
