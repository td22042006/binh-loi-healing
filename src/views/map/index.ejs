<!-- Map Dashboard — Show All Features -->
<div class="row g-4 h-100">
    <!-- Map Canvas Area -->
    <div class="col-lg-9">
        <div class="widget-card p-0 overflow-hidden position-relative" style="height: calc(100vh - 150px);">
            <!-- Map Container -->
            <div id="map-platform" style="width: 100%; height: 100%; z-index: 1;"></div>
            
            <!-- Map Overlay Controls -->
            <div class="position-absolute top-0 start-0 m-3 d-flex flex-column gap-2" style="z-index: 10;">
                <div class="card-glass p-2 d-flex gap-2">
                    <button class="btn btn-sm btn-primary-bl rounded-pill px-3 map-filter-btn active" data-type="all">Tất cả</button>
                    <button class="btn btn-sm btn-white rounded-pill px-3 map-filter-btn" data-type="culture">Văn hóa</button>
                    <button class="btn btn-sm btn-white rounded-pill px-3 map-filter-btn" data-type="nature">Thiên nhiên</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Map Info Sidebar -->
    <div class="col-lg-3">
        <div class="widget-card h-100 overflow-hidden d-flex flex-column">
            <h6 class="fw-bold mb-3 d-flex align-items-center gap-2">
                <i class="bi bi-geo-alt-fill text-danger"></i> Điểm đến gần bạn
            </h6>
            <div id="map-location-list" class="flex-grow-1 overflow-auto custom-scrollbar d-flex flex-column gap-2 pe-1">
                <!-- JS Rendered -->
            </div>
            <div class="pt-3 border-top mt-3">
                <button class="btn btn-premium w-100 rounded-pill small py-2" onclick="findNearest()">Tìm điểm gần nhất</button>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
    const destinations = <%- JSON.stringify(destinations) %>;
    let map = L.map('map-platform', { zoomControl: false }).setView([10.845, 106.550], 14);
    L.control.zoom({ position: 'bottomright' }).addTo(map);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

    function renderMapItems(type = 'all') {
        const filtered = type === 'all' ? destinations : destinations.filter(d => d.type === type);
        const listContainer = document.getElementById('map-location-list');
        listContainer.innerHTML = '';

        filtered.forEach(d => {
            if (!d.latitude || !d.longitude) return;
            
            const marker = L.marker([d.latitude, d.longitude]).addTo(map);
            marker.bindPopup(`<div class="p-1"><h6 class="fw-bold mb-1 small">${d.name}</h6><a href="/explore/${d.slug}" class="x-small text-decoration-none">Xem chi tiết</a></div>`);

            // Add to sidebar list
            const item = document.createElement('div');
            item.className = 'p-2 rounded-3 border bg-light hover-lift cursor-pointer';
            item.innerHTML = `
                <div class="d-flex gap-2 align-items-center">
                    <img src="${d.cover_image}" class="rounded-2" style="width: 40px; height: 40px; object-fit: cover;">
                    <div class="overflow-hidden">
                        <span class="d-block fw-bold x-small text-truncate">${d.name}</span>
                        <span class="text-muted x-small">${d.type}</span>
                    </div>
                </div>
            `;
            item.onclick = () => {
                map.flyTo([d.latitude, d.longitude], 16);
                marker.openPopup();
            };
            listContainer.appendChild(item);
        });
    }

    document.querySelectorAll('.map-filter-btn').forEach(btn => {
        btn.onclick = () => {
            document.querySelectorAll('.map-filter-btn').forEach(b => b.classList.remove('active', 'btn-primary-bl'));
            btn.classList.add('active', 'btn-primary-bl');
            renderMapItems(btn.dataset.type);
        };
    });

    renderMapItems();
</script>
