<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

<section class="min-vh-100 d-flex flex-column pt-5 mt-4">
    <!-- Map UI Layout: Sidebar + Full Map -->
    <div class="row g-0 flex-grow-1 position-relative">
        
        <!-- Left Sidebar (Destinations List) -->
        <div class="col-lg-3 bg-white shadow-lg z-index-10 d-flex flex-column" style="height: calc(100vh - 80px);">
            <div class="p-4 border-bottom bg-light">
                <h5 class="fw-black text-primary mb-1"><i class="bi bi-map-fill me-2"></i>Bản đồ Google Maps</h5>
                <p class="small text-muted mb-3">Khám phá và định vị không gian Bình Lợi</p>
                
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0 rounded-start-pill"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" id="mapSearch" class="form-control border-start-0 rounded-end-pill px-0 shadow-none" placeholder="Tìm địa điểm..." onkeyup="filterMapList()">
                </div>
                
                <div class="d-flex gap-2 overflow-auto pb-2 mt-3 no-scrollbar">
                    <button class="btn btn-outline-primary btn-sm rounded-pill flex-shrink-0 active filter-btn" data-type="all">Tất cả</button>
                    <button class="btn btn-outline-primary btn-sm rounded-pill flex-shrink-0 filter-btn" data-type="temple">Tâm linh</button>
                    <button class="btn btn-outline-primary btn-sm rounded-pill flex-shrink-0 filter-btn" data-type="park">Sinh thái</button>
                    <button class="btn btn-outline-primary btn-sm rounded-pill flex-shrink-0 filter-btn" data-type="craft">Làng nghề</button>
                </div>
            </div>

            <!-- Destinations List -->
            <div class="flex-grow-1 overflow-auto p-3" id="mapDestList">
                <% allDests.forEach(dest => { %>
                    <div class="card-bl border-0 shadow-sm p-2 mb-3 cursor-pointer dest-item" data-type="<%= dest.type %>" data-name="<%= dest.name.toLowerCase() %>" data-lat="<%= dest.lat || 10.74 %>" data-lng="<%= dest.lng || 106.5 %>" onclick="focusMarker(<%= dest.lat || 10.74 %>, <%= dest.lng || 106.5 %>, '<%= dest.name %>')">
                        <div class="d-flex gap-3">
                            <div class="rounded-3 overflow-hidden shadow-sm" style="width: 70px; height: 70px; flex-shrink: 0;">
                                <img src="<%= fixImg(dest.cover_image) %>" class="w-100 h-100 object-fit-cover">
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1 text-dark small"><%= dest.name %></h6>
                                <p class="x-small text-muted mb-2 line-clamp-1"><%= dest.short_desc %></p>
                                <span class="badge bg-light text-primary border"><%= dest.type %></span>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>

        <!-- Right Side: Google Map -->
        <div class="col-lg-9 position-relative">
            <div id="map" style="width: 100%; height: calc(100vh - 80px); z-index: 1;"></div>
            
            <!-- Map Controls Overlay -->
            <div class="position-absolute top-0 end-0 m-4 d-flex flex-column gap-2" style="z-index: 1000;">
                <button class="btn btn-white rounded-circle shadow-lg p-0 map-control-btn" style="width: 45px; height: 45px;" onclick="locateMe()" title="Vị trí của tôi">
                    <i class="bi bi-geo-fill text-primary fs-5"></i>
                </button>
            </div>
        </div>
    </div>
</section>

<script>
let map, markers = [];
const destData = <%- JSON.stringify(allDests) %>;

function initMap() {
    const center = [10.7431, 106.5028];
    
    map = L.map('map', {
        center: center,
        zoom: 14,
        zoomControl: true,
        attributionControl: false
    });

    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; OpenStreetMap &copy; CartoDB',
        subdomains: 'abcd',
        maxZoom: 20
    }).addTo(map);

    // Add destination markers
    destData.forEach(dest => {
        const lat = parseFloat(dest.lat) || (10.74 + (Math.random() * 0.05 - 0.025));
        const lng = parseFloat(dest.lng) || (106.5 + (Math.random() * 0.05 - 0.025));
        
        const greenIcon = L.divIcon({
            className: 'custom-div-icon',
            html: `<div style="background-color: #198754; width: 22px; height: 22px; border-radius: 50%; border: 3px solid #ffffff; box-shadow: 0 2px 5px rgba(0,0,0,0.3);"></div>`,
            iconSize: [22, 22],
            iconAnchor: [11, 11],
            popupAnchor: [0, -11]
        });

        const marker = L.marker([lat, lng], { icon: greenIcon }).addTo(map);

        const content = `
            <div style="width: 220px; padding: 5px; font-family: 'Times New Roman', Times, serif;">
                <img src="${dest.cover_image && (dest.cover_image.startsWith('http') || dest.cover_image.startsWith('data:')) ? dest.cover_image : '/images/hero-1.png'}" style="width: 100%; height: 100px; object-fit: cover; border-radius: 8px; margin-bottom: 10px;">
                <span class="badge bg-success bg-opacity-10 text-success mb-1" style="font-size: 11px;">${dest.type}</span>
                <h6 style="margin: 5px 0; font-weight: bold; font-family: 'Times New Roman', Times, serif;">${dest.name}</h6>
                <p style="font-size: 12px; color: #475569; margin: 0 0 8px; font-family: 'Times New Roman', Times, serif;">${dest.short_desc || ''}</p>
                <a href="/explore/${dest.slug}" style="display: block; text-align: center; background: #198754; color: white; padding: 6px 12px; border-radius: 20px; text-decoration: none; font-size: 13px; font-weight: bold; font-family: 'Times New Roman', Times, serif;">Khám phá chi tiết</a>
            </div>
        `;

        marker.bindPopup(content);

        markers.push({ marker, slug: dest.slug, name: dest.name, coords: [lat, lng] });
    });
}

document.addEventListener('DOMContentLoaded', initMap);

function focusMarker(lat, lng, name) {
    map.panTo([parseFloat(lat), parseFloat(lng)]);
    map.setZoom(16);
    
    const found = markers.find(m => m.name === name);
    if (found) {
        found.marker.openPopup();
    }
}

function filterMapList() {
    const query = document.getElementById('mapSearch').value.toLowerCase();
    const activeFilter = document.querySelector('.filter-btn.active')?.getAttribute('data-type') || 'all';
    
    document.querySelectorAll('.dest-item').forEach(item => {
        const name = item.getAttribute('data-name');
        const type = item.getAttribute('data-type');
        const matchesQuery = name.includes(query);
        const matchesType = activeFilter === 'all' || type === activeFilter;
        item.style.display = (matchesQuery && matchesType) ? 'block' : 'none';
    });
}

document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
        document.querySelectorAll('.filter-btn').forEach(b => { b.classList.remove('active', 'btn-primary'); b.classList.add('btn-outline-primary'); });
        e.target.classList.remove('btn-outline-primary');
        e.target.classList.add('active', 'btn-primary');
        filterMapList();
    });
});

function locateMe() {
    if (!navigator.geolocation) { alert('Trình duyệt không hỗ trợ định vị.'); return; }
    navigator.geolocation.getCurrentPosition(pos => {
        const myPos = [pos.coords.latitude, pos.coords.longitude];
        map.panTo(myPos);
        map.setZoom(16);
        
        const blueIcon = L.divIcon({
            className: 'my-location-icon',
            html: `<div style="background-color: #4285F4; width: 16px; height: 16px; border-radius: 50%; border: 3px solid #ffffff; box-shadow: 0 2px 5px rgba(0,0,0,0.3);"></div>`,
            iconSize: [16, 16],
            iconAnchor: [8, 8]
        });
        
        L.marker(myPos, { icon: blueIcon }).addTo(map).bindPopup('Vị trí của bạn').openPopup();
    });
}
</script>

<style>
    body { overflow-x: hidden; }
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    .z-index-10 { z-index: 10; }
    .map-control-btn { transition: all 0.2s; }
    .map-control-btn:hover { transform: scale(1.1); }
</style>
