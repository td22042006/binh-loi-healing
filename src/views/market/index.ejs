<section class="market-hero py-5 bg-dark text-white position-relative overflow-hidden">
    <div class="container py-5 text-center position-relative" style="z-index: 10;">
        <span class="badge bg-secondary text-dark px-3 py-2 rounded-pill mb-3">OCOP BÌNH LỢI</span>
        <h1 class="display-3 fw-black mb-3">Tinh Hoa Đặc Sản Địa Phương</h1>
        <p class="lead opacity-75 mx-auto" style="max-width: 700px;">Mỗi sản phẩm là một câu chuyện về tâm huyết của người nông dân Bình Lợi, được chứng nhận OCOP quốc gia.</p>
    </div>
    <div class="hero-overlay-dark"></div>
    <div class="bg-pattern position-absolute top-0 start-0 w-100 h-100 opacity-10"></div>
</section>

<div class="container py-5">
    <!-- Filter Bar -->
    <div class="d-flex justify-content-between align-items-center mb-5 flex-wrap gap-3">
        <div class="btn-group shadow-sm rounded-pill overflow-hidden">
            <button class="btn btn-primary-bl px-4">Tất cả</button>
            <button class="btn btn-light px-4">Cây cảnh</button>
            <button class="btn btn-light px-4">Thực phẩm</button>
            <button class="btn btn-light px-4">Thủ công</button>
        </div>
        <div class="text-muted small">Hiển thị <%= products.length %> sản phẩm</div>
    </div>

    <!-- Product Grid -->
    <div class="row g-4">
        <% products.forEach(product => { %>
        <div class="col-6 col-lg-3">
            <div class="card-bl h-100 shadow-sm border-0 overflow-hidden hover-up transition-all">
                <div class="position-relative overflow-hidden" style="height: 200px;">
                    <img src="<%= product.image %>" class="w-100 h-100 object-fit-cover" alt="<%= product.name %>">
                    <div class="position-absolute top-0 start-0 m-2">
                        <span class="badge bg-warning text-dark shadow-sm">OCOP 4⭐</span>
                    </div>
                </div>
                <div class="p-3 p-md-4">
                    <h6 class="fw-bold mb-1 text-truncate"><%= product.name %></h6>
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <div class="text-warning small">
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-half"></i>
                        </div>
                        <span class="x-small text-muted">(<%= product.sold %> đã bán)</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fw-black text-primary"><%= product.price.toLocaleString() %>đ</span>
                        <button class="btn btn-outline-bl btn-sm rounded-circle" style="width: 32px; height: 32px; padding: 0;">
                            <i class="bi bi-cart-plus"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <% }) %>
    </div>
</div>

<style>
.market-hero { height: 40vh; display: flex; align-items: center; }
.hover-up:hover { transform: translateY(-10px); }
.fw-black { font-weight: 900; }
</style>
