<!-- Vibrant Market Dashboard — The Gift of Nature -->
<div class="row g-4">
    <!-- Products Main Area -->
    <div class="col-lg-8">
        <div class="widget-card p-4">
            <div class="d-flex flex-wrap justify-content-between align-items-center mb-5 gap-3">
                <div>
                    <h3 class="fw-black font-display mb-1" style="color: var(--primary);">Đặc sản Bình Lợi</h3>
                    <p class="text-muted small mb-0">Sản phẩm OCOP tinh hoa từ làng nghề bản địa</p>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-primary-bl rounded-pill px-4 shadow-sm">Tất cả</button>
                    <button class="btn btn-outline-success rounded-pill px-4 fw-bold">Thực phẩm</button>
                    <button class="btn btn-outline-warning rounded-pill px-4 fw-bold">Thủ công</button>
                </div>
            </div>

            <div class="row g-4">
                <% products.forEach(p => { 
                    const isFood = p.category === 'Thực phẩm';
                    const themeColor = isFood ? '#10b981' : '#f59e0b';
                %>
                <div class="col-6 col-md-4">
                    <div class="card-heal p-0 overflow-hidden border-2 transition-all hover-lift h-100 d-flex flex-column" 
                         style="border-bottom: 4px solid <%= themeColor %>;">
                        <div class="position-relative" style="height: 180px;">
                            <img src="<%= fixImg(p.image) %>" class="w-100 h-100 object-fit-cover">
                            <div class="position-absolute top-0 start-0 m-2">
                                <span class="badge rounded-pill px-3 py-2 fw-black shadow-sm" 
                                      style="background: <%= themeColor %>; color: white; font-size: 0.6rem; letter-spacing: 1px;">
                                    <%= p.category.toUpperCase() %>
                                </span>
                            </div>
                        </div>
                        <div class="p-3 d-flex flex-column flex-grow-1">
                            <h6 class="fw-black mb-1 line-clamp-1" style="font-size: 1rem;"><%= p.name %></h6>
                            <p class="text-muted x-small mb-3"><i class="bi bi-geo-alt-fill me-1" style="color: <%= themeColor %>;"></i><%= p.origin %></p>
                            
                            <div class="mt-auto">
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="fw-black fs-5" style="color: var(--primary);"><%= new Intl.NumberFormat('vi-VN').format(p.price) %>đ</span>
                                    <button onclick="addToCart(<%= p.id %>, '<%= p.name %>', <%= p.price %>, '<%= p.image %>')" 
                                            class="btn rounded-circle d-flex align-items-center justify-content-center shadow-sm" 
                                            style="width: 38px; height: 38px; background: <%= themeColor %>; color: white; border: none;">
                                        <i class="bi bi-plus-lg fs-5"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>
    </div>

    <!-- Right Sidebar: Vibrant Cart & Discovery -->
    <div class="col-lg-4">
        <!-- VIBRANT CART WIDGET -->
        <div class="widget-card p-4 mb-4 border-0 shadow-lg" style="background: white;">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-black font-display mb-0 text-primary">Giỏ hàng OCOP</h5>
                <i class="bi bi-bag-heart-fill fs-4 text-warning"></i>
            </div>
            
            <div id="cart-items-vibrant" class="d-flex flex-column gap-3 mb-4 custom-scrollbar" style="max-height: 400px; overflow-y: auto;">
                <!-- JS Rendered -->
                <div class="text-center py-5 text-muted opacity-50" id="empty-cart-vibrant">
                    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 80px; height: 80px;">
                        <i class="bi bi-cart3 fs-1"></i>
                    </div>
                    <p class="fw-bold">Chưa có đặc sản nào được chọn</p>
                </div>
            </div>

            <div class="pt-4 border-top">
                <div class="p-3 rounded-4 mb-4" style="background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="x-small fw-bold text-success text-uppercase tracking-widest">Tổng thanh toán</span>
                        <span class="fw-black text-success fs-3" id="total-price-vibrant">0đ</span>
                    </div>
                    <div class="d-flex align-items-center gap-2 x-small fw-bold text-success opacity-75">
                        <i class="bi bi-star-fill"></i> Tích lũy <span id="reward-points-vibrant">0</span> XP
                    </div>
                </div>
                <a href="/cart" class="btn btn-premium w-100 py-3 rounded-pill shadow-lg">THANH TOÁN ĐƠN HÀNG</a>
            </div>
        </div>

        <!-- Trust Badge Widget -->
        <div class="widget-card p-4 border-0" style="background: var(--grad-main); color: white;">
            <div class="d-flex gap-3 align-items-start mb-3">
                <i class="bi bi-shield-check fs-2 text-warning"></i>
                <div>
                    <h6 class="fw-bold mb-1 text-white">Cam kết chất lượng</h6>
                    <p class="x-small opacity-75 mb-0">Sản phẩm được chứng nhận OCOP 3-4 sao, đảm bảo an toàn vệ sinh và nguồn gốc bản địa.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let cart = JSON.parse(localStorage.getItem('bl_cart') || '[]');
    renderVibrantCart();

    async function addToCart(id, name, price, img) {
        const item = cart.find(i => i.id === id);
        if (item) item.qty++;
        else cart.push({ id, name, price, img, qty: 1 });
        localStorage.setItem('bl_cart', JSON.stringify(cart));
        renderVibrantCart();
        
        // Save to server
        try { await axios.post('/api/cart/add', { product_id: id, quantity: 1 }); } catch(e) {}
    }

    function renderVibrantCart() {
        const container = document.getElementById('cart-items-vibrant');
        const emptyMsg = document.getElementById('empty-cart-vibrant');
        const totalEl = document.getElementById('total-price-vibrant');
        const pointsEl = document.getElementById('reward-points-vibrant');
        
        const totalPrice = cart.reduce((sum, item) => sum + (item.qty * item.price), 0);
        totalEl.innerText = totalPrice.toLocaleString() + 'đ';
        pointsEl.innerText = Math.floor(totalPrice / 10000);
        
        if (cart.length === 0) {
            emptyMsg.style.display = 'block';
            document.querySelectorAll('.cart-row-vibrant').forEach(e => e.remove());
            return;
        }
        
        emptyMsg.style.display = 'none';
        document.querySelectorAll('.cart-row-vibrant').forEach(e => e.remove());
        
        cart.forEach(item => {
            const html = `
                <div class="cart-row-vibrant d-flex gap-3 align-items-center p-3 rounded-4 border bg-white hover-lift">
                    <img src="${item.img}" class="rounded-3 object-fit-cover shadow-sm" style="width: 50px; height: 50px;">
                    <div class="flex-grow-1 overflow-hidden">
                        <span class="fw-bold d-block text-truncate small">${item.name}</span>
                        <span class="text-primary fw-black" style="font-size: 0.85rem;">${item.price.toLocaleString()}đ</span>
                    </div>
                    <div class="badge bg-light text-dark rounded-pill px-2">x${item.qty}</div>
                </div>
            `;
            container.insertAdjacentHTML('beforeend', html);
        });
    }
</script>
