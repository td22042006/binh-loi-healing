<div class="container py-5 mt-5">
    <!-- Market Header -->
    <div class="glass-panel p-5 mb-5 text-center position-relative overflow-hidden">
        <h1 class="display-4 fw-bold mb-2" style="font-family: var(--font-heading);">Chợ OCOP Bình Lợi</h1>
        <p class="lead text-muted mx-auto" style="max-width: 700px;">Mang tinh hoa làng nghề và nông sản sạch Bình Lợi về ngôi nhà của bạn.</p>
        <div class="d-flex justify-content-center gap-3 mt-4">
            <div class="badge bg-white text-primary border px-3 py-2 rounded-pill fw-bold"><i class="bi bi-patch-check-fill me-1"></i>CHỨNG NHẬN OCOP 3-5 SAO</div>
            <div class="badge bg-white text-primary border px-3 py-2 rounded-pill fw-bold"><i class="bi bi-truck me-1"></i>GIAO HÀNG TOÀN QUỐC</div>
        </div>
        <i class="bi bi-shop position-absolute top-50 start-0 text-primary opacity-05" style="font-size: 15rem; transform: translate(-30%, -50%);"></i>
    </div>

    <div class="row g-4">
        <!-- Sidebar Filters -->
        <div class="col-lg-3">
            <div class="glass-panel p-4 sticky-top" style="top: 100px;">
                <h5 class="fw-bold mb-4">Danh mục</h5>
                <div class="list-group list-group-flush mb-5">
                    <a href="#" class="list-group-item bg-transparent border-0 px-0 py-2 d-flex justify-content-between align-items-center active fw-bold text-primary">Tất cả sản phẩm <span class="badge bg-primary rounded-pill">24</span></a>
                    <a href="#" class="list-group-item bg-transparent border-0 px-0 py-2 d-flex justify-content-between align-items-center">Cây cảnh & Hoa <span class="badge bg-light text-muted rounded-pill">12</span></a>
                    <a href="#" class="list-group-item bg-transparent border-0 px-0 py-2 d-flex justify-content-between align-items-center">Nông sản sạch <span class="badge bg-light text-muted rounded-pill">8</span></a>
                    <a href="#" class="list-group-item bg-transparent border-0 px-0 py-2 d-flex justify-content-between align-items-center">Thủ công mỹ nghệ <span class="badge bg-light text-muted rounded-pill">4</span></a>
                </div>

                <h5 class="fw-bold mb-4">Khoảng giá</h5>
                <input type="range" class="form-range mb-3" min="0" max="2000000" step="50000">
                <div class="d-flex justify-content-between small text-muted">
                    <span>0đ</span>
                    <span>2.000.000đ+</span>
                </div>
            </div>
        </div>

        <!-- Product Grid -->
        <div class="col-lg-9">
            <div class="row g-4">
                <% products.forEach(product => { %>
                <div class="col-md-6 col-xl-4">
                    <div class="card-healing p-0 overflow-hidden h-100 border-0 shadow-sm">
                        <div class="position-relative">
                            <img src="<%= product.image %>" class="w-100" style="height: 250px; object-fit: cover;">
                            <span class="position-absolute top-0 end-0 m-3 badge bg-warning text-dark fw-bold rounded-pill shadow">OCOP ★★★</span>
                        </div>
                        <div class="p-4">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h6 class="fw-bold mb-0 text-truncate" style="max-width: 150px;"><%= product.name %></h6>
                                <span class="text-primary fw-bold"><%= product.price.toLocaleString() %>đ</span>
                            </div>
                            <div class="d-flex align-items-center gap-1 mb-3">
                                <i class="bi bi-star-fill text-warning small"></i>
                                <span class="small fw-bold"><%= product.rating %></span>
                                <span class="text-muted small ms-1">(Đã bán <%= product.sold %>)</span>
                            </div>
                            <div class="d-grid gap-2">
                                <button class="btn btn-premium btn-sm rounded-pill py-2">MUA NGAY</button>
                                <button class="btn btn-light btn-sm rounded-pill py-2"><i class="bi bi-cart-plus me-1"></i>THÊM GIỎ HÀNG</button>
                            </div>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>
    </div>
</div>
