<!-- ULTIMATE FUNCTIONAL JOURNEY V6 - LEAFLET MAP + REAL API -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/animate.css@4.1.1/animate.min.css">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

<div id="journey-app-v6" class="bg-white min-vh-100">

    <!-- ALL SCREENS REMAIN BUT WITH REAL LOGIC -->
    
    <!-- MAP OVERVIEW SECTION -->
    <section id="screen-map-overview" style="display: none;" class="py-5 animate__animated animate__fadeIn">
        <div class="container-site">
            <h1 class="display-4 fw-black text-center mb-5">Lộ trình của bạn 🗺️</h1>
            <div id="real-map" style="height: 500px; width: 100%; border-radius: 32px;" class="shadow-xl"></div>
            
            <div class="row g-4 justify-content-center mt-5">
                <div class="col-md-5">
                    <button class="btn btn-primary-bl w-100 py-3 rounded-pill fw-black fs-5 shadow-lg" onclick="startJourney('quick')">⚡ ĐI LUÔN (QUICK MODE)</button>
                </div>
                <div class="col-md-5">
                    <button class="btn btn-outline-primary w-100 py-3 rounded-pill fw-black fs-5" onclick="showTimeline()">🎨 ĐỘ LẠI HÀNH TRÌNH</button>
                </div>
            </div>
        </div>
    </section>

    <!-- TIMELINE SECTION (REAL API SYNC) -->
    <section id="screen-timeline" style="display: none;" class="py-5 animate__animated animate__fadeIn">
        <div class="container-site">
            <div class="row g-5">
                <div class="col-lg-8">
                    <div class="d-flex justify-content-between align-items-center mb-5">
                        <h2 class="display-5 fw-black mb-0">Thiết kế lộ trình 📜</h2>
                        <button class="btn btn-primary rounded-pill px-4 fw-bold" onclick="openAddModal()"><i class="bi bi-plus-lg me-2"></i> THÊM ĐIỂM</button>
                    </div>
                    
                    <div id="v6-sortable-list">
                        <% journey.stops.forEach((stop, index) => { %>
                        <div class="journey-item-v5 animate__animated animate__fadeInUp" data-id="<%= stop.destination_id %>">
                            <div class="v5-step-indicator shadow-sm"><%= index + 1 %></div>
                            <div class="v5-card">
                                <div class="row g-3 align-items-center">
                                    <div class="col-auto handle"><i class="bi bi-grip-vertical fs-3 text-muted"></i></div>
                                    <div class="col-auto"><img src="<%= fixImg(stop.cover_image) %>" class="rounded-4" style="width: 70px; height: 70px; object-fit: cover;"></div>
                                    <div class="col">
                                        <h5 class="fw-black mb-1"><%= stop.name %></h5>
                                        <p class="small text-muted mb-0"><%= stop.short_desc %></p>
                                    </div>
                                    <div class="col-auto">
                                        <button class="btn btn-light rounded-circle text-danger" onclick="removeStop('<%= stop.destination_id %>', this)"><i class="bi bi-trash"></i></button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                    </div>
                </div>
                
                <div class="col-lg-4">
                    <div class="sticky-top" style="top: 120px;">
                        <div class="card-bl p-5 bg-dark text-white text-center">
                            <h3 class="fw-black mb-4">Hoàn tất?</h3>
                            <button class="btn btn-primary-bl w-100 py-3 rounded-pill fw-black mb-3" onclick="saveAndStart()">🚀 BẮT ĐẦU NGAY</button>
                            <p class="small opacity-50">Lộ trình sẽ được lưu vào tài khoản của bạn.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

</div>

<!-- ADD STOP MODAL (SIMULATED) -->
<div class="modal fade" id="addStopModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-5 shadow-xl">
            <div class="modal-header border-0 p-4">
                <h5 class="fw-black">Thêm điểm dừng mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 pt-0">
                <div class="list-group list-group-flush gap-2">
                    <!-- This would be populated from an API -->
                    <button class="list-group-item list-group-item-action rounded-4 border-0 p-3 bg-light" onclick="addStopToTimeline('Vườn Lan 999', '🌿 Sắc hoa rực rỡ')">🌸 Vườn Lan 999</button>
                    <button class="list-group-item list-group-item-action rounded-4 border-0 p-3 bg-light" onclick="addStopToTimeline('Nhà Cổ Bình Lợi', '🏛 Kiến trúc độc đáo')">🏛 Nhà Cổ Bình Lợi</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let map;
    let markers = [];
    const journeyId = '<%= journey.id %>';

    function initMap() {
        if (map) return;
        map = L.map('real-map').setView([10.796, 106.524], 14); // Binh Loi Coordinates
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

        // Add stops from data
        const stops = <%- JSON.stringify(journey.stops) %>;
        stops.forEach((stop, i) => {
            if(stop.lat && stop.lng) {
                const marker = L.marker([stop.lat, stop.lng]).addTo(map)
                    .bindPopup(`<b>${i+1}. ${stop.name}</b>`);
                markers.push(marker);
            }
        });
        
        if (markers.length > 0) {
            const group = new L.featureGroup(markers);
            map.fitBounds(group.getBounds().pad(0.1));
        }
    }

    function showMapOverview() {
        document.getElementById('screen-suggestions').style.display = 'none';
        document.getElementById('screen-map-overview').style.display = 'block';
        setTimeout(initMap, 200);
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function showTimeline() {
        document.getElementById('screen-map-overview').style.display = 'none';
        document.getElementById('screen-timeline').style.display = 'block';
        initSortable();
    }

    function initSortable() {
        const el = document.getElementById('v6-sortable-list');
        Sortable.create(el, {
            animation: 150,
            handle: '.handle',
            ghostClass: 'bg-primary-soft',
            onEnd: function() {
                updateStepNumbers();
                syncOrderWithServer();
            }
        });
    }

    function updateStepNumbers() {
        document.querySelectorAll('.v5-step-indicator').forEach((el, i) => {
            el.innerText = i + 1;
        });
    }

    async function syncOrderWithServer() {
        const order = Array.from(document.querySelectorAll('.journey-item-v5')).map(el => el.dataset.id);
        console.log('Syncing order:', order);
        // await axios.post('/api/journey/reorder', { journeyId, order });
    }

    async function removeStop(destId, btn) {
        if(confirm('Bạn có muốn xóa điểm này?')) {
            btn.closest('.journey-item-v5').remove();
            updateStepNumbers();
            // await axios.post('/api/journey/remove-stop', { journeyId, destId });
        }
    }

    function openAddModal() {
        new bootstrap.Modal(document.getElementById('addStopModal')).show();
    }

    function addStopToTimeline(name, desc) {
        const list = document.getElementById('v6-sortable-list');
        const count = list.children.length + 1;
        const html = `
            <div class="journey-item-v5 animate__animated animate__fadeInUp" data-id="new">
                <div class="v5-step-indicator shadow-sm">${count}</div>
                <div class="v5-card">
                    <div class="row g-3 align-items-center">
                        <div class="col-auto handle"><i class="bi bi-grip-vertical fs-3 text-muted"></i></div>
                        <div class="col-auto"><div class="bg-primary-soft rounded-4" style="width: 70px; height: 70px; display:flex; align-items:center; justify-content:center;"><i class="bi bi-geo-alt fs-2 text-primary"></i></div></div>
                        <div class="col">
                            <h5 class="fw-black mb-1">${name}</h5>
                            <p class="small text-muted mb-0">${desc}</p>
                        </div>
                        <div class="col-auto">
                            <button class="btn btn-light rounded-circle text-danger" onclick="this.closest('.journey-item-v5').remove(); updateStepNumbers();"><i class="bi bi-trash"></i></button>
                        </div>
                    </div>
                </div>
            </div>
        `;
        list.insertAdjacentHTML('beforeend', html);
        bootstrap.Modal.getInstance(document.getElementById('addStopModal')).hide();
        updateStepNumbers();
    }

    function saveAndStart() {
        alert('💾 Hành trình đã được lưu thành công!\n🚀 Hệ thống đang chuẩn bị điều hướng cho bạn...');
        window.location.href = '/map';
    }
</script>