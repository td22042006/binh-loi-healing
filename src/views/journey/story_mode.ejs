<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<div class="journey-header-new">
    <div class="container-custom">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 class="onboard-title mb-1">Hành trình của bạn</h1>
                <p class="text-muted mb-0"><%= greeting %>, <%= user ? user.full_name : 'bạn đồng hành' %>! Lộ trình này dành riêng cho bạn.</p>
            </div>
            <a href="/onboarding" class="btn btn-outline-secondary rounded-pill px-4 btn-sm">Thay đổi vibe</a>
        </div>
    </div>
</div>

<main class="py-5">
    <div class="container-custom">
        <!-- Stats -->
        <div class="stats-grid-new mb-5">
            <div class="stat-item-new">
                <div class="stat-label-new">Khoảng cách</div>
                <div class="stat-value-new"><%= journey.total_km %> KM</div>
            </div>
            <div class="stat-item-new">
                <div class="stat-label-new">Thời gian</div>
                <div class="stat-value-new"><%= journey.total_minutes %> PHÚT</div>
            </div>
            <div class="stat-item-new">
                <div class="stat-label-new">Điểm dừng</div>
                <div class="stat-value-new"><%= journey.stops.length %> ĐIỂM</div>
            </div>
        </div>

        <div class="row g-5">
            <!-- Map -->
            <div class="col-lg-7 order-1 order-lg-2">
                <div class="sticky-top" style="top: 100px;">
                    <div id="map-new" class="map-container-new"></div>
                    <div class="text-center">
                        <button class="btn-primary-v5 w-100" onclick="alert('Đang bắt đầu dẫn đường...')">BẮT ĐẦU DI CHUYỂN 🚀</button>
                    </div>
                </div>
            </div>

            <!-- Steps -->
            <div class="col-lg-5 order-2 order-lg-1">
                <h3 class="fw-bold mb-4">Các điểm dừng chân</h3>
                <div class="timeline-list-new">
                    <% journey.stops.forEach((stop, i) => { %>
                        <div class="step-card-new" id="step-<%= i %>" onclick="focusOnMap(<%= i %>)">
                            <div class="step-number-new"><%= i + 1 %></div>
                            <div class="step-info-new">
                                <h4><%= stop.name %></h4>
                                <p><%= stop.short_desc %></p>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    let map;
    let markers = [];

    document.addEventListener('DOMContentLoaded', () => {
        initMap();
    });

    function initMap() {
        if (!document.getElementById('map-new')) return;
        
        map = L.map('map-new', { zoomControl: false }).setView([10.796, 106.524], 14);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png').addTo(map);

        const stops = <%- JSON.stringify(journey.stops) %>;
        const latlngs = [];

        stops.forEach((stop, i) => {
            const pos = [stop.lat, stop.lng];
            latlngs.push(pos);

            const m = L.marker(pos).addTo(map);
            m.bindPopup(`<b>${stop.name}</b>`);
            markers.push(m);
        });

        if (latlngs.length > 0) {
            L.polyline(latlngs, { color: '#059669', weight: 3, dashArray: '5, 10' }).addTo(map);
            const group = new L.featureGroup(markers);
            map.fitBounds(group.getBounds().pad(0.2));
        }
    }

    function focusOnMap(i) {
        document.querySelectorAll('.step-card-new').forEach(c => c.classList.remove('active'));
        document.getElementById('step-' + i).classList.add('active');

        map.flyTo(markers[i].getLatLng(), 16);
        markers[i].openPopup();
    }
</script>