<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

<main class="py-5 min-vh-100" style="background: linear-gradient(135deg, #f4fbf7 0%, #ffffff 100%); color: #1e293b; padding-top: 100px !important;">
    <div class="container py-lg-4">
        
        <!-- Premium Header with Locking State -->
        <div class="row align-items-center mb-5 animate__animated animate__fadeIn">
            <div class="col-lg-8">
                <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 mb-2 fw-bold text-uppercase x-small" style="letter-spacing: 2px; border: 1px solid rgba(25, 135, 84, 0.25);">
                    <i class="bi bi-compass-fill me-1 text-success"></i> HÀNH TRÌNH CHỮA LÀNH THÔNG MINH
                </span>
                <h1 class="fw-black text-dark mb-2 tracking-wide text-uppercase" style="font-family: 'Times New Roman', Times, serif; font-size: 2.4rem; background: linear-gradient(120deg, #15803d, #166534); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                    <%= journey.mood.replace(/_/g, ' ') %>
                </h1>
                <p class="text-secondary mb-0" id="journey-subtitle" style="font-size: 0.95rem; font-family: 'Times New Roman', Times, serif;">
                    Bản đồ tương tác thời gian thực kết nối các điểm dừng chân lý tưởng dành cho bạn.
                </p>
            </div>
            <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
                <!-- Timeline status badge -->
                <div class="d-inline-flex gap-2 align-items-center bg-white border border-success border-opacity-20 rounded-pill px-4 py-2 shadow-sm">
                    <span class="badge bg-success rounded-circle p-1" id="lock-status-dot" style="width: 10px; height: 10px; display: inline-block; box-shadow: 0 0 10px #198754;"></span>
                    <span class="small fw-bold text-success" id="lock-status-text" style="font-size: 0.82rem;">Lộ trình đã chốt</span>
                    <button class="btn btn-sm btn-success rounded-pill px-3 py-1 ms-3 fw-bold text-uppercase" style="font-size: 0.72rem; letter-spacing: 1px;" onclick="toggleTimelineLock()" id="btn-lock-toggle">
                        <i class="bi bi-pencil-square me-1"></i>Thay đổi
                    </button>
                </div>
            </div>
        </div>

        <!-- Metrics Display (Premium Glassmorphism Cards) -->
        <div class="row g-3 mb-5 text-center">
            <div class="col-6 col-md-3">
                <div class="p-3 rounded-4 h-100 shadow-sm d-flex flex-column justify-content-center bg-white border" style="transition: all 0.3s;" onmouseover="this.style.borderColor='#198754'" onmouseout="this.style.borderColor='#e2e8f0'">
                    <i class="bi bi-clock-fill text-success fs-3 mb-2"></i>
                    <h4 class="fw-black text-dark mb-0" style="font-family: 'Times New Roman', Times, serif;"><%= journey.total_minutes %> Phút</h4>
                    <span class="x-small text-muted fw-bold text-uppercase mt-1" style="font-size: 0.65rem; letter-spacing: 1px;">Tổng thời gian</span>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="p-3 rounded-4 h-100 shadow-sm d-flex flex-column justify-content-center bg-white border" style="transition: all 0.3s;" onmouseover="this.style.borderColor='#198754'" onmouseout="this.style.borderColor='#e2e8f0'">
                    <i class="bi bi-geo-alt-fill text-success fs-3 mb-2"></i>
                    <h4 class="fw-black text-dark mb-0" style="font-family: 'Times New Roman', Times, serif;" id="metric-stops-count"><%= journey.stops.length %> Điểm</h4>
                    <span class="x-small text-muted fw-bold text-uppercase mt-1" style="font-size: 0.65rem; letter-spacing: 1px;">Điểm dừng chân</span>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="p-3 rounded-4 h-100 shadow-sm d-flex flex-column justify-content-center bg-white border" style="transition: all 0.3s;" onmouseover="this.style.borderColor='#198754'" onmouseout="this.style.borderColor='#e2e8f0'">
                    <i class="bi bi-signpost-split-fill text-success fs-3 mb-2"></i>
                    <h4 class="fw-black text-dark mb-0" style="font-family: 'Times New Roman', Times, serif;"><%= journey.total_km %> Km</h4>
                    <span class="x-small text-muted fw-bold text-uppercase mt-1" style="font-size: 0.65rem; letter-spacing: 1px;">Quãng đường</span>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="p-3 rounded-4 h-100 shadow-sm d-flex flex-column justify-content-center bg-white border" style="transition: all 0.3s;" onmouseover="this.style.borderColor='#198754'" onmouseout="this.style.borderColor='#e2e8f0'">
                    <i class="bi bi-stars text-warning fs-3 mb-2"></i>
                    <h4 class="fw-black text-success mb-0" style="font-family: 'Times New Roman', Times, serif;">+<%= journey.stops.reduce((sum, s) => sum + (s.points || 0), 0) %></h4>
                    <span class="x-small text-muted fw-bold text-uppercase mt-1" style="font-size: 0.65rem; letter-spacing: 1px;">Điểm tích lũy</span>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- Left Panel: Interactive Itinerary (timeline form) -->
            <div class="col-lg-6">
                <!-- Timeline customization settings -->
                <div class="card border-0 shadow-sm rounded-4 p-4 mb-4 d-none bg-white border" id="timeline-edit-panel">
                    <h6 class="fw-bold mb-3 text-success d-flex align-items-center gap-2">
                        <i class="bi bi-sliders"></i> Công cụ điều chỉnh lộ trình
                    </h6>
                    <div class="row g-2 align-items-center">
                        <div class="col-md-7">
                            <select class="form-select bg-white text-dark border-secondary rounded-pill shadow-none" id="select-new-destination">
                                <option value="">-- Chọn địa điểm thêm --</option>
                                <% allDestinations.forEach(dest => { %>
                                    <option value="<%= dest.id %>"><%= dest.name %> (<%= dest.type %>)</option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-5">
                            <button class="btn btn-success rounded-pill w-100 fw-bold" onclick="addDestinationToTimeline()">
                                <i class="bi bi-plus-circle me-1"></i>Thêm điểm dừng
                            </button>
                        </div>
                    </div>
                    <div class="mt-3 x-small text-muted">
                        <i class="bi bi-info-circle me-1"></i> Ở chế độ thay đổi, bạn có thể thêm/bớt địa điểm, thay đổi giờ khởi hành hoặc kéo thả để sắp xếp lại thứ tự hành trình.
                    </div>
                </div>

                <!-- Vertical Timeline -->
                <div class="timeline-container position-relative ps-4" id="sortable-timeline">
                    <!-- Vertical line in timeline -->
                    <div class="position-absolute top-0 bottom-0 border-start border-3 border-success opacity-20" style="left: 15px; z-index: 1;"></div>
                    
                    <% journey.stops.forEach((stop, i) => { %>
                        <div class="timeline-item position-relative mb-4" data-id="<%= stop.destination_id %>" id="stop-card-<%= i %>">
                            <!-- Index dot with timeline marker -->
                            <div class="timeline-badge bg-success text-white rounded-circle border border-4 border-white shadow d-flex align-items-center justify-content-center fw-bold" 
                                 style="width: 38px; height: 38px; position: absolute; left: -35px; top: 12px; z-index: 2; transition: all 0.3s; font-family: 'Times New Roman', Times, serif;">
                                <%= i + 1 %>
                            </div>

                            <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white border" style="transition: all 0.3s;">
                                <div class="row g-0 align-items-center">
                                    <!-- Image (full visibility) -->
                                    <div class="col-sm-4" style="height: 140px; min-height: 140px;">
                                        <img src="<%= fixImg(stop.cover_image) %>" class="w-100 h-100" style="object-fit: cover;" alt="<%= stop.name %>">
                                    </div>
                                    <!-- Body content -->
                                    <div class="col-sm-8 p-3 position-relative">
                                        
                                        <!-- Edit actions overlay (only shown when editing) -->
                                        <div class="position-absolute top-0 end-0 m-2 d-flex gap-1 edit-actions d-none" style="z-index: 10;">
                                            <div class="btn btn-light btn-sm rounded-circle drag-handle shadow-sm border" style="cursor: grab;" title="Kéo thả đổi vị trí">
                                                <i class="bi bi-arrows-move text-dark"></i>
                                            </div>
                                            <button class="btn btn-danger btn-sm rounded-circle shadow-sm" onclick="removeStopFromTimeline(<%= stop.destination_id %>)" title="Xóa khỏi lộ trình">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        </div>

                                        <!-- Custom timeframe -->
                                        <div class="d-flex align-items-center gap-2 mb-2">
                                            <span class="badge bg-success bg-opacity-10 text-success fw-bold px-2 py-1" style="font-size: 0.72rem; border: 1px solid rgba(25, 135, 84, 0.2);">
                                                <i class="bi bi-clock-fill me-1"></i>
                                                <% 
                                                    // Dynamic hourly calculation based on index
                                                    let startHour = 8 + (i * 1.5);
                                                    let startHourStr = Math.floor(startHour).toString().padStart(2, '0') + ":" + ((startHour % 1) * 60).toString().padStart(2, '0');
                                                    let endHour = startHour + 1.25;
                                                    let endHourStr = Math.floor(endHour).toString().padStart(2, '0') + ":" + ((endHour % 1) * 60).toString().padStart(2, '0');
                                                %>
                                                <span class="stop-timeframe"><%= startHourStr %> - <%= endHourStr %></span>
                                            </span>
                                            <span class="text-secondary x-small"><i class="bi bi-cpu-fill me-1"></i>Tối ưu AI</span>
                                        </div>

                                        <h5 class="fw-bold mb-1 text-dark text-truncate" style="font-size: 1.05rem; font-family: 'Times New Roman', Times, serif;"><%= stop.name %></h5>
                                        
                                        <p class="text-secondary mb-3 line-clamp-2" style="font-size: 0.85rem; line-height: 1.5; font-family: 'Times New Roman', Times, serif;"><%= stop.short_description || stop.highlight %></p>
                                        
                                        <div class="d-flex align-items-center justify-content-between">
                                            <a href="/explore/<%= stop.slug %>" class="btn btn-outline-success btn-sm rounded-pill px-3 py-1" style="font-size: 0.75rem; font-weight: 600;">
                                                Chi tiết <i class="bi bi-chevron-right ms-1"></i>
                                            </a>
                                            <span class="text-success x-small fw-bold"><i class="bi bi-star-fill me-1 text-warning"></i>+<%= stop.points %> Điểm</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <!-- Complete / Start Navigation Button -->
                <div class="d-grid gap-2 mt-5">
                    <button class="btn btn-success btn-lg py-3 rounded-pill shadow-sm fw-bold text-uppercase tracking-widest" id="btn-timeline-action" onclick="lockJourneyAndConfirm()" style="font-family: 'Times New Roman', Times, serif; font-size: 1rem; box-shadow: 0 4px 12px rgba(25, 135, 84, 0.2);">
                        CHỐT & LƯU LỘ TRÌNH
                    </button>
                </div>
            </div>

            <!-- Right Panel: Google Maps integration -->
            <div class="col-lg-6">
                <div class="sticky-top" style="top: 100px; z-index: 5;">
                    <div class="card border-0 shadow-lg rounded-5 overflow-hidden p-1" style="height: 65vh; min-height: 480px; background: #ffffff; border: 1px solid #e2e8f0;">
                        <!-- Google Map Container -->
                        <div id="google-journey-map" class="w-100 h-100 rounded-4"></div>
                        
                        <!-- Map Info floating card -->
                        <div class="position-absolute bottom-0 start-0 w-100 p-3" style="z-index: 10;">
                            <div class="bg-white text-dark p-3 rounded-4 shadow border border-success border-opacity-20">
                                <div class="d-flex align-items-center justify-content-between mb-1">
                                    <h6 class="fw-bold mb-0 text-success" style="font-family: 'Times New Roman', Times, serif;"><i class="bi bi-map-fill me-1"></i>Bản đồ Google Maps trực tuyến</h6>
                                    <span class="badge bg-success rounded-pill" style="font-size: 0.7rem;">Live</span>
                                </div>
                                <p class="x-small text-secondary mb-0" style="font-family: 'Times New Roman', Times, serif;">Lộ trình tự động cập nhật khi bạn thay đổi vị trí các điểm dừng chân.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<style>
    .timeline-badge.active {
        background-color: var(--success) !important;
        transform: scale(1.1);
    }
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>

<script>
    let map, markers = [], routeLine;
    let isTimelineLocked = true;
    const journeyId = '<%= journey.id %>';
    const stopsData = <%- JSON.stringify(journey.stops) %>;

    document.addEventListener('DOMContentLoaded', () => {
        initLeafletMap();
        initTimelineReordering();
        gsap.from('.timeline-item', { opacity: 0, x: -30, stagger: 0.1, duration: 0.6, ease: 'power2.out' });
    });

    // Initialize Leaflet Map
    function initLeafletMap() {
        try {
            const centerPos = [10.796, 106.524];
            
            map = L.map('google-journey-map', {
                center: centerPos,
                zoom: 14,
                zoomControl: true,
                attributionControl: false
            });

            L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
                maxZoom: 20
            }).addTo(map);

            renderRouteOnMap();
        } catch (e) {
            console.error("Leaflet failed to initialize", e);
        }
    }

    // Render route with exact coords and custom numbering markers
    function renderRouteOnMap() {
        // Clear old markers/lines
        markers.forEach(m => map.removeLayer(m));
        markers = [];
        if (routeLine) {
            map.removeLayer(routeLine);
            routeLine = null;
        }

        if (!stopsData || stopsData.length === 0) return;

        const bounds = L.latLngBounds();
        const routeCoords = [];

        stopsData.forEach((stop, i) => {
            const stopLat = parseFloat(stop.lat) || (10.79 + (i * 0.005));
            const stopLng = parseFloat(stop.lng) || (106.52 + (i * 0.005));
            const pos = [stopLat, stopLng];
            
            bounds.extend(pos);
            routeCoords.push(pos);

            // Custom DivIcon green circular badge with numeric index
            const markerIcon = L.divIcon({
                className: 'journey-marker-icon',
                html: `<div style="background-color: #0d9488; width: 28px; height: 28px; border-radius: 50%; border: 3px solid #ffffff; box-shadow: 0 2px 5px rgba(0,0,0,0.3); display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 13px; font-family: 'Times New Roman', Times, serif;">${i + 1}</div>`,
                iconSize: [28, 28],
                iconAnchor: [14, 14],
                popupAnchor: [0, -14]
            });

            const marker = L.marker(pos, { icon: markerIcon }).addTo(map);

            const infoWindowHtml = `
                <div style="width: 180px; font-family: sans-serif; padding: 4px;">
                    <img src="${stop.cover_image ? '/' + stop.cover_image.replace(/^public\//, '') : '/images/placeholder.png'}" 
                         style="width: 100%; height: 90px; object-fit: cover; border-radius: 8px;" class="mb-2">
                    <h6 style="margin: 0 0 4px 0; font-weight: bold; font-size: 0.9rem; color: #0d9488;">${i + 1}. ${stop.name}</h6>
                    <span style="font-size: 0.72rem; color: #666; font-weight: bold;">⏰ ${stop.open_hours || '07:00 - 18:00'}</span>
                </div>
            `;

            marker.bindPopup(infoWindowHtml);
            
            marker.on('click', () => {
                highlightTimelineStop(i);
            });

            markers.push(marker);
        });

        // Draw Polyline connecting coordinates
        if (routeCoords.length >= 2) {
            routeLine = L.polyline(routeCoords, {
                color: '#0d9488',
                opacity: 0.8,
                weight: 6
            }).addTo(map);
        }

        map.fitBounds(bounds);
    }

    // Interactive highlighted focus of timeline card and map markers
    function highlightTimelineStop(idx) {
        document.querySelectorAll('.timeline-badge').forEach((badge, i) => {
            badge.classList.toggle('active', i === idx);
        });
        const targetCard = document.getElementById(`stop-card-${idx}`);
        if (targetCard) {
            targetCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
            targetCard.querySelector('.card').style.border = '2px solid var(--primary)';
            setTimeout(() => {
                targetCard.querySelector('.card').style.border = 'none';
            }, 2500);
        }
    }

    // Sortable reordering setup
    let sortableInstance;
    function initTimelineReordering() {
        const el = document.getElementById('sortable-timeline');
        if (!el) return;
        sortableInstance = Sortable.create(el, {
            handle: '.drag-handle',
            animation: 250,
            disabled: true,
            onEnd: function() {
                saveNewItineraryOrder();
            }
        });
    }

    // Toggle locks to change the journey plan
    function toggleTimelineLock() {
        isTimelineLocked = !isTimelineLocked;
        
        const dot = document.getElementById('lock-status-dot');
        const text = document.getElementById('lock-status-text');
        const btn = document.getElementById('btn-lock-toggle');
        const actionBtn = document.getElementById('btn-timeline-action');
        const editPanel = document.getElementById('timeline-edit-panel');

        if (isTimelineLocked) {
            // Locked mode
            dot.className = 'badge bg-success rounded-circle p-1';
            text.innerText = 'Hành trình đã chốt';
            btn.innerHTML = '<i class="bi bi-pencil-square me-1"></i>Thay đổi';
            actionBtn.innerText = 'BẮT ĐẦU DI CHUYỂN';
            actionBtn.setAttribute('onclick', 'startNavigation()');
            editPanel.classList.add('d-none');
            document.querySelectorAll('.edit-actions').forEach(el => el.classList.add('d-none'));
            sortableInstance.option('disabled', true);
        } else {
            // Edit mode
            dot.className = 'badge bg-warning rounded-circle p-1';
            text.innerText = 'Đang chỉnh sửa';
            btn.innerHTML = '<i class="bi bi-check-circle-fill me-1"></i>Chốt';
            actionBtn.innerText = 'LƯU HÀNH TRÌNH';
            actionBtn.setAttribute('onclick', 'lockJourneyAndConfirm()');
            editPanel.classList.remove('d-none');
            document.querySelectorAll('.edit-actions').forEach(el => el.classList.remove('d-none'));
            sortableInstance.option('disabled', false);
        }
    }

    // Save Reordered Route
    function saveNewItineraryOrder() {
        const order = sortableInstance.toArray();
        axios.post('/api/journey/update-stop', {
            journeyId: journeyId,
            action: 'reorder',
            order: order
        }).then(() => {
            location.reload();
        }).catch(err => {
            console.error(err);
            alert("Lỗi khi cập nhật thứ tự lộ trình");
        });
    }

    // Remove Stop from Timeline
    function removeStopFromTimeline(destId) {
        if (confirm("Bạn chắc chắn muốn loại bỏ địa điểm này khỏi hành trình?")) {
            axios.post('/api/journey/update-stop', {
                journeyId: journeyId,
                action: 'remove',
                destinationId: destId
            }).then(() => {
                location.reload();
            }).catch(err => {
                console.error(err);
                alert("Lỗi khi loại bỏ địa điểm");
            });
        }
    }

    // Add Destination Stop
    function addDestinationToTimeline() {
        const selectEl = document.getElementById('select-new-destination');
        const destId = selectEl.value;
        if (!destId) {
            alert("Vui lòng chọn một địa điểm!");
            return;
        }

        axios.post('/api/journey/update-stop', {
            journeyId: journeyId,
            action: 'add',
            destinationId: destId
        }).then(() => {
            location.reload();
        }).catch(err => {
            console.error(err);
            alert("Lỗi khi thêm địa điểm");
        });
    }

    // Complete / Lock Journey confirmation
    function lockJourneyAndConfirm() {
        toggleTimelineLock();
        alert("Hành trình của bạn đã được chốt và tối ưu hóa thành công!");
    }

    // Start Real-time navigation mode
    function startNavigation() {
        const actionBtn = document.getElementById('btn-timeline-action');
        actionBtn.innerHTML = '<span class="spinner-grow spinner-grow-sm me-2"></span> ĐANG DI CHUYỂN...';
        actionBtn.className = 'btn btn-success btn-lg py-3 rounded-pill w-100 fw-bold';
        
        let idx = 0;
        const interval = setInterval(() => {
            if (idx >= markers.length) {
                clearInterval(interval);
                actionBtn.innerText = 'ĐÃ HOÀN THÀNH HÀNH TRÌNH';
                actionBtn.className = 'btn btn-outline-success btn-lg py-3 rounded-pill w-100 fw-bold';
                return;
            }
            highlightTimelineStop(idx);
            if (markers[idx]) {
                map.panTo(markers[idx].getLatLng());
                markers[idx].openPopup();
            }
            idx++;
        }, 4000);
    }
</script>