<!-- BOOTSTRAP 5 CLEAN PREMIUM LAYOUT -->
<div class="bg-light min-vh-100">
    <!-- Header Section -->
    <div class="bg-white border-bottom py-5 mb-5 shadow-sm">
        <div class="container-site">
            <div class="row align-items-center">
                <div class="col-lg-7">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-2">
                            <li class="breadcrumb-item"><a href="/" class="text-primary text-decoration-none small fw-bold">TRANG CHỦ</a></li>
                            <li class="breadcrumb-item active small fw-bold" aria-current="page">HÀNH TRÌNH CỦA TÔI</li>
                        </ol>
                    </nav>
                    <h1 class="display-5 fw-bold text-dark mb-3">Hành trình trải nghiệm <span class="text-primary"><%= seasonName %></span></h1>
                    <p class="text-muted lead mb-0">Lộ trình được tối ưu hóa dựa trên sở thích và cảm xúc của bạn.</p>
                </div>
                <div class="col-lg-5 text-lg-end mt-4 mt-lg-0">
                    <div class="d-inline-flex gap-3 bg-soft-primary p-3 rounded-4 shadow-sm">
                        <div class="text-center px-3 border-end">
                            <div class="fw-bold fs-4 text-primary"><%= Math.round(journey.total_minutes/60) %>h</div>
                            <div class="small text-muted text-uppercase fw-bold" style="font-size: 10px;">Thời gian</div>
                        </div>
                        <div class="text-center px-3 border-end">
                            <div class="fw-bold fs-4 text-primary"><%= journey.total_km %>km</div>
                            <div class="small text-muted text-uppercase fw-bold" style="font-size: 10px;">Quãng đường</div>
                        </div>
                        <div class="text-center px-3">
                            <div class="fw-bold fs-4 text-primary"><%= journey.stops.length %></div>
                            <div class="small text-muted text-uppercase fw-bold" style="font-size: 10px;">Điểm dừng</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container-site pb-5">
        <div class="row g-4">
            <!-- Timeline Column -->
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                    <div class="card-header bg-white border-bottom py-3 px-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="mb-0 fw-bold"><i class="bi bi-map me-2 text-primary"></i> Lộ trình chi tiết</h5>
                            <button class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-bold" onclick="toggleEdit()">
                                <i class="bi bi-pencil-square me-1"></i> Tùy chỉnh
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-4">
                        <!-- Bootstrap 5 Vertical Timeline -->
                        <div class="position-relative ps-4 border-start border-2 border-primary border-opacity-25" style="margin-left: 12px;">
                            <% journey.stops.forEach((stop, index) => { %>
                                <div class="mb-5 position-relative">
                                    <!-- Timeline Dot -->
                                    <div class="position-absolute start-0 translate-middle-x bg-primary rounded-circle shadow-sm" 
                                         style="width: 20px; height: 20px; left: -14px; top: 10px; border: 4px solid #fff;"></div>
                                    
                                    <div class="card border-0 bg-light rounded-4 overflow-hidden shadow-sm-hover transition">
                                        <div class="row g-0">
                                            <div class="col-md-4">
                                                <img src="<%= fixImg(stop.cover_image) %>" class="img-fluid h-100 object-fit-cover" style="min-height: 180px;">
                                            </div>
                                            <div class="col-md-8">
                                                <div class="card-body p-4">
                                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                                        <span class="badge bg-white text-primary border rounded-pill px-3 py-2 small mb-2 shadow-sm">
                                                            <%= index === 0 ? '08:30 AM' : 'ĐIỂM DỪNG ' + (index + 1) %>
                                                        </span>
                                                        <div class="dropdown edit-controls" style="display: none;">
                                                            <button class="btn btn-link text-muted p-0" data-bs-toggle="dropdown"><i class="bi bi-three-dots"></i></button>
                                                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg">
                                                                <li><a class="dropdown-item py-2" href="#"><i class="bi bi-arrow-up me-2"></i> Di chuyển lên</a></li>
                                                                <li><a class="dropdown-item py-2 text-danger" href="#"><i class="bi bi-trash me-2"></i> Xóa điểm này</a></li>
                                                            </ul>
                                                        </div>
                                                    </div>
                                                    <h4 class="fw-bold mb-2"><%= stop.name %></h4>
                                                    <p class="text-muted small mb-4"><%= stop.short_desc || 'Khám phá không gian yên bình và nhận những năng lượng tích cực từ thiên nhiên.' %></p>
                                                    <div class="d-flex gap-2">
                                                        <a href="<%= baseUrl %>/explore/<%= stop.slug %>" class="btn btn-primary btn-sm rounded-pill px-4 fw-bold">Chi tiết</a>
                                                        <a href="https://maps.google.com/?q=<%= stop.lat %>,<%= stop.lng %>" target="_blank" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Bản đồ</a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <!-- Transport Gap -->
                                    <% if (index < journey.stops.length - 1) { %>
                                        <div class="py-3 text-center text-muted small fw-bold opacity-50">
                                            <i class="bi bi-arrow-down mb-1 d-block"></i>
                                            <span>Di chuyển 15 phút bằng xe máy</span>
                                        </div>
                                    <% } %>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sidebar Actions -->
            <div class="col-lg-4">
                <div class="sticky-top" style="top: 100px;">
                    <!-- Action Card -->
                    <div class="card border-0 shadow-sm rounded-4 bg-primary text-white p-4 mb-4 overflow-hidden position-relative">
                        <div class="position-relative" style="z-index: 10;">
                            <h5 class="fw-bold mb-4">Sẵn sàng trải nghiệm?</h5>
                            <button class="btn btn-white btn-lg w-100 rounded-pill fw-bold text-primary mb-3 shadow-sm py-3" onclick="startJourney()">
                                <i class="bi bi-play-circle-fill me-2"></i> BẮT ĐẦU NGAY
                            </button>
                            <p class="small mb-0 opacity-75 text-center">Bật GPS để nhận chỉ đường từng bước và thu thập huy hiệu tự động.</p>
                        </div>
                        <i class="bi bi-cursor-fill position-absolute bottom-0 end-0 m-n3 opacity-10" style="font-size: 120px;"></i>
                    </div>

                    <!-- Preparation Card -->
                    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                        <h6 class="fw-bold mb-3">Lưu ý chuẩn bị</h6>
                        <ul class="list-group list-group-flush small">
                            <li class="list-group-item px-0 py-3 border-light bg-transparent d-flex gap-3">
                                <i class="bi bi-battery-full text-success fs-5"></i>
                                <span>Sạc đầy điện thoại để sử dụng Passport điện tử.</span>
                            </li>
                            <li class="list-group-item px-0 py-3 border-light bg-transparent d-flex gap-3">
                                <i class="bi bi-sun text-warning fs-5"></i>
                                <span>Trang bị nón, kem chống nắng và nước uống.</span>
                            </li>
                        </ul>
                    </div>

                    <!-- Suggestions Card -->
                    <div class="card border-0 shadow-sm rounded-4 p-4">
                        <h6 class="fw-bold mb-3">Hành trình phổ biến khác</h6>
                        <div class="d-grid gap-2">
                            <a href="/journey/preset/song-cham" class="btn btn-light text-start p-3 border-0 rounded-4 transition shadow-sm-hover">
                                <div class="fw-bold small mb-1">🌿 Sống chậm Bình Lợi</div>
                                <div class="text-muted" style="font-size: 11px;">Chữa lành & Tĩnh lặng</div>
                            </a>
                            <a href="/journey/preset/miet-vuon" class="btn btn-light text-start p-3 border-0 rounded-4 transition shadow-sm-hover">
                                <div class="fw-bold small mb-1">🥥 Miệt vườn giữa phố</div>
                                <div class="text-muted" style="font-size: 11px;">Ẩm thực & Trải nghiệm</div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-soft-primary { background-color: rgba(92, 138, 94, 0.1); }
    .text-primary { color: #5c8a5e !important; }
    .btn-primary { background-color: #5c8a5e; border-color: #5c8a5e; }
    .btn-primary:hover { background-color: #4a6e4b; border-color: #4a6e4b; transform: translateY(-2px); }
    .btn-outline-primary { color: #5c8a5e; border-color: #5c8a5e; }
    .btn-outline-primary:hover { background-color: #5c8a5e; color: #fff; }
    .rounded-4 { border-radius: 1.5rem !important; }
    .transition { transition: all 0.3s ease; }
    .shadow-sm-hover:hover { shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important; }
    .object-fit-cover { object-fit: cover; }
    .letter-spacing-lg { letter-spacing: 1px; }
</style>

<script>
    let isEdit = false;
    function toggleEdit() {
        isEdit = !isEdit;
        const controls = document.querySelectorAll('.edit-controls');
        controls.forEach(c => c.style.display = isEdit ? 'block' : 'none');
    }

    function startJourney() {
        alert('Hệ thống đang kích hoạt GPS... Chúc bạn có một hành trình chữa lành tuyệt vời tại Bình Lợi!');
    }
</script>
