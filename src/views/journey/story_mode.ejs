<div class="bg-white min-vh-100 py-5">
    <div class="container-site">
        
        <!-- HEADER: CLEAN & PREMIUM -->
        <div class="row mb-5 animate__animated animate__fadeIn">
            <div class="col-lg-8">
                <span class="text-primary fw-bold letter-spacing-lg mb-2 d-block">TRẢI NGHIỆM ĐÃ SẴN SÀNG</span>
                <h1 class="display-3 fw-black mb-3">Hành trình của bạn tại <span class="text-primary">Bình Lợi</span></h1>
                <p class="text-muted lead" style="max-width: 600px;">Hệ thống đã thiết kế một lộ trình riêng biệt để bạn có thể cảm nhận trọn vẹn sự an nhiên và bản sắc nơi đây.</p>
            </div>
            <div class="col-lg-4 text-lg-end d-flex align-items-end justify-content-lg-end mt-4 mt-lg-0">
                <div class="p-3 bg-light rounded-4 d-inline-flex gap-4 shadow-sm">
                    <div class="text-center">
                        <div class="fw-black fs-4 text-dark"><%= Math.round(journey.total_minutes/60) %>h</div>
                        <div class="small text-muted fw-bold" style="font-size: 10px;">THỜI GIAN</div>
                    </div>
                    <div class="text-center">
                        <div class="fw-black fs-4 text-dark"><%= journey.total_km %>km</div>
                        <div class="small text-muted fw-bold" style="font-size: 10px;">QUÃNG ĐƯỜNG</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-5">
            <!-- LEFT: THE JOURNEY LIST -->
            <div class="col-lg-8">
                <div class="journey-flow">
                    <% journey.stops.forEach((stop, index) => { %>
                    <div class="journey-item mb-5 animate__animated animate__fadeInUp" style="animation-delay: <%= index * 0.1 %>s">
                        <div class="row g-0 align-items-center">
                            <div class="col-auto me-4">
                                <div class="step-circle"><%= index + 1 %></div>
                            </div>
                            <div class="col">
                                <div class="card border-0 bg-white shadow-sm rounded-5 overflow-hidden journey-card-v4 transition">
                                    <div class="row g-0">
                                        <div class="col-md-4">
                                            <div class="position-relative h-100">
                                                <img src="<%= fixImg(stop.cover_image) %>" class="img-fluid h-100 object-fit-cover" style="min-height: 200px;">
                                                <div class="card-img-overlay d-flex align-items-start justify-content-end p-2">
                                                    <span class="badge bg-white text-dark rounded-pill shadow-sm small"><%= (index === 0) ? 'BẮT ĐẦU' : 'CHẶNG ' + (index + 1) %></span>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-md-8">
                                            <div class="card-body p-4 p-md-5">
                                                <h3 class="fw-black mb-2"><%= stop.name %></h3>
                                                <p class="text-muted mb-4"><%= stop.short_desc || 'Không gian yên bình mang lại cảm giác thư thái và phục hồi năng lượng.' %></p>
                                                <div class="d-flex gap-2">
                                                    <a href="<%= baseUrl %>/explore/<%= stop.slug %>" class="btn btn-dark btn-pill px-4 py-2 small fw-bold">XEM CHI TIẾT</a>
                                                    <button class="btn btn-outline-primary btn-pill px-4 py-2 small fw-bold" onclick="simulateCheckin('<%= stop.name %>')">CHECK-IN</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>

            <!-- RIGHT: SMART ASSISTANT -->
            <div class="col-lg-4">
                <div class="sticky-top" style="top: 120px;">
                    <div class="card border-0 rounded-5 shadow-2xl bg-dark text-white p-5 overflow-hidden position-relative mb-4">
                        <div class="position-relative" style="z-index: 10;">
                            <h4 class="fw-black mb-4">Trợ lý du lịch <br><span class="text-primary">Bình Lợi AI</span></h4>
                            
                            <div id="next-stop-box" class="mb-5 p-4 bg-white bg-opacity-10 rounded-4">
                                <div class="small opacity-50 mb-1">ĐIỂM ĐẾN TIẾP THEO</div>
                                <h5 class="fw-bold mb-0 text-primary"><%= journey.stops[0].name %></h5>
                            </div>

                            <button class="btn btn-primary btn-lg w-100 rounded-pill py-3 fw-black shadow-lg mb-3" onclick="startNav()">
                                🚀 KHỞI HÀNH NGAY
                            </button>
                            <div class="text-center small opacity-50 fw-bold">TIẾN ĐỘ: <span id="progress-text">0%</span></div>
                            <div class="progress mt-2" style="height: 6px; background: rgba(255,255,255,0.1);">
                                <div class="progress-bar bg-primary rounded-pill" role="progressbar" style="width: 0%" id="progress-bar"></div>
                            </div>
                        </div>
                        <i class="bi bi-compass position-absolute bottom-0 end-0 m-n4 opacity-10" style="font-size: 150px;"></i>
                    </div>

                    <!-- HELP CARD -->
                    <div class="card border-0 rounded-5 shadow-sm p-4">
                        <h6 class="fw-black mb-3">Bạn cần hỗ trợ?</h6>
                        <div class="d-grid gap-2">
                            <button class="btn btn-light text-start p-3 rounded-4 border-0 small d-flex align-items-center gap-3">
                                <i class="bi bi-chat-dots-fill text-primary"></i>
                                <span>Chat với điểm đến</span>
                            </button>
                            <button class="btn btn-light text-start p-3 rounded-4 border-0 small d-flex align-items-center gap-3">
                                <i class="bi bi-telephone-fill text-primary"></i>
                                <span>Hotline hỗ trợ 24/7</span>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .journey-item { position: relative; }
    .journey-item::before {
        content: ''; position: absolute; left: 24px; top: 50px; bottom: -50px;
        width: 2px; background: rgba(0,0,0,0.05); z-index: 0;
    }
    .journey-item:last-child::before { display: none; }

    .step-circle {
        width: 48px; height: 48px; background: var(--color-primary); color: #fff;
        border-radius: 50%; display: flex; align-items: center; justify-content: center;
        font-weight: 900; font-size: 1.2rem; position: relative; z-index: 10;
        box-shadow: 0 0 0 10px #fff;
    }

    .journey-card-v4 { border: 1px solid rgba(0,0,0,0.02); }
    .journey-card-v4:hover {
        transform: scale(1.02);
        box-shadow: 0 30px 60px rgba(0,0,0,0.08) !important;
    }

    .rounded-5 { border-radius: 2rem !important; }
    .shadow-2xl { box-shadow: 0 40px 100px rgba(0,0,0,0.4); }
    .btn-pill { border-radius: 100px; }
    .fw-black { font-weight: 900; }
    .letter-spacing-lg { letter-spacing: 2px; }
</style>

<script>
    let currentProgress = 0;
    function simulateCheckin(name) {
        currentProgress += (100 / <%= journey.stops.length %>);
        if(currentProgress > 100) currentProgress = 100;
        
        document.getElementById('progress-bar').style.width = currentProgress + '%';
        document.getElementById('progress-text').innerHTML = Math.round(currentProgress) + '%';
        
        alert('📍 Tuyệt vời! Bạn đã Check-in tại ' + name + '.\nĐiểm tiếp theo đã sẵn sàng.');
    }

    function startNav() {
        alert('🚀 Đang mở bản đồ dẫn đường... Hãy bật GPS để bắt đầu hành trình nhé!');
    }
</script>
