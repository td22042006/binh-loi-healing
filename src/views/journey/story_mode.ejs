<!-- ULTIMATE JOURNEY V7 - ROUTE TIMELINE BAR + INTERACTIVE MAP -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/animate.css@4.1.1/animate.min.css">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

<div id="journey-app-v7" class="bg-white min-vh-100">

    <!-- ALL PREVIOUS SCREENS (Suggestions, Timeline) -->

    <!-- SCREEN 5: FINAL JOURNEY OVERVIEW (THE ROUTE TIMELINE BAR) -->
    <section id="screen-confirmed" style="display: none;" class="py-0 animate__animated animate__fadeIn">
        
        <!-- HORIZONTAL ROUTE TIMELINE BAR -->
        <div class="route-timeline-wrapper bg-white shadow-sm sticky-top border-bottom" style="top: 80px; z-index: 1000;">
            <div class="container-site py-4">
                <div class="d-flex align-items-center justify-content-between position-relative px-5">
                    <!-- Progress Line Background -->
                    <div class="position-absolute start-0 end-0 bg-light" style="height: 4px; top: 50%; transform: translateY(-50%); z-index: 1; margin: 0 60px;"></div>
                    
                    <!-- Nodes -->
                    <% journey.stops.forEach((stop, index) => { %>
                        <div class="timeline-node position-relative" style="z-index: 2;" onclick="focusOnMap(<%= index %>)">
                            <div class="node-icon-circle shadow-sm <%= index === 0 ? 'current' : 'pending' %>">
                                <i class="bi bi-geo-alt-fill"></i>
                            </div>
                            <div class="node-label position-absolute start-50 translate-middle-x mt-2 text-center" style="width: 100px;">
                                <div class="fw-black small text-uppercase" style="font-size: 9px;"><%= stop.name %></div>
                                <div class="text-muted" style="font-size: 8px;">08:3<%= index %></div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>

        <div class="container-site py-5">
            <div class="row g-4">
                <!-- MAIN MAP VIEW -->
                <div class="col-lg-8">
                    <div class="card-bl h-100 p-0 border-0 shadow-xl overflow-hidden" style="min-height: 550px;">
                        <div id="final-map" style="height: 550px; width: 100%;"></div>
                    </div>
                </div>

                <!-- SIDE INFO & CONTROLS -->
                <div class="col-lg-4">
                    <div class="card-bl p-4 shadow-xl border-0 bg-dark text-white h-100 d-flex flex-column justify-content-between">
                        <div>
                            <span class="badge bg-primary-soft text-primary mb-3">HÀNH TRÌNH ĐANG DIỄN RA</span>
                            <h2 class="fw-black mb-4">Điểm tiếp theo: <br><span class="text-primary"><%= journey.stops[0].name %></span></h2>
                            
                            <div class="list-group list-group-flush bg-transparent border-0">
                                <div class="list-group-item bg-transparent text-white border-white border-opacity-10 px-0 py-3">
                                    <div class="d-flex justify-content-between mb-1">
                                        <span class="small opacity-50 fw-bold">QUÃNG ĐƯỜNG CÒN LẠI</span>
                                        <span class="fw-black text-primary">2.4 KM</span>
                                    </div>
                                    <div class="progress" style="height: 4px; background: rgba(255,255,255,0.1);">
                                        <div class="progress-bar bg-primary" style="width: 30%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-5">
                            <button class="btn btn-primary-bl w-100 py-3 rounded-pill fw-black mb-3 fs-5" onclick="simulateNav()">
                                🚀 DẪN ĐƯỜNG (GPS)
                            </button>
                            <div class="row g-2">
                                <div class="col-6">
                                    <button class="btn btn-outline-light w-100 py-3 rounded-pill small fw-bold" onclick="alert('Đang kết nối với Quản lý...')">💬 CHAT</button>
                                </div>
                                <div class="col-6">
                                    <button class="btn btn-outline-light w-100 py-3 rounded-pill small fw-bold" onclick="finishEarly()">🏁 KẾT THÚC</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

</div>

<style>
    /* Route Timeline Bar Styles */
    .node-icon-circle {
        width: 36px; height: 36px; border-radius: 50%;
        background: #fff; border: 3px solid #eee;
        display: flex; align-items: center; justify-content: center;
        color: #ccc; cursor: pointer; transition: all 0.3s ease;
    }
    .node-icon-circle.current {
        background: var(--color-primary); border-color: #fff;
        color: #fff; box-shadow: 0 0 0 8px rgba(13, 148, 136, 0.1);
    }
    .node-icon-circle.completed {
        background: #22c55e; border-color: #fff; color: #fff;
    }
    .node-icon-circle.pending:hover {
        border-color: var(--color-primary); color: var(--color-primary);
    }

    .node-label { margin-top: 10px; }

    /* Elite Journey Styles */
    #journey-app-v7 { font-family: 'Outfit', sans-serif; }
    .fw-black { font-weight: 900; }
    .shadow-xl { box-shadow: 0 25px 60px rgba(0,0,0,0.1); }
</style>

<script>
    let finalMap;
    let mapMarkers = [];

    function showConfirmedScreen() {
        document.getElementById('screen-timeline').style.display = 'none';
        document.getElementById('screen-confirmed').style.display = 'block';
        setTimeout(initFinalMap, 300);
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function initFinalMap() {
        if (finalMap) return;
        finalMap = L.map('final-map').setView([10.796, 106.524], 14);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(finalMap);

        const stops = <%- JSON.stringify(journey.stops) %>;
        const latlngs = [];

        stops.forEach((stop, i) => {
            if(stop.lat && stop.lng) {
                const pos = [stop.lat, stop.lng];
                latlngs.push(pos);
                const marker = L.marker(pos).addTo(finalMap)
                    .bindPopup(`<b>${stop.name}</b>`);
                mapMarkers.push(marker);
            }
        });

        if (latlngs.length > 1) {
            L.polyline(latlngs, {color: '#0d9488', weight: 4, opacity: 0.6, dashArray: '10, 10'}).addTo(finalMap);
            finalMap.fitBounds(L.latLngBounds(latlngs).pad(0.2));
        }
    }

    function focusOnMap(index) {
        if (mapMarkers[index]) {
            finalMap.setView(mapMarkers[index].getLatLng(), 16);
            mapMarkers[index].openPopup();
        }
    }

    function simulateNav() {
        alert('🚀 Hệ thống đang khởi động GPS dẫn đường chi tiết từng chặng...');
    }

    function finishEarly() {
        if(confirm('Bạn muốn kết thúc hành trình sớm?')) {
            alert('Đã lưu dữ liệu hành trình. Hẹn gặp lại bạn!');
            window.location.href = '/summary';
        }
    }
    
    // Override previous saveAndStart
    function saveAndStart() {
        showConfirmedScreen();
    }
</script>