<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

<main class="py-5 bg-light min-vh-100">
    <div class="container py-lg-4">
        
        <!-- TOP: Route Timeline Bar (New!) -->
        <div class="card border-0 shadow-sm rounded-5 mb-4 overflow-hidden bg-white reveal-up">
            <div class="card-body p-4 p-lg-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0 text-primary">TIẾN ĐỘ HÀNH TRÌNH</h5>
                    <div id="realtime-status" class="badge bg-success rounded-pill px-3 py-2 animate__animated animate__pulse animate__infinite">
                        <i class="bi bi-geo-fill me-2"></i>Đang theo dõi vị trí...
                    </div>
                </div>
                
                <div class="route-timeline-container position-relative px-4">
                    <div class="route-line position-absolute top-50 start-0 translate-middle-y bg-light w-100" style="height: 4px; z-index: 1;"></div>
                    <div class="route-line-progress position-absolute top-50 start-0 translate-middle-y bg-primary" style="height: 4px; z-index: 2; width: 0%; transition: width 0.5s ease;"></div>
                    
                    <div class="d-flex justify-content-between position-relative" style="z-index: 10;" id="timeline-bar-nodes">
                        <% journey.stops.forEach((stop, i) => { %>
                            <div class="timeline-node text-center" style="width: 60px;" id="node-<%= i %>">
                                <div class="node-circle mx-auto mb-2 bg-white border border-2 border-light text-muted d-flex align-items-center justify-content-center shadow-sm" style="width: 40px; height: 40px; border-radius: 50%; transition: all 0.3s ease;">
                                    <i class="bi bi-geo-alt"></i>
                                </div>
                                <span class="small fw-bold d-none d-md-block text-truncate-1 opacity-50"><%= stop.name %></span>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Dashboard -->
        <div class="row g-4 reveal-up">
            <!-- Left: Timeline & List -->
            <div class="col-lg-5">
                <div class="card border-0 shadow-lg rounded-5 bg-white h-100 overflow-hidden">
                    <div class="card-header bg-white border-0 p-4 p-lg-5 pb-0">
                        <div class="d-flex justify-content-between align-items-center">
                            <h3 class="fw-bold mb-0">Lộ trình chi tiết</h3>
                            <div class="form-check form-switch p-0 m-0">
                                <label class="form-check-label fw-bold small text-muted me-5" for="editModeSwitch">Tùy chỉnh</label>
                                <input class="form-check-input ms-0" type="checkbox" id="editModeSwitch" onchange="toggleEditMode(this.checked)">
                            </div>
                        </div>
                    </div>
                    
                    <div class="card-body p-4 p-lg-5">
                        <div id="sortable-timeline" class="timeline-v5">
                            <% journey.stops.forEach((stop, i) => { %>
                                <div class="card border-0 bg-light rounded-4 mb-3 journey-stop-card shadow-sm-hover" data-id="<%= stop.destination_id %>" id="card-<%= i %>">
                                    <div class="card-body p-3">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="flex-shrink-0 drag-handle d-none">
                                                <i class="bi bi-grip-vertical fs-4 text-muted"></i>
                                            </div>
                                            <div class="flex-grow-1" onclick="focusEliteMap(<%= i %>)">
                                                <div class="d-flex justify-content-between align-items-start">
                                                    <h6 class="fw-bold mb-1 text-dark"><%= stop.name %></h6>
                                                    <div class="check-indicator d-none" id="check-<%= i %>">
                                                        <i class="bi bi-check-circle-fill text-success fs-5"></i>
                                                    </div>
                                                </div>
                                                <div class="d-flex gap-2">
                                                    <button class="btn btn-primary btn-sm rounded-pill px-3 py-1 fw-bold" onclick="handleCheckIn(<%= i %>, event)">Check-in</button>
                                                    <button class="btn btn-outline-secondary btn-sm rounded-pill px-2 py-1" onclick="openChat(<%= stop.destination_id %>, event)"><i class="bi bi-chat-dots"></i></button>
                                                    <button class="btn btn-outline-danger btn-sm rounded-pill px-2 py-1 delete-stop d-none" onclick="removeStop(<%= stop.destination_id %>, event)"><i class="bi bi-trash"></i></button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: Map -->
            <div class="col-lg-7">
                <div class="sticky-top" style="top: 100px;">
                    <div class="card border-0 shadow-lg rounded-5 overflow-hidden position-relative" style="height: 700px;">
                        <div id="map-elite" class="h-100"></div>
                        
                        <!-- Floating Stats -->
                        <div class="position-absolute top-0 end-0 m-4 shadow-lg p-3 bg-white rounded-4" style="z-index: 1000; width: 180px;">
                            <div class="mb-3 text-center">
                                <h6 class="small fw-bold text-muted text-uppercase">Quãng đường</h6>
                                <h4 class="fw-bold mb-0 text-primary" id="stat-km"><%= journey.total_km %> <small>KM</small></h4>
                            </div>
                            <div class="text-center border-top pt-3">
                                <h6 class="small fw-bold text-muted text-uppercase">Thời gian</h6>
                                <h4 class="fw-bold mb-0 text-primary" id="stat-min"><%= journey.total_minutes %> <small>PHÚT</small></h4>
                            </div>
                        </div>

                        <!-- Start Button -->
                        <div class="position-absolute bottom-0 start-0 end-0 p-4" style="z-index: 1000;">
                            <button class="btn btn-primary btn-lg w-100 rounded-pill shadow-lg fw-bold py-3" onclick="startHealingJourney()" id="main-start-btn">
                                BẮT ĐẦU NGAY 🚀
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<style>
    .journey-stop-card { cursor: pointer; transition: all 0.2s ease; }
    .journey-stop-card.active { background: #fff !important; border-left: 6px solid var(--v5-primary) !important; box-shadow: 0 5px 15px rgba(0,0,0,0.05) !important; }
    .drag-handle { cursor: grab; }
    .node-circle.active { background: var(--v5-primary) !important; color: #fff !important; border-color: var(--v5-primary) !important; transform: scale(1.2); }
    .node-circle.completed { background: #28a745 !important; color: #fff !important; border-color: #28a745 !important; }
    .text-truncate-1 { overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
</style>

<script>
    let mapElite;
    let markers = [];
    let completed = new Set();
    let sortable;
    let journeyId = '<%= journey.id %>';

    document.addEventListener('DOMContentLoaded', () => {
        initMap();
        initSortable();
        gsap.to('.reveal-up', { opacity: 1, y: 0, stagger: 0.15, duration: 1 });
        updateTimelineBar(0);
    });

    function initMap() {
        mapElite = L.map('map-elite', { zoomControl: false }).setView([10.796, 106.524], 14);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png').addTo(mapElite);
        refreshMapData();
    }

    function refreshMapData() {
        markers.forEach(m => mapElite.removeLayer(m));
        markers = [];
        const stops = <%- JSON.stringify(journey.stops) %>;
        stops.forEach((stop, i) => {
            const m = L.marker([stop.lat, stop.lng]).addTo(mapElite);
            m.bindPopup(`<b class="text-primary">${stop.name}</b>`);
            markers.push(m);
        });
        if (markers.length > 0) {
            const group = new L.featureGroup(markers);
            mapElite.fitBounds(group.getBounds().pad(0.1));
        }
    }

    function initSortable() {
        const el = document.getElementById('sortable-timeline');
        sortable = Sortable.create(el, {
            handle: '.drag-handle',
            animation: 150,
            onEnd: function (evt) {
                const order = sortable.toArray();
                saveNewOrder(order);
            }
        });
    }

    function toggleEditMode(enabled) {
        document.querySelectorAll('.drag-handle, .delete-stop').forEach(el => {
            el.classList.toggle('d-none', !enabled);
        });
        sortable.option('disabled', !enabled);
    }

    function saveNewOrder(order) {
        // Logic to update DB via API
        axios.post('/api/journey/update-stop', { journeyId, action: 'reorder', order })
            .then(res => {
                location.reload(); // Refresh to update map and metrics properly
            });
    }

    function focusEliteMap(i) {
        document.querySelectorAll('.journey-stop-card').forEach(c => c.classList.remove('active'));
        document.getElementById('card-' + i).classList.add('active');
        mapElite.flyTo(markers[i].getLatLng(), 16);
        markers[i].openPopup();
        updateTimelineBar(i);
    }

    function updateTimelineBar(currentIdx) {
        document.querySelectorAll('.node-circle').forEach((node, i) => {
            node.classList.remove('active');
            if (i === currentIdx) node.classList.add('active');
            if (completed.has(i)) node.classList.add('completed');
        });
        const progress = Math.round((currentIdx / (markers.length - 1)) * 100);
        document.querySelector('.route-line-progress').style.width = progress + '%';
    }

    function handleCheckIn(i, event) {
        event.stopPropagation();
        completed.add(i);
        document.getElementById('check-' + i).classList.remove('d-none');
        document.getElementById('node-' + i).querySelector('.node-circle').classList.add('completed');
        
        if (completed.size === markers.length) {
            confetti({ particleCount: 200, spread: 70 });
            alert('Tuyệt vời! Bạn đã hoàn tất hành trình.');
        } else {
            focusEliteMap((i + 1) % markers.length);
        }
    }

    function openChat(destId, event) {
        event.stopPropagation();
        const msg = prompt("Nhập tin nhắn gửi đến quản lý địa điểm:");
        if (msg) {
            axios.post('/api/send-message', { destinationId: destId, message: msg })
                .then(res => alert("Đã gửi tin nhắn!"));
        }
    }

    function removeStop(destId, event) {
        event.stopPropagation();
        if (confirm('Xóa địa điểm này khỏi hành trình?')) {
            axios.post('/api/journey/update-stop', { journeyId, destinationId: destId, action: 'remove' })
                .then(res => location.reload());
        }
    }

    function startHealingJourney() {
        confetti({ particleCount: 100 });
        focusEliteMap(0);
        document.getElementById('main-start-btn').innerText = "HÀNH TRÌNH ĐANG DIỄN RA...";
        document.getElementById('main-start-btn').classList.replace('btn-primary', 'btn-success');
    }
</script>