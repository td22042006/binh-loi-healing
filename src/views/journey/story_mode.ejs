<!-- THE ULTIMATE CONSOLIDATED JOURNEY - PHIÊN BẢN HOÀN THIỆN -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/animate.css@4.1.1/animate.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

<div id="journey-master-v5" class="bg-white min-vh-100">

    <!-- STEP 1: VIBE SELECTOR (SPOTIFY STYLE) -->
    <section id="screen-vibe" class="py-5 animate__animated animate__fadeIn">
        <div class="container-site text-center">
            <h1 class="v4-vibe-title display-4 fw-black">Hôm nay bạn<br>muốn đi kiểu gì?</h1>
            <p class="v4-vibe-subtitle mb-5">Chọn vibe chuyến đi, không cần suy nghĩ nhiều. ✨</p>
            
            <div class="row g-4 justify-content-center">
                <div class="col-6 col-md-3">
                    <div class="v5-vibe-card p-4" onclick="toggleVibe('chill', this)">
                        <div class="vibe-icon display-4">🌿</div>
                        <div class="fw-black mt-3">Chill nhẹ</div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="v5-vibe-card p-4" onclick="toggleVibe('peace', this)">
                        <div class="vibe-icon display-4">🛕</div>
                        <div class="fw-black mt-3">Bình yên</div>
                    </div>
                </div>
                <!-- ... other vibes ... -->
            </div>
            <div class="mt-5">
                <button class="btn btn-primary-bl btn-pill px-5 py-3 fs-5" onclick="goToSwipe()">TIẾP TỤC ➔</button>
            </div>
        </div>
    </section>

    <!-- STEP 2: TIKTOK SWIPE SUGGESTIONS -->
    <section id="screen-swipe" style="display: none;" class="py-5 animate__animated animate__slideInRight">
        <div class="container-site text-center">
            <h2 class="display-5 fw-black mb-5">Hành trình gợi ý ✨</h2>
            <div class="swiper swiper-journey mx-auto" style="max-width: 400px;">
                <div class="swiper-wrapper">
                    <div class="swiper-slide card-bl border-0 shadow-lg">
                        <img src="<%= baseUrl %>/images/hero-1.png" class="w-100 h-50 object-fit-cover">
                        <div class="p-4 text-start">
                            <h4 class="fw-black">Một ngày miền Tây giữa phố</h4>
                            <p class="small text-muted mb-4">6 tiếng | 🛵 Xe máy | 98% Phù hợp</p>
                            <button class="btn btn-primary-bl w-100 py-3 rounded-pill fw-black" onclick="goToOverview()">CHỌN LỘ TRÌNH NÀY</button>
                        </div>
                    </div>
                    <!-- Slide 2 ... -->
                </div>
                <div class="swiper-pagination mt-4"></div>
            </div>
            <button class="btn btn-link mt-4 text-muted" onclick="backToVibe()">← Quay lại chọn vibe</button>
        </div>
    </section>

    <!-- STEP 3: ROUTE OVERVIEW (MAP + TIMELINE BAR) -->
    <section id="screen-overview" style="display: none;" class="animate__animated animate__fadeIn">
        <!-- THE FAMOUS ROUTE TIMELINE BAR -->
        <div class="route-timeline-v5 py-4 border-bottom sticky-top bg-white shadow-sm" style="top: 85px; z-index: 1000;">
            <div class="container-site">
                <div class="d-flex align-items-center justify-content-between position-relative px-5">
                    <div class="position-absolute start-0 end-0 bg-light" style="height: 4px; top: 50%; transform: translateY(-50%); margin: 0 60px;"></div>
                    <% journey.stops.forEach((stop, index) => { %>
                        <div class="text-center position-relative" style="z-index: 5;" onclick="focusOnMap(<%= index %>)">
                            <div class="glass-node <%= index === 0 ? 'active' : '' %> mx-auto" id="node-<%= index %>">
                                <i class="bi bi-geo-alt-fill"></i>
                            </div>
                            <div class="fw-black mt-2" style="font-size: 9px;"><%= stop.name %></div>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>

        <div class="container-site py-5">
            <div class="row g-4">
                <div class="col-lg-8">
                    <div id="v5-map" class="rounded-5 shadow-xl border overflow-hidden" style="height: 500px;"></div>
                    
                    <!-- TIMELINE LIST -->
                    <div class="mt-5">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h2 class="fw-black">Chi tiết hành trình</h2>
                            <button class="btn btn-outline-primary rounded-pill px-4" onclick="enableEdit()"><i class="bi bi-sliders me-2"></i>TÙY CHỈNH</button>
                        </div>
                        <div id="v5-timeline-list">
                            <% journey.stops.forEach((stop, index) => { %>
                            <div class="journey-item-v5 mb-3" data-id="<%= stop.destination_id %>">
                                <div class="card-bl p-4 d-flex align-items-center gap-4">
                                    <div class="handle d-none me-2"><i class="bi bi-grip-vertical fs-3"></i></div>
                                    <div class="display-6 fw-black text-primary opacity-25">0<%= index + 1 %></div>
                                    <div class="flex-grow-1">
                                        <h5 class="fw-black mb-1"><%= stop.name %></h5>
                                        <p class="small text-muted mb-0"><%= stop.short_desc %></p>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-light rounded-circle text-danger d-none btn-remove" onclick="removePoint(this)"><i class="bi bi-trash"></i></button>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="sticky-top" style="top: 180px;">
                        <div class="card-bl p-5 bg-dark text-white text-center shadow-2xl">
                            <h3 class="fw-black mb-3">Sẵn sàng chưa?</h3>
                            <p class="small opacity-50 mb-5">Hành trình dự kiến 6 giờ di chuyển.</p>
                            <button class="btn btn-primary-bl w-100 py-4 fs-4 fw-black rounded-pill mb-4" onclick="launchJourney()">BẮT ĐẦU NGAY 🚀</button>
                            <button class="btn btn-outline-light w-100 py-3 rounded-pill fw-bold" onclick="alert('Đã lưu hành trình!')">💾 LƯU LẠI</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

</div>

<script>
    let v5Swiper;
    let v5Map;
    let v5Markers = [];

    function goToSwipe() {
        document.getElementById('screen-vibe').style.display = 'none';
        document.getElementById('screen-swipe').style.display = 'block';
        v5Swiper = new Swiper('.swiper-journey', {
            effect: 'cards', grabCursor: true, pagination: { el: '.swiper-pagination' }
        });
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function goToOverview() {
        document.getElementById('screen-swipe').style.display = 'none';
        document.getElementById('screen-overview').style.display = 'block';
        setTimeout(initV5Map, 300);
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function initV5Map() {
        if (v5Map) return;
        v5Map = L.map('v5-map').setView([10.796, 106.524], 14);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(v5Map);

        const stops = <%- JSON.stringify(journey.stops) %>;
        const coords = [];

        stops.forEach((stop, i) => {
            if(stop.lat && stop.lng) {
                coords.push([stop.lat, stop.lng]);
                const marker = L.marker([stop.lat, stop.lng]).addTo(v5Map).bindPopup(`<b>${stop.name}</b>`);
                v5Markers.push(marker);
            }
        });

        if (coords.length > 1) {
            L.polyline(coords, { color: '#0d9488', weight: 4, dashArray: '10, 10' }).addTo(v5Map);
            v5Map.fitBounds(L.latLngBounds(coords).pad(0.2));
        }
    }

    function focusOnMap(index) {
        document.querySelectorAll('.glass-node').forEach(n => n.classList.remove('active'));
        document.getElementById('node-' + index).classList.add('active');
        v5Map.setView(v5Markers[index].getLatLng(), 16);
        v5Markers[index].openPopup();
    }

    function enableEdit() {
        document.querySelectorAll('.handle').forEach(h => h.classList.remove('d-none'));
        document.querySelectorAll('.btn-remove').forEach(b => b.classList.remove('d-none'));
        Sortable.create(document.getElementById('v5-timeline-list'), { handle: '.handle', animation: 200 });
        alert('🎨 Chế độ tùy chỉnh: Kéo thả để sắp xếp lại điểm đến!');
    }

    function launchJourney() {
        alert('🚀 HÀNH TRÌNH CHỮA LÀNH BẮT ĐẦU! CHÚC BẠN CÓ TRẢI NGHIỆM TUYỆT VỜI.');
        window.location.href = '/map';
    }

    function backToVibe() {
        document.getElementById('screen-swipe').style.display = 'none';
        document.getElementById('screen-vibe').style.display = 'block';
    }
</script>