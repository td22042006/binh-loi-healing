<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

<div class="elite-header-journey py-5" style="background: #fff; border-bottom: 1px solid #eee;">
    <div class="container-elite">
        <div class="row align-items-center">
            <div class="col-lg-8 reveal-up">
                <span class="elite-header-pill mb-3">Suggested Itinerary</span>
                <h1 class="elite-title mb-1" style="color: var(--v5-primary); font-size: 3rem;">Lộ trình của bạn</h1>
                <p class="text-muted mb-0">Chúng tôi đã thiết kế một hành trình <%= seasonName.toLowerCase() %> dành riêng cho <%= user ? user.full_name : 'bạn' %>.</p>
            </div>
            <div class="col-lg-4 text-lg-end mt-4 mt-lg-0 reveal-up">
                <a href="/onboarding" class="btn btn-outline-primary rounded-pill px-4">Đổi tâm trạng ➔</a>
            </div>
        </div>
    </div>
</div>

<main class="py-5 bg-light">
    <div class="container-elite">
        <!-- Dashboard Overview -->
        <div class="row g-4 mb-5 reveal-up">
            <div class="col-md-4">
                <div class="glass-panel p-4 h-100 text-center">
                    <div class="text-primary mb-2"><i class="bi bi-geo-alt fs-2"></i></div>
                    <h6 class="text-uppercase fw-bold small opacity-50">Tổng quãng đường</h6>
                    <h3 class="fw-black mb-0"><%= journey.total_km %> <small>KM</small></h3>
                </div>
            </div>
            <div class="col-md-4">
                <div class="glass-panel p-4 h-100 text-center">
                    <div class="text-primary mb-2"><i class="bi bi-clock fs-2"></i></div>
                    <h6 class="text-uppercase fw-bold small opacity-50">Thời gian dự kiến</h6>
                    <h3 class="fw-black mb-0"><%= journey.total_minutes %> <small>PHÚT</small></h3>
                </div>
            </div>
            <div class="col-md-4">
                <div class="glass-panel p-4 h-100 text-center">
                    <div class="text-primary mb-2"><i class="bi bi-stars fs-2"></i></div>
                    <h6 class="text-uppercase fw-bold small opacity-50">Số điểm dừng</h6>
                    <h3 class="fw-black mb-0"><%= journey.stops.length %> <small>ĐIỂM</small></h3>
                </div>
            </div>
        </div>

        <div class="row g-5">
            <!-- Timeline & Content (Main Focus) -->
            <div class="col-lg-6 order-2 order-lg-1">
                <div class="mb-4 d-flex justify-content-between align-items-center reveal-up">
                    <h3 class="fw-bold mb-0">Timeline hành trình</h3>
                    <div class="badge bg-primary rounded-pill px-3 py-2" id="progress-badge">Tiến độ: 0%</div>
                </div>

                <div class="timeline-list-full">
                    <% journey.stops.forEach((stop, i) => { %>
                        <div class="glass-panel p-4 mb-4 reveal-up elite-step-card" id="step-<%= i %>" onclick="focusEliteMap(<%= i %>)">
                            <div class="row g-3">
                                <div class="col-auto">
                                    <div class="step-num-circle"><%= i + 1 %></div>
                                </div>
                                <div class="col">
                                    <div class="d-flex justify-content-between">
                                        <h5 class="fw-bold mb-2"><%= stop.name %></h5>
                                        <div class="check-mark d-none" id="check-<%= i %>">
                                            <i class="bi bi-check-circle-fill text-success fs-4"></i>
                                        </div>
                                    </div>
                                    <p class="text-muted small mb-3"><%= stop.short_desc || stop.story %></p>
                                    
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-sm btn-primary rounded-pill px-3" onclick="handleCheckIn(<%= i %>, event)">
                                            <i class="bi bi-qr-code-scan me-1"></i> Check-in
                                        </button>
                                        <a href="https://www.google.com/maps/dir/?api=1&destination=<%= stop.lat %>,<%= stop.lng %>" 
                                           target="_blank" class="btn btn-sm btn-outline-secondary rounded-pill px-3" onclick="event.stopPropagation()">
                                            <i class="bi bi-signpost-2"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

            <!-- Map (Sidebar Focus) -->
            <div class="col-lg-6 order-1 order-lg-2">
                <div class="sticky-top" style="top: 120px;">
                    <div class="map-elite-wrapper shadow-lg overflow-hidden" style="height: 600px; border-radius: 32px; border: 4px solid #fff;">
                        <div id="map-elite" style="width: 100%; height: 100%;"></div>
                    </div>
                    <div class="mt-4 p-4 glass-panel text-center">
                        <p class="small text-muted mb-3">Bạn đã sẵn sàng cho chuyến hành trình này?</p>
                        <button class="btn btn-primary btn-lg w-100 rounded-pill fw-bold" onclick="startHealingJourney()">
                            BẮT ĐẦU DI CHUYỂN NGAY ➔
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<style>
    .step-num-circle {
        width: 35px; height: 35px;
        background: var(--v5-primary); color: #fff;
        border-radius: 50%; display: flex; align-items: center; justify-content: center;
        font-weight: 900;
    }
    .elite-step-card { cursor: pointer; transition: all 0.3s ease; }
    .elite-step-card:hover { transform: scale(1.02); border-color: var(--v5-primary); }
    .elite-step-card.active { border-left: 8px solid var(--v5-primary); background: #f8faf8; }
</style>

<script>
    let mapElite;
    let markers = [];
    let completed = new Set();

    document.addEventListener('DOMContentLoaded', () => {
        initMap();
        gsap.to('.reveal-up', { opacity: 1, y: 0, stagger: 0.1, duration: 0.8, ease: 'power2.out' });
    });

    function initMap() {
        mapElite = L.map('map-elite', { zoomControl: false }).setView([10.796, 106.524], 14);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png').addTo(mapElite);

        const stops = <%- JSON.stringify(journey.stops) %>;
        stops.forEach((stop, i) => {
            const m = L.marker([stop.lat, stop.lng]).addTo(mapElite);
            m.bindPopup(`<b>${stop.name}</b>`);
            markers.push(m);
        });

        if (stops.length > 0) {
            const group = new L.featureGroup(markers);
            mapElite.fitBounds(group.getBounds().pad(0.2));
        }
    }

    function focusEliteMap(i) {
        document.querySelectorAll('.elite-step-card').forEach(c => c.classList.remove('active'));
        document.getElementById('step-' + i).classList.add('active');
        mapElite.flyTo(markers[i].getLatLng(), 16);
        markers[i].openPopup();
    }

    function handleCheckIn(i, event) {
        event.stopPropagation();
        completed.add(i);
        document.getElementById('check-' + i).classList.remove('d-none');
        updateProgress();
        
        if (completed.size === markers.length) {
            confetti({ particleCount: 200, spread: 70 });
            alert('Tuyệt vời! Bạn đã hoàn thành hành trình.');
        } else {
            focusEliteMap((i + 1) % markers.length);
        }
    }

    function updateProgress() {
        const p = Math.round((completed.size / markers.length) * 100);
        document.getElementById('progress-badge').innerText = `Tiến độ: ${p}%`;
    }

    function startHealingJourney() {
        confetti({ particleCount: 100 });
        focusEliteMap(0);
    }
</script>