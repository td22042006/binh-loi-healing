<% 
let stops = journey.stops || [];
let totalKm = journey.total_km || 0;
let totalMin = journey.total_minutes || 0;
%>

<div id="cinematic-journey-root" class="cinematic-journey">
    
    <!-- BACKGROUND & AMBIANCE -->
    <div class="cinematic-overlay"></div>
    
    <div class="container-site position-relative" style="z-index: 100;">
        
        <!-- HEADER: THE VISION -->
        <header class="text-center py-5 animate__animated animate__fadeInDown">
            <div class="minimal-step-label text-accent mb-2">BẢN MỚI 2026 ✦ HÀNH TRÌNH CỦA RIÊNG BẠN</div>
            <h1 class="display-text fw-black text-white mb-3">Chuyến du hành<br>Bình Lợi <span class="text-accent">Chữa lành</span></h1>
            <div class="d-flex justify-content-center gap-4 text-white-50 small fw-bold text-uppercase letter-spacing-lg">
                <span><i class="bi bi-clock me-2"></i> <%= Math.round(totalMin/60) %> GIỜ</span>
                <span><i class="bi bi-geo-alt me-2"></i> <%= totalKm %> KM</span>
                <span><i class="bi bi-bicycle me-2"></i> TỰ DO</span>
            </div>
        </header>

        <!-- THE CURVED PATH TIMELINE -->
        <div class="cinematic-timeline">
            <% stops.forEach((stop, index) => { %>
                <div class="cinematic-node <%= index % 2 === 0 ? 'node-left' : 'node-right' %> animate__animated animate__fadeInUp" style="animation-delay: <%= index * 0.2 %>s">
                    <div class="node-content card-bl p-0 overflow-hidden border-0 shadow-2xl">
                        <div class="position-relative">
                            <img src="<%= fixImg(stop.cover_image) %>" class="node-img" alt="<%= stop.name %>">
                            <div class="node-number"><%= index + 1 %></div>
                        </div>
                        <div class="p-4 bg-white">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h4 class="fw-black mb-0 text-dark"><%= stop.name %></h4>
                                <span class="badge bg-soft-primary text-primary rounded-pill"><%= (index === 0) ? '08:00' : 'CHẶNG ' + (index + 1) %></span>
                            </div>
                            <p class="text-muted small mb-4"><%= stop.short_desc || 'Tận hưởng nhịp sống chậm rãi và bình yên tại điểm dừng chân này.' %></p>
                            <div class="d-flex gap-2">
                                <a href="<%= baseUrl %>/explore/<%= stop.slug %>" class="btn btn-primary-bl btn-pill flex-grow-1 py-2">CHI TIẾT</a>
                                <button class="btn btn-outline-dark btn-pill px-3" onclick="alert('Đã thêm vào mục yêu thích!')"><i class="bi bi-heart"></i></button>
                            </div>
                        </div>
                    </div>
                    <% if (index < stops.length - 1) { %>
                        <div class="path-connector"></div>
                    <% } %>
                </div>
            <% }) %>
        </div>

        <!-- ACTION HUB -->
        <div class="cinematic-hub py-5 text-center">
            <div class="card-bl bg-dark text-white p-5 border-0 shadow-3xl">
                <h3 class="fw-black mb-4">Bạn đã sẵn sàng khởi hành?</h3>
                <div class="row g-3 justify-content-center">
                    <div class="col-md-6">
                        <button class="btn btn-accent btn-pill w-100 py-3 fw-black fs-5" onclick="startNavigation()">🚀 BẮT ĐẦU NGAY</button>
                    </div>
                    <div class="col-md-4">
                        <button class="btn btn-outline-light btn-pill w-100 py-3 fw-bold" onclick="toggleEditMode()">🎨 TÙY CHỈNH LẠI</button>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- FLOATING ASSISTANT -->
    <div class="floating-assistant animate__animated animate__bounceInRight">
        <div class="assistant-bubble">
            <div class="small opacity-75">Tiếp theo:</div>
            <div class="fw-bold"><%= stops[0].name %></div>
            <div class="mt-2 text-accent small fw-bold" style="cursor: pointer;" onclick="window.location.href='/map'">XEM BẢN ĐỒ →</div>
        </div>
        <div class="assistant-icon">
            <i class="bi bi-stars"></i>
        </div>
    </div>
</div>

<style>
:root {
    --color-dark-green: #1b2d1c;
    --color-accent: #d4af37; /* Gold accent */
}

.cinematic-journey {
    background-color: var(--color-dark-green);
    min-height: 100vh;
    padding-bottom: 100px;
    position: relative;
    overflow-x: hidden;
}

.cinematic-overlay {
    position: absolute; top: 0; left: 0; width: 100%; height: 500px;
    background: linear-gradient(to bottom, rgba(0,0,0,0.5), transparent);
    z-index: 1;
}

.text-accent { color: var(--color-accent) !important; }
.btn-accent { background: var(--color-accent); color: #000; border: none; }
.btn-accent:hover { background: #b8962e; transform: translateY(-3px); }

.cinematic-timeline {
    position: relative;
    max-width: 800px;
    margin: 60px auto;
}

.cinematic-node {
    position: relative;
    margin-bottom: 100px;
    width: 100%;
}

.node-content {
    max-width: 450px;
    transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.node-left .node-content { margin-right: auto; }
.node-right .node-content { margin-left: auto; }

.node-img { width: 100%; height: 250px; object-fit: cover; transition: transform 0.8s ease; }
.node-content:hover .node-img { transform: scale(1.1); }

.node-number {
    position: absolute; top: 20px; left: 20px;
    width: 45px; height: 45px; background: var(--color-accent);
    color: #000; border-radius: 50%; display: flex;
    align-items: center; justify-content: center;
    font-weight: 900; font-size: 1.2rem;
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
}

.path-connector {
    position: absolute;
    width: 4px; height: 100px;
    background: rgba(212, 175, 55, 0.2);
    left: 50%; bottom: -100px;
    transform: translateX(-50%);
}

.floating-assistant {
    position: fixed; bottom: 40px; right: 40px;
    display: flex; align-items: center; gap: 15px;
    z-index: 1000;
}

.assistant-bubble {
    background: #fff; padding: 15px 25px; border-radius: 24px 24px 0 24px;
    box-shadow: 0 20px 40px rgba(0,0,0,0.2);
    color: #000; min-width: 200px;
}

.assistant-icon {
    width: 60px; height: 60px; background: var(--color-accent);
    color: #000; border-radius: 50%; display: flex;
    align-items: center; justify-content: center;
    font-size: 1.5rem; box-shadow: 0 10px 25px rgba(212, 175, 55, 0.3);
}

.shadow-3xl { box-shadow: 0 40px 100px rgba(0,0,0,0.4); }

@media (max-width: 768px) {
    .node-left .node-content, .node-right .node-content { margin: 0 auto; }
    .floating-assistant { right: 20px; bottom: 20px; }
    .display-text { font-size: 2.5rem; }
}
</style>

<script>
function startNavigation() {
    alert('🚀 Đang khởi động lộ trình chữa lành... Hãy bắt đầu di chuyển đến <%= stops[0].name %>!');
}

function toggleEditMode() {
    alert('🎨 Đang mở trình tùy chỉnh nâng cao (Drag & Drop)...');
    // Implementation for drag & drop
}
</script>
