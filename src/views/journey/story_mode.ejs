<!-- Vibrant Journey Story Mode — Immersive Healing Experience -->
<div class="row g-0 h-100 overflow-hidden" style="margin: -2rem;">
    <!-- Main Story Canvas -->
    <div class="col-12 position-relative" style="height: calc(100vh - 100px);">
        
        <!-- Story Background (Dynamic) -->
        <div id="story-bg" class="position-absolute top-0 start-0 w-100 h-100 bg-dark">
            <img src="/images/hero-1.jpg" class="w-100 h-100 object-fit-cover opacity-50" style="filter: blur(5px);">
        </div>

        <!-- Story Content Overlay -->
        <div class="position-relative h-100 d-flex flex-column justify-content-center align-items-center p-4" style="z-index: 10;">
            
            <!-- Progress Indicators (Top) -->
            <div class="d-flex gap-2 w-100 px-lg-5 mb-5" style="max-width: 1000px;">
                <% (journey.stops || [1,2,3,4]).forEach((s, i) => { %>
                <div class="flex-grow-1 rounded-pill" style="height: 4px; background: <%= i === 0 ? 'var(--accent-gold)' : 'rgba(255,255,255,0.2)' %>;"></div>
                <% }) %>
            </div>

            <div class="widget-card p-5 border-0 shadow-2xl text-center text-white backdrop-blur-xl" 
                 style="background: rgba(15, 61, 46, 0.4); max-width: 800px; border-radius: 40px; border: 1px solid rgba(255,255,255,0.1);">
                
                <span class="badge rounded-pill bg-warning text-dark fw-black mb-3 px-4 py-2" style="letter-spacing: 2px;">CHẶNG 1: KHỞI ĐẦU XANH</span>
                
                <h1 class="fw-black font-display mb-4" style="font-size: 3.5rem; line-height: 1;">Chào mừng đến với Vườn Mai Vàng 1</h1>
                
                <p class="fs-5 opacity-90 mb-5 px-lg-4" style="line-height: 1.8;">
                    Nơi đây không chỉ có những gốc mai quý hiếm, mà còn là khởi nguồn cho sự tĩnh lặng trong tâm hồn. Hãy hít một hơi thật sâu và cảm nhận mùi hương của phù sa và gió sông.
                </p>

                <div class="d-flex flex-wrap justify-content-center gap-3">
                    <a href="/checkin" class="btn btn-premium px-5 py-3 rounded-pill fs-4">QUÉT MÃ CHECK-IN <i class="bi bi-qr-code-scan ms-2"></i></a>
                    <button class="btn btn-outline-light rounded-pill px-5 py-3 fw-bold border-2" style="background: rgba(255,255,255,0.1);">XEM HƯỚNG DẪN ZEN WALK</button>
                </div>
            </div>

            <!-- Navigation Controls -->
            <div class="position-absolute top-50 start-0 translate-middle-y ps-4 d-none d-lg-block">
                <button class="btn btn-white rounded-circle shadow-lg d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;"><i class="bi bi-chevron-left fs-3"></i></button>
            </div>
            <div class="position-absolute top-50 end-0 translate-middle-y pe-4 d-none d-lg-block">
                <button class="btn btn-white rounded-circle shadow-lg d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;"><i class="bi bi-chevron-right fs-3"></i></button>
            </div>
        </div>

        <!-- BOTTOM NAVIGATION: FULL JOURNEY PREVIEW -->
        <div class="position-absolute bottom-0 start-0 w-100 p-4" style="z-index: 20; background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);">
            <div class="d-flex justify-content-center gap-4">
                <div class="d-flex flex-column align-items-center">
                    <div class="rounded-circle bg-warning text-dark fw-black d-flex align-items-center justify-content-center shadow-lg" style="width: 40px; height: 40px;">1</div>
                    <span class="text-white x-small fw-bold mt-2">Vườn Mai</span>
                </div>
                <div class="d-flex flex-column align-items-center opacity-50">
                    <div class="rounded-circle bg-white text-dark fw-black d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">2</div>
                    <span class="text-white x-small fw-bold mt-2">Xưởng Nhang</span>
                </div>
                <div class="d-flex flex-column align-items-center opacity-50">
                    <div class="rounded-circle bg-white text-dark fw-black d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">3</div>
                    <span class="text-white x-small fw-bold mt-2">Bánh Tráng</span>
                </div>
                <div class="d-flex flex-column align-items-center opacity-50">
                    <div class="rounded-circle bg-white text-dark fw-black d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">4</div>
                    <span class="text-white x-small fw-bold mt-2">Kết thúc</span>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .backdrop-blur-xl {
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
    }
    .shadow-2xl {
        box-shadow: 0 35px 60px -15px rgba(0, 0, 0, 0.5);
    }
    #story-bg img {
        transition: transform 10s linear;
    }
    .col-12:hover #story-bg img {
        transform: scale(1.1);
    }
</style>