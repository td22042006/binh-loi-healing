<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

<main class="py-5 bg-light min-vh-100">
    <div class="container">
        
        <!-- Header Section (Open Style) -->
        <div class="row align-items-center mb-5 reveal-up">
            <div class="col-lg-8">
                <span class="badge bg-primary px-3 py-2 mb-3 text-uppercase fw-bold shadow-sm">Suggested Itinerary</span>
                <h1 class="display-4 fw-bold mb-2" style="color: var(--v5-primary); font-family: 'Playfair Display', serif;">Hành trình của bạn</h1>
                <p class="lead text-muted mb-0">Hành trình <%= seasonName.toLowerCase() %> dành riêng cho bạn.</p>
            </div>
            <div class="col-lg-4 text-lg-end mt-4 mt-lg-0">
                <div class="d-flex justify-content-lg-end gap-4">
                    <div class="text-center">
                        <h3 class="fw-bold mb-0 text-primary"><%= journey.total_km %></h3>
                        <small class="text-uppercase text-muted fw-bold">KM</small>
                    </div>
                    <div class="text-center border-start ps-4">
                        <h3 class="fw-bold mb-0 text-primary"><%= journey.total_minutes %></h3>
                        <small class="text-uppercase text-muted fw-bold">Phút</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Timeline Bar (Stand-alone Card) -->
        <div class="card border-0 shadow-sm rounded-4 mb-5 bg-white reveal-up">
            <div class="card-body p-4">
                <div class="route-timeline-container position-relative px-4 py-3">
                    <div class="route-line position-absolute top-50 start-0 translate-middle-y bg-light w-100" style="height: 4px; z-index: 1;"></div>
                    <div class="route-line-progress position-absolute top-50 start-0 translate-middle-y bg-primary" style="height: 4px; z-index: 2; width: 0%; transition: width 0.5s ease;"></div>
                    <div class="d-flex justify-content-between position-relative" style="z-index: 10;">
                        <% journey.stops.forEach((stop, i) => { %>
                            <div class="timeline-node text-center" style="width: 40px;" id="node-<%= i %>">
                                <div class="node-circle mx-auto bg-white border border-2 border-light text-muted d-flex align-items-center justify-content-center shadow-sm rounded-circle" style="width: 35px; height: 35px; transition: all 0.3s ease;">
                                    <i class="bi bi-geo-alt small"></i>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Dashboard Grid -->
        <div class="row g-4 reveal-up">
            <div class="col-lg-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="fw-bold mb-0">Lộ trình</h3>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="editModeSwitch" onchange="toggleEditMode(this.checked)">
                        <label class="form-check-label small fw-bold text-muted" for="editModeSwitch">Tùy chỉnh</label>
                    </div>
                </div>

                <div id="sortable-timeline" class="timeline-list">
                    <% journey.stops.forEach((stop, i) => { %>
                        <div class="card border-0 shadow-sm rounded-4 mb-3 journey-stop-card" data-id="<%= stop.destination_id %>" id="card-<%= i %>">
                            <div class="card-body p-4">
                                <div class="d-flex gap-3">
                                    <div class="flex-shrink-0 drag-handle d-none">
                                        <i class="bi bi-grip-vertical fs-4 text-muted"></i>
                                    </div>
                                    <div class="flex-grow-1" onclick="focusEliteMap(<%= i %>)">
                                        <h6 class="fw-bold mb-1"><%= stop.name %></h6>
                                        <p class="text-muted small mb-3 text-truncate-2"><%= stop.short_desc || stop.story %></p>
                                        <div class="d-flex gap-2">
                                            <button class="btn btn-primary btn-sm rounded-pill px-3" onclick="handleCheckIn(<%= i %>, event)">Check-in</button>
                                            <button class="btn btn-outline-secondary btn-sm rounded-pill px-2" onclick="openChat(<%= stop.destination_id %>, event)"><i class="bi bi-chat-dots"></i></button>
                                            <button class="btn btn-outline-danger btn-sm rounded-pill px-2 delete-stop d-none" onclick="removeStop(<%= stop.destination_id %>, event)"><i class="bi bi-trash"></i></button>
                                        </div>
                                    </div>
                                    <div class="check-indicator d-none" id="check-<%= i %>">
                                        <i class="bi bi-check-circle-fill text-success fs-4"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="sticky-top" style="top: 100px;">
                    <div class="card border-0 shadow-lg rounded-5 overflow-hidden mb-4" style="height: 600px;">
                        <div id="map-elite" class="h-100"></div>
                    </div>
                    <button class="btn btn-primary btn-lg w-100 rounded-pill shadow-lg fw-bold py-3" onclick="startHealingJourney()" id="main-start-btn">
                        BẮT ĐẦU NGAY 🚀
                    </button>
                </div>
            </div>
        </div>
    </div>
</main>

<style>
    .journey-stop-card { cursor: pointer; transition: all 0.2s ease; border-left: 0 solid var(--v5-primary); }
    .journey-stop-card.active { border-left: 6px solid var(--v5-primary) !important; background: #fff !important; }
    .node-circle.active { background: var(--v5-primary) !important; color: #fff !important; border-color: var(--v5-primary) !important; transform: scale(1.2); }
    .node-circle.completed { background: #28a745 !important; color: #fff !important; border-color: #28a745 !important; }
    .text-truncate-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>

<script>
    let mapElite, markers = [], completed = new Set(), sortable, journeyId = '<%= journey.id %>';

    document.addEventListener('DOMContentLoaded', () => {
        initMap(); initSortable();
        gsap.to('.reveal-up', { opacity: 1, y: 0, stagger: 0.1, duration: 0.8 });
        updateTimelineBar(0);
    });

    function initMap() {
        mapElite = L.map('map-elite', { zoomControl: false }).setView([10.796, 106.524], 14);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png').addTo(mapElite);
        refreshMapData();
    }

    function refreshMapData() {
        const stops = <%- JSON.stringify(journey.stops) %>;
        stops.forEach((stop, i) => {
            const m = L.marker([stop.lat, stop.lng]).addTo(mapElite);
            m.bindPopup(`<b>${stop.name}</b>`);
            markers.push(m);
        });
        if (markers.length > 0) mapElite.fitBounds(new L.featureGroup(markers).getBounds().pad(0.1));
    }

    function initSortable() {
        sortable = Sortable.create(document.getElementById('sortable-timeline'), {
            handle: '.drag-handle', animation: 150, disabled: true,
            onEnd: function() { saveNewOrder(sortable.toArray()); }
        });
    }

    function toggleEditMode(enabled) {
        document.querySelectorAll('.drag-handle, .delete-stop').forEach(el => el.classList.toggle('d-none', !enabled));
        sortable.option('disabled', !enabled);
    }

    function saveNewOrder(order) {
        axios.post('/api/journey/update-stop', { journeyId, action: 'reorder', order }).then(() => location.reload());
    }

    function focusEliteMap(i) {
        document.querySelectorAll('.journey-stop-card').forEach(c => c.classList.remove('active'));
        document.getElementById('card-' + i).classList.add('active');
        mapElite.flyTo(markers[i].getLatLng(), 16);
        markers[i].openPopup();
        updateTimelineBar(i);
    }

    function updateTimelineBar(currentIdx) {
        document.querySelectorAll('.node-circle').forEach((node, i) => {
            node.classList.remove('active');
            if (i === currentIdx) node.classList.add('active');
            if (completed.has(i)) node.classList.add('completed');
        });
        document.querySelector('.route-line-progress').style.width = Math.round((currentIdx / (markers.length - 1)) * 100) + '%';
    }

    function handleCheckIn(i, event) {
        event.stopPropagation();
        completed.add(i);
        document.getElementById('check-' + i).classList.remove('d-none');
        updateTimelineBar(i);
        if (completed.size === markers.length) { confetti(); alert('Hoàn thành hành trình!'); }
        else { focusEliteMap((i + 1) % markers.length); }
    }

    function openChat(destId, event) {
        event.stopPropagation();
        const msg = prompt("Nhập tin nhắn:");
        if (msg) axios.post('/api/send-message', { destinationId: destId, message: msg }).then(() => alert("Đã gửi!"));
    }

    function removeStop(destId, event) {
        event.stopPropagation();
        if (confirm('Xóa địa điểm?')) axios.post('/api/journey/update-stop', { journeyId, destinationId: destId, action: 'remove' }).then(() => location.reload());
    }

    function startHealingJourney() {
        confetti(); focusEliteMap(0);
        document.getElementById('main-start-btn').innerText = "HÀNH TRÌNH ĐANG DIỄN RA...";
    }
</script>