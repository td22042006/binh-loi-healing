<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

<main class="py-5 bg-light min-vh-100 mt-5">
    <div class="container">
        
        <!-- Journey Dashboard Header -->
        <div class="glass-panel p-5 mb-5 reveal-up overflow-hidden position-relative">
            <div class="row align-items-center position-relative" style="z-index: 5;">
                <div class="col-lg-7">
                    <span class="badge bg-primary px-3 py-2 mb-3 text-uppercase fw-bold shadow-sm" style="letter-spacing: 1px;">Hành trình cá nhân hóa</span>
                    <h1 class="display-3 fw-bold mb-2" style="font-family: var(--font-heading);"><%= journey.mood.replace('_', ' ').toUpperCase() %></h1>
                    <p class="lead text-muted mb-0">Hành trình <%= journey.duration === 'half_day' ? 'Nửa ngày' : 'Cả ngày' %> được thiết kế để bạn tận hưởng Bình Lợi trọn vẹn nhất.</p>
                </div>
                <div class="col-lg-5 text-lg-end mt-4 mt-lg-0">
                    <div class="d-inline-flex gap-4 p-3 bg-white bg-opacity-50 rounded-4 border">
                        <div class="text-center px-3 border-end">
                            <h3 class="fw-bold mb-0 text-primary"><%= journey.total_km %></h3>
                            <small class="text-uppercase text-muted fw-bold" style="font-size: 10px;">KM Dự kiến</small>
                        </div>
                        <div class="text-center px-3 border-end">
                            <h3 class="fw-bold mb-0 text-primary"><%= journey.total_minutes %></h3>
                            <small class="text-uppercase text-muted fw-bold" style="font-size: 10px;">Phút trải nghiệm</small>
                        </div>
                        <div class="text-center px-3">
                            <h3 class="fw-bold mb-0 text-primary"><%= journey.stops.length %></h3>
                            <small class="text-uppercase text-muted fw-bold" style="font-size: 10px;">Điểm dừng</small>
                        </div>
                    </div>
                </div>
            </div>
            <i class="bi bi-map position-absolute top-50 end-0 text-primary opacity-05" style="font-size: 15rem; transform: translate(20%, -50%);"></i>
        </div>

        <!-- Interactive Journey Timeline -->
        <div class="card-healing p-4 mb-5 reveal-up">
            <div class="route-timeline-container position-relative px-4 py-3">
                <div class="route-line position-absolute top-50 start-0 translate-middle-y bg-light w-100" style="height: 6px; z-index: 1; border-radius: 10px;"></div>
                <div class="route-line-progress position-absolute top-50 start-0 translate-middle-y bg-primary" style="height: 6px; z-index: 2; width: 0%; transition: width 0.8s cubic-bezier(0.165, 0.84, 0.44, 1); border-radius: 10px;"></div>
                <div class="d-flex justify-content-between position-relative" style="z-index: 10;">
                    <% journey.stops.forEach((stop, i) => { %>
                        <div class="timeline-node text-center" style="width: 40px;" id="node-<%= i %>" onclick="focusStop(<%= i %>)">
                            <div class="node-circle mx-auto bg-white border border-4 border-light text-muted d-flex align-items-center justify-content-center shadow-sm rounded-circle cursor-pointer" style="width: 45px; height: 45px; transition: all 0.4s ease;">
                                <span class="fw-bold"><%= i + 1 %></span>
                            </div>
                            <span class="d-none d-md-block small text-muted mt-2 fw-bold text-truncate mx-auto" style="max-width: 100px;"><%= stop.name %></span>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>

        <div class="row g-4 reveal-up">
            <!-- Left: Timeline Journey List -->
            <div class="col-lg-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="fw-bold mb-0" style="font-family: var(--font-heading);">Lộ trình chi tiết</h3>
                    <div class="dropdown">
                        <button class="btn btn-outline-primary btn-sm rounded-pill px-3 fw-bold dropdown-toggle" data-bs-toggle="dropdown">
                            <i class="bi bi-gear-fill me-2"></i>Tùy chỉnh
                        </button>
                        <ul class="dropdown-menu border-0 shadow-lg rounded-4 p-2">
                            <li><a class="dropdown-item py-2 rounded-3" href="#" onclick="toggleEditMode()"><i class="bi bi-pencil-square me-2"></i>Sắp xếp lại</a></li>
                            <li><a class="dropdown-item py-2 rounded-3 text-danger" href="/onboarding"><i class="bi bi-trash me-2"></i>Tạo hành trình mới</a></li>
                        </ul>
                    </div>
                </div>

                <div id="sortable-timeline" class="timeline-journey">
                    <% journey.stops.forEach((stop, i) => { %>
                        <div class="timeline-item reveal-up" data-id="<%= stop.destination_id %>" id="card-<%= i %>">
                            <div class="timeline-dot"></div>
                            <div class="card-healing p-4 journey-stop-card" onclick="focusStop(<%= i %>)">
                                <div class="d-flex gap-3">
                                    <div class="drag-handle d-none flex-shrink-0">
                                        <i class="bi bi-grip-vertical fs-3 text-muted"></i>
                                    </div>
                                    <div class="flex-grow-1">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <div>
                                                <h5 class="fw-bold mb-0"><%= stop.name %></h5>
                                                <small class="text-primary fw-bold text-uppercase" style="font-size: 10px;"><%= stop.type %></small>
                                            </div>
                                            <div class="check-indicator d-none" id="check-<%= i %>">
                                                <span class="badge bg-success-subtle text-success rounded-pill px-3 py-1 fw-bold">
                                                    <i class="bi bi-check-circle-fill me-1"></i>Đã đến
                                                </span>
                                            </div>
                                        </div>
                                        <p class="text-muted small mb-3"><%= stop.short_description || stop.story %></p>
                                        <div class="d-flex gap-2">
                                            <a href="/checkin?slug=<%= stop.slug %>" class="btn btn-premium btn-sm rounded-pill px-4">SCAN QR</a>
                                            <button class="btn btn-light btn-sm rounded-pill px-3" onclick="openSupport(<%= stop.destination_id %>, event)">
                                                <i class="bi bi-chat-dots me-1"></i>Hỗ trợ
                                            </button>
                                            <button class="btn btn-outline-danger btn-sm rounded-pill px-2 delete-stop d-none" onclick="removeStop(<%= stop.destination_id %>, event)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <!-- Smart Suggestion (Weather/Crowd based) -->
                <div class="glass-panel p-4 mt-4 border-primary border-opacity-25" style="background: rgba(26, 77, 46, 0.05);">
                    <div class="d-flex gap-3 align-items-center">
                        <div class="bg-primary text-white rounded-circle p-3 shadow-sm">
                            <i class="bi bi-cloud-sun-fill fs-4"></i>
                        </div>
                        <div class="text-start">
                            <h6 class="fw-bold mb-1">Gợi ý từ AI Bình Lợi</h6>
                            <p class="small text-muted mb-0">Hôm nay nắng đẹp, rất thích hợp để tham quan **Vườn Lan** hoặc **Vườn Dừa**. Bạn có muốn thêm vào lộ trình?</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: Interactive Map & Controls -->
            <div class="col-lg-7">
                <div class="sticky-top" style="top: 100px;">
                    <div class="card-healing shadow-lg overflow-hidden mb-4" style="height: 600px;">
                        <div id="map-premium" class="h-100"></div>
                        <!-- Live Stats Overlay -->
                        <div class="position-absolute bottom-0 start-0 m-4 p-3 glass-panel d-none d-md-block" style="z-index: 1000; background: rgba(255,255,255,0.8);">
                            <div class="d-flex gap-4">
                                <div><small class="text-muted d-block fw-bold">GPS</small><span class="fw-bold text-primary" id="live-coords">-- , --</span></div>
                                <div class="border-start ps-3"><small class="text-muted d-block fw-bold">TRẠNG THÁI</small><span class="fw-bold text-success">Đang di chuyển</span></div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="d-grid gap-3">
                        <button class="btn btn-premium btn-lg py-3 shadow-lg animate__animated animate__pulse animate__infinite" onclick="startJourney()" id="btn-start">
                            BẮT ĐẦU TRẢI NGHIỆM SỐ ➔
                        </button>
                        <button class="btn btn-success btn-lg py-3 shadow-lg d-none" id="btn-finish" onclick="finishJourney()">
                            HOÀN THÀNH HÀNH TRÌNH 🎉
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<!-- Achievement Modal -->
<div class="modal fade" id="achievementModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-5 shadow-lg overflow-hidden">
            <div class="modal-body p-5 text-center bg-white">
                <div class="achievement-icon mb-4">
                    <img src="/images/badge-explorer.png" class="img-fluid" style="width: 150px;">
                </div>
                <h2 class="fw-bold mb-3" style="font-family: var(--font-heading);">Hành trình hoàn tất!</h2>
                <p class="text-muted mb-4">Bạn đã chính thức trở thành **Người khám phá Bình Lợi** thực thụ. Các kỷ niệm của bạn đã được lưu vào Passport.</p>
                
                <div class="row g-3 mb-4">
                    <div class="col-6"><div class="bg-light p-3 rounded-4"><h4 class="fw-bold text-primary mb-0"><%= journey.total_km %></h4><small>KM ĐI QUA</small></div></div>
                    <div class="col-6"><div class="bg-light p-3 rounded-4"><h4 class="fw-bold text-primary mb-0">5</h4><small>STAMP MỚI</small></div></div>
                </div>

                <div class="d-grid gap-2">
                    <a href="/passport" class="btn btn-premium py-3 rounded-pill">XEM PASSPORT CỦA TÔI</a>
                    <button class="btn btn-link text-muted" data-bs-dismiss="modal">Đóng</button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .journey-stop-card { cursor: pointer; transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); }
    .journey-stop-card:hover { transform: scale(1.02); box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important; }
    .journey-stop-card.active { border: 2px solid var(--v5-primary); background: #fdfdfb; }
    .node-circle.active { border-color: var(--v5-primary) !important; background: var(--v5-primary) !important; color: white !important; transform: scale(1.2); }
    .node-circle.completed { background: #28a745 !important; border-color: #28a745 !important; color: white !important; }
    .opacity-05 { opacity: 0.05; }
    .drag-handle { cursor: grab; }
</style>

<script>
    let map, markers = [], polyline, completed = new Set(), sortable;
    const journeyId = '<%= journey.id %>';
    let isEditMode = false;

    document.addEventListener('DOMContentLoaded', () => {
        initMap();
        initSortable();
        gsap.from('.reveal-up', { opacity: 0, y: 30, stagger: 0.1, duration: 0.8, ease: 'power2.out' });
    });

    function initMap() {
        map = L.map('map-premium', { zoomControl: false }).setView([10.796, 106.524], 14);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png').addTo(map);
        refreshRoute();
    }

    function refreshRoute() {
        markers.forEach(m => map.removeLayer(m));
        if (polyline) map.removeLayer(polyline);
        markers = [];
        
        const stops = <%- JSON.stringify(journey.stops) %>;
        const coords = stops.map(s => [s.lat, s.lng]);

        stops.forEach((stop, i) => {
            const m = L.circleMarker([stop.lat, stop.lng], {
                radius: 10, fillOpacity: 1, color: '#fff', weight: 4, fillColor: '#1a4d2e'
            }).addTo(map);
            m.bindPopup(`<b class="text-primary">${stop.name}</b>`);
            markers.push(m);
        });

        if (coords.length > 1) {
            polyline = L.polyline(coords, { color: '#1a4d2e', weight: 4, dashArray: '10, 10', opacity: 0.5 }).addTo(map);
            map.fitBounds(polyline.getBounds().pad(0.1));
        }
    }

    function focusStop(i) {
        document.querySelectorAll('.journey-stop-card').forEach(c => c.classList.remove('active'));
        const card = document.getElementById('card-' + i);
        if (card) {
            card.classList.add('active');
            card.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
        map.flyTo(markers[i].getLatLng(), 16, { duration: 1.5 });
        markers[i].openPopup();
        updateTimeline(i);
        document.getElementById('live-coords').innerText = `${markers[i].getLatLng().lat.toFixed(4)}, ${markers[i].getLatLng().lng.toFixed(4)}`;
    }

    function updateTimeline(idx) {
        document.querySelectorAll('.node-circle').forEach((node, i) => {
            node.classList.remove('active');
            if (i === idx) node.classList.add('active');
            if (completed.has(i)) node.classList.add('completed');
        });
        const prog = (idx / (markers.length - 1)) * 100;
        document.querySelector('.route-line-progress').style.width = prog + '%';
    }

    function startJourney() {
        confetti({ particleCount: 150, spread: 70, origin: { y: 0.6 } });
        focusStop(0);
        document.getElementById('btn-start').innerText = "ĐANG TRẢI NGHIỆM...";
        document.getElementById('btn-finish').classList.remove('d-none');
    }

    function toggleEditMode() {
        isEditMode = !isEditMode;
        document.querySelectorAll('.drag-handle, .delete-stop').forEach(el => el.classList.toggle('d-none', !isEditMode));
        sortable.option('disabled', !isEditMode);
    }

    function initSortable() {
        sortable = Sortable.create(document.getElementById('sortable-timeline'), {
            handle: '.drag-handle', animation: 250, disabled: true,
            onEnd: function() {
                const order = sortable.toArray();
                axios.post('/api/journey/update-stop', { journeyId, action: 'reorder', order }).then(() => location.reload());
            }
        });
    }

    function openSupport(destId, event) {
        event.stopPropagation();
        const msg = prompt("Bạn cần hỗ trợ gì tại địa điểm này?");
        if (msg) axios.post('/api/send-message', { destinationId: destId, message: msg }).then(() => alert("Yêu cầu đã được gửi đến quản lý!"));
    }

    function finishJourney() {
        const modal = new bootstrap.Modal(document.getElementById('achievementModal'));
        modal.show();
        confetti({ particleCount: 300, spread: 100 });
    }
</script>