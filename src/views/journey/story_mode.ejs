<!-- ULTIMATE JOURNEY MASTERPIECE V5 - ELITE XANH-TRANG -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/animate.css@4.1.1/animate.min.css">
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

<div id="journey-app-v5" class="bg-white min-vh-100">

    <!-- SCREEN 1: VIBE SELECTION (SMART WIZARD) -->
    <!-- (Existing Step 1-3 Logic but with v5 Styles) -->
    
    <!-- SCREEN 2: SWIPE SUGGESTIONS (TIKTOK STYLE) -->
    <section id="screen-suggestions" class="py-5 animate__animated animate__fadeIn">
        <div class="container-site text-center">
            <h1 class="display-3 fw-black text-dark mb-2">Hành trình dành cho bạn ✨</h1>
            <p class="lead text-muted mb-5">Vuốt để chọn "vibe" phù hợp nhất với tâm hồn bạn hôm nay.</p>

            <div class="suggestion-swipe-container mb-5" style="max-width: 500px; margin: 0 auto; height: 650px; position: relative;">
                <!-- Premium Card -->
                <div class="card-bl h-100 shadow-xl border-0 position-relative animate__animated animate__zoomIn">
                    <img src="<%= baseUrl %>/images/hero-1.png" class="w-100 h-60 object-fit-cover" style="height: 55%; border-radius: 32px 32px 0 0;">
                    <div class="p-5 text-start">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="badge bg-primary-soft text-primary rounded-pill px-3 py-2 fw-bold">98% MATCH</span>
                            <div class="small fw-black text-uppercase letter-spacing-lg text-primary">Sống Chậm</div>
                        </div>
                        <h2 class="fw-black mb-3">Một ngày miền Tây giữa phố</h2>
                        <div class="d-flex gap-4 text-muted small fw-bold mb-4">
                            <span>⏱ 6H</span>
                            <span>📍 12KM</span>
                            <span>🛵 XE MÁY</span>
                        </div>
                        <button class="btn btn-primary-bl w-100 py-3 fs-5 fw-black rounded-pill" onclick="showMapOverview()">CHỌN VIBE NÀY ➔</button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SCREEN 3: ROUTE OVERVIEW (MAP PREVIEW) -->
    <section id="screen-map-overview" style="display: none;" class="py-5 animate__animated animate__fadeIn">
        <div class="container-site">
            <div class="text-center mb-5">
                <h1 class="display-4 fw-black">Tổng quan lộ trình 🗺️</h1>
                <p class="text-muted">Xem trước toàn bộ tuyến đường và các điểm dừng của bạn.</p>
            </div>

            <!-- MAP VISUALIZATION -->
            <div id="route-overview-map" class="shadow-xl">
                <div class="map-simulation-path"></div>
                <!-- Simulated Markers -->
                <% journey.stops.forEach((stop, index) => { %>
                    <div class="map-simulation-marker position-absolute" style="top: <%= 20 + (index * 15) %>%; left: <%= 15 + (index * 20) %>%;">
                        <%= index + 1 %>
                    </div>
                <% }) %>
                <div class="position-absolute bottom-0 start-0 m-4 p-3 bg-white rounded-4 shadow-sm small fw-bold">
                    <i class="bi bi-info-circle me-2 text-primary"></i> Lộ trình tối ưu: 12.5 km
                </div>
            </div>

            <div class="row g-4 justify-content-center mt-5">
                <div class="col-md-5">
                    <div class="card-bl p-4 text-center border-primary border-2">
                        <h4 class="fw-black mb-3 text-primary">A. Đi luôn (Quick Mode) ⚡</h4>
                        <p class="small text-muted mb-4">Dành cho người lười chỉnh, đi nhanh, không suy nghĩ.</p>
                        <button class="btn btn-primary-bl w-100 py-3 rounded-pill fw-black" onclick="startJourney('quick')">🚀 BẮT ĐẦU NGAY</button>
                    </div>
                </div>
                <div class="col-md-5">
                    <div class="card-bl p-4 text-center">
                        <h4 class="fw-black mb-3">B. Độ lại hành trình 🎛️</h4>
                        <p class="small text-muted mb-4">Kéo thả, thêm bớt điểm theo ý thích cá nhân.</p>
                        <button class="btn btn-outline-primary w-100 py-3 rounded-pill fw-black" onclick="showTimeline()">🎨 TÙY CHỈNH THEO MÌNH</button>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SCREEN 4: TIMELINE & CUSTOMIZE (STORY MODE) -->
    <section id="screen-timeline" style="display: none;" class="py-5 animate__animated animate__fadeIn">
        <div class="container-site">
            <div class="row g-5">
                <div class="col-lg-8">
                    <h2 class="display-5 fw-black mb-5">Timeline trải nghiệm 📜</h2>
                    
                    <div id="v5-sortable-list">
                        <% journey.stops.forEach((stop, index) => { %>
                        <div class="journey-item-v5 animate__animated animate__fadeInUp" style="animation-delay: <%= index * 0.1 %>s">
                            <div class="v5-step-indicator shadow-sm"><%= index + 1 %></div>
                            <div class="v5-card">
                                <div class="row g-3 align-items-center">
                                    <div class="col-auto handle d-none" style="cursor: grab;"><i class="bi bi-grip-vertical fs-3 text-muted"></i></div>
                                    <div class="col-auto">
                                        <img src="<%= fixImg(stop.cover_image) %>" class="rounded-4" style="width: 70px; height: 70px; object-fit: cover;">
                                    </div>
                                    <div class="col">
                                        <h5 class="fw-black mb-1"><%= stop.name %></h5>
                                        <p class="small text-muted mb-0"><%= stop.short_desc %></p>
                                    </div>
                                    <div class="col-auto">
                                        <button class="btn btn-light rounded-circle text-danger d-none btn-remove" onclick="this.closest('.journey-item-v5').remove()"><i class="bi bi-trash"></i></button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                    </div>

                    <div id="customize-tools" class="d-none animate__animated animate__fadeIn">
                        <div class="p-4 bg-primary-soft rounded-5 mt-4">
                            <h6 class="fw-black mb-3"><i class="bi bi-sliders me-2"></i> Điều chỉnh lộ trình</h6>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="small fw-bold mb-2">PHƯƠNG TIỆN</label>
                                    <select class="form-select rounded-pill px-3" onchange="updateTransport(this.value)">
                                        <option value="bike">🛵 XE MÁY</option>
                                        <option value="bicycle">🚲 XE ĐẠP</option>
                                        <option value="walk">🚶 ĐI BỘ</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="small fw-bold mb-2">DỰ KIẾN: <span id="time-label">6 GIỜ</span></label>
                                    <input type="range" class="form-range" min="2" max="10" value="6" oninput="document.getElementById('time-label').innerText = this.value + ' GIỜ'">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="sticky-top" style="top: 120px;">
                        <div class="card-bl p-5 bg-dark text-white shadow-xl text-center">
                            <h3 class="fw-black mb-4">Sẵn sàng đi?</h3>
                            <button class="btn btn-primary-bl w-100 py-3 rounded-pill fw-black mb-3 fs-5" onclick="startJourney('custom')">🚀 BẮT ĐẦU</button>
                            <button class="btn btn-outline-light w-100 py-3 rounded-pill fw-bold" onclick="enableCustomize()">🎨 BẬT TÙY CHỈNH</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

</div>

<script>
    function showMapOverview() {
        document.getElementById('screen-suggestions').style.display = 'none';
        document.getElementById('screen-map-overview').style.display = 'block';
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function showTimeline() {
        document.getElementById('screen-map-overview').style.display = 'none';
        document.getElementById('screen-timeline').style.display = 'block';
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function enableCustomize() {
        document.getElementById('customize-tools').classList.remove('d-none');
        document.querySelectorAll('.handle').forEach(h => h.classList.remove('d-none'));
        document.querySelectorAll('.btn-remove').forEach(b => b.classList.remove('d-none'));
        
        const el = document.getElementById('v5-sortable-list');
        Sortable.create(el, {
            animation: 150,
            handle: '.handle',
            ghostClass: 'bg-primary-soft'
        });
        alert('🎨 Kéo thả để sắp xếp lại các điểm đến!');
    }

    function startJourney(mode) {
        alert('🚀 Hệ thống đang kích hoạt GPS, Passport và Huy hiệu cho chế độ: ' + mode.toUpperCase());
        // Transition to real-time assistant screen (already implemented in logic)
        window.location.href = '/map'; // Redirect to real map for now
    }
</script>