<% 
let stops = journey.stops || [];
let totalKm = journey.total_km || 0;
let totalMin = journey.total_minutes || 0;
let mood = journey.mood || 'An nhiên';
let duration = (journey.duration === 'full_day') ? 'Cả ngày' : 'Buổi sáng/chiều';
%>

<section class="journey-header bg-primary text-white py-5 position-relative overflow-hidden">
    <div class="container-site position-relative" style="z-index: 10;">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-4">
                <li class="breadcrumb-item"><a href="<%= baseUrl %>/" class="text-white-50 text-decoration-none">Trang chủ</a></li>
                <li class="breadcrumb-item active text-white" aria-current="page">Hành trình cá nhân</li>
            </ol>
        </nav>
        <div class="row align-items-end g-4">
            <div class="col-lg-8">
                <span class="badge bg-secondary text-dark mb-2 px-3 py-2 rounded-pill">PERSONALIZED JOURNEY</span>
                <h1 class="display-4 fw-black mb-0">Hành trình <%= mood %></h1>
                <p class="lead opacity-75 mt-2 mb-0">Được thiết kế riêng dựa trên sở thích và thời gian của bạn tại Bình Lợi.</p>
            </div>
            <div class="col-lg-4 text-lg-end">
                <div class="d-flex gap-3 justify-content-lg-end">
                    <div class="text-center p-3 bg-white bg-opacity-10 rounded-4" style="min-width: 100px;">
                        <h4 class="mb-0 fw-bold"><%= totalKm %></h4>
                        <p class="small mb-0 opacity-50 text-uppercase">Km</p>
                    </div>
                    <div class="text-center p-3 bg-white bg-opacity-10 rounded-4" style="min-width: 100px;">
                        <h4 class="mb-0 fw-bold"><%= totalMin %></h4>
                        <p class="small mb-0 opacity-50 text-uppercase">Phút</p>
                    </div>
                    <div class="text-center p-3 bg-white bg-opacity-10 rounded-4" style="cursor: pointer;" onclick="alert('Đã đồng bộ với lịch của bạn!')">
                        <i class="bi bi-calendar-check fs-4"></i>
                        <p class="small mb-0 opacity-50 text-uppercase">Đồng bộ</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="position-absolute top-0 end-0 opacity-10 m-n5 d-none d-lg-block">
        <i class="bi bi-signpost-split-fill" style="font-size: 300px;"></i>
    </div>
</section>

<div class="container-site py-5">
    <div class="row g-5">
        <!-- Timeline Section -->
        <div class="col-lg-8">
            <h4 class="display-text mb-5"><i class="bi bi-list-ol text-primary me-2"></i> Lộ trình trải nghiệm</h4>
            
            <div class="journey-timeline">
                <% stops.forEach((stop, index) => { %>
                <div class="timeline-item animate__animated animate__fadeInUp" style="animation-delay: <%= index * 0.2 %>s">
                    <div class="timeline-marker">
                        <div class="marker-dot"></div>
                        <% if (index < stops.length - 1) { %>
                        <div class="marker-line"></div>
                        <div class="marker-distance small fw-bold text-primary bg-white px-2 py-1 border rounded-pill shadow-sm">
                            <i class="bi bi-bicycle me-1"></i> 1.5km
                        </div>
                        <% } %>
                    </div>
                    <div class="timeline-content">
                        <div class="card-bl border-0 shadow-sm overflow-hidden mb-4">
                            <div class="row g-0">
                                <div class="col-md-4 position-relative">
                                    <img src="<%= (stop.cover_image && stop.cover_image.startsWith('http')) ? stop.cover_image : (baseUrl + '/' + stop.cover_image) %>" 
                                         class="w-100 h-100 object-fit-cover" style="min-height: 220px;" alt="<%= stop.name %>">
                                    <div class="position-absolute top-0 start-0 m-3 d-flex gap-1">
                                        <button class="btn btn-white btn-sm rounded-circle shadow-sm" title="Di chuyển lên"><i class="bi bi-arrow-up-short"></i></button>
                                        <button class="btn btn-white btn-sm rounded-circle shadow-sm" title="Xóa"><i class="bi bi-x-short"></i></button>
                                    </div>
                                </div>
                                <div class="col-md-8">
                                    <div class="card-bl-body p-4">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <span class="badge bg-soft-primary text-primary border border-primary border-opacity-10 px-2 py-1 rounded-pill small">CHẶNG <%= index + 1 %></span>
                                            <span class="text-muted small"><i class="bi bi-alarm"></i> <%= 8 + index %>:30 - <%= 9 + index %>:30</span>
                                        </div>
                                        <h4 class="fw-bold mb-2"><%= stop.name %></h4>
                                        <div class="d-flex gap-2 mb-3">
                                            <span class="badge bg-light text-dark fw-normal border"><i class="bi bi-camera me-1"></i> Check-in</span>
                                            <% if(stop.type == 'craft') { %>
                                                <span class="badge bg-light text-dark fw-normal border"><i class="bi bi-hammer me-1"></i> Workshop</span>
                                            <% } else if(stop.type == 'temple') { %>
                                                <span class="badge bg-light text-dark fw-normal border"><i class="bi bi-flower1 me-1"></i> Lễ Phật</span>
                                            <% } else { %>
                                                <span class="badge bg-light text-dark fw-normal border"><i class="bi bi-eye me-1"></i> Tham quan</span>
                                            <% } %>
                                        </div>
                                        <p class="text-muted small mb-4 line-clamp-2"><%= stop.story %></p>
                                        
                                        <div class="d-flex gap-2">
                                            <a href="<%= baseUrl %>/explore/<%= stop.slug %>" class="btn btn-outline-bl btn-sm px-4 rounded-pill">Chi tiết</a>
                                            <a href="<%= baseUrl %>/checkin?slug=<%= stop.slug %>" class="btn btn-primary-bl btn-sm px-4 rounded-pill">Check-in</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <% if (index == 1) { %>
                        <div class="alert bg-soft-secondary border-0 rounded-4 p-4 mb-5 d-flex align-items-center gap-4">
                            <div class="bg-white p-3 rounded-circle shadow-sm">
                                <i class="bi bi-cup-hot fs-2 text-secondary"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1">Gợi ý nghỉ chân: Quán Nước Ven Kênh</h6>
                                <p class="small text-muted mb-0">Thưởng thức nước dừa tươi Bình Lợi và nghỉ ngơi 15 phút trước khi tiếp tục hành trình.</p>
                            </div>
                            <button class="btn btn-secondary btn-sm ms-auto rounded-pill px-3">Ghé ngay</button>
                        </div>
                        <% } %>
                    </div>
                </div>
                <% }) %>
            </div>
            
            <div class="text-center mt-4">
                <div class="p-4 bg-light rounded-4 border border-dashed">
                    <p class="mb-0 text-muted">Bạn đã hoàn thành lộ trình? Hãy chia sẻ cảm nhận của mình nhé!</p>
                </div>
            </div>
        </div>

        <!-- Sidebar Info -->
        <div class="col-lg-4">
            <div class="sticky-top" style="top: 100px;">
                <div class="card-bl p-4 mb-4 bg-dark text-white border-0 shadow-lg">
                    <h5 class="fw-bold mb-4">Gợi ý chuẩn bị</h5>
                    <ul class="list-unstyled mb-4" style="line-height: 2.2;">
                        <li><i class="bi bi-check2-circle text-secondary me-2"></i> Trang phục thoải mái, nhẹ nhàng.</li>
                        <li><i class="bi bi-check2-circle text-secondary me-2"></i> Mang theo sạc dự phòng cho điện thoại.</li>
                        <li><i class="bi bi-check2-circle text-secondary me-2"></i> Một chai nước cá nhân để bù điện giải.</li>
                        <li><i class="bi bi-check2-circle text-secondary me-2"></i> Tinh thần sẵn sàng chữa lành.</li>
                    </ul>
                    <a href="<%= baseUrl %>/map" class="btn btn-secondary w-100 py-3 fw-bold rounded-3">
                        <i class="bi bi-map-fill me-2"></i> Xem bản đồ tương tác
                    </a>
                </div>

                <div class="card-bl p-4 border-0 shadow-sm mb-4">
                    <h6 class="fw-bold mb-3">Thông số hành trình</h6>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Thời lượng</span>
                        <span class="fw-bold small"><%= duration %></span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Số điểm dừng</span>
                        <span class="fw-bold small"><%= stops.length %> điểm</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted small">Mức độ vận động</span>
                        <span class="fw-bold small text-success">Nhẹ nhàng</span>
                    </div>
                    <hr>
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-bl btn-sm w-100 rounded-pill" onclick="alert('Đã lưu hành trình!')"><i class="bi bi-heart me-1"></i> Lưu</button>
                        <button class="btn btn-outline-bl btn-sm w-100 rounded-pill" onclick="alert('Link chia sẻ: ' + window.location.href)"><i class="bi bi-share me-1"></i> Chia sẻ</button>
                    </div>
                </div>

                <div class="card-bl p-4 border-0 shadow-sm bg-light">
                    <h6 class="fw-bold mb-3">Hành trình gợi ý khác</h6>
                    <div class="list-group list-group-flush bg-transparent">
                        <a href="<%= baseUrl %>/journey/preset/an-nhien" class="list-group-item list-group-item-action bg-transparent px-0 small border-0 py-2 text-primary">Tuyến An Nhiên</a>
                        <a href="<%= baseUrl %>/journey/preset/lang-nghe" class="list-group-item list-group-item-action bg-transparent px-0 small border-0 py-2 text-primary">Khám Phá Làng Nghề</a>
                        <a href="<%= baseUrl %>/journey/preset/hoi-xuan" class="list-group-item list-group-item-action bg-transparent px-0 small border-0 py-2 text-primary">Tuyến Hội Xuân</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.journey-header {
    background: linear-gradient(135deg, #5c8a5e 0%, #4a6e4b 100%);
}
.fw-black { font-weight: 900; }
.journey-timeline {
    position: relative;
    padding-left: 50px;
}
.timeline-item {
    position: relative;
}
.timeline-marker {
    position: absolute;
    left: -50px;
    height: 100%;
    width: 30px;
    display: flex;
    flex-direction: column;
    align-items: center;
}
.marker-dot {
    width: 24px;
    height: 24px;
    background: #fff;
    border: 6px solid var(--color-primary);
    border-radius: 50%;
    z-index: 5;
    margin-top: 40px;
}
.marker-line {
    width: 4px;
    flex-grow: 1;
    background: rgba(92, 138, 94, 0.15);
    margin: 5px 0;
}
.marker-distance {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    white-space: nowrap;
    font-size: 10px;
    z-index: 10;
}
.line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
@media (max-width: 768px) {
    .journey-timeline { padding-left: 30px; }
    .timeline-marker { left: -30px; }
    .marker-dot { width: 18px; height: 18px; border-width: 4px; }
}
</style>
