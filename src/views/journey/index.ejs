<% 
let stops = journey.stops || [];
let totalKm = journey.total_km || 0;
let totalMin = journey.total_minutes || 0;
let mood = journey.mood || 'An nhiên';
%>

<!-- CONTAINER CHÍNH -->
<div class="container-site py-4" id="journey-app">
    
    <!-- MÀN HÌNH 1: GỢI Ý HÀNH TRÌNH (SWIPE) -->
    <div id="view-suggestions" class="animate__animated animate__fadeIn">
        <div class="text-center mb-4">
            <h2 class="fw-black mb-1">Gợi ý cho bạn</h2>
            <p class="small text-muted">Vuốt để chọn vibe phù hợp nhất</p>
        </div>

        <div class="suggestion-swipe-container">
            <!-- Thẻ 1 -->
            <div class="swipe-card" onclick="selectJourney('song-cham')">
                <div class="swipe-match-badge">98% Match</div>
                <img src="<%= baseUrl %>/images/hero-1.png" class="swipe-card-img">
                <div class="swipe-card-content">
                    <span class="swipe-card-vibe">🌿 CHILL & HEALING</span>
                    <h3 class="swipe-card-title">Một ngày miền Tây giữa phố</h3>
                    <div class="swipe-card-stats">
                        <span><i class="bi bi-clock me-1"></i> 6 tiếng</span>
                        <span><i class="bi bi-geo-alt me-1"></i> 5 điểm</span>
                    </div>
                </div>
            </div>

            <!-- Thẻ 2 (Hidden behind) -->
            <div class="swipe-card" style="transform: scale(0.9) translateY(20px); z-index: -1; opacity: 0.5;">
                <img src="<%= baseUrl %>/images/hero-2.png" class="swipe-card-img">
                <div class="swipe-card-content">
                    <span class="swipe-card-vibe">🏺 VĂN HÓA</span>
                    <h3 class="swipe-card-title">Đi chill Bình Lợi không vội</h3>
                    <div class="swipe-card-stats">
                        <span><i class="bi bi-clock me-1"></i> 4 tiếng</span>
                        <span><i class="bi bi-geo-alt me-1"></i> 3 điểm</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="text-center mt-4">
            <button class="btn btn-primary-bl btn-pill px-5 py-3" onclick="activateJourney()">
                CHỌN VIBE NÀY ✦
            </button>
        </div>
    </div>

    <!-- MÀN HÌNH 2: CHI TIẾT HÀNH TRÌNH (STORY TIMELINE) -->
    <div id="view-active-journey" style="display: none;" class="animate__animated animate__fadeIn">
        <!-- Header Tổng quan -->
        <div class="card-bl border-0 p-4 mb-4 bg-primary text-white shadow-lg overflow-hidden position-relative">
            <div class="position-relative" style="z-index: 10;">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <span class="badge bg-white text-primary rounded-pill mb-2">HÀNH TRÌNH ĐANG DIỄN RA</span>
                        <h2 class="fw-black mb-0">Một ngày miền Tây giữa phố</h2>
                    </div>
                    <button class="btn btn-white btn-sm rounded-circle" onclick="toggleEditMode()">
                        <i class="bi bi-pencil-square"></i>
                    </button>
                </div>
                <div class="row g-3">
                    <div class="col-4">
                        <div class="small opacity-75">THỜI GIAN</div>
                        <div class="fw-bold fs-5">~6 tiếng</div>
                    </div>
                    <div class="col-4">
                        <div class="small opacity-75">QUÃNG ĐƯỜNG</div>
                        <div class="fw-bold fs-5">12.5 km</div>
                    </div>
                    <div class="col-4">
                        <div class="small opacity-75">DI CHUYỂN</div>
                        <div class="fw-bold fs-5">🛵 Xe máy</div>
                    </div>
                </div>
            </div>
            <i class="bi bi-geo-fill position-absolute bottom-0 end-0 m-n3 opacity-10" style="font-size: 150px;"></i>
        </div>

        <!-- Story Timeline -->
        <div class="story-timeline">
            <% stops.forEach((stop, index) => { %>
            <div class="story-item">
                <div class="story-time-col">
                    <%= (index === 0) ? '08:00' : (index === 1 ? '09:30' : '11:00') %>
                </div>
                <div class="story-content-col">
                    <img src="<%= fixImg(stop.cover_image) %>" class="story-img-preview">
                    <div class="story-info">
                        <h6><%= stop.name %></h6>
                        <p><%= stop.short_desc || 'Thiền nhẹ, chill đầu ngày' %></p>
                    </div>
                    <div class="d-flex gap-1">
                        <button class="story-action-btn" title="Chat hỏi"><i class="bi bi-chat-dots-fill"></i></button>
                        <button class="story-action-btn text-danger btn-remove" style="display: none;" title="Bỏ điểm này"><i class="bi bi-x-lg"></i></button>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>

        <!-- Sticky Bottom Actions -->
        <div class="sticky-bottom-actions py-4 bg-white border-top mt-5" style="position: sticky; bottom: 0; margin-left: -15px; margin-right: -15px; padding: 20px;">
            <div class="row g-2 justify-content-center">
                <div class="col-6">
                    <button class="btn btn-primary-bl w-100 py-3 rounded-pill fw-black" onclick="startNavigation()">
                        🚀 BẮT ĐẦU NGAY
                    </button>
                </div>
                <div class="col-6">
                    <button class="btn btn-outline-dark w-100 py-3 rounded-pill fw-bold" onclick="toggleEditMode()" id="btn-edit-mode">
                        🎨 TÙY CHỈNH
                    </button>
                </div>
            </div>
        </div>
    </div>

</div>

<script>
let isEditMode = false;

function activateJourney() {
    document.getElementById('view-suggestions').style.display = 'none';
    document.getElementById('view-active-journey').style.display = 'block';
    window.scrollTo({ top: 0, behavior: 'smooth' });
}

function toggleEditMode() {
    isEditMode = !isEditMode;
    const btn = document.getElementById('btn-edit-mode');
    const removeBtns = document.querySelectorAll('.btn-remove');
    
    if (isEditMode) {
        btn.innerHTML = '💾 LƯU LẠI';
        btn.classList.replace('btn-outline-dark', 'btn-success');
        removeBtns.forEach(b => b.style.display = 'flex');
        alert('Chế độ Tùy chỉnh: Bạn có thể thêm/xóa hoặc kéo thả để sắp xếp lại lộ trình.');
    } else {
        btn.innerHTML = '🎨 TÙY CHỈNH';
        btn.classList.replace('btn-success', 'btn-outline-dark');
        removeBtns.forEach(b => b.style.display = 'none');
    }
}

function startNavigation() {
    alert('🚀 Bật GPS... Đang bắt đầu dẫn đường đến điểm đầu tiên: <%= stops[0].name %>');
    // Navigation logic here
}

// Giả lập swipe
let startX;
const container = document.querySelector('.suggestion-swipe-container');
if(container) {
    container.addEventListener('touchstart', e => startX = e.touches[0].clientX);
    container.addEventListener('touchend', e => {
        const diff = e.changedTouches[0].clientX - startX;
        if (Math.abs(diff) > 50) {
            alert('Đang chuyển sang vibe tiếp theo...');
        }
    });
}
</script>
