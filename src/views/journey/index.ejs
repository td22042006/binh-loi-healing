<% 
let stops = journey.stops || [];
let totalKm = journey.total_km || 0;
let totalMin = journey.total_minutes || 0;
let mood = journey.mood || 'An nhiên';
let durationStr = (journey.duration === 'full_day') ? 'Cả ngày' : 'Buổi sáng/chiều';
%>

<section class="journey-hero">
    <div class="container-site position-relative" style="z-index: 10;">
        <div class="row g-4 align-items-center">
            <div class="col-lg-7">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-3">
                        <li class="breadcrumb-item"><a href="/" class="text-white-50 text-decoration-none small">TRANG CHỦ</a></li>
                        <li class="breadcrumb-item active text-white small" aria-current="page">HÀNH TRÌNH</li>
                    </ol>
                </nav>
                <span class="journey-badge mb-3 d-inline-block">✦ <%= seasonName %></span>
                <h1 class="display-3 fw-black mb-3">Hành trình<br><span class="text-accent"><%= mood %></span></h1>
                <p class="lead opacity-75 mb-0" style="max-width: 600px;">
                    Một lộ trình được thiết kế riêng để bạn cảm nhận trọn vẹn nhịp sống và linh hồn của vùng đất Bình Lợi.
                </p>
            </div>
            <div class="col-lg-5">
                <div class="row g-3">
                    <div class="col-6">
                        <div class="stat-card-glass">
                            <h2 class="fw-black mb-0"><%= totalKm %></h2>
                            <p class="small text-uppercase mb-0 opacity-75">Quãng đường (km)</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="stat-card-glass">
                            <h2 class="fw-black mb-0"><%= totalMin %></h2>
                            <p class="small text-uppercase mb-0 opacity-75">Thời gian (phút)</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="container-site py-5">
    <div class="row g-5">
        <!-- Main Timeline -->
        <div class="col-lg-8">
            <div class="d-flex align-items-center justify-content-between mb-5">
                <h3 class="display-text mb-0">Lộ trình trải nghiệm</h3>
                <span class="badge bg-soft-primary text-primary px-3 py-2 rounded-pill"><%= stops.length %> Điểm dừng chân</span>
            </div>

            <div class="journey-timeline-v2">
                <% stops.forEach((stop, index) => { %>
                <div class="timeline-step animate__animated animate__fadeInUp" style="animation-delay: <%= index * 0.1 %>s">
                    <div class="step-number"><%= index + 1 %></div>
                    
                    <div class="card-bl border-0">
                        <div class="row g-0">
                            <div class="col-md-5">
                                <div class="position-relative h-100">
                                    <img src="<%= fixImg(stop.cover_image) %>" class="w-100 h-100 object-fit-cover" alt="<%= stop.name %>" style="min-height: 250px;">
                                    <div class="position-absolute top-0 start-0 m-3">
                                        <span class="badge bg-white text-primary rounded-pill shadow-sm"><i class="bi bi-star-fill me-1"></i><%= stop.points %> pts</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-7">
                                <div class="card-bl-body">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <span class="card-bl-tag mb-2">✦ <%= (stop.type || 'Tham quan') %></span>
                                            <h4 class="card-bl-title"><%= stop.name %></h4>
                                        </div>
                                        <div class="dropdown">
                                            <button class="btn btn-link text-muted p-0" data-bs-toggle="dropdown">
                                                <i class="bi bi-three-dots-vertical fs-5"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg rounded-4">
                                                <% if (index > 0) { %>
                                                    <li><a class="dropdown-item py-2" onclick="updateStop('<%= journey.id %>', '<%= stop.destination_id %>', 'reorder', <%= index - 1 %>)"><i class="bi bi-arrow-up me-2"></i> Di chuyển lên</a></li>
                                                <% } %>
                                                <% if (index < stops.length - 1) { %>
                                                    <li><a class="dropdown-item py-2" onclick="updateStop('<%= journey.id %>', '<%= stop.destination_id %>', 'reorder', <%= index + 1 %>)"><i class="bi bi-arrow-down me-2"></i> Di chuyển xuống</a></li>
                                                <% } %>
                                                <li><hr class="dropdown-divider"></li>
                                                <li><a class="dropdown-item py-2 text-danger" onclick="if(confirm('Xóa chặng này?')) updateStop('<%= journey.id %>', '<%= stop.destination_id %>', 'remove')"><i class="bi bi-trash me-2"></i> Xóa chặng dừng</a></li>
                                            </ul>
                                        </div>
                                    </div>
                                    
                                    <p class="card-bl-desc mb-4 text-truncate-3"><%= stop.short_desc || stop.story %></p>
                                    
                                    <div class="d-flex flex-wrap gap-2 mb-4">
                                        <div class="transport-tag">
                                            <i class="bi bi-clock me-2"></i>45 phút
                                        </div>
                                        <div class="transport-tag">
                                            <select class="border-0 bg-transparent fw-bold" onchange="updateStop('<%= journey.id %>', '<%= stop.destination_id %>', 'update_transport', 0, this.value)">
                                                <option value="cycling" <%= stop.transport === 'cycling' ? 'selected' : '' %>>🚲 Xe đạp</option>
                                                <option value="motorbike" <%= stop.transport === 'motorbike' ? 'selected' : '' %>>🛵 Xe máy</option>
                                                <option value="walking" <%= stop.transport === 'walking' ? 'selected' : '' %>>🚶 Đi bộ</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="d-flex gap-2">
                                        <a href="<%= baseUrl %>/explore/<%= stop.slug %>" class="btn btn-primary-bl btn-pill flex-grow-1">Khám phá</a>
                                        <a href="https://www.google.com/maps/dir/?api=1&destination=<%= stop.lat %>,<%= stop.lng %>" target="_blank" class="btn btn-pill border px-3">
                                            <i class="bi bi-geo-alt"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>

        <!-- Sidebar Actions -->
        <div class="col-lg-4">
            <div class="sticky-top" style="top: 100px;">
                <div class="card-bl p-4 mb-4 border-0 bg-dark text-white shadow-lg overflow-hidden position-relative">
                    <div class="position-relative" style="z-index: 10;">
                        <h5 class="fw-black mb-4">Chuẩn bị hành trang</h5>
                        <div class="d-flex gap-3 mb-4">
                            <div class="icon-box bg-white bg-opacity-20 rounded-circle text-white">
                                <i class="bi bi-lightning-charge"></i>
                            </div>
                            <p class="small mb-0">Sạc đầy điện thoại để Check-in & nhận Huy hiệu.</p>
                        </div>
                        <div class="d-flex gap-3 mb-4">
                            <div class="icon-box bg-white bg-opacity-20 rounded-circle text-white">
                                <i class="bi bi-droplet"></i>
                            </div>
                            <p class="small mb-0">Mang theo nước uống cá nhân để bảo vệ môi trường.</p>
                        </div>
                        <a href="<%= baseUrl %>/map" class="btn btn-white w-100 py-3 fw-bold rounded-pill text-dark">
                            XEM BẢN ĐỒ TƯƠNG TÁC
                        </a>
                    </div>
                    <i class="bi bi-stars position-absolute top-0 end-0 m-4 opacity-25 fs-1"></i>
                </div>

                <div class="card-bl p-4 mb-4 border-0 shadow-sm">
                    <h6 class="fw-black mb-3">Tùy chọn hành trình</h6>
                    <div class="d-grid gap-2">
                        <button class="btn btn-outline-bl btn-pill" onclick="shareJourney()">
                            <i class="bi bi-share me-2"></i> CHIA SẺ HÀNH TRÌNH
                        </button>
                        <button class="btn btn-outline-bl btn-pill" onclick="alert('Đã lưu!')">
                            <i class="bi bi-heart me-2"></i> LƯU VÀO YÊU THÍCH
                        </button>
                    </div>
                    <hr>
                    <div class="d-grid">
                        <% 
                        let mapUrl = "https://www.google.com/maps/dir/";
                        stops.forEach(s => {
                            mapUrl += `${s.lat},${s.lng}/`;
                        });
                        %>
                        <a href="<%= mapUrl %>" target="_blank" class="btn btn-primary-bl btn-pill py-3">
                            <i class="bi bi-google me-2"></i> MỞ GOOGLE MAPS
                        </a>
                    </div>
                </div>

                <div class="card-bl p-4 border-0 shadow-sm">
                    <h6 class="fw-black mb-3">Gợi ý khác cho bạn</h6>
                    <div class="list-group list-group-flush">
                        <a href="<%= baseUrl %>/journey/preset/song-cham" class="list-group-item list-group-item-action px-0 border-0 py-3 d-flex align-items-center">
                            <div class="icon-box bg-soft-primary text-primary me-3">🌿</div>
                            <div class="small fw-bold">Sống chậm Bình Lợi</div>
                        </a>
                        <a href="<%= baseUrl %>/journey/preset/miet-vuon" class="list-group-item list-group-item-action px-0 border-0 py-3 d-flex align-items-center">
                            <div class="icon-box bg-soft-primary text-primary me-3">🥥</div>
                            <div class="small fw-bold">Miệt vườn giữa phố</div>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
async function updateStop(journeyId, destinationId, action, order = 0, transport = 'walking') {
    try {
        const response = await fetch('<%= baseUrl %>/api/journey/update-stop', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ journeyId, destinationId, action, order, transport })
        });
        const result = await response.json();
        if (result.success) {
            window.location.reload();
        } else {
            alert('Lỗi: ' + result.message);
        }
    } catch (e) {
        console.error(e);
        alert('Không thể kết nối máy chủ');
    }
}

function shareJourney() {
    const url = window.location.href;
    const text = "Khám phá hành trình <%= mood %> tại Bình Lợi Healing!";
    if (navigator.share) {
        navigator.share({ title: 'Bình Lợi Healing', text: text, url: url });
    } else {
        navigator.clipboard.writeText(url).then(() => alert('Đã copy link hành trình!'));
    }
}
</script>
