<% 
let stops = journey.stops || [];
let totalKm = journey.total_km || 0;
let totalMin = journey.total_minutes || 0;
let mood = journey.mood || 'An nhiên';
let durationStr = (journey.duration === 'full_day') ? 'Cả ngày' : 'Buổi sáng/chiều';
%>

<section class="journey-header bg-primary text-white py-5 position-relative overflow-hidden">
    <div class="container-site position-relative" style="z-index: 10;">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-4">
                <li class="breadcrumb-item"><a href="/" class="text-white-75 text-decoration-none">Trang chủ</a></li>
                <li class="breadcrumb-item active text-white" aria-current="page">Hành trình cá nhân</li>
            </ol>
        </nav>
        <div class="row align-items-end g-4">
            <div class="col-lg-8">
                <div class="mb-2">
                    <span class="badge bg-white text-dark rounded-pill me-1"><%= seasonName %></span>
                    <% 
                    let targetAudience = "Mọi đối tượng";
                    if (mood.includes("Du xuân")) targetAudience = "Gia đình, Giới trẻ";
                    if (mood.includes("Miệt vườn")) targetAudience = "Gia đình, Trẻ em";
                    if (mood.includes("Tâm linh")) targetAudience = "Người lớn tuổi, Hành hương";
                    if (mood.includes("Sống chậm")) targetAudience = "Dân văn phòng, Cặp đôi";
                    %>
                    <span class="badge bg-light text-dark border rounded-pill"><i class="bi bi-people me-1"></i><%= targetAudience %></span>
                </div>
                <h1 class="display-4 fw-black mb-0">Hành trình <%= mood %></h1>
                <p class="lead opacity-75 mt-2 mb-0">Hành trình khám phá bản sắc Bình Lợi - Miền Tây giữa lòng Sài Gòn.</p>
            </div>
            <div class="col-lg-4 text-lg-end">
                <div class="d-flex gap-3 justify-content-lg-end">
                    <div class="text-center p-3 bg-white bg-opacity-10 rounded-4" style="min-width: 100px;">
                        <h4 class="mb-0 fw-bold"><%= totalKm %></h4>
                        <p class="small mb-0 opacity-50 text-uppercase">Km</p>
                    </div>
                    <div class="text-center p-3 bg-white bg-opacity-10 rounded-4" style="min-width: 100px;">
                        <h4 class="mb-0 fw-bold"><%= totalMin %></h4>
                        <p class="small mb-0 opacity-50 text-uppercase">Phút</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="container-site py-5">
    <div class="row g-5">
        <!-- Timeline Section -->
        <div class="col-lg-8">
            <h4 class="display-text mb-5"><i class="bi bi-list-ol text-primary me-2"></i> Lộ trình trải nghiệm</h4>
            
            <div class="journey-timeline">
                <% stops.forEach((stop, index) => { %>
                <div class="timeline-item mb-5 animate__animated animate__fadeInUp" style="animation-delay: <%= index * 0.1 %>s">
                    <div class="timeline-marker">
                        <div class="marker-dot"></div>
                        <% if (index < stops.length - 1) { %>
                            <div class="marker-line"></div>
                            <% 
                            const d = Model.haversine(stop.lat, stop.lng, stops[index+1].lat, stops[index+1].lng);
                            const km = Math.round((d / 1000) * 10) / 10;
                            %>
                            <div class="marker-distance badge bg-white text-muted border py-1 px-2 rounded-pill shadow-sm"><%= km %> km</div>
                        <% } %>
                    </div>
                    
                    <div class="card-bl p-0 overflow-hidden shadow-sm">
                        <div class="row g-0">
                            <div class="col-md-4">
                                <img src="<%= fixImg(stop.cover_image) %>" class="w-100 h-100 object-fit-cover" alt="<%= stop.name %>" style="min-height: 180px;">
                            </div>
                            <div class="col-md-8">
                                <div class="p-4">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <span class="badge bg-light text-primary border mb-1"><%= (stop.type || 'Tham quan').toUpperCase() %></span>
                                            <h5 class="fw-bold mb-1"><%= stop.name %></h5>
                                        </div>
                                        <div class="btn-group">
                                            <% if (index > 0) { %>
                                                <button class="btn btn-light btn-sm" onclick="updateStop('<%= journey.id %>', '<%= stop.destination_id %>', 'reorder', <%= index - 1 %>)" title="Lên"><i class="bi bi-chevron-up"></i></button>
                                            <% } %>
                                            <% if (index < stops.length - 1) { %>
                                                <button class="btn btn-light btn-sm" onclick="updateStop('<%= journey.id %>', '<%= stop.destination_id %>', 'reorder', <%= index + 1 %>)" title="Xuống"><i class="bi bi-chevron-down"></i></button>
                                            <% } %>
                                            <button class="btn btn-light btn-sm text-danger" onclick="if(confirm('Xóa chặng này?')) updateStop('<%= journey.id %>', '<%= stop.destination_id %>', 'remove')" title="Xóa"><i class="bi bi-trash"></i></button>
                                        </div>
                                    </div>
                                    <p class="small text-dark line-clamp-2 mb-3"><%= stop.short_desc || stop.story %></p>
                                    
                                    <div class="d-flex flex-wrap gap-2 mb-3">
                                        <span class="badge bg-soft-success text-success border border-success-subtle small"><i class="bi bi-clock me-1"></i>45-60 phút</span>
                                        <% if (stop.type === 'temple') { %>
                                            <span class="badge bg-soft-primary text-primary small"><i class="bi bi-activity me-1"></i>Viếng chùa, thiền định</span>
                                        <% } else if (stop.type === 'craft') { %>
                                            <span class="badge bg-soft-warning text-warning small"><i class="bi bi-hammer me-1"></i>Trải nghiệm làng nghề</span>
                                        <% } else { %>
                                            <span class="badge bg-soft-info text-info small"><i class="bi bi-camera me-1"></i>Ngắm cảnh, check-in</span>
                                        <% } %>
                                        
                                        <select class="form-select form-select-sm d-inline-block w-auto border-0 bg-light rounded-pill" style="font-size: 11px;" 
                                                onchange="updateStop('<%= journey.id %>', '<%= stop.destination_id %>', 'update_transport', 0, this.value)">
                                            <option value="cycling" <%= stop.transport === 'cycling' ? 'selected' : '' %>>🚲 Xe đạp</option>
                                            <option value="motorbike" <%= stop.transport === 'motorbike' ? 'selected' : '' %>>🛵 Xe máy</option>
                                            <option value="walking" <%= stop.transport === 'walking' ? 'selected' : '' %>>🚶 Đi bộ</option>
                                        </select>
                                    </div>

                                    <div class="d-flex gap-2">
                                        <a href="<%= baseUrl %>/explore/<%= stop.slug %>" class="btn btn-sm btn-outline-bl rounded-pill px-3">Chi tiết</a>
                                        <a href="<%= baseUrl %>/checkin?slug=<%= stop.slug %>" class="btn btn-sm btn-primary-bl rounded-pill px-3">Check-in</a>
                                        <a href="https://www.google.com/maps/dir/?api=1&destination=<%= stop.lat %>,<%= stop.lng %>" target="_blank" class="btn btn-sm btn-light border rounded-pill px-3">Chỉ đường</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <% if (index === 0 && stops.length > 2) { %>
                    <div class="alert bg-soft-secondary border-0 rounded-4 p-4 mb-5 d-flex align-items-center gap-4 animate__animated animate__fadeIn">
                        <div class="bg-white p-3 rounded-circle shadow-sm">
                            <i class="bi bi-cup-hot fs-2 text-secondary"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-1">Gợi ý nghỉ chân & Ăn nhẹ</h6>
                            <p class="small text-muted mb-0">Thưởng thức nước dừa tươi Bình Lợi và nghỉ ngơi 15 phút trước khi tiếp tục hành trình.</p>
                        </div>
                        <button class="btn btn-secondary btn-sm ms-auto rounded-pill px-3">Ghé ngay</button>
                    </div>
                <% } %>
                <% }) %>
            </div>
        </div>

        <!-- Sidebar Info -->
        <div class="col-lg-4">
            <div class="sticky-top" style="top: 100px;">
                <div class="card-bl p-4 mb-4 bg-dark text-white border-0 shadow-lg">
                    <h5 class="fw-bold mb-4">Gợi ý chuẩn bị</h5>
                    <ul class="list-unstyled mb-4" style="line-height: 2.2;">
                        <li><i class="bi bi-check2-circle text-secondary me-2"></i> Trang phục thoải mái, nhẹ nhàng.</li>
                        <li><i class="bi bi-check2-circle text-secondary me-2"></i> Mang theo sạc dự phòng cho điện thoại.</li>
                        <li><i class="bi bi-check2-circle text-secondary me-2"></i> Một chai nước cá nhân.</li>
                        <li><i class="bi bi-check2-circle text-secondary me-2"></i> Tinh thần sẵn sàng chữa lành.</li>
                    </ul>
                    <a href="<%= baseUrl %>/map" class="btn btn-secondary w-100 py-3 fw-bold rounded-3 text-dark">
                        <i class="bi bi-map-fill me-2"></i> Xem bản đồ tương tác
                    </a>
                </div>

                <div class="card-bl p-4 border-0 shadow-sm mb-4">
                    <h6 class="fw-bold mb-3">Thông số hành trình</h6>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Thời lượng dự kiến</span>
                        <span class="fw-bold small"><%= durationStr %> (<%= totalMin %> phút)</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Số điểm dừng</span>
                        <span class="fw-bold small"><%= stops.length %> điểm</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted small">Quãng đường</span>
                        <span class="fw-bold small text-success"><%= totalKm %> km</span>
                    </div>
                    <div class="d-grid mt-3">
                        <% 
                        let mapUrl = "https://www.google.com/maps/dir/";
                        stops.forEach(s => {
                            mapUrl += `${s.lat},${s.lng}/`;
                        });
                        %>
                        <a href="<%= mapUrl %>" target="_blank" class="btn btn-primary-bl w-100 rounded-pill">
                            <i class="bi bi-geo-alt-fill me-1"></i> Chỉ đường thực tế (Maps)
                        </a>
                    </div>
                    <hr>
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-bl btn-sm w-100 rounded-pill" onclick="alert('Đã lưu hành trình vào mục yêu thích!')"><i class="bi bi-heart me-1"></i> Lưu</button>
                        <button class="btn btn-outline-bl btn-sm w-100 rounded-pill" onclick="shareJourney()"><i class="bi bi-share me-1"></i> Chia sẻ</button>
                    </div>
                </div>

                <div class="card-bl p-4 border-0 shadow-sm bg-light">
                    <h6 class="fw-bold mb-3">Khám phá theo chủ đề</h6>
                    <div class="list-group list-group-flush bg-transparent">
                        <a href="<%= baseUrl %>/journey/preset/du-xuan" class="list-group-item list-group-item-action bg-transparent px-0 small border-0 py-2 text-primary fw-bold">🌸 Du xuân Bình Lợi</a>
                        <a href="<%= baseUrl %>/journey/preset/miet-vuon" class="list-group-item list-group-item-action bg-transparent px-0 small border-0 py-2 text-primary fw-bold">🥥 Miệt vườn giữa phố</a>
                        <a href="<%= baseUrl %>/journey/preset/tam-linh" class="list-group-item list-group-item-action bg-transparent px-0 small border-0 py-2 text-primary fw-bold">🧘 Tâm linh & Nguồn cội</a>
                        <a href="<%= baseUrl %>/journey/preset/song-cham" class="list-group-item list-group-item-action bg-transparent px-0 small border-0 py-2 text-primary fw-bold">🌿 Sống chậm Bình Lợi</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.journey-header {
    background: linear-gradient(135deg, #5c8a5e 0%, #4a6e4b 100%);
}
.fw-black { font-weight: 900; }
.journey-timeline {
    position: relative;
    padding-left: 50px;
}
.timeline-item {
    position: relative;
}
.timeline-marker {
    position: absolute;
    left: -50px;
    height: 100%;
    width: 30px;
    display: flex;
    flex-direction: column;
    align-items: center;
}
.marker-dot {
    width: 24px;
    height: 24px;
    background: #fff;
    border: 6px solid var(--color-primary);
    border-radius: 50%;
    z-index: 5;
    margin-top: 40px;
}
.marker-line {
    width: 4px;
    flex-grow: 1;
    background: rgba(92, 138, 94, 0.15);
    margin: 5px 0;
}
.marker-distance {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    white-space: nowrap;
    font-size: 10px;
    z-index: 10;
}
.line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    height: 3em;
}
@media (max-width: 768px) {
    .journey-timeline { padding-left: 30px; }
    .timeline-marker { left: -30px; }
    .marker-dot { width: 18px; height: 18px; border-width: 4px; }
}
</style>

<script>
async function updateStop(journeyId, destinationId, action, order = 0, transport = 'walking') {
    try {
        const response = await fetch('<%= baseUrl %>/api/journey/update-stop', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ journeyId, destinationId, action, order, transport })
        });
        const result = await response.json();
        if (result.success) {
            window.location.reload();
        } else {
            alert('Lỗi: ' + result.message);
        }
    } catch (e) {
        console.error(e);
        alert('Không thể kết nối máy chủ');
    }
}

function shareJourney() {
    const url = window.location.href;
    const text = "Khám phá hành trình <%= mood %> tại Bình Lợi Healing!";
    if (navigator.share) {
        navigator.share({ title: 'Bình Lợi Healing', text: text, url: url });
    } else {
        const tempInput = document.createElement('input');
        document.body.appendChild(tempInput);
        tempInput.value = url;
        tempInput.select();
        document.execCommand('copy');
        document.body.removeChild(tempInput);
        alert('Đã copy link hành trình!');
    }
}
</script>
