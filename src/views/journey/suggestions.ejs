<!-- Journey Suggestions — Chương 4.3 -->
<section class="py-5" style="margin-top: 80px;">
    <div class="container py-4">
        <div class="text-center mb-5 reveal-up">
            <span class="section-label">GỢI Ý LỘ TRÌNH</span>
            <h2 class="section-title">Hành trình dành riêng cho bạn</h2>
            <p class="section-desc mx-auto">Dựa trên sở thích của bạn, chúng tôi đề xuất 3 hành trình tối ưu nhất để trải nghiệm trọn vẹn Bình Lợi.</p>
        </div>

        <div class="row g-4">
            <% routes.forEach((route, i) => { %>
            <div class="col-lg-4 reveal-up">
                <div class="card-heal h-100">
                    <div class="card-img position-relative" style="height: 200px;">
                        <img src="<%= route.image %>" class="w-100 h-100 object-fit-cover">
                        <div class="position-absolute top-0 end-0 m-3">
                            <span class="badge-gold"><%= route.match_score %>% Phù hợp</span>
                        </div>
                    </div>
                    <div class="p-4">
                        <h5 class="fw-bold mb-3 font-display"><%= route.name %></h5>
                        <div class="d-flex flex-column gap-3 mb-4">
                            <% route.stops.forEach((stop, j) => { %>
                            <div class="d-flex gap-3 align-items-start">
                                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 24px; height: 24px; background: var(--primary-50); color: var(--primary); font-size: 0.7rem; font-weight: 700;">
                                    <%= j + 1 %>
                                </div>
                                <span style="font-size: 0.88rem; color: var(--text-secondary);"><%= stop.name %></span>
                            </div>
                            <% }) %>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mt-auto pt-3" style="border-top: 1px solid var(--border-light);">
                            <div class="text-muted small"><i class="bi bi-clock me-1"></i><%= route.duration %></div>
                            <a href="/journey/start?route=<%= route.id %>" class="btn btn-primary-bl btn-sm rounded-pill px-4">Bắt đầu ngay</a>
                        </div>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>
        
        <div class="text-center mt-5 reveal-up">
            <a href="/onboarding" class="text-muted text-decoration-none small"><i class="bi bi-arrow-left me-1"></i> Chọn lại sở thích của bạn</a>
        </div>
    </div>
</section>
