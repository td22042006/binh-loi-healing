<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

<style>
.sug-hero {
    background: linear-gradient(135deg, var(--primary-green-dark) 0%, var(--primary-green) 50%, #0c251a 100%);
    padding: 120px 0 70px;
    position: relative;
    overflow: hidden;
}
.sug-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 80% 50%, rgba(240,165,0,0.1) 0%, transparent 60%);
    pointer-events: none;
}
.sug-criteria-bar {
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 24px;
    padding: 24px;
    display: flex;
    gap: 20px;
    justify-content: space-around;
    flex-wrap: wrap;
    margin-top: 40px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
}
.sug-criteria-item {
    display: flex;
    align-items: center;
    gap: 12px;
    color: rgba(255, 255, 255, 0.95);
    font-size: 0.88rem;
    font-weight: 600;
}
.sug-criteria-icon {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.15rem;
    box-shadow: var(--shadow-sm);
}
.sug-section {
    background: var(--bg);
    padding: 70px 0;
    min-height: 60vh;
}
.sug-card {
    background: #ffffff;
    border-radius: 28px;
    overflow: hidden;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--border-light);
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    height: 100%;
    display: flex;
    flex-direction: column;
}
.sug-card:hover {
    transform: translateY(-10px);
    box-shadow: var(--shadow-xl);
    border-color: var(--primary-green-light);
}
.sug-card-img-wrap {
    position: relative;
    height: 220px;
    overflow: hidden;
}
.sug-card-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s var(--ease-out);
}
.sug-card:hover .sug-card-img-wrap img {
    transform: scale(1.1);
}
.sug-card-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.8) 0%, rgba(0, 0, 0, 0.2) 60%, transparent 100%);
}
.sug-card-img-bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20px;
}
.sug-recommended-badge {
    position: absolute;
    top: 16px;
    left: 16px;
    background: linear-gradient(135deg, var(--accent), var(--accent-dark));
    color: #fff;
    border-radius: var(--radius-full);
    padding: 6px 16px;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 1px;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 6px;
    box-shadow: 0 4px 12px rgba(240, 165, 0, 0.3);
    z-index: 2;
}
.sug-card-body {
    padding: 24px;
    flex: 1;
    display: flex;
    flex-direction: column;
}
.sug-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 16px;
}
.sug-tag {
    background: rgba(30, 90, 62, 0.06);
    border: 1px solid rgba(30, 90, 62, 0.15);
    color: var(--primary-green-light);
    border-radius: var(--radius-full);
    padding: 4px 14px;
    font-size: 0.72rem;
    font-weight: 700;
}
.sug-stops-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 22px;
}
.sug-stop-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.85rem;
    color: var(--text);
    font-weight: 550;
}
.sug-stop-num {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary-green), var(--primary-green-light));
    color: #fff;
    font-size: 0.7rem;
    font-weight: 900;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 2px 6px rgba(30, 90, 62, 0.25);
}
.sug-metrics {
    display: flex;
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 22px;
    background: var(--surface-alt);
}
.sug-metric {
    flex: 1;
    text-align: center;
    padding: 12px 8px;
    border-right: 1px solid var(--border);
    font-size: 0.75rem;
    color: var(--text-secondary);
    font-weight: 600;
}
.sug-metric:last-child {
    border-right: none;
}
.sug-metric .val {
    font-size: 1.15rem;
    font-weight: 900;
    color: var(--primary-green);
    display: block;
    margin-bottom: 2px;
}
.btn-sug-primary {
    width: 100%;
    padding: 14px;
    border-radius: var(--radius-full);
    border: none;
    background: linear-gradient(135deg, var(--primary-green) 0%, var(--primary-green-light) 100%);
    color: #fff;
    font-weight: 800;
    font-size: 0.88rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s;
    box-shadow: 0 4px 16px rgba(30, 90, 62, 0.3);
}
.btn-sug-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(30, 90, 62, 0.45);
}
.btn-sug-outline {
    width: 100%;
    padding: 14px;
    border-radius: var(--radius-full);
    border: 2px solid var(--primary-green);
    background: transparent;
    color: var(--primary-green);
    font-weight: 800;
    font-size: 0.88rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s;
}
.btn-sug-outline:hover {
    background: var(--primary-green);
    color: #fff;
    box-shadow: 0 4px 12px rgba(30, 90, 62, 0.2);
}
</style>

<!-- Hero -->
<div class="sug-hero">
    <div class="container position-relative" style="z-index:1;">
        <div class="text-center">
            <div style="display:inline-flex;align-items:center;justify-content:center;width:64px;height:64px;border-radius:20px;background:rgba(255,255,255,0.08);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,0.18);margin-bottom:20px;">
                <i class="bi bi-compass-fill" style="font-size:1.8rem;color:var(--accent);"></i>
            </div>
            <h1 style="color:#fff;font-family: var(--font-display);font-size:clamp(2rem,4.5vw,2.8rem);font-weight:900;margin-bottom:12px;letter-spacing:-0.03em;">
                Đề Xuất Hành Trình & Tour Tối Ưu
            </h1>
            <p style="color:rgba(255,255,255,0.75);max-width:580px;margin:0 auto;font-size:1rem;line-height:1.75;">
                Dựa trên sở thích cá nhân, hệ thống đã chuẩn bị <strong style="color:var(--accent);"><%= suggestions.length %> lộ trình</strong> đặc biệt dành riêng cho bạn khám phá Bình Lợi.
            </p>

            <!-- Criteria bar -->
            <div class="sug-criteria-bar mx-auto" style="max-width:760px;">
                <div class="sug-criteria-item">
                    <span class="sug-criteria-icon">🌸</span>
                    <div>
                        <div style="font-size:0.65rem;color:rgba(255,255,255,0.6);text-transform:uppercase;letter-spacing:1px;font-weight:700;margin-bottom:2px;">Tâm trạng</div>
                        <div style="font-size:0.85rem;"><%= session.mood ? session.mood.replace(/,/g,' & ').toUpperCase() : 'CHỮA LÀNH' %></div>
                    </div>
                </div>
                <div class="sug-criteria-item">
                    <span class="sug-criteria-icon">👥</span>
                    <div>
                        <div style="font-size:0.65rem;color:rgba(255,255,255,0.6);text-transform:uppercase;letter-spacing:1px;font-weight:700;margin-bottom:2px;">Quy mô</div>
                        <div style="font-size:0.85rem;"><%= session.pax || 1 %> Người</div>
                    </div>
                </div>
                <div class="sug-criteria-item">
                    <span class="sug-criteria-icon">💰</span>
                    <div>
                        <div style="font-size:0.65rem;color:rgba(255,255,255,0.6);text-transform:uppercase;letter-spacing:1px;font-weight:700;margin-bottom:2px;">Ngân sách</div>
                        <div style="font-size:0.85rem;"><%= session.budget === 'low' ? 'Tiết kiệm' : (session.budget === 'high' ? 'Cao cấp' : 'Tiêu chuẩn') %></div>
                    </div>
                </div>
                <div class="sug-criteria-item">
                    <span class="sug-criteria-icon">🌤️</span>
                    <div>
                        <div style="font-size:0.65rem;color:rgba(255,255,255,0.6);text-transform:uppercase;letter-spacing:1px;font-weight:700;margin-bottom:2px;">Thời điểm</div>
                        <div style="font-size:0.85rem;"><%= session.season === 'spring' ? 'Lễ hội 🌸' : (session.season === 'summer' ? 'Mùa hè ☀️' : 'Hôm nay') %></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Cards -->
<section class="sug-section">
    <div class="container">
        <div class="row g-4 justify-content-center sug-cards-wrap">
            <% suggestions.forEach((sug, i) => { %>
            <div class="col-md-6 col-lg-4 sug-reveal" style="opacity:0;transform:translateY(40px);">
                <div class="sug-card">
                    <!-- Image -->
                    <div class="sug-card-img-wrap">
                        <img src="<%= (sug.stops && sug.stops[0] && sug.stops[0].cover_image) ? (sug.stops[0].cover_image.startsWith('http') || sug.stops[0].cover_image.startsWith('data:') ? sug.stops[0].cover_image : sug.stops[0].cover_image.replace(/^public\//, '/')) : '/images/placeholder.png' %>" alt="<%= sug.name %>" onerror="this.src='/images/placeholder.png'">
                        <div class="sug-card-img-overlay"></div>
                        <% if (i === 0) { %>
                        <div class="sug-recommended-badge"><i class="bi bi-star-fill"></i> Đề xuất tốt nhất</div>
                        <% } %>
                        <div class="sug-card-img-bottom">
                            <h4 style="color:#fff;font-family: var(--font-display);font-weight:900;margin:0;text-shadow:0 2px 8px rgba(0,0,0,0.5);font-size:1.25rem;"><%= sug.name %></h4>
                        </div>
                    </div>

                    <!-- Body -->
                    <div class="sug-card-body">
                        <!-- Tags -->
                        <div class="sug-tags">
                            <% sug.tags.forEach(tag => { %>
                            <span class="sug-tag"><%= tag %></span>
                            <% }) %>
                        </div>

                        <!-- Desc -->
                        <p style="font-size:0.85rem;color:var(--text-secondary);line-height:1.7;margin-bottom:20px;"><%= sug.desc %></p>

                        <!-- Stops list -->
                        <% if (sug.stops && sug.stops.length > 0) { %>
                        <div class="sug-stops-list">
                            <% sug.stops.slice(0, 3).forEach((stop, si) => { %>
                            <div class="sug-stop-item">
                                <span class="sug-stop-num"><%= si + 1 %></span>
                                <span class="text-dark"><%= stop.name %></span>
                                <% if (stop.type) { %><span class="badge bg-light text-primary-green border small py-1" style="font-size: 0.65rem;"><%= stop.type %></span><% } %>
                            </div>
                            <% }) %>
                            <% if (sug.stops.length > 3) { %>
                            <div style="font-size:0.75rem;color:var(--text-muted);padding-left:36px;font-style:italic;">+ <%= sug.stops.length - 3 %> địa điểm khác…</div>
                            <% } %>
                        </div>
                        <% } %>

                        <!-- Metrics -->
                        <div class="sug-metrics">
                            <div class="sug-metric">
                                <span class="val"><%= sug.stops.length %></span>
                                <i class="bi bi-geo-alt-fill text-success"></i> Điểm đến
                            </div>
                            <div class="sug-metric">
                                <span class="val"><%= sug.duration %></span>
                                <i class="bi bi-clock-fill text-warning"></i> Thời gian
                            </div>
                            <div class="sug-metric">
                                <span class="val"><%= sug.km %></span>
                                <i class="bi bi-signpost-split-fill text-info"></i> Quãng đường
                            </div>
                        </div>

                        <!-- CTA -->
                        <div class="mt-auto">
                            <form action="/journey/confirm" method="POST">
                                <input type="hidden" name="journeyData" value='<%= JSON.stringify(sug).replace(/'/g, "&#39;") %>'>
                                <button type="submit" class="<%= i === 0 ? 'btn-sug-primary' : 'btn-sug-outline' %>">
                                    Khám phá lộ trình này <i class="bi bi-arrow-right ms-1"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>

        <!-- Back link -->
        <div class="text-center mt-5">
            <a href="/onboarding" style="color:var(--text-secondary);font-weight:700;font-size:0.9rem;text-decoration:none;" class="transition-all" onmouseover="this.style.color='var(--primary-green)'" onmouseout="this.style.color='var(--text-secondary)'">
                <i class="bi bi-arrow-left me-2"></i>Thay đổi tiêu chí tìm kiếm
            </a>
        </div>
    </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const cards = document.querySelectorAll('.sug-reveal');
    gsap.to(cards, {
        opacity: 1,
        y: 0,
        stagger: 0.15,
        duration: 0.7,
        ease: 'power3.out',
        delay: 0.2
    });
});
</script>
