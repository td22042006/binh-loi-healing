<aside class="sidebar-main">
    <div class="p-4 mb-4 text-center">
        <a class="text-decoration-none" href="/">
            <img src="/images/logo.png" alt="Logo" style="height: 50px; filter: brightness(10);">
            <div class="mt-2">
                <span class="d-block fw-black lh-1 text-white" style="font-size: 1.2rem; letter-spacing: 1px;">BÌNH LỢI</span>
                <span class="d-block" style="font-size: 0.6rem; color: var(--accent-gold); letter-spacing: 2px; font-weight: 800;">HEALING PLATFORM</span>
            </div>
        </a>
    </div>

    <div class="flex-grow-1 overflow-auto custom-scrollbar">
        <!-- FEATURED: JOURNEY -->
        <div class="px-4 mb-3 small text-white opacity-50 text-uppercase tracking-widest fw-bold" style="font-size: 0.65rem;">HÀNH TRÌNH CỦA BẠN</div>
        <nav class="d-flex flex-column mb-4">
            <a href="/journey" class="nav-item-platform active">
                <i class="bi bi-compass-fill"></i> Lộ trình Chữa lành
            </a>
            <a href="/onboarding" class="nav-item-platform">
                <i class="bi bi-stars"></i> Chọn Vibe mới
            </a>
            <a href="/map" class="nav-item-platform">
                <i class="bi bi-map-fill"></i> Bản đồ Tương tác
            </a>
        </nav>

        <div class="px-4 mb-3 small text-white opacity-50 text-uppercase tracking-widest fw-bold" style="font-size: 0.65rem;">KHÁM PHÁ & TRẢI NGHIỆM</div>
        <nav class="d-flex flex-column mb-4">
            <a href="/explore" class="nav-item-platform">
                <i class="bi bi-geo-alt-fill"></i> Điểm đến Storytelling
            </a>
            <a href="/workshops" class="nav-item-platform">
                <i class="bi bi-palette-fill"></i> Workshop Nghệ nhân
            </a>
            <a href="/market" class="nav-item-platform">
                <i class="bi bi-shop"></i> Chợ OCOP Bản địa
            </a>
            <a href="/festivals" class="nav-item-platform">
                <i class="bi bi-calendar-event-fill"></i> Lễ hội & Sự kiện
            </a>
        </nav>

        <div class="px-4 mb-3 small text-white opacity-50 text-uppercase tracking-widest fw-bold" style="font-size: 0.65rem;">HỆ THỐNG</div>
        <nav class="d-flex flex-column">
            <% if (user && user.role === 'admin') { %>
                <a href="/admin/users" class="nav-item-platform">
                    <i class="bi bi-people-fill"></i> Quản lý người dùng
                </a>
                <a href="/admin/reviews" class="nav-item-platform">
                    <i class="bi bi-chat-quote-fill"></i> Duyệt đánh giá
                </a>
                <a href="/admin/settings" class="nav-item-platform">
                    <i class="bi bi-gear-fill"></i> Cấu hình hệ thống
                </a>
                <a href="/admin/products" class="nav-item-platform">
                    <i class="bi bi-box-seam-fill"></i> Quản lý sản phẩm
                </a>
            <% } %>
            <% if (user && (user.role === 'admin' || user.role === 'manager')) { %>
                <a href="/manager" class="nav-item-platform">
                    <i class="bi bi-speedometer2"></i> Trang quản lý địa điểm
                </a>
            <% } %>
            <a href="/chat" class="nav-item-platform">
                <i class="bi bi-chat-dots-fill"></i> Nhóm thảo luận
            </a>
        </nav>
    </div>

    <% if (user) { %>
    <div class="p-3 mt-auto">
        <div class="glass-item p-3 text-white text-center">
            <div class="fw-bold mb-1" style="font-size: 0.75rem; color: var(--accent-gold);">LEVEL <%= Math.floor((user.total_points || 0) / 100) + 1 %></div>
            <div class="progress rounded-pill mb-3" style="height: 4px; background: rgba(255,255,255,0.1);">
                <div class="progress-bar bg-warning" style="width: <%= (user.total_points % 100) %>%"></div>
            </div>
            <div class="d-flex align-items-center gap-2 text-start">
                <img src="<%= user.avatar || '/images/default-avatar.png' %>" class="rounded-circle" style="width: 32px; height: 32px; object-fit: cover;">
                <div class="overflow-hidden">
                    <span class="d-block fw-bold line-clamp-1 x-small"><%= user.full_name %></span>
                    <a href="/auth/logout" class="text-white opacity-50 x-small text-decoration-none">Đăng xuất</a>
                </div>
            </div>
        </div>
    </div>
    <% } %>
</aside>
