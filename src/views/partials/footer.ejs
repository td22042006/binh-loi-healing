<footer class="footer-main py-5" style="background: #922724; color: rgba(255,255,255,0.8); font-size: 0.88rem; border-top: 1px solid rgba(255,255,255,0.1);">
    <div class="container">
        <div class="row g-5">
            <!-- Brand Column -->
            <div class="col-lg-4">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <img src="<%= fixImg(settings.brand_logo, '/images/logo.png') %>" alt="Logo" style="height: 40px; filter: brightness(0) invert(1);" onerror="this.src='/images/logo.png'">
                    <div class="d-flex flex-column justify-content-center">
                        <span class="d-block fw-black lh-1" style="font-family: 'Inter', sans-serif; font-size: 1.25rem; font-weight: 900; letter-spacing: 0.5px; color: #ffffff;"><%= settings.brand_name || 'BÌNH LỢI' %></span>
                        <span class="d-block" style="font-family: 'Inter', sans-serif; font-size: 0.75rem; color: rgba(255,255,255,0.85); font-weight: 600; margin-top: 5px; letter-spacing: 0.5px; line-height: 1; font-style: italic;"><%= settings.brand_subtext || 'Chạm vào bình yên' %></span>
                    </div>
                </div>
                <p class="mb-4" style="line-height: 1.8; max-width: 320px; color: rgba(255,255,255,0.75);">
                    <%= settings.site_description || '"Bình từ tâm, Lợi từ tầm" - Hệ sinh thái du lịch chữa lành và văn hóa số thông minh tại cửa ngõ TP.HCM, mang đến trải nghiệm thiên nhiên độc bản.' %>
                </p>
                <div class="d-flex gap-2">
                    <a href="<%= settings.social_tiktok || '#' %>" target="_blank" class="footer-social-btn" title="TikTok"><i class="bi bi-tiktok"></i></a>
                    <a href="<%= settings.social_facebook || '#' %>" target="_blank" class="footer-social-btn" title="Facebook"><i class="bi bi-facebook"></i></a>
                    <a href="<%= settings.social_instagram || '#' %>" target="_blank" class="footer-social-btn" title="Instagram"><i class="bi bi-instagram"></i></a>
                </div>
            </div>

            <!-- Quick Links -->
            <div class="col-6 col-lg-2">
                <h6 class="fw-bold mb-3 text-uppercase tracking-widest" style="font-size: 0.8rem; color: #ffffff;">Khám phá</h6>
                <ul class="list-unstyled d-flex flex-column gap-2">
                    <li><a href="/explore" class="footer-link-premium">Điểm đến</a></li>
                    <li><a href="/workshops" class="footer-link-premium">Lớp Workshop</a></li>
                    <li><a href="/onboarding" class="footer-link-premium">Tạo hành trình AI</a></li>
                    <li><a href="/map" class="footer-link-premium">Bản đồ số</a></li>
                </ul>
            </div>

            <!-- Community & Social -->
            <div class="col-6 col-lg-3">
                <h6 class="fw-bold mb-3 text-uppercase tracking-widest" style="font-size: 0.8rem; color: #ffffff;">Cộng đồng</h6>
                <ul class="list-unstyled d-flex flex-column gap-2">
                    <li><a href="/reviews" class="footer-link-premium">Chia sẻ Check-in</a></li>
                    <li><a href="/checkin" class="footer-link-premium">Quét mã QR Code</a></li>
                    <% if (locals.user && locals.user.role === 'user') { %>
                        <li><a href="/passport" class="footer-link-premium">Hồ sơ du khách</a></li>
                        <li><a href="/passport" class="footer-link-premium">Đổi điểm thưởng</a></li>
                    <% } else if (!locals.user) { %>
                        <li><a href="/passport" class="footer-link-premium">Hồ sơ du khách</a></li>
                        <li><a href="/passport" class="footer-link-premium">Đổi điểm thưởng</a></li>
                    <% } %>
                </ul>
            </div>

            <!-- Contact -->
            <div class="col-lg-3">
                <h6 class="fw-bold mb-3 text-uppercase tracking-widest" style="font-size: 0.8rem; color: #ffffff;">Liên hệ với chúng tôi</h6>
                <ul class="list-unstyled d-flex flex-column gap-3" style="color: rgba(255,255,255,0.75);">
                    <li class="d-flex gap-2">
                        <i class="bi bi-geo-alt text-white" style="margin-top: 2px;"></i>
                        <span>Xã Bình Lợi, Huyện Bình Chánh,<br>TP. Hồ Chí Minh</span>
                    </li>
                    <li class="d-flex gap-2">
                        <i class="bi bi-telephone text-white"></i>
                        <span><%= settings.contact_phone || '(028) 3765 0xxx' %></span>
                    </li>
                    <li class="d-flex gap-2">
                        <i class="bi bi-envelope text-white"></i>
                        <span><%= settings.contact_email || 'contact@binhloi-healing.vn' %></span>
                    </li>
                </ul>
            </div>
        </div>

        <hr class="my-4" style="border-color: rgba(255,255,255,0.15);">

        <!-- Bottom Copyright -->
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3" style="color: rgba(255,255,255,0.6); font-size: 0.8rem;">
            <span>© <%= new Date().getFullYear() %> Bình Lợi Healing. Mọi quyền được bảo lưu.</span>
            <span>Đồng hành chiến lược bởi <span class="fw-bold" style="color: #ffffff;">LOMAR 2026</span></span>
        </div>
    </div>
</footer>

<style>
    .footer-social-btn {
        width: 38px; height: 38px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.08);
        color: #ffffff;
        display: flex; align-items: center; justify-content: center;
        transition: all 0.3s ease;
        font-size: 1rem;
        text-decoration: none;
    }
    .footer-social-btn:hover {
        background: #ffffff;
        color: var(--primary) !important;
        transform: translateY(-3px);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
    }
    .footer-link-premium {
        color: rgba(255, 255, 255, 0.75);
        text-decoration: none;
        transition: all 0.2s ease;
    }
    .footer-link-premium:hover {
        color: #ffffff !important;
        padding-left: 4px;
    }
    .tracking-widest { letter-spacing: 1.5px !important; }
</style>
