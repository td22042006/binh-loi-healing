<footer class="footer-red">
    <div class="container">
        <div class="row g-5">
            <!-- Brand Column -->
            <div class="col-lg-4">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <img src="/images/logo.png" alt="Logo" style="height: 42px; filter: brightness(10);" onerror="this.style.display='none'">
                    <div>
                        <span class="footer-brand-name d-block lh-1">BÌNH LỢI</span>
                        <span class="footer-brand-sub d-block">Chạm vào bình yên</span>
                    </div>
                </div>
                <p class="footer-desc mb-4">
                    "Bình từ tâm, Lợi từ tầm" – Hệ sinh thái du lịch chữa lành và văn hóa số thông minh tại cửa ngõ TP.HCM.
                </p>
                <div class="d-flex gap-2">
                    <a href="https://www.facebook.com/xabinhloitphcm" target="_blank" class="footer-social"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="footer-social"><i class="bi bi-youtube"></i></a>
                    <a href="#" class="footer-social"><i class="bi bi-tiktok"></i></a>
                    <a href="#" class="footer-social"><i class="bi bi-instagram"></i></a>
                </div>
            </div>

            <!-- Khám phá -->
            <div class="col-6 col-lg-2">
                <h6>KHÁM PHÁ</h6>
                <a href="/explore" class="footer-link">Điểm đến</a>
                <a href="/workshops" class="footer-link">Lớp Workshop</a>
                <a href="/map" class="footer-link">Bản đồ số</a>
                <a href="/journey" class="footer-link">Hành trình</a>
                <a href="/festivals" class="footer-link">Lễ hội</a>
            </div>

            <!-- Hỗ trợ -->
            <div class="col-6 col-lg-2">
                <h6>HỖ TRỢ</h6>
                <a href="/reviews" class="footer-link">Cộng đồng</a>
                <a href="/checkin" class="footer-link">Quét mã QR</a>
                <% if (locals.user && locals.user.role === 'user') { %>
                <a href="/profile" class="footer-link">Hồ sơ du khách</a>
                <a href="/profile/rewards" class="footer-link">Đổi điểm thưởng</a>
                <% } else if (!locals.user) { %>
                <a href="/passport" class="footer-link">Hồ sơ du khách</a>
                <a href="/passport" class="footer-link">Đổi điểm thưởng</a>
                <% } %>
            </div>

            <!-- Newsletter -->
            <div class="col-lg-4">
                <h6>ĐĂNG KÝ NHẬN TIN</h6>
                <p style="color: rgba(255,255,255,0.55); font-size: 0.82rem; line-height: 1.6; margin-bottom: 16px;">Nhận thông tin sự kiện, workshop mới nhất từ Bình Lợi.</p>
                <div class="d-flex gap-2">
                    <input type="email" class="footer-newsletter-input" placeholder="Email của bạn...">
                    <button class="footer-newsletter-btn" type="button"><i class="bi bi-arrow-right"></i></button>
                </div>
                <div class="mt-4 pt-3" style="border-top: 1px solid rgba(255,255,255,0.1);">
                    <div class="d-flex gap-2 align-items-start" style="color: rgba(255,255,255,0.5); font-size: 0.8rem;">
                        <i class="bi bi-geo-alt" style="margin-top: 2px;"></i>
                        <span>Xã Bình Lợi, Huyện Bình Chánh, TP.HCM</span>
                    </div>
                    <div class="d-flex gap-2 align-items-center mt-2" style="color: rgba(255,255,255,0.5); font-size: 0.8rem;">
                        <i class="bi bi-telephone"></i>
                        <span>(028) 3765 0xxx</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bottom Copyright -->
        <div class="footer-bottom d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            <span>© <%= new Date().getFullYear() %> Bình Lợi Healing. Mọi quyền được bảo lưu.</span>
            <span>Đồng hành chiến lược bởi <span style="color: #fff; font-weight: 700;">LOMAR 2026</span></span>
        </div>
    </div>
</footer>
