<header class="header-main px-4">
    <div class="d-flex justify-content-between align-items-center w-100 h-100">
        <!-- Page Context -->
        <div class="d-none d-xl-block" style="min-width: 150px;">
            <h5 class="fw-black mb-0 font-display" id="platform-page-title" style="color: var(--primary);">Hành trình Chữa lành</h5>
            <span class="text-muted x-small fw-bold">Bình Lợi, TP.HCM</span>
        </div>

        <!-- JOURNEY TRACKER (THE HEART) -->
        <div class="flex-grow-1 mx-4 d-none d-md-block">
            <div class="journey-timeline-bar py-2 px-4 mb-0">
                <div class="d-flex align-items-center gap-2 me-3">
                    <i class="bi bi-geo-alt-fill text-danger fs-5"></i>
                    <span class="fw-black x-small text-uppercase tracking-widest" style="color: var(--primary);">Lộ trình:</span>
                </div>
                <div class="d-flex align-items-center flex-grow-1 justify-content-between position-relative px-2">
                    <div class="position-absolute top-50 start-0 w-100 bg-light" style="height: 2px; z-index: 1; transform: translateY(-50%);"></div>
                    
                    <!-- Journey Steps -->
                    <% 
                        // Mock stops if no journey, usually passed from controller
                        const mockStops = ['Khởi đầu', 'Làng nghề', 'Thiên nhiên', 'Kết thúc'];
                        mockStops.forEach((stop, i) => { 
                    %>
                    <div class="position-relative" style="z-index: 5;">
                        <div class="rounded-circle d-flex align-items-center justify-content-center transition-all" 
                             style="width: 24px; height: 24px; background: <%= i === 0 ? 'var(--primary)' : 'white' %>; border: 2px solid <%= i === 0 ? 'var(--primary)' : '#e2e8f0' %>; color: <%= i === 0 ? 'white' : '#cbd5e1' %>; font-size: 0.65rem; font-weight: 800;">
                            <%= i + 1 %>
                        </div>
                        <span class="position-absolute start-50 translate-middle-x mt-1 fw-bold text-nowrap <%= i === 0 ? 'text-primary' : 'text-muted opacity-50' %>" style="font-size: 0.55rem; top: 100%;"><%= stop %></span>
                    </div>
                    <% }) %>
                </div>
            </div>
        </div>

        <!-- USER STATS & ACTIONS -->
        <div class="d-flex align-items-center gap-3">
            <% if (user) { %>
            <!-- Points Badge -->
            <div class="p-1 pe-3 rounded-pill d-flex align-items-center gap-2" style="background: var(--grad-gold); color: #000; box-shadow: 0 4px 12px rgba(255, 152, 0, 0.2);">
                <div class="bg-white rounded-circle d-flex align-items-center justify-content-center" style="width: 28px; height: 28px;">
                    <i class="bi bi-lightning-charge-fill" style="color: var(--accent);"></i>
                </div>
                <span class="fw-black" style="font-size: 0.8rem;"><%= user.total_points || 0 %> XP</span>
            </div>

            <div class="d-flex gap-2">
                <!-- Cart Icon -->
                <a href="/cart" class="btn btn-light rounded-circle shadow-sm position-relative d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                    <i class="bi bi-bag-heart text-primary"></i>
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-white" style="font-size: 0.55rem; padding: 3px 6px;">0</span>
                </a>
                
                <!-- Notif Icon -->
                <button class="btn btn-light rounded-circle shadow-sm position-relative d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                    <i class="bi bi-bell text-primary"></i>
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-white" style="font-size: 0.55rem; padding: 3px 6px;">3</span>
                </button>
            </div>
            <% } else { %>
            <a href="/auth/login" class="btn btn-premium rounded-pill px-4 btn-sm">Tham gia ngay</a>
            <% } %>
        </div>
    </div>
</header>
