<!-- Media Library Modal — Chương 7: Quản lý Hình ảnh -->
<div class="modal fade" id="mediaLibraryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content glass-card border-0">
            <div class="modal-header border-bottom border-light p-4">
                <h5 class="modal-title fw-black font-display"><i class="bi bi-images me-2"></i>Thư viện Hình ảnh</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <div class="modal-body p-0">
                <div class="d-flex" style="height: 70vh;">
                    <!-- Sidebar: Tabs & Categories -->
                    <div class="border-end border-light bg-light bg-opacity-10 p-3" style="width: 200px;">
                        <div class="nav flex-column nav-pills" id="media-tabs" role="tablist">
                            <button class="nav-link active text-start mb-2" data-bs-toggle="pill" data-bs-target="#tab-library">
                                <i class="bi bi-collection me-2"></i>Thư viện
                            </button>
                            <button class="nav-link text-start mb-2" data-bs-toggle="pill" data-bs-target="#tab-upload">
                                <i class="bi bi-cloud-upload me-2"></i>Tải lên
                            </button>
                        </div>
                    </div>
                    
                    <!-- Content Area -->
                    <div class="flex-grow-1 p-4 overflow-auto">
                        <div class="tab-content h-100">
                            <!-- Library Tab -->
                            <div class="tab-pane fade show active h-100" id="tab-library">
                                <div class="d-flex justify-content-between mb-4">
                                    <div class="input-group" style="max-width: 300px;">
                                        <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-search"></i></span>
                                        <input type="text" id="mediaSearch" class="form-control border-start-0" placeholder="Tìm kiếm ảnh...">
                                    </div>
                                    <button class="btn btn-sm btn-outline-secondary" onclick="loadMediaLibrary()">
                                        <i class="bi bi-arrow-clockwise"></i> Làm mới
                                    </button>
                                </div>
                                
                                <div class="row g-3" id="mediaGrid">
                                    <!-- Images will be loaded here via JS -->
                                    <div class="col-12 text-center py-5 opacity-50">
                                        <div class="spinner-border spinner-border-sm mb-3"></div>
                                        <p>Đang tải thư viện...</p>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Upload Tab -->
                            <div class="tab-pane fade h-100" id="tab-upload">
                                <div class="d-flex flex-column align-items-center justify-content-center h-100 border-2 border-dashed rounded-4 p-5" 
                                     id="dropZone" style="border-color: rgba(var(--primary-rgb), 0.3); background: rgba(var(--primary-rgb), 0.05);">
                                    <i class="bi bi-cloud-arrow-up display-1 text-primary mb-4"></i>
                                    <h4 class="fw-bold">Kéo và thả ảnh vào đây</h4>
                                    <p class="text-muted">Hoặc nhấn vào nút bên dưới để chọn file</p>
                                    <input type="file" id="mediaFileInput" class="d-none" accept="image/*">
                                    <button class="btn btn-premium px-5 py-3 rounded-pill" onclick="document.getElementById('mediaFileInput').click()">
                                        CHỌN FILE TỪ MÁY TÍNH
                                    </button>
                                    <p class="small text-muted mt-3">Hỗ trợ JPG, PNG, WEBP (Tối đa 5MB)</p>
                                    
                                    <div id="uploadProgress" class="w-100 mt-4 d-none">
                                        <div class="progress" style="height: 10px;">
                                            <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 0%"></div>
                                        </div>
                                        <p class="text-center mt-2 small" id="uploadStatus">Đang tải lên...</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="modal-footer border-top border-light p-3">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Đóng</button>
                <button type="button" class="btn btn-primary rounded-pill px-5 fw-bold d-none" id="btnConfirmSelection">
                    CHỌN ẢNH <i class="bi bi-check2-circle ms-2"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .media-item { cursor: pointer; transition: all 0.2s; position: relative; }
    .media-item:hover { transform: translateY(-5px); }
    .media-item.selected { outline: 3px solid var(--primary); border-radius: 12px; }
    .media-item.selected::after {
        content: '\F272';
        font-family: 'bootstrap-icons';
        position: absolute;
        top: 10px;
        right: 10px;
        background: var(--primary);
        color: white;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
    }
</style>

<script>
    let currentTargetInput = null;
    let selectedImageUrl = null;

    // Open Library from outside
    function openMediaLibrary(inputName) {
        currentTargetInput = inputName;
        selectedImageUrl = null;
        document.getElementById('btnConfirmSelection').classList.add('d-none');
        const modal = new bootstrap.Modal(document.getElementById('mediaLibraryModal'));
        modal.show();
        loadMediaLibrary();
    }

    // Load from API
    async function loadMediaLibrary() {
        const grid = document.getElementById('mediaGrid');
        try {
            const res = await axios.get('/api/admin/media');
            if (res.data.success) {
                renderMediaGrid(res.data.data);
            }
        } catch (e) {
            grid.innerHTML = `<div class="col-12 text-center text-danger">Lỗi khi tải dữ liệu: ${e.message}</div>`;
        }
    }

    function renderMediaGrid(items) {
        const grid = document.getElementById('mediaGrid');
        if (items.length === 0) {
            grid.innerHTML = `<div class="col-12 text-center py-5 opacity-50"><i class="bi bi-inbox display-4 mb-3 d-block"></i>Chưa có ảnh nào được tải lên</div>`;
            return;
        }

        grid.innerHTML = items.map(item => `
            <div class="col-md-3 col-6">
                <div class="media-item card overflow-hidden border-0 shadow-sm rounded-4" onclick="selectMedia(this, '${item.url}')">
                    <img src="${item.url}" class="card-img-top" style="height: 140px; object-fit: cover;" alt="${item.original_name}">
                    <div class="card-body p-2">
                        <p class="small text-truncate mb-0 fw-bold">${item.original_name}</p>
                        <span class="text-muted" style="font-size: 10px;">${(item.size / 1024).toFixed(1)} KB</span>
                    </div>
                </div>
            </div>
        `).join('');
    }

    function selectMedia(el, url) {
        document.querySelectorAll('.media-item').forEach(i => i.classList.remove('selected'));
        el.classList.add('selected');
        selectedImageUrl = url;
        document.getElementById('btnConfirmSelection').classList.remove('d-none');
    }

    // Confirm selection
    document.getElementById('btnConfirmSelection').addEventListener('click', () => {
        if (selectedImageUrl && currentTargetInput) {
            const input = document.querySelector(`input[name="${currentTargetInput}"]`);
            if (input) {
                input.value = selectedImageUrl;
                // Trigger preview if exists
                if (typeof previewMedia === 'function') previewMedia(currentTargetInput);
            }
            bootstrap.Modal.getInstance(document.getElementById('mediaLibraryModal')).hide();
        }
    });

    // Upload logic
    document.getElementById('mediaFileInput').addEventListener('change', async (e) => {
        const file = e.target.files[0];
        if (!file) return;

        const formData = new FormData();
        formData.append('file', file);
        
        const progress = document.getElementById('uploadProgress');
        const bar = progress.querySelector('.progress-bar');
        const status = document.getElementById('uploadStatus');

        progress.classList.remove('d-none');
        bar.style.width = '0%';
        status.innerText = 'Đang chuẩn bị...';

        try {
            const res = await axios.post('/api/admin/upload', formData, {
                onUploadProgress: (progressEvent) => {
                    const percentCompleted = Math.round((progressEvent.loaded * 100) / progressEvent.total);
                    bar.style.width = percentCompleted + '%';
                    status.innerText = `Đang tải lên: ${percentCompleted}%`;
                }
            });

            if (res.data.success) {
                status.innerText = 'Tải lên thành công!';
                setTimeout(() => {
                    progress.classList.add('d-none');
                    // Switch to library tab and reload
                    const tabTrigger = new bootstrap.Tab(document.querySelector('#media-tabs button[data-bs-target="#tab-library"]'));
                    tabTrigger.show();
                    loadMediaLibrary();
                }, 1000);
            }
        } catch (e) {
            status.innerHTML = `<span class="text-danger">Lỗi: ${e.response?.data?.message || e.message}</span>`;
            bar.classList.add('bg-danger');
        }
    });
</script>
