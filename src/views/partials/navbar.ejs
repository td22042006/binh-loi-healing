<nav class="navbar navbar-expand-lg navbar-premium fixed-top">
    <div class="container position-relative">
        <!-- Mobile: Hamburger LEFT -->
        <button class="navbar-toggler border-0 shadow-none p-0 d-lg-none" type="button"
                data-bs-toggle="offcanvas" data-bs-target="#mobileMenu"
                aria-controls="mobileMenu" aria-label="Menu" style="z-index: 10;">
            <div class="nav-hamburger">
                <span></span><span></span><span></span>
            </div>
        </button>

        <!-- PWA Standalone Back Button (only shown on PWA when not on homepage) -->
        <button id="pwaBackButton" class="btn border-0 p-0 d-none" onclick="window.history.back()" style="z-index: 10; width: 30px; height: 30px; align-items: center; justify-content: center; position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--primary);">
            <i class="bi bi-chevron-left fs-3 fw-bold"></i>
        </button>

        <!-- Brand -->
        <a class="navbar-brand d-flex align-items-center gap-2 mx-auto mx-lg-0" href="/">
            <img src="<%= fixImg(settings.brand_logo, '/images/logo.png') %>" alt="Logo" style="height: 42px;" onerror="this.src='/images/logo.png'">
            <div class="d-flex flex-column justify-content-center">
                <span class="d-block fw-black lh-1" style="font-family: 'Inter', sans-serif; font-size: 1.35rem; font-weight: 900; color: var(--primary); letter-spacing: 0.5px;"><%= settings.brand_name || 'BÌNH LỢI' %></span>
                <span class="d-block" style="font-family: 'Dancing Script', cursive; font-size: 1.15rem; color: var(--primary-green); font-weight: 700; margin-top: 2px; line-height: 1;"><%= settings.brand_subtext || 'Chạm vào bình yên' %></span>
            </div>
        </a>

        <!-- Desktop Nav Links (hidden on mobile) -->
        <div class="d-none d-lg-flex align-items-center flex-grow-1 justify-content-center">
            <ul class="navbar-nav gap-1">
                <li class="nav-item"><a class="nav-link" href="/">Trang chủ</a></li>
                <li class="nav-item"><a class="nav-link" href="/explore">Khám phá</a></li>
                <li class="nav-item"><a class="nav-link" href="/workshops">Workshop</a></li>
                <li class="nav-item"><a class="nav-link" href="/reviews">Cộng đồng</a></li>
                <li class="nav-item"><a class="nav-link" href="/journey">Đề xuất hành trình/tour</a></li>
                <li class="nav-item"><a class="nav-link" href="/map">Bản đồ</a></li>
            </ul>
        </div>

        <!-- Desktop Auth (hidden on mobile) -->
        <div class="d-none d-lg-flex align-items-center gap-3" style="z-index: 10;">
            <% if (user) { %>
            <div class="dropdown">
                <a href="#" class="d-flex align-items-center gap-2 text-decoration-none p-1 rounded-pill" data-bs-toggle="dropdown" style="background: var(--primary-50); padding-right: 14px !important;">
                    <img src="<%= user.avatar || '/images/default-avatar.png' %>" class="rounded-circle" style="width: 34px; height: 34px; object-fit: cover; border: 2px solid var(--primary-100);">
                    <span class="fw-bold" style="font-size: 0.82rem; color: var(--primary);"><%= user.full_name.split(' ').pop() %></span>
                    <i class="bi bi-chevron-down" style="font-size: 0.65rem; color: var(--text-muted);"></i>
                </a>
                <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg p-2 mt-2" style="border-radius: var(--radius-lg); min-width: 220px;">
                    <li class="px-3 py-2 mb-1">
                        <div class="fw-bold" style="font-size: 0.88rem;"><%= user.full_name %></div>
                        <div style="font-size: 0.75rem; color: var(--text-muted);"><%= user.email %></div>
                    </li>
                    <li><hr class="dropdown-divider my-1"></li>
                    <% if (user.role === 'admin') { %>
                    <li><a class="dropdown-item py-2 rounded-2" href="/admin" style="color: var(--primary); font-weight: 600;"><i class="bi bi-shield-check me-2"></i>Admin Panel</a></li>
                    <% } %>
                    <% if (user.role === 'manager') { %>
                    <li><a class="dropdown-item py-2 rounded-2" href="/manager" style="color: var(--primary); font-weight: 600;"><i class="bi bi-shield-check me-2"></i>Quản lý Panel</a></li>
                    <% } %>
                    <% if (user.role === 'user') { %>
                    <li><a class="dropdown-item py-2 rounded-2" href="/profile"><i class="bi bi-person me-2 text-muted"></i>Hồ sơ du khách</a></li>
                    <li><a class="dropdown-item py-2 rounded-2" href="/profile/rewards"><i class="bi bi-gift me-2 text-muted"></i>Điểm thưởng</a></li>
                    <% } %>
                    <li><hr class="dropdown-divider my-1"></li>
                    <li><a class="dropdown-item py-2 rounded-2 text-danger" href="/auth/logout"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
                </ul>
            </div>
            <% } else { %>
            <a href="/auth/login" class="btn btn-premium rounded-pill px-4 py-2 fw-bold" style="font-size: 0.82rem;">Đăng nhập</a>
            <% } %>
        </div>
    </div>
</nav>

<!-- MOBILE OFFCANVAS MENU (Modern App Sidebar Style) -->
<div class="offcanvas offcanvas-start border-0 shadow-lg" tabindex="-1" id="mobileMenu" style="width: 285px; z-index: 1060; border-radius: 0 24px 24px 0;">
    <div class="offcanvas-header p-4" style="background: linear-gradient(135deg, var(--primary-50) 0%, #ffffff 100%); border-bottom: 1px solid var(--border-light);">
        <div class="d-flex align-items-center gap-2">
            <img src="<%= fixImg(settings.brand_logo, '/images/logo.png') %>" alt="Logo" style="height: 34px;" onerror="this.src='/images/logo.png'">
            <div class="d-flex flex-column justify-content-center">
                <span class="fw-black d-block lh-1" style="font-family: 'Inter', sans-serif; color: var(--primary); font-size: 1.05rem; font-weight: 900;"><%= settings.brand_name || 'BÌNH LỢI' %></span>
                <span class="d-block text-truncate" style="font-family: 'Dancing Script', cursive; font-size: 0.95rem; color: var(--primary-green); font-weight: 700; margin-top: 1px;"><%= settings.brand_subtext || 'Chạm vào bình yên' %></span>
            </div>
        </div>
        <button type="button" class="btn-close shadow-none p-2" data-bs-dismiss="offcanvas" aria-label="Đóng"></button>
    </div>
    <div class="offcanvas-body d-flex flex-column p-0">
        <!-- Navigation Links -->
        <div class="p-3">
            <div class="text-uppercase x-small text-muted fw-bold px-3 mb-2" style="letter-spacing: 1px; font-size: 0.65rem;">DANH MỤC MENU</div>
            <a class="mobile-menu-link" href="/"><i class="bi bi-house-door-fill text-primary"></i> Trang chủ</a>
            <a class="mobile-menu-link" href="/explore"><i class="bi bi-compass-fill text-success"></i> Khám phá</a>
            <a class="mobile-menu-link" href="/workshops"><i class="bi bi-palette-fill text-warning"></i> Workshop</a>
            <a class="mobile-menu-link" href="/reviews"><i class="bi bi-chat-heart-fill text-danger"></i> Cộng đồng</a>
            <a class="mobile-menu-link" href="/journey"><i class="bi bi-signpost-split-fill text-info"></i> Đề xuất hành trình</a>
            <a class="mobile-menu-link" href="/map"><i class="bi bi-map-fill text-primary"></i> Bản đồ</a>
            <a class="mobile-menu-link" href="/festivals"><i class="bi bi-calendar-event-fill text-success"></i> Lễ hội</a>
            <% if (locals.user) { %>
            <a class="mobile-menu-link" href="/chat" style="color: var(--primary); font-weight: 600;"><i class="bi bi-envelope-heart-fill text-danger"></i> Hộp thư hỗ trợ</a>
            <% } %>
        </div>

        <!-- User Section at Bottom -->
        <div class="mt-auto border-top p-3 bg-light bg-opacity-50">
            <% if (user) { %>
            <div class="d-flex align-items-center gap-2 mb-3 pb-3 border-bottom">
                <img src="<%= user.avatar || '/images/default-avatar.png' %>" class="rounded-circle shadow-sm" style="width: 38px; height: 38px; object-fit: cover; border: 2px solid var(--primary-100);">
                <div class="overflow-hidden">
                    <div class="fw-bold text-dark text-truncate" style="font-size: 0.85rem;"><%= user.full_name %></div>
                    <div class="x-small text-muted text-truncate"><%= user.phone || user.email %></div>
                </div>
            </div>
            <% if (user.role === 'user') { %>
            <a class="mobile-menu-link" href="/profile"><i class="bi bi-person-circle text-primary"></i> Hồ sơ du khách</a>
            <a class="mobile-menu-link" href="/profile/rewards"><i class="bi bi-gift-fill text-warning"></i> Điểm thưởng</a>
            <% } %>
            <% if (user.role === 'admin') { %>
            <a class="mobile-menu-link text-primary fw-bold" href="/admin"><i class="bi bi-shield-check"></i> Admin Panel</a>
            <% } %>
            <% if (user.role === 'manager') { %>
            <a class="mobile-menu-link text-primary fw-bold" href="/manager"><i class="bi bi-shield-check"></i> Quản lý Panel</a>
            <% } %>
            <a class="mobile-menu-link text-danger mt-1" href="/auth/logout"><i class="bi bi-box-arrow-right"></i> Đăng xuất</a>
            <% } else { %>
            <a href="/auth/login" class="btn btn-premium rounded-pill w-100 py-2 fw-bold shadow-sm" style="font-size: 0.82rem;">
                <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập / Đăng ký
            </a>
            <% } %>
        </div>
    </div>
</div>

<style>
    /* Hamburger */
    .nav-hamburger { width: 22px; height: 16px; position: relative; cursor: pointer; }
    .nav-hamburger span { display: block; height: 2px; background: var(--primary); border-radius: 2px; transition: all 0.3s ease; position: absolute; left: 0; width: 100%; }
    .nav-hamburger span:nth-child(1) { top: 0; }
    .nav-hamburger span:nth-child(2) { top: 7px; width: 70%; }
    .nav-hamburger span:nth-child(3) { top: 14px; width: 85%; }

    /* Mobile: Center the brand */
    @media (max-width: 991.98px) {
        .navbar > .container {
            display: flex;
            justify-content: center;
            position: relative;
        }
        .navbar-toggler {
            position: absolute !important;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
        }
        .navbar-brand { margin: 0 auto !important; }
    }

    /* Mobile Offcanvas Menu Sidebar */
    #mobileMenu {
        background: #ffffff !important;
        box-shadow: 0 10px 40px rgba(0,0,0,0.15) !important;
    }
    .mobile-menu-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 14px;
        font-size: 0.84rem;
        font-weight: 600;
        color: #334155;
        text-decoration: none;
        border-radius: 12px;
        transition: all 0.2s ease;
        margin-bottom: 3px;
    }
    .mobile-menu-link:hover, .mobile-menu-link:active {
        background: var(--primary-50, #fdf5f5);
        color: var(--primary, #922724);
    }
    .mobile-menu-link i {
        width: 22px;
        text-align: center;
        font-size: 1.05rem;
    }

    /* Dropdown polish */
    .dropdown-item { font-size: 0.85rem; transition: all 0.15s ease; }
    .dropdown-item:hover { background: var(--primary-50); color: var(--primary); }
    .dropdown-item:active { background: var(--primary-100); }
</style>