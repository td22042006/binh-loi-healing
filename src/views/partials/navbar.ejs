            </div>
            <% if (user.role === 'user') { %>
            <a class="mobile-menu-link" href="/profile"><i class="bi bi-person-circle"></i> Hồ sơ du khách</a>
            <a class="mobile-menu-link" href="/profile/rewards"><i class="bi bi-gift" style="color: #f59e0b;"></i> Điểm thưởng</a>
            <% } %>
            <% if (user.role === 'admin') { %>
            <a class="mobile-menu-link" href="/admin" style="color: var(--primary); font-weight: 700;"><i class="bi bi-shield-check"></i> Admin Panel</a>
            <% } %>
            <% if (user.role === 'manager') { %>
            <a class="mobile-menu-link" href="/manager" style="color: var(--primary); font-weight: 700;"><i class="bi bi-shield-check"></i> Quản lý Panel</a>
            <% } %>
            <a class="mobile-menu-link text-danger" href="/auth/logout" style="margin-top: 8px;"><i class="bi bi-box-arrow-right"></i> Đăng xuất</a>
            <% } else { %>
            <a href="/auth/login" class="btn btn-premium rounded-pill w-100 py-2 fw-bold" style="font-size: 0.88rem;">
                <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập / Đăng ký
            </a>
            <% } %>
        </div>
    </div>
</div>

<style>
    /* Hamburger */
    .nav-hamburger { width: 24px; height: 18px; position: relative; cursor: pointer; }
    .nav-hamburger span { display: block; height: 2px; background: var(--primary); border-radius: 2px; transition: all 0.3s ease; position: absolute; left: 0; width: 100%; }
    .nav-hamburger span:nth-child(1) { top: 0; }
    .nav-hamburger span:nth-child(2) { top: 8px; width: 70%; }
    .nav-hamburger span:nth-child(3) { top: 16px; width: 85%; }

    /* Mobile: Center the brand */
    @media (max-width: 991.98px) {
        .navbar > .container {
            display: flex;
            justify-content: center;
            position: relative;
        }
        .navbar-toggler {
            position: absolute !important;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
        }
        .navbar-brand { margin: 0 auto !important; }
    }

    /* Mobile Offcanvas Menu */
    #mobileMenu {
        background: rgba(255,255,255,0.99) !important;
        backdrop-filter: blur(20px) !important;
    }
    .mobile-menu-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 13px 16px;
        font-size: 0.92rem;
        font-weight: 500;
        color: var(--text, #1e293b);
        text-decoration: none;
        border-radius: 12px;
        transition: all 0.15s ease;
    }
    .mobile-menu-link:hover, .mobile-menu-link:focus {
        background: var(--primary-50, #fbf5f5);
        color: var(--primary, #922724);
    }
    .mobile-menu-link i {
        width: 20px;
        text-align: center;
        font-size: 1.1rem;
    }

    /* Dropdown polish */
    .dropdown-item { font-size: 0.85rem; transition: all 0.15s ease; }
    .dropdown-item:hover { background: var(--primary-50); color: var(--primary); }
    .dropdown-item:active { background: var(--primary-100); }
</style>