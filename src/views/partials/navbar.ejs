<!-- MOBILE OFFCANVAS MENU (completely outside nav to avoid any nesting issues) -->
<div class="offcanvas offcanvas-start" tabindex="-1" id="mobileMenu" style="width: 300px; z-index: 1060;">
    <div class="offcanvas-header p-4" style="border-bottom: 1px solid #f1f5f9;">
        <div class="d-flex align-items-center gap-2">
            <img src="<%= fixImg(settings.brand_logo, '/images/logo.png') %>" alt="Logo" style="height: 32px;" onerror="this.src='/images/logo.png'">
            <div class="d-flex flex-column justify-content-center">
                <span class="fw-black d-block lh-1" style="font-family: 'Playfair Display', serif; color: var(--primary); font-size: 1.1rem; font-weight: 900;"><%= settings.brand_name || 'BÌNH LỢI' %></span>
                <span class="d-block" style="font-family: 'Dancing Script', cursive; font-size: 0.8rem; color: var(--primary-green); font-weight: 700; margin-top: -2px; line-height: 1;"><%= settings.brand_subtext || 'Chạm vào bình yên' %></span>
            </div>
        </div>
        <button type="button" class="btn-close shadow-none" data-bs-dismiss="offcanvas" aria-label="Đóng"></button>
    </div>
    <div class="offcanvas-body d-flex flex-column p-0">
        <!-- Navigation Links -->
        <div class="p-3">
            <a class="mobile-menu-link" href="/"><i class="bi bi-house-door"></i> Trang chủ</a>
            <a class="mobile-menu-link" href="/explore"><i class="bi bi-compass"></i> Khám phá</a>
            <a class="mobile-menu-link" href="/workshops"><i class="bi bi-palette"></i> Workshop</a>
            <a class="mobile-menu-link" href="/reviews"><i class="bi bi-chat-heart"></i> Cộng đồng</a>
            <a class="mobile-menu-link" href="/journey"><i class="bi bi-signpost-split"></i> Hành trình</a>
            <a class="mobile-menu-link" href="/map"><i class="bi bi-map"></i> Bản đồ</a>
            <a class="mobile-menu-link" href="/festivals"><i class="bi bi-calendar-event"></i> Lễ hội</a>
            <a class="mobile-menu-link" href="/checkin"><i class="bi bi-qr-code-scan" style="color: var(--primary);"></i> Quét QR Check-in</a>
        </div>

        <!-- User Section at Bottom -->
        <div class="mt-auto border-top p-3">
            <% if (user) { %>
            <div class="d-flex align-items-center gap-2 mb-3 pb-3 border-bottom">
                <img src="<%= user.avatar || '/images/default-avatar.png' %>" class="rounded-circle" style="width: 40px; height: 40px; object-fit: cover;">
                <div>
                    <div class="fw-bold" style="font-size: 0.9rem;"><%= user.full_name %></div>
                    <div style="font-size: 0.72rem; color: var(--text-muted);"><%= user.phone || user.email %></div>
