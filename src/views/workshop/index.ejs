<!-- Workshop Listing - Info & Introduction Only -->
<section class="py-5" style="margin-top: 60px;">
    <!-- Hero Header -->
    <div class="position-relative overflow-hidden mb-5" style="height: 320px; background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.7)), url('/images/hero-2.png') center/cover;">
        <div class="position-absolute top-50 start-50 translate-middle text-center w-100 px-3">
            <span class="badge bg-warning text-dark rounded-pill px-3 py-2 mb-3 fw-bold tracking-widest text-uppercase"><i class="bi bi-palette me-1"></i> Trải nghiệm làng nghề</span>
            <h1 class="display-4 fw-black text-white mb-2">Workshop & Hoạt Động</h1>
            <p class="text-white-50 lead mx-auto" style="max-width: 600px;">Học làm nhang, chăm mai, nặn bánh dân gian - trải nghiệm cùng nghệ nhân địa phương. Đến trong khung giờ là có thể tham gia!</p>
        </div>
    </div>

    <div class="container py-4">
        <!-- Redesigned Search & Collapse Filter Bar -->
        <div class="card border-0 shadow-premium rounded-4 p-3 mb-5 bg-white reveal-up">
            <form action="/workshops" method="GET" id="workshopSearchForm">
                <!-- Search bar and collapse trigger -->
                <div class="d-flex flex-column flex-md-row gap-2">
                    <div class="position-relative flex-grow-1">
                        <i class="bi bi-search position-absolute top-50 translate-middle-y text-muted" style="left: 18px;"></i>
                        <input type="text" name="q" class="form-control border-0 bg-light rounded-pill py-3 ps-5 pe-4 shadow-none" 
                            placeholder="Tìm kiếm workshop (làm nhang, chăm mai, thiền...)" 
                            value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" style="font-size: 0.9rem;">
                    </div>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-outline-secondary rounded-pill px-4 fw-bold d-flex align-items-center justify-content-center" data-bs-toggle="collapse" data-bs-target="#filterCollapse" aria-expanded="false" style="font-size: 0.85rem; border: 1px solid rgba(0,0,0,0.15); height: 48px;">
                            <i class="bi bi-funnel me-1"></i> Bộ lọc <%= typeFilter ? '(Đang lọc)' : '' %>
                        </button>
                        <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold text-white btn-premium d-flex align-items-center justify-content-center" style="background: var(--primary); font-size: 0.85rem; height: 48px;">
                            Tìm kiếm
                        </button>
                    </div>
                </div>

                <!-- Collapsible Filters -->
                <div class="collapse <%= typeFilter ? 'show' : '' %> mt-3 pt-3 border-top" id="filterCollapse">
                    <div class="row g-3">
                        <!-- Category Type Filter -->
                        <div class="col-12">
                            <label class="form-label text-muted fw-bold x-small text-uppercase mb-2"><i class="bi bi-tag text-primary me-1"></i>Loại Workshop</label>
                            <select name="type" class="form-select border bg-light rounded-pill py-2 px-3 shadow-none small" onchange="this.form.submit()">
                                <option value="">Tất cả loại hình</option>
                                <% Object.entries(typeLabels).forEach(([key, label]) => { %>
                                    <option value="<%= key %>" <%= typeFilter === key ? 'selected' : '' %>><%= label %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>

                    <!-- Reset Link -->
                    <% if ((typeof searchQuery !== 'undefined' && searchQuery) || typeFilter) { %>
                    <div class="text-end mt-3">
                        <a href="/workshops" class="text-danger small fw-bold text-decoration-none"><i class="bi bi-x-circle me-1"></i>Xóa tất cả bộ lọc</a>
                    </div>
                    <% } %>
                </div>
            </form>
        </div>


        <!-- Grid -->
        <div class="row g-4">
            <% workshops.forEach((ws, i) => { %>
            <div class="col-md-6 col-lg-4 reveal-up">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 d-flex flex-column bg-white" style="transition: transform 0.3s, box-shadow 0.3s;" onmouseover="this.style.transform='translateY(-8px)'; this.style.boxShadow='0 20px 40px rgba(0,0,0,0.12)'" onmouseout="this.style.transform=''; this.style.boxShadow=''">
                    <div class="position-relative" style="height: 220px; overflow: hidden;">
                        <img src="<%= fixImg(ws.image) %>" alt="<%= ws.title %>" class="w-100 h-100" style="object-fit: cover;">
                        <div class="position-absolute top-0 start-0 m-3" style="z-index: 5;">
                            <span class="badge-nature"><%= typeLabels[ws.type] || ws.type %></span>
                        </div>
                        <% if (ws.stats && ws.stats.avg_rating) { %>
                        <div class="position-absolute top-0 end-0 m-3" style="z-index: 5;">
                            <span class="badge-gold"><i class="bi bi-star-fill me-1"></i><%= parseFloat(ws.stats.avg_rating).toFixed(1) %></span>
                        </div>
                        <% } %>
                    </div>
                    <div class="p-4 d-flex flex-column flex-grow-1">
                        <h5 class="fw-bold mb-2"><%= ws.title %></h5>
                        <p class="text-muted line-clamp-2 mb-3" style="font-size: 0.88rem;"><%= ws.description %></p>
                        
                        <div class="mt-auto">
                            <div class="d-flex align-items-center gap-3 mb-3 flex-wrap" style="font-size: 0.8rem; color: var(--text-secondary);">
                                <span><i class="bi bi-clock me-1"></i><%= ws.duration || '2-3 giờ' %></span>
                                <span><i class="bi bi-people me-1"></i><%= ws.max_participants || 20 %> người</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center pt-3" style="border-top: 1px solid var(--border-light);">
                                <div>
                                    <% if (ws.price === 0) { %>
                                        <span class="fw-black" style="color: var(--success); font-size: 1.1rem;">Miễn phí</span>
                                    <% } else { %>
                                        <span class="fw-black" style="color: var(--primary); font-size: 1.1rem;"><%= new Intl.NumberFormat('vi-VN').format(ws.price) %>đ</span>
                                        <span class="text-muted" style="font-size: 0.75rem;">/người</span>
                                    <% } %>
                                </div>
                                <a href="/workshops/<%= ws.id %>" class="btn btn-primary-bl btn-sm rounded-pill px-3">Xem chi tiết <i class="bi bi-arrow-right ms-1"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>

        <% if (workshops.length === 0) { %>
        <div class="text-center py-5">
            <i class="bi bi-palette display-1" style="color: var(--border);"></i>
            <p class="text-muted mt-3">Chưa có workshop nào trong danh mục này.</p>
            <a href="/workshops" class="btn btn-premium rounded-pill px-4">Xem tất cả Workshop</a>
        </div>
        <% } %>

        <!-- Info Banner -->
        <div class="mt-5 p-4 rounded-4 text-center" style="background: linear-gradient(135deg, rgba(92,138,94,0.1), rgba(200,169,110,0.1)); border: 1px dashed var(--primary-100);">
            <i class="bi bi-info-circle-fill text-primary fs-3 mb-2 d-block"></i>
            <h5 class="fw-bold mb-2">Không cần đăng ký trước!</h5>
            <p class="text-muted mb-0" style="max-width: 500px; margin: 0 auto;">Workshop tại Bình Lợi hoạt động theo khung giờ cố định. Bạn chỉ cần đến đúng giờ là có thể tham gia ngay.</p>
        </div>
    </div>
</section>
