<% /* Workshop Index - Chương 5.11 */ %>

<!-- Hero Section -->
<section class="hero-mini" style="background: linear-gradient(135deg, var(--v5-primary) 0%, var(--v5-primary-dark, #1a5c2e) 100%); padding: 100px 0 60px; color: white;">
    <div class="container text-center">
        <h1 class="display-4 fw-black mb-3" style="font-family: var(--font-display);">Workshop & Trải Nghiệm</h1>
        <p class="lead opacity-75">Tự tay trải nghiệm văn hóa làng nghề Bình Lợi</p>
    </div>
</section>

<!-- Filter -->
<section class="py-4 bg-light">
    <div class="container">
        <div class="d-flex flex-wrap gap-2 justify-content-center">
            <a href="/workshops" class="btn <%= !typeFilter ? 'btn-primary' : 'btn-outline-primary' %> rounded-pill px-4">Tất cả</a>
            <% Object.entries(typeLabels).forEach(([key, label]) => { %>
                <a href="/workshops?type=<%= key %>" class="btn <%= typeFilter === key ? 'btn-primary' : 'btn-outline-primary' %> rounded-pill px-4"><%= label %></a>
            <% }); %>
        </div>
    </div>
</section>

<!-- Workshop Grid -->
<section class="py-5">
    <div class="container">
        <% if (workshops.length === 0) { %>
            <div class="text-center py-5">
                <i class="bi bi-palette display-1 text-muted"></i>
                <p class="text-muted mt-3">Chưa có workshop nào.</p>
            </div>
        <% } else { %>
            <div class="row g-4">
                <% workshops.forEach(ws => { %>
                    <div class="col-md-6 col-lg-4 reveal-up">
                        <div class="card border-0 shadow-lg rounded-4 overflow-hidden h-100" style="transition: transform 0.3s ease;">
                            <div class="position-relative">
                                <img src="<%= fixImg(ws.image) %>" class="card-img-top" style="height: 220px; object-fit: cover;" alt="<%= ws.title %>">
                                <% if (ws.price === 0) { %>
                                    <span class="badge bg-success position-absolute top-0 end-0 m-3 rounded-pill px-3 py-2">MIỄN PHÍ</span>
                                <% } else { %>
                                    <span class="badge bg-warning text-dark position-absolute top-0 end-0 m-3 rounded-pill px-3 py-2"><%= new Intl.NumberFormat('vi-VN').format(ws.price) %>đ</span>
                                <% } %>
                                <span class="badge bg-dark bg-opacity-75 position-absolute bottom-0 start-0 m-3 rounded-pill px-3">
                                    <i class="bi bi-clock me-1"></i><%= ws.duration_minutes %> phút
                                </span>
                            </div>
                            <div class="card-body p-4">
                                <div class="d-flex align-items-center gap-2 mb-2">
                                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3"><%= typeLabels[ws.type] || ws.type %></span>
                                    <% if (ws.stats && ws.stats.avg_rating) { %>
                                        <span class="text-warning small"><i class="bi bi-star-fill"></i> <%= parseFloat(ws.stats.avg_rating).toFixed(1) %></span>
                                    <% } %>
                                </div>
                                <h5 class="fw-bold mb-2"><%= ws.title %></h5>
                                <p class="text-muted small mb-3" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"><%= ws.description %></p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <small class="text-muted"><i class="bi bi-geo-alt me-1"></i><%= ws.destination_name || 'Bình Lợi' %></small>
                                    <small class="text-muted"><i class="bi bi-people me-1"></i>Tối đa <%= ws.max_participants %> người</small>
                                </div>
                            </div>
                            <div class="card-footer bg-transparent border-0 p-4 pt-0">
                                <a href="/workshops/<%= ws.id %>" class="btn btn-premium w-100 rounded-pill">
                                    <i class="bi bi-calendar-check me-2"></i>Xem & Đăng ký
                                </a>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </div>
</section>
