<!-- Workshop Listing — Chương 5.11 -->
<section class="py-5" style="margin-top: 80px;">
    <div class="container py-4">
        <!-- Header -->
        <div class="row align-items-end mb-5">
            <div class="col-lg-7 reveal-up">
                <span class="section-label">TRẢI NGHIỆM</span>
                <h2 class="section-title">Workshop & Hoạt Động</h2>
                <p class="section-desc">Học làm nhang, chăm mai, nặn bánh dân gian — trải nghiệm làng nghề truyền thống cùng nghệ nhân địa phương.</p>
            </div>
            <div class="col-lg-5 reveal-up">
                <div class="d-flex gap-2 flex-wrap justify-content-lg-end">
                    <a href="/workshops" class="btn btn-sm <%= !typeFilter ? 'btn-primary-bl' : 'btn-ghost' %> rounded-pill px-3" style="font-size: 0.82rem;">Tất cả</a>
                    <% Object.entries(typeLabels).forEach(([key, label]) => { %>
                        <a href="/workshops?type=<%= key %>" class="btn btn-sm <%= typeFilter === key ? 'btn-primary-bl' : 'btn-ghost' %> rounded-pill px-3" style="font-size: 0.82rem;"><%= label %></a>
                    <% }) %>
                </div>
            </div>
        </div>

        <!-- Grid -->
        <div class="row g-4">
            <% workshops.forEach((ws, i) => { %>
            <div class="col-md-6 col-lg-4 reveal-up">
                <div class="card-heal h-100 d-flex flex-column">
                    <div class="card-img position-relative" style="height: 220px;">
                        <img src="<%= fixImg(ws.image) %>" alt="<%= ws.title %>">
                        <div class="position-absolute top-0 start-0 m-3" style="z-index: 5;">
                            <span class="badge-nature"><%= typeLabels[ws.type] || ws.type %></span>
                        </div>
                        <% if (ws.stats && ws.stats.avg_rating) { %>
                        <div class="position-absolute top-0 end-0 m-3" style="z-index: 5;">
                            <span class="badge-gold"><i class="bi bi-star-fill me-1"></i><%= parseFloat(ws.stats.avg_rating).toFixed(1) %></span>
                        </div>
                        <% } %>
                    </div>
                    <div class="p-4 d-flex flex-column flex-grow-1">
                        <h5 class="fw-bold mb-2"><%= ws.title %></h5>
                        <p class="text-muted line-clamp-2 mb-3" style="font-size: 0.88rem;"><%= ws.description %></p>
                        
                        <div class="mt-auto">
                            <div class="d-flex align-items-center gap-3 mb-3 flex-wrap" style="font-size: 0.8rem; color: var(--text-secondary);">
                                <span><i class="bi bi-clock me-1"></i><%= ws.duration || '2-3 giờ' %></span>
                                <span><i class="bi bi-people me-1"></i><%= ws.max_participants || 20 %> người</span>
                                <% if (ws.stats) { %>
                                <span><i class="bi bi-ticket me-1"></i><%= ws.stats.total_bookings || 0 %> đặt</span>
                                <% } %>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <% if (ws.price === 0) { %>
                                        <span class="fw-black" style="color: var(--success); font-size: 1.1rem;">Miễn phí</span>
                                    <% } else { %>
                                        <span class="fw-black" style="color: var(--primary); font-size: 1.1rem;"><%= new Intl.NumberFormat('vi-VN').format(ws.price) %>đ</span>
                                        <span class="text-muted" style="font-size: 0.75rem;">/người</span>
                                    <% } %>
                                </div>
                                <a href="/workshops/<%= ws.id %>" class="btn btn-primary-bl btn-sm rounded-pill px-3">Chi tiết <i class="bi bi-arrow-right ms-1"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>

        <% if (workshops.length === 0) { %>
        <div class="text-center py-5">
            <i class="bi bi-palette display-1" style="color: var(--border);"></i>
            <p class="text-muted mt-3">Chưa có workshop nào trong danh mục này.</p>
            <a href="/workshops" class="btn btn-premium rounded-pill px-4">Xem tất cả Workshop</a>
        </div>
        <% } %>
    </div>
</section>
