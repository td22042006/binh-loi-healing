<!-- Workshop Detail — Chương 5.11 -->
<section class="py-5" style="margin-top: 80px;">
    <div class="container py-4">
        <div class="row g-5">
            <!-- Left: Gallery + Info -->
            <div class="col-lg-7">
                <!-- Image -->
                <div class="rounded-2xl overflow-hidden mb-4 reveal-up" style="height: 400px;">
                    <img src="<%= fixImg(workshop.image) %>" class="w-100 h-100 object-fit-cover" alt="<%= workshop.title %>">
                </div>
                
                <!-- Info -->
                <div class="reveal-up">
                    <div class="d-flex gap-2 mb-3 flex-wrap">
                        <span class="badge-nature"><%= workshop.type %></span>
                        <% if (stats && stats.avg_rating) { %>
                        <span class="badge-gold"><i class="bi bi-star-fill me-1"></i><%= parseFloat(stats.avg_rating).toFixed(1) %> (<%= stats.total_reviews || 0 %> đánh giá)</span>
                        <% } %>
                    </div>
                    <h1 class="fw-black font-display mb-3" style="font-size: 2rem;"><%= workshop.title %></h1>
                    <p style="font-size: 0.95rem; line-height: 1.9; color: var(--text-secondary);"><%= workshop.description %></p>
                    
                    <!-- Meta -->
                    <div class="row g-3 mt-4">
                        <div class="col-6 col-md-3">
                            <div class="p-3 rounded-xl text-center" style="background: var(--surface-alt);">
                                <i class="bi bi-clock d-block mb-1" style="color: var(--primary);"></i>
                                <span class="fw-bold d-block" style="font-size: 0.82rem;"><%= workshop.duration || '2-3 giờ' %></span>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="p-3 rounded-xl text-center" style="background: var(--surface-alt);">
                                <i class="bi bi-people d-block mb-1" style="color: var(--primary);"></i>
                                <span class="fw-bold d-block" style="font-size: 0.82rem;">Tối đa <%= workshop.max_participants || 20 %></span>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="p-3 rounded-xl text-center" style="background: var(--surface-alt);">
                                <i class="bi bi-ticket d-block mb-1" style="color: var(--primary);"></i>
                                <span class="fw-bold d-block" style="font-size: 0.82rem;"><%= stats ? stats.total_bookings || 0 : 0 %> đã đặt</span>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="p-3 rounded-xl text-center" style="background: var(--surface-alt);">
                                <i class="bi bi-geo-alt d-block mb-1" style="color: var(--primary);"></i>
                                <span class="fw-bold d-block" style="font-size: 0.82rem;">Bình Lợi</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Related -->
                <% if (relatedWorkshops && relatedWorkshops.length > 0) { %>
                <div class="mt-5 reveal-up">
                    <h5 class="fw-bold mb-3">Workshop liên quan</h5>
                    <div class="row g-3">
                        <% relatedWorkshops.slice(0, 2).forEach(rw => { %>
                        <div class="col-6">
                            <a href="/workshops/<%= rw.id %>" class="text-decoration-none">
                                <div class="card-heal">
                                    <div class="card-img" style="height: 140px;"><img src="<%= fixImg(rw.image) %>" alt="<%= rw.title %>"></div>
                                    <div class="p-3"><h6 class="fw-bold mb-0" style="font-size: 0.85rem; color: var(--text);"><%= rw.title %></h6></div>
                                </div>
                            </a>
                        </div>
                        <% }) %>
                    </div>
                </div>
                <% } %>
            </div>

            <!-- Right: Booking Form -->
            <div class="col-lg-5">
                <div class="p-4 rounded-2xl reveal-up" style="background: var(--surface); border: 1px solid var(--border-light); position: sticky; top: 100px;">
                    <!-- Price -->
                    <div class="d-flex justify-content-between align-items-center mb-4 pb-3" style="border-bottom: 1px solid var(--border-light);">
                        <div>
                            <% if (workshop.price === 0) { %>
                                <span class="fw-black font-display" style="font-size: 1.8rem; color: var(--success);">Miễn phí</span>
                            <% } else { %>
                                <span class="fw-black font-display" style="font-size: 1.8rem; color: var(--primary);"><%= new Intl.NumberFormat('vi-VN').format(workshop.price) %>đ</span>
                                <span class="text-muted">/người</span>
                            <% } %>
                        </div>
                        <span class="text-muted" style="font-size: 0.82rem;">+50 điểm</span>
                    </div>

                    <!-- Form -->
                    <form id="bookingForm">
                        <input type="hidden" name="workshop_id" value="<%= workshop.id %>">
                        <div class="mb-3">
                            <label class="form-label fw-bold" style="font-size: 0.82rem; color: var(--text-secondary);">Ngày tham gia</label>
                            <input type="date" class="form-control rounded-lg border-0" name="booking_date" style="background: var(--surface-alt); padding: 12px;" required>
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-6">
                                <label class="form-label fw-bold" style="font-size: 0.82rem; color: var(--text-secondary);">Giờ</label>
                                <select class="form-select rounded-lg border-0" name="booking_time" style="background: var(--surface-alt); padding: 12px;">
                                    <option>08:00</option><option>09:00</option><option>10:00</option><option>14:00</option>
                                </select>
                            </div>
                            <div class="col-6">
                                <label class="form-label fw-bold" style="font-size: 0.82rem; color: var(--text-secondary);">Số người</label>
                                <input type="number" class="form-control rounded-lg border-0" name="num_people" value="1" min="1" max="10" style="background: var(--surface-alt); padding: 12px;">
                            </div>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold" style="font-size: 0.82rem; color: var(--text-secondary);">Ghi chú</label>
                            <textarea class="form-control rounded-lg border-0" name="note" rows="2" placeholder="Yêu cầu đặc biệt..." style="background: var(--surface-alt); padding: 12px; resize: none;"></textarea>
                        </div>
                        <button type="submit" class="btn btn-premium w-100 py-3" id="btnBook">
                            <i class="bi bi-calendar-check me-2"></i>Đặt chỗ ngay
                        </button>
                    </form>
                    <div id="bookingResult" class="mt-3 d-none"></div>
                    
                    <!-- User's existing bookings -->
                    <% if (userBookings && userBookings.length > 0) { %>
                    <div class="mt-4 pt-3" style="border-top: 1px solid var(--border-light);">
                        <h6 class="fw-bold mb-3" style="font-size: 0.85rem;">Vé của bạn</h6>
                        <% userBookings.forEach(b => { %>
                        <div class="d-flex align-items-center gap-2 p-2 rounded-lg mb-2" style="background: var(--primary-50);">
                            <i class="bi bi-qr-code" style="color: var(--primary);"></i>
                            <div class="flex-grow-1">
                                <span class="fw-bold d-block" style="font-size: 0.78rem;"><%= b.qr_ticket %></span>
                                <span class="text-muted" style="font-size: 0.7rem;"><%= new Date(b.booking_date).toLocaleDateString('vi-VN') %></span>
                            </div>
                            <span class="badge rounded-pill" style="font-size: 0.65rem; background: rgba(16,185,129,0.1); color: var(--success);"><%= b.status %></span>
                        </div>
                        <% }) %>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
document.getElementById('bookingForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('btnBook');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang xử lý...';
    try {
        const formData = new FormData(e.target);
        const res = await axios.post('/api/workshop/book', Object.fromEntries(formData));
        const el = document.getElementById('bookingResult');
        el.classList.remove('d-none');
        if (res.data.success) {
            el.innerHTML = `<div class="alert border-0 rounded-xl p-3" style="background: var(--primary-50); color: var(--primary);"><i class="bi bi-check-circle-fill me-2"></i>${res.data.message}</div>`;
            btn.innerHTML = '<i class="bi bi-check-circle me-2"></i>Đã đặt thành công!';
        } else {
            el.innerHTML = `<div class="alert alert-danger border-0 rounded-xl p-3">${res.data.message}</div>`;
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-calendar-check me-2"></i>Đặt chỗ ngay';
        }
    } catch(err) {
        alert('Lỗi: ' + (err.response?.data?.message || err.message));
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-calendar-check me-2"></i>Đặt chỗ ngay';
    }
});
</script>
