<% /* My Workshop Bookings */ %>
<section class="py-5" style="margin-top: 80px;">
    <div class="container" style="max-width: 900px;">
        <h2 class="fw-black mb-4"><i class="bi bi-ticket-perforated text-primary me-2"></i>Workshop của tôi</h2>
        <% if (bookings.length === 0) { %>
            <div class="text-center py-5"><i class="bi bi-palette display-1 text-muted"></i><p class="text-muted mt-3">Bạn chưa đăng ký workshop nào.</p><a href="/workshops" class="btn btn-premium rounded-pill px-5 mt-2">Khám phá Workshop</a></div>
        <% } else { %>
            <% bookings.forEach(b => { %>
            <div class="card border-0 shadow-sm rounded-4 p-4 mb-3">
                <div class="d-flex gap-3 align-items-center">
                    <img src="<%= b.workshop_image || '/images/hero-2.png' %>" class="rounded-3" style="width:80px;height:80px;object-fit:cover;">
                    <div class="flex-grow-1">
                        <h5 class="fw-bold mb-1"><%= b.workshop_title %></h5>
                        <small class="text-muted"><i class="bi bi-geo-alt me-1"></i><%= b.destination_name || 'Bình Lợi' %> · <%= new Date(b.booking_date).toLocaleDateString('vi-VN') %> · <%= b.num_people %> người</small>
                    </div>
                    <div class="text-end">
                        <span class="badge bg-<%= b.status === 'confirmed' ? 'success' : b.status === 'completed' ? 'primary' : b.status === 'cancelled' ? 'danger' : 'warning' %> rounded-pill px-3 py-2"><%= b.status === 'confirmed' ? 'Đã xác nhận' : b.status === 'completed' ? 'Hoàn thành' : b.status === 'cancelled' ? 'Đã hủy' : 'Chờ xác nhận' %></span>
                        <br><code class="small"><%= b.qr_ticket %></code>
                    </div>
                </div>
            </div>
            <% }); %>
        <% } %>
    </div>
</section>
