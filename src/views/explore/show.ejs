<section class="explore-hero-premium position-relative overflow-hidden" style="height: 80vh;">
    <!-- Cinematic Background -->
    <div class="hero-bg" style="background: url('<%= fixImg(dest.cover_image, '/images/hero-3.png') %>') center/cover no-repeat fixed;">
    </div>
    <div class="hero-overlay-dark" style="background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.8) 100%);"></div>
    
    <div class="hero-content container-site text-white d-flex flex-column justify-content-end h-100 pb-5">
        <div class="row align-items-end">
            <div class="col-lg-8 animate__animated animate__fadeInUp">
                <span class="badge bg-white text-dark mb-3 px-3 py-2 rounded-pill fw-bold tracking-widest text-uppercase shadow-sm"><i class="bi bi-tag-fill text-primary me-1"></i> <%= dest.type %></span>
                <h1 class="display-1 fw-black mb-3 letter-spacing-sm text-shadow-lg" style="color: var(--accent);"><%= dest.name %></h1>
                <p class="lead opacity-90 d-flex align-items-center gap-2 mb-4">
                    <i class="bi bi-geo-alt-fill text-danger"></i> <%= dest.short_desc %>
                </p>
                

                <!-- Interactive Actions -->
                <div class="d-flex flex-wrap gap-3 mb-4">
                    <button class="btn btn-light rounded-pill px-4 fw-bold shadow-sm d-flex align-items-center gap-2 <%= hasLiked ? 'text-danger' : '' %>" onclick="handleLikeToggle(this, '<%= dest.id %>')">
                        <i class="bi <%= hasLiked ? 'bi-heart-fill' : 'bi-heart' %> <%= hasLiked ? 'text-danger' : '' %>"></i> Thích (<span id="likes-count"><%= totalLikes %></span>)
                    </button>
                    <button class="btn btn-light rounded-pill px-4 fw-bold shadow-sm d-flex align-items-center gap-2 <%= hasSaved ? 'text-primary' : '' %>" onclick="handleSaveToggle(this, '<%= dest.id %>')">
                        <i class="bi <%= hasSaved ? 'bi-bookmark-fill' : 'bi-bookmark' %> <%= hasSaved ? 'text-primary' : '' %>"></i> <%= hasSaved ? 'Đã lưu' : 'Lưu điểm đến' %>
                    </button>
                    <button class="btn btn-light rounded-pill px-4 fw-bold shadow-sm d-flex align-items-center gap-2" onclick="shareDestination('<%= dest.name %>', '<%= baseUrl %>/explore/<%= dest.slug %>')">
                        <i class="bi bi-share-fill text-success"></i> Chia sẻ
                    </button>
                    <button class="btn btn-primary-bl rounded-pill px-4 fw-bold shadow-lg d-flex align-items-center gap-2" onclick="addToJourney('<%= dest.id %>')">
                        <i class="bi bi-signpost-split-fill"></i> Thêm vào hành trình
                    </button>
                </div>

                <% if (user && (user.role === 'manager' || user.role === 'admin') && user.managed_destination_id === dest.id) { %>
                    <a href="/manager" class="btn btn-outline-light btn-sm rounded-pill px-3 fw-bold backdrop-blur-md">
                        <i class="bi bi-pencil-square me-1"></i> Quản lý điểm đến
                    </a>
                <% } %>
            </div>
            

        </div>
    </div>
</section>

<div class="container-site mt-5 position-relative" style="z-index: 100;">
    <div class="row g-5">
        <!-- Main Content: Storytelling -->
        <div class="col-lg-8">
            <div class="card-bl p-4 p-md-5 mb-5 shadow-lg border-0 rounded-4">


                <h2 class="display-text text-primary mb-4 border-bottom pb-3">Câu chuyện Văn hóa</h2>
                <div class="story-text-rich" style="font-size: 1.15rem; line-height: 2.2; color: #444; text-align: justify;">
                    <%- dest.story.replace(/\n/g, '<br><br>') %>
                </div>

                <!-- Highlight Box -->
                <div class="highlight-quote p-5 rounded-4 mt-5 position-relative overflow-hidden bg-light border-start border-5 border-secondary">
                    <i class="bi bi-quote display-1 position-absolute top-0 end-0 opacity-10 m-3 text-secondary"></i>
                    <h4 class="mb-3 fw-black text-dark"><i class="bi bi-stars text-warning me-2"></i> Trải nghiệm tinh hoa</h4>
                    <p class="mb-0 fst-italic lead text-muted" style="line-height: 1.8;"><%= dest.highlight %></p>
                </div>
            </div>



            <!-- Image Gallery (Góc nhìn Nghệ thuật từ check-in thực tế của du khách) -->
            <div class="mb-5">
                <div class="d-flex justify-content-between align-items-end mb-4">
                    <div>
                        <h3 class="display-text mb-1">Góc nhìn Nghệ thuật</h3>
                        <p class="text-muted small mb-0"><i class="bi bi-camera-fill text-success me-1"></i> Khoảnh khắc được chụp thực tế tại điểm bởi du khách</p>
                    </div>
                </div>
                
                <div class="row g-3">
                    <% if (galleryImages && galleryImages.length > 0) { %>
                        <div class="col-md-8">
                            <div class="rounded-4 overflow-hidden shadow-premium ratio ratio-16x9 position-relative custom-gallery-card">
                                <img src="<%= fixImg(galleryImages[0]) %>" class="w-100 h-100 object-fit-cover" alt="Artistic Perspective 1">
                                <div class="position-absolute bottom-0 start-0 w-100 p-4 text-white" style="background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 100%);">
                                    <h6 class="mb-0 fw-bold"><i class="bi bi-geo-alt-fill text-danger me-1"></i> Góc nhìn chính từ check-in</h6>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="d-flex flex-column gap-3 h-100">
                                <% if (galleryImages[1]) { %>
                                <div class="rounded-4 overflow-hidden shadow-premium ratio ratio-4x3 position-relative custom-gallery-card flex-grow-1">
                                    <img src="<%= fixImg(galleryImages[1]) %>" class="w-100 h-100 object-fit-cover" alt="Artistic Perspective 2">
                                </div>
                                <% } %>
                                <% if (galleryImages[2]) { %>
                                <div class="rounded-4 overflow-hidden shadow-premium ratio ratio-4x3 position-relative custom-gallery-card flex-grow-1">
                                    <img src="<%= fixImg(galleryImages[2]) %>" class="w-100 h-100 object-fit-cover" alt="Artistic Perspective 3">
                                    <% if (galleryImages.length > 3) { %>
                                    <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark bg-opacity-50 d-flex align-items-center justify-content-center text-white backdrop-blur-sm">
                                        <div class="text-center">
                                            <i class="bi bi-images fs-3 mb-1"></i>
                                            <div class="fw-bold tracking-widest text-uppercase x-small">+<%= galleryImages.length - 3 %> ẢNH</div>
                                        </div>
                                    </div>
                                    <% } %>
                                </div>
                                <% } %>
                            </div>
                        </div>
                    <% } else { %>
                        <div class="col-12 text-center py-5 rounded-4 bg-white border border-dashed">
                            <i class="bi bi-camera display-4 text-muted opacity-35 mb-3 d-block"></i>
                            <h6 class="fw-bold text-secondary mb-1">Chưa có hình ảnh góc nhìn nghệ thuật nào</h6>
                            <p class="x-small text-muted mb-0">Hãy là người đầu tiên chia sẻ khoảnh khắc đẹp tại điểm đến này lên mục Cộng đồng!</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Sidebar: Actions -->
        <div class="col-lg-4">
            <div class="sticky-top" style="top: 100px;">
                <!-- Info Card -->
                <div class="card-bl p-4 mb-4 shadow-sm border-0 rounded-4 bg-white">
                    <h6 class="text-primary fw-black mb-4 text-uppercase tracking-widest border-bottom pb-3"><i class="bi bi-info-circle-fill me-2"></i> Thông tin hữu ích</h6>
                    
                    <div class="d-flex align-items-start gap-3 mb-4">
                        <div class="bg-light p-3 rounded-circle text-primary"><i class="bi bi-clock-fill fs-5"></i></div>
                        <div>
                            <div class="x-small text-muted fw-bold text-uppercase">Giờ mở cửa</div>
                            <div class="fw-bold text-dark"><%= dest.open_hours || 'Cả ngày' %></div>
                        </div>
                    </div>
                    
                    <div class="d-flex align-items-start gap-3 mb-4">
                        <div class="bg-light p-3 rounded-circle text-success"><i class="bi bi-ticket-perforated-fill fs-5"></i></div>
                        <div>
                            <div class="x-small text-muted fw-bold text-uppercase">Chi phí dự kiến</div>
                            <div class="fw-bold text-dark"><%= dest.cost || 'Miễn phí' %></div>
                        </div>
                    </div>
                    
                    <div class="d-flex align-items-start gap-3 mb-4">
                        <div class="bg-light p-3 rounded-circle text-warning"><i class="bi bi-sun-fill fs-5"></i></div>
                        <div>
                            <div class="x-small text-muted fw-bold text-uppercase">Thời điểm đẹp nhất</div>
                            <div class="fw-bold text-dark"><%= dest.best_time || 'Sáng sớm / Hoàng hôn' %></div>
                        </div>
                    </div>
                    
                    <div class="bg-light p-3 rounded-4 mt-4 border-start border-4 border-primary">
                        <div class="small fw-bold text-dark mb-1"><i class="bi bi-lightbulb-fill text-warning me-1"></i> Mẹo Check-in</div>
                        <p class="x-small text-muted mb-0"><%= dest.checkin_tip || 'Hãy mang trang phục thoải mái để dễ dàng trải nghiệm.' %></p>
                    </div>
                </div>

                <!-- Action Card -->
                <div class="card-bl p-4 mb-4 shadow-xl border-0 rounded-4" style="background: linear-gradient(145deg, #ffffff, #f0f4f1);">
                    <div class="text-center mb-4">
                        <div class="bg-warning text-dark d-inline-flex align-items-center gap-2 px-4 py-2 rounded-pill fw-black mb-3 shadow-sm border border-white">
                            <i class="bi bi-star-fill"></i> +<%= dest.points %> POINTS
                        </div>
                        <h5 class="fw-black text-primary">Xác thực Check-in</h5>
                        <p class="small text-muted mb-0">Quét mã QR tại điểm để nhận điểm thưởng và huy hiệu.</p>
                    </div>
                    
                    <div class="d-grid gap-3">
                        <a href="<%= baseUrl %>/checkin?slug=<%= dest.slug %>" class="btn btn-primary-bl btn-lg shadow-md rounded-pill fw-bold">
                            <i class="bi bi-qr-code-scan me-2"></i> QUÉT QR NGAY
                        </a>
                        <a href="https://www.google.com/maps/dir/?api=1&destination=<%= dest.lat %>,<%= dest.lng %>" target="_blank" class="btn btn-light border btn-lg rounded-pill fw-bold text-dark shadow-sm">
                            <i class="bi bi-cursor-fill text-primary me-2"></i> Chỉ đường Maps
                        </a>
                        <button class="btn btn-outline-secondary btn-lg rounded-pill fw-bold mt-2 d-none d-md-block" data-bs-toggle="modal" data-bs-target="#chatModal">
                            <i class="bi bi-chat-dots-fill me-2"></i> Hỏi đáp Quản lý
                        </button>
                    </div>
                </div>
            </div>

            <!-- Floating Chat Toggle -->
            <div class="fab-chat">
                <button class="btn btn-primary-bl rounded-circle shadow-lg p-0 d-flex align-items-center justify-content-center" data-bs-toggle="modal" data-bs-target="#chatModal" title="Nhắn tin hỗ trợ">
                    <i class="bi bi-chat-fill text-white"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Video Modal -->
<div class="modal fade" id="videoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content bg-transparent border-0">
            <div class="modal-header border-0 pb-0 justify-content-end">
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div class="ratio ratio-16x9 rounded-4 overflow-hidden shadow-lg bg-black d-flex align-items-center justify-content-center">
                    <div class="text-white text-center">
                        <i class="bi bi-camera-video fs-1 mb-3"></i>
                        <h5>Đang tải Video Cinematic...</h5>
                        <p class="small text-white-50">Tích hợp Youtube/Vimeo API tại đây</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Chat Modal (Same as before but with minor UI polish) -->
<div class="modal fade" id="chatModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 rounded-4 shadow-premium overflow-hidden h-100">
            <div class="modal-header bg-primary text-white border-0 p-4">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-white rounded-circle p-2 d-flex align-items-center justify-content-center text-primary" style="width: 40px; height: 40px;">
                        <i class="bi bi-headset fs-5"></i>
                    </div>
                    <div>
                        <h5 class="modal-title fw-black mb-0">Hỗ trợ Trực tuyến</h5>
                        <small class="opacity-75">Quản lý <%= dest.name %></small>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 bg-light">
                <div id="chat-history" class="mb-4 overflow-auto" style="height: 350px;">
                    <% if (messages && messages.length > 0) { %>
                        <% messages.forEach(msg => { %>
                            <div class="mb-3 d-flex <%= msg.sender_id.length > 10 ? 'justify-content-end' : 'justify-content-start' %>">
                                <div class="p-3 rounded-4 small shadow-sm <%= msg.sender_id.length > 10 ? 'bg-primary text-white' : 'bg-white text-dark' %>" style="max-width: 85%;">
                                    <%= msg.message %>
                                    <div class="x-small opacity-50 mt-1 text-end"><%= new Date(msg.created_at).toLocaleTimeString('vi-VN', {hour: '2-digit', minute:'2-digit'}) %></div>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="text-center mb-4">
                            <span class="badge bg-secondary text-dark rounded-pill px-3 py-1">Hôm nay</span>
                        </div>
                        <div class="d-flex justify-content-start mb-3">
                            <div class="p-3 rounded-4 small shadow-sm bg-white text-dark" style="max-width: 85%;">
                                <strong>👋 Chào bạn!</strong><br>
                                Tôi là quản lý tại đây. Bạn cần hỗ trợ thông tin gì về giá cả, thời gian mở cửa, hay đặt chỗ trước không?
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
            <div class="modal-footer border-0 bg-white p-3">
                <div class="input-group">
                    <input type="text" id="chat-message" class="form-control border-0 bg-light rounded-pill ps-4 py-3" placeholder="Nhập tin nhắn..." onkeypress="if(event.key === 'Enter') sendChatMessage('<%= dest.id %>')">
                    <button class="btn btn-primary-bl rounded-circle ms-2 shadow-sm d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;" onclick="sendChatMessage('<%= dest.id %>')">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// Premium Dynamic Toast Notifications
function showToast(message, type = 'success') {
    const toast = document.createElement('div');
    toast.className = `position-fixed bottom-0 end-0 m-4 p-3 rounded-4 text-white shadow-premium animate__animated animate__fadeInUp bg-${type}`;
    toast.style.zIndex = '9999';
    toast.innerHTML = `<i class="bi bi-info-circle-fill me-2"></i> ${message}`;
    document.body.appendChild(toast);
    setTimeout(() => {
        toast.classList.replace('animate__fadeInUp', 'animate__fadeOutDown');
        setTimeout(() => toast.remove(), 500);
    }, 3000);
}

function handleLikeToggle(btn, destinationId) {
    axios.post(window.APP_CONFIG.apiUrl + '/destination/like', { destinationId })
        .then(res => {
            if (res.data.success) {
                const icon = btn.querySelector('i');
                const countSpan = document.getElementById('likes-count');
                countSpan.innerText = res.data.likesCount;
                if (res.data.liked) {
                    icon.className = 'bi bi-heart-fill text-danger';
                    btn.classList.add('text-danger');
                    showToast('Đã thêm vào danh sách yêu thích!', 'danger');
                } else {
                    icon.className = 'bi bi-heart';
                    btn.classList.remove('text-danger');
                    showToast('Đã bỏ yêu thích.', 'secondary');
                }
            }
        })
        .catch(err => {
            if (err.response?.status === 401) {
                showToast('Vui lòng đăng nhập để thích địa điểm.', 'warning');
            } else {
                showToast('Lỗi: ' + (err.response?.data?.message || err.message), 'warning');
            }
        });
}

function handleSaveToggle(btn, destinationId) {
    axios.post(window.APP_CONFIG.apiUrl + '/destination/save', { destinationId })
        .then(res => {
            if (res.data.success) {
                const icon = btn.querySelector('i');
                const textNode = btn.childNodes[btn.childNodes.length - 1];
                if (res.data.saved) {
                    icon.className = 'bi bi-bookmark-fill text-primary';
                    btn.classList.add('text-primary');
                    textNode.textContent = ' Đã lưu';
                    showToast('Đã lưu địa điểm thành công!', 'primary');
                } else {
                    icon.className = 'bi bi-bookmark';
                    btn.classList.remove('text-primary');
                    textNode.textContent = ' Lưu điểm đến';
                    showToast('Đã xóa khỏi danh sách lưu.', 'secondary');
                }
            }
        })
        .catch(err => {
            if (err.response?.status === 401) {
                showToast('Vui lòng đăng nhập để lưu địa điểm.', 'warning');
            } else {
                showToast('Lỗi: ' + (err.response?.data?.message || err.message), 'warning');
            }
        });
}

function shareDestination(name, url) {
    if (navigator.clipboard) {
        navigator.clipboard.writeText(url)
            .then(() => {
                showToast('Đã sao chép liên kết vào bộ nhớ tạm!', 'success');
            })
            .catch(() => {
                prompt('Sao chép liên kết dưới đây để chia sẻ:', url);
            });
    } else {
        prompt('Sao chép liên kết dưới đây để chia sẻ:', url);
    }
}

function addToJourney(destinationId) {
    axios.post(window.APP_CONFIG.apiUrl + '/destination/add-to-journey', { destinationId })
        .then(res => {
            if (res.data.success) {
                showToast('Đã thêm vào hành trình! <a href="/hanh-trinh-cua-toi" class="text-white fw-bold text-decoration-underline ms-2">Xem ngay</a>', 'success');
            }
        })
        .catch(err => {
            if (err.response?.status === 401) {
                showToast('Vui lòng đăng nhập để thêm địa điểm vào hành trình.', 'warning');
            } else {
                showToast('Lỗi: ' + (err.response?.data?.message || err.message), 'warning');
            }
        });
}

function startStorytelling() {
    alert('Đang kết nối thư viện Audio... Chào mừng bạn đến với <%= dest.name %>. Hãy đeo tai nghe để trải nghiệm không gian âm thanh thực tế!');
}

// Live Chat History Polling & Rendering
let lastMessagesCount = 0;
function pollMessages(destinationId) {
    axios.get(window.APP_CONFIG.apiUrl + '/get-messages?destinationId=' + destinationId)
        .then(res => {
            if (res.data.success && res.data.data) {
                const messages = res.data.data;
                if (messages.length !== lastMessagesCount) {
                    lastMessagesCount = messages.length;
                    renderChatHistory(messages);
                }
            }
        })
        .catch(err => console.error("Polling messages error:", err));
}

function renderChatHistory(messages) {
    const chatHistory = document.getElementById('chat-history');
    if (!chatHistory) return;

    let html = '';
    if (messages.length > 0) {
        messages.forEach(msg => {
            const currentUserId = '<%= user ? user.id : "" %>';
            const currentSessionDbId = '<%= sessionDbId %>';
            const isMe = (msg.sender_id && msg.sender_id === currentUserId) || (msg.sender_uuid && msg.sender_uuid === currentSessionDbId);
            
            const timeStr = new Date(msg.created_at).toLocaleTimeString('vi-VN', {hour: '2-digit', minute:'2-digit'});
            
            html += `
                <div class="mb-3 d-flex ${isMe ? 'justify-content-end' : 'justify-content-start'}">
                    <div class="p-3 rounded-4 small shadow-sm ${isMe ? 'bg-primary text-white' : 'bg-white text-dark'}" style="max-width: 85%;">
                        ${msg.message}
                        <div class="x-small opacity-50 mt-1 text-end">${timeStr}</div>
                    </div>
                </div>
            `;
        });
    } else {
        html = `
            <div class="text-center mb-4">
                <span class="badge bg-secondary text-dark rounded-pill px-3 py-1">Hôm nay</span>
            </div>
            <div class="d-flex justify-content-start mb-3">
                <div class="p-3 rounded-4 small shadow-sm bg-white text-dark" style="max-width: 85%;">
                    <strong>👋 Chào bạn!</strong><br>
                    Tôi là quản lý tại đây. Bạn cần hỗ trợ thông tin gì về giá cả, thời gian mở cửa, hay đặt chỗ trước không?
                </div>
            </div>
        `;
    }
    chatHistory.innerHTML = html;
    chatHistory.scrollTop = chatHistory.scrollHeight;
}

function sendChatMessage(destinationId) {
    const input = document.getElementById('chat-message');
    const message = input.value.trim();
    if (!message) return;

    input.value = ''; // Clear input for snappy UI

    axios.post(window.APP_CONFIG.apiUrl + '/send-message', {
        destinationId,
        message
    }).then(res => {
        if (res.data.success) {
            pollMessages(destinationId);
        }
    }).catch(err => {
        showToast('Lỗi gửi tin nhắn: ' + (err.response?.data?.message || err.message), 'warning');
    });
}

// DOM Setup
document.addEventListener('DOMContentLoaded', function() {
    const chatHistory = document.getElementById('chat-history');
    if (chatHistory) {
        chatHistory.scrollTop = chatHistory.scrollHeight;
    }
    
    // Start Chat Polling every 5 seconds if modal is active or page is open
    const destId = '<%= dest.id %>';
    pollMessages(destId);
    setInterval(() => {
        pollMessages(destId);
    }, 5000);
});
</script>

<style>
.play-video-btn:hover {
    transform: scale(1.1) !important;
    background: white;
    color: var(--v5-primary) !important;
}
.group-hover-scale { transition: none; }
.group-hover:hover .group-hover-scale { transform: none; }
.group-hover-opacity-100 { opacity: 0; }
.group-hover:hover .group-hover-opacity-100 { opacity: 1; }
.transition-opacity { transition: opacity 0.3s ease; }
.bg-gradient-to-t { background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 100%); }
.hero-bg, .hero-overlay-dark {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 0;
}
