<!-- Explore Catalog - Premium Redesign -->
<section class="py-5" style="margin-top: 80px; background: #f8faf9;">
    <div class="container py-4">
        
        <!-- Hero Header -->
        <div class="mb-5 text-center px-3" style="padding-top: 20px; padding-bottom: 20px;">
            <h1 class="fw-black text-dark mb-3 font-display display-5">Khám Phá Bình Lợi</h1>
            <p class="text-secondary mx-auto small mb-0" style="max-width: 550px; font-size: 0.95rem;">Lọc tìm những địa điểm chữa lành tâm hồn, trải nghiệm sinh thái sông nước và văn hóa bản địa lâu đời.</p>
        </div>

        <!-- Redesigned Search & Category Filter Bar -->
        <div class="card border-0 shadow-premium rounded-4 p-4 mb-5 bg-white reveal-up">
            <form action="/explore" method="GET" id="exploreSearchForm">
                <!-- Search bar -->
                <div class="position-relative mb-4">
                    <i class="bi bi-search position-absolute top-50 translate-middle-y text-muted" style="left: 20px;"></i>
                    <input type="text" name="q" class="form-control border-0 bg-light rounded-pill py-3 ps-5 pe-4 shadow-none" 
                        placeholder="Tên Vườn mai, Xưởng nhang, Chùa cổ..." 
                        value="<%= searchQuery || '' %>" style="font-size: 0.95rem; height: 52px;">
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold text-white btn-premium position-absolute end-0 top-50 translate-middle-y me-2" style="background: var(--primary); font-size: 0.88rem; height: 38px;">
                        Tìm kiếm
                    </button>
                </div>

                <!-- Capsule Filters -->
                <div class="d-flex flex-wrap gap-2 justify-content-center align-items-center">
                    <span class="small text-muted fw-bold text-uppercase me-2 d-none d-md-inline"><i class="bi bi-funnel me-1"></i> Danh mục:</span>
                    <button type="button" onclick="setFilterType('')" class="btn-filter-capsule <%= !currentType ? 'active' : '' %>">
                        <i class="bi bi-grid-fill"></i> Tất cả
                    </button>
                    <button type="button" onclick="setFilterType('temple')" class="btn-filter-capsule <%= currentType === 'temple' ? 'active' : '' %>">
                        <i class="bi bi-brightness-high-fill"></i> Tâm linh
                    </button>
                    <button type="button" onclick="setFilterType('park')" class="btn-filter-capsule <%= currentType === 'park' ? 'active' : '' %>">
                        <i class="bi bi-tree-fill"></i> Sinh thái
                    </button>
                    <button type="button" onclick="setFilterType('craft')" class="btn-filter-capsule <%= currentType === 'craft' ? 'active' : '' %>">
                        <i class="bi bi-flower1"></i> Làng nghề
                    </button>
                </div>
                <input type="hidden" name="type" id="filterTypeInput" value="<%= currentType || '' %>">
                
                <% if (searchQuery || currentType) { %>
                <div class="text-center mt-3 mb-0">
                    <a href="/explore" class="text-danger small fw-bold text-decoration-none"><i class="bi bi-x-circle me-1"></i>Xóa bộ lọc</a>
                </div>
                <% } %>
            </form>
        </div>

        <script>
        function setFilterType(val) {
            document.getElementById('filterTypeInput').value = val;
            document.getElementById('exploreSearchForm').submit();
        }
        </script>


        <!-- Destination Cards Catalog -->
        <div class="row g-4">
            <% destinations.forEach(dest => { %>
            <div class="col-md-6 col-lg-4 reveal-up">
                <a href="/explore/<%= dest.slug %>" class="text-decoration-none">
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 destination-card-custom" style="transition: all 0.3s ease;">
                        
                        <!-- Top Image Banner -->
                        <div class="position-relative" style="height: 240px; overflow: hidden;">
                            <img src="<%= fixImg(dest.cover_image) %>" class="w-100 h-100" style="object-fit: cover; transition: transform 0.5s;" alt="<%= dest.name %>">
                            
                            <!-- Custom type tag -->
                            <div class="position-absolute top-0 start-0 m-3">
                                <span class="badge bg-success bg-opacity-25 text-white border border-success border-opacity-50 rounded-pill px-3 py-2 text-uppercase fw-bold" style="font-size: 0.65rem; backdrop-filter: blur(8px);">
                                    <%= dest.type === 'temple' ? 'Tâm linh' : (dest.type === 'park' ? 'Sinh thái' : 'Làng nghề') %>
                                </span>
                            </div>

                            <!-- Rewards Point Tag -->
                            <div class="position-absolute bottom-0 end-0 m-3">
                                <span class="badge bg-dark bg-opacity-80 text-warning rounded-pill px-3 py-2 fw-bold" style="font-size: 0.68rem; backdrop-filter: blur(8px);">
                                    <i class="bi bi-gift-fill me-1"></i>+<%= dest.points %> ĐIỂM
                                </span>
                            </div>
                        </div>

                        <!-- Card Body Details -->
                        <div class="card-body p-4 d-flex flex-column justify-content-between">
                            <div>
                                <h5 class="fw-black text-dark mb-2" style="font-size: 1.15rem; font-family: 'Inter', sans-serif;"><%= dest.name %></h5>
                                
                                <div class="d-flex align-items-center gap-3 text-muted mb-3" style="font-size: 0.78rem;">
                                    <span><i class="bi bi-clock-fill text-success me-1"></i><%= dest.open_hours || '07:00 - 18:00' %></span>
                                    <span><i class="bi bi-geo-alt-fill text-danger me-1"></i>Bình Lợi</span>
                                </div>

                                <p class="text-muted mb-0 line-clamp-3 small" style="line-height: 1.6;"><%= dest.short_desc || dest.highlight %></p>
                            </div>

                            <!-- Footer Action Link -->
                            <div class="mt-4 pt-3 border-top border-light d-flex justify-content-between align-items-center">
                                <span class="text-primary small fw-bold">Chi tiết hành trình</span>
                                <i class="bi bi-arrow-right-circle-fill text-primary fs-5"></i>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
            <% }) %>
        </div>

        <!-- Empty Result Fallback -->
        <% if (destinations.length === 0) { %>
        <div class="card border-0 shadow-sm rounded-4 p-5 text-center bg-white reveal-up">
            <i class="bi bi-compass-fill display-1 text-muted opacity-25 mb-3 d-block"></i>
            <h4 class="fw-bold text-dark">Không tìm thấy địa điểm nào phù hợp</h4>
            <p class="text-muted small mb-4">Vui lòng thử lại với từ khóa khác hoặc xóa bớt các tiêu chí lọc.</p>
            <a href="/explore" class="btn btn-primary-bl rounded-pill px-4 py-2 fw-bold small">XÓA BỘ LỌC & XEM TẤT CẢ</a>
        </div>
        <% } %>

        <!-- Pagination Section -->
        <% if (destinations.length > 0) { %>
        <div class="mt-5 pt-4 border-top">
            <% 
            let queryParts = [];
            if (currentType) queryParts.push(`type=${currentType}`);
            if (searchQuery) queryParts.push(`q=${encodeURIComponent(searchQuery)}`);
            let paginationUrl = '/explore' + (queryParts.length > 0 ? '?' + queryParts.join('&') : '');
            %>
            <%- include('../partials/pagination', { pagination: pagination, paginationUrl: paginationUrl }) %>
        </div>
        <% } %>
    </div>
</section>

<style>
    .destination-card-custom:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 30px rgba(0,0,0,0.08) !important;
    }
    .destination-card-custom:hover img {
        transform: scale(1.06);
    }
    
    /* Capsule Filter buttons */
    .btn-filter-capsule {
        background: #ffffff;
        border: 1px solid rgba(0, 0, 0, 0.08);
        color: var(--text-secondary);
        padding: 8px 20px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.88rem;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all 0.25s ease;
        cursor: pointer;
    }
    .btn-filter-capsule:hover {
        background: var(--primary-50);
        border-color: var(--primary-200);
        color: var(--primary);
        transform: translateY(-1px);
    }
    .btn-filter-capsule.active {
        background: var(--primary);
        color: #ffffff;
        border-color: var(--primary);
        box-shadow: 0 4px 12px rgba(146, 39, 36, 0.15);
    }
</style>
