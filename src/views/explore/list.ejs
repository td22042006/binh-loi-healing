<section class="pt-5" style="padding-top: 100px !important;">
    <div class="container">
        <!-- Header + Search -->
        <div class="mb-4 reveal-up">
            <h1 class="section-title mb-1">Khám phá Bình Lợi</h1>
            <p class="text-muted mb-4" style="font-size: 0.95rem;">Tìm kiếm không gian chữa lành và trải nghiệm văn hóa độc bản.</p>
        </div>

        <!-- Search Bar -->
        <div class="mb-4 reveal-up">
            <form action="/explore" method="GET" id="exploreSearchForm">
                <div class="position-relative">
                    <i class="bi bi-search position-absolute top-50 translate-middle-y text-muted" style="left: 18px; font-size: 1.1rem;"></i>
                    <input type="text" name="q" class="form-control border rounded-4 py-3 ps-5 pe-4 shadow-sm" 
                        placeholder="Tìm kiếm theo tên, mô tả..." 
                        value="<%= searchQuery || '' %>" 
                        style="font-size: 0.95rem; background: var(--surface);">
                </div>
            </form>
        </div>

        <!-- Filter Pills (inline) -->
        <div class="d-flex flex-wrap gap-2 mb-4 reveal-up">
            <a href="/explore" class="btn <%= !currentType ? 'btn-primary text-white' : 'btn-outline-secondary' %> rounded-pill px-4 py-2 fw-bold" style="font-size: 0.82rem;">
                Tất cả
            </a>
            <a href="/explore?type=temple<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" 
               class="btn <%= currentType === 'temple' ? 'btn-primary text-white' : 'btn-outline-secondary' %> rounded-pill px-4 py-2 fw-bold" style="font-size: 0.82rem;">
                <i class="bi bi-bank me-1"></i> Tâm linh
            </a>
            <a href="/explore?type=park<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" 
               class="btn <%= currentType === 'park' ? 'btn-primary text-white' : 'btn-outline-secondary' %> rounded-pill px-4 py-2 fw-bold" style="font-size: 0.82rem;">
                <i class="bi bi-tree me-1"></i> Sinh thái
            </a>
            <a href="/explore?type=craft<%= searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '' %>" 
               class="btn <%= currentType === 'craft' ? 'btn-primary text-white' : 'btn-outline-secondary' %> rounded-pill px-4 py-2 fw-bold" style="font-size: 0.82rem;">
                <i class="bi bi-palette me-1"></i> Làng nghề
            </a>
        </div>

        <% if (searchQuery) { %>
        <div class="mb-4">
            <span class="badge bg-light text-dark border px-3 py-2 rounded-pill shadow-sm" style="font-size: 0.85rem;">
                Kết quả cho: <strong class="text-primary">"<%= searchQuery %>"</strong>
                <a href="/explore" class="text-danger ms-2 text-decoration-none"><i class="bi bi-x-circle-fill"></i></a>
            </span>
        </div>
        <% } %>

        <!-- Results count -->
        <p class="text-muted small mb-4 fw-bold"><%= destinations.length %> địa điểm</p>

        <!-- Destination Grid -->
        <div class="row g-4">
            <% destinations.forEach(dest => { %>
            <div class="col-md-6 col-lg-4">
                <a href="/explore/<%= dest.slug %>" class="text-decoration-none">
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100" style="transition: all 0.3s ease;">
                        <!-- Image -->
                        <div class="position-relative" style="height: 220px;">
                            <img src="<%= fixImg(dest.cover_image) %>" class="w-100 h-100" style="object-fit: cover;" alt="<%= dest.name %>">
                            <!-- Type badge -->
                            <div class="position-absolute top-0 start-0 m-3">
                                <span class="badge-nature"><%= dest.type %></span>
                            </div>
                            <!-- Points -->
                            <div class="position-absolute bottom-0 end-0 m-3">
                                <span class="badge bg-dark bg-opacity-75 text-warning rounded-pill px-2 py-1" style="font-size: 0.72rem;">
                                    <i class="bi bi-stars me-1"></i>+<%= dest.points %> điểm
                                </span>
                            </div>
                        </div>
                        <!-- Body -->
                        <div class="card-body p-3">
                            <h5 class="fw-bold mb-1 text-dark" style="font-size: 1rem;"><%= dest.name %></h5>
                            <div class="d-flex align-items-center gap-2 mb-2 text-muted" style="font-size: 0.78rem;">
                                <span><i class="bi bi-clock me-1"></i><%= dest.open_hours || '07:00 - 18:00' %></span>
                                <% if (dest.is_active) { %>
                                <span class="text-success fw-bold"><i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i>Mở cửa</span>
                                <% } %>
                            </div>
                            <p class="text-muted mb-0 line-clamp-2" style="font-size: 0.82rem;"><%= dest.short_desc || dest.highlight %></p>
                        </div>
                    </div>
                </a>
            </div>
            <% }) %>
        </div>

        <% if (destinations.length === 0) { %>
        <div class="text-center py-5">
            <i class="bi bi-compass display-1 text-muted opacity-25"></i>
            <p class="text-muted mt-3">Không tìm thấy địa điểm nào phù hợp.</p>
            <a href="/explore" class="btn btn-outline-primary rounded-pill">Xem tất cả</a>
        </div>
        <% } %>

        <!-- Pagination -->
        <div class="mt-5 pt-4 border-top">
            <% 
            let queryParts = [];
            if (currentType) queryParts.push(`type=${currentType}`);
            if (currentSeason) queryParts.push(`season=${currentSeason}`);
            if (searchQuery) queryParts.push(`q=${encodeURIComponent(searchQuery)}`);
            let paginationUrl = '/explore' + (queryParts.length > 0 ? '?' + queryParts.join('&') : '');
            %>
            <%- include('../partials/pagination', { pagination: pagination, paginationUrl: paginationUrl }) %>
        </div>
    </div>
</section>

<style>
    .card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg) !important; }
    .card img { transition: transform 0.4s ease; }
    .card:hover img { transform: scale(1.05); }
</style>
