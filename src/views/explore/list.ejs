<!-- Vibrant Explore Dashboard — The Journey of Stories -->
<div class="row g-4">
    <!-- Main Discovery Area -->
    <div class="col-lg-8">
        <div class="widget-card p-4">
            <div class="d-flex flex-wrap justify-content-between align-items-center mb-5 gap-3">
                <div>
                    <h3 class="fw-black font-display mb-1" style="color: var(--primary);">Khám phá Bình Lợi</h3>
                    <p class="text-muted small mb-0">Hơn 25 điểm đến mang đậm câu chuyện bản sắc</p>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-primary-bl rounded-pill px-4 shadow-sm">Tất cả</button>
                    <button class="btn btn-outline-danger rounded-pill px-3 fw-bold"><i class="bi bi-heart-fill me-1"></i> Chữa lành</button>
                    <button class="btn btn-outline-info rounded-pill px-3 fw-bold"><i class="bi bi-tree-fill me-1"></i> Sinh thái</button>
                </div>
            </div>

            <!-- Bento-style Grid -->
            <div class="row g-4">
                <% destinations.forEach((dest, i) => { 
                    const isFeature = i % 5 === 0;
                    const typeColor = dest.type === 'culture' ? '#f59e0b' : (dest.type === 'nature' ? '#10b981' : '#ef4444');
                %>
                <div class="<%= isFeature ? 'col-12' : 'col-md-6' %>">
                    <a href="/explore/<%= dest.slug %>" class="text-decoration-none">
                        <div class="card-heal p-0 overflow-hidden border-0 shadow-lg position-relative group" 
                             style="height: <%= isFeature ? '320px' : '260px' %>;">
                            <img src="<%= fixImg(dest.cover_image) %>" class="w-100 h-100 object-fit-cover transition-all group-hover-scale" style="filter: brightness(0.85);">
                            
                            <!-- Content Overlay -->
                            <div class="position-absolute top-0 start-0 w-100 h-100 p-4 d-flex flex-column justify-content-between" 
                                 style="background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, transparent 60%); z-index: 5;">
                                <div class="d-flex justify-content-between align-items-start">
                                    <span class="badge rounded-pill px-3 py-2 fw-black shadow-lg" 
                                          style="background: <%= typeColor %>; color: white; font-size: 0.65rem; letter-spacing: 1px;">
                                        <%= dest.type.toUpperCase() %>
                                    </span>
                                    <div class="bg-white bg-opacity-20 backdrop-blur-md rounded-circle d-flex align-items-center justify-content-center shadow-lg" 
                                         style="width: 40px; height: 40px; border: 1px solid rgba(255,255,255,0.2);">
                                        <i class="bi bi-bookmark-heart text-white fs-5"></i>
                                    </div>
                                </div>
                                
                                <div>
                                    <h4 class="text-white fw-black font-display mb-2" style="font-size: <%= isFeature ? '1.8rem' : '1.4rem' %>;"><%= dest.name %></h4>
                                    <div class="d-flex align-items-center gap-3">
                                        <span class="text-white opacity-75 x-small fw-bold"><i class="bi bi-geo-alt-fill me-1"></i><%= dest.address || 'Bình Lợi' %></span>
                                        <span class="text-warning x-small fw-black"><i class="bi bi-plus-circle-fill me-1"></i>+1 STAMP</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
                <% }) %>
            </div>
        </div>
    </div>

    <!-- Right Sidebar: Interactive Journey Bar & Map -->
    <div class="col-lg-4">
        <!-- VIBRANT JOURNEY PLANNER -->
        <div class="widget-card p-4 mb-4 border-0 shadow-lg" style="background: white;">
            <h5 class="fw-black font-display mb-4 text-primary">Lộ trình gợi ý</h5>
            <div class="d-flex flex-column gap-3 position-relative">
                <div class="position-absolute start-0 h-100 border-start border-2 border-dashed border-primary opacity-10" style="left: 17px; z-index: 1;"></div>
                
                <% ['Vườn Mai Bình Lợi', 'Xưởng Nhang Minh', 'Chùa Pháp Tạng'].forEach((step, i) => { %>
                <div class="d-flex gap-3 align-items-center position-relative" style="z-index: 5;">
                    <div class="rounded-circle d-flex align-items-center justify-content-center shadow-sm" 
                         style="width: 34px; height: 34px; background: <%= i === 0 ? 'var(--grad-main)' : 'white' %>; border: 2px solid var(--primary); color: <%= i === 0 ? 'white' : 'var(--primary)' %>; font-size: 0.8rem; font-weight: 800;">
                        <%= i + 1 %>
                    </div>
                    <div>
                        <span class="d-block fw-bold <%= i === 0 ? 'text-primary' : 'text-muted' %>" style="font-size: 0.85rem;"><%= step %></span>
                        <span class="x-small text-muted opacity-50">30-45 phút trải nghiệm</span>
                    </div>
                </div>
                <% }) %>
            </div>
            
            <div class="p-4 mt-4 rounded-4" style="background: var(--bg-body); border: 1px solid var(--border-glass);">
                <p class="x-small fw-bold text-muted mb-3"><i class="bi bi-info-circle me-1"></i> Dựa trên sở thích của bạn: <b>Thiên nhiên & Chữa lành</b></p>
                <a href="/journey/start" class="btn btn-premium w-100 py-3 rounded-pill shadow-lg">BẮT ĐẦU NGAY</a>
            </div>
        </div>

        <!-- QUICK MAP WIDGET -->
        <div class="widget-card p-0 overflow-hidden shadow-lg border-0" style="height: 250px;">
            <div class="p-3 position-absolute w-100 h-100 d-flex flex-column justify-content-between" style="z-index: 5; background: rgba(15, 61, 46, 0.4);">
                <span class="badge bg-white text-dark rounded-pill px-3 py-2 fw-black shadow-sm align-self-start" style="font-size: 0.6rem;">MAPS</span>
                <div class="text-center">
                    <h5 class="text-white fw-black mb-1">Bản đồ thực tế ảo</h5>
                    <p class="text-white opacity-75 x-small mb-3">Xem vị trí của bạn trên bản đồ</p>
                    <a href="/map" class="btn btn-light rounded-pill px-4 btn-sm fw-bold shadow-lg">MỞ BẢN ĐỒ</a>
                </div>
            </div>
            <img src="/images/hero-1.png" class="w-100 h-100 object-fit-cover blur-sm">
        </div>
    </div>
</div>

<style>
    .group-hover-scale { transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
    .card-heal:hover .group-hover-scale { transform: scale(1.05); }
    .backdrop-blur-md { backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); }
</style>
