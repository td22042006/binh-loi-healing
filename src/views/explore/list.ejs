<!-- Explore Catalog - Premium Redesign -->
<section class="py-5" style="margin-top: 80px; background: #f8faf9;">
    <div class="container py-4">
        
        <!-- Header Section -->
        <div class="text-center mb-5 reveal-up">
            <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 mb-2 text-uppercase fw-bold" style="letter-spacing: 1px; font-size: 0.72rem;">
                <i class="bi bi-compass-fill"></i> Hệ bản đồ số
            </span>
            <h1 class="fw-black text-dark mb-1 letter-spacing-sm" style="font-family: 'Inter', sans-serif;">Khám Phá Bình Lợi</h1>
            <p class="text-muted small mx-auto" style="max-width: 500px;">Lọc tìm những địa điểm chữa lành tâm hồn, trải nghiệm sinh thái sông nước và văn hóa bản địa lâu đời.</p>
        </div>

        <!-- Premium Search & Multi-Filter Control Board -->
        <div class="card border-0 shadow-premium rounded-4 p-4 mb-5 bg-white reveal-up">
            <form action="/explore" method="GET" id="exploreSearchForm">
                <div class="row g-3">
                    <!-- Search Input -->
                    <div class="col-lg-5 col-md-12">
                        <label class="form-label text-muted fw-bold x-small text-uppercase mb-2"><i class="bi bi-search text-success"></i> Từ khóa tìm kiếm</label>
                        <div class="position-relative">
                            <i class="bi bi-search position-absolute top-50 translate-middle-y text-muted" style="left: 16px;"></i>
                            <input type="text" name="q" class="form-control border bg-light bg-opacity-50 rounded-pill py-2 ps-5 pe-4 shadow-none small" 
                                placeholder="Tên vườn mai, xưởng nhang, chùa cổ..." 
                                value="<%= searchQuery || '' %>">
                        </div>
                    </div>

                    <!-- Category Type Filter -->
                    <div class="col-lg-4 col-md-6">
                        <label class="form-label text-muted fw-bold x-small text-uppercase mb-2"><i class="bi bi-tag text-primary"></i> Danh mục trải nghiệm</label>
                        <select name="type" class="form-select border bg-light bg-opacity-50 rounded-pill py-2 px-3 shadow-none small" onchange="this.form.submit()">
                            <option value="">Tất cả danh mục</option>
                            <option value="temple" <%= currentType === 'temple' ? 'selected' : '' %>>Tâm linh - Chữa lành</option>
                            <option value="park" <%= currentType === 'park' ? 'selected' : '' %>>Sinh thái - Sông nước</option>
                            <option value="craft" <%= currentType === 'craft' ? 'selected' : '' %>>Làng nghề - Bản sắc</option>
                        </select>
                    </div>

                    <!-- Seasonal Experience Filter -->
                    <div class="col-lg-3 col-md-6">
                        <label class="form-label text-muted fw-bold x-small text-uppercase mb-2"><i class="bi bi-cloud-sun text-warning"></i> Mùa trải nghiệm đẹp nhất</label>
                        <select name="season" class="form-select border bg-light bg-opacity-50 rounded-pill py-2 px-3 shadow-none small" onchange="this.form.submit()">
                            <option value="">Mọi thời điểm trong năm</option>
                            <option value="spring" <%= currentSeason === 'spring' ? 'selected' : '' %>>Mùa xuân (Mai Vàng khoe sắc)</option>
                            <option value="summer" <%= currentSeason === 'summer' ? 'selected' : '' %>>Mùa hạ (Miệt vườn cây trái)</option>
                            <option value="autumn" <%= currentSeason === 'autumn' ? 'selected' : '' %>>Mùa thu (Lễ hội thả hoa đăng)</option>
                            <option value="winter" <%= currentSeason === 'winter' ? 'selected' : '' %>>Mùa đông (Mùa cấy cẩm chướng)</option>
                        </select>
                    </div>
                </div>

                <!-- Submit and Reset Buttons -->
                <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top border-light">
                    <span class="text-muted small fw-bold"><%= destinations.length %> địa điểm tìm thấy</span>
                    <div class="d-flex gap-2">
                        <% if (searchQuery || currentType || currentSeason) { %>
                        <a href="/explore" class="btn btn-light rounded-pill px-4 py-2 small fw-bold"><i class="bi bi-x-circle me-1"></i> Xóa bộ lọc</a>
                        <% } %>
                        <button type="submit" class="btn btn-primary-bl rounded-pill px-4 py-2 small fw-bold">ÁP DỤNG BỘ LỌC</button>
                    </div>
                </div>
            </form>
        </div>

        <!-- Destination Cards Catalog -->
        <div class="row g-4">
            <% destinations.forEach(dest => { %>
            <div class="col-md-6 col-lg-4 reveal-up">
                <a href="/explore/<%= dest.slug %>" class="text-decoration-none">
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 destination-card-custom" style="transition: all 0.3s ease;">
                        
                        <!-- Top Image Banner -->
                        <div class="position-relative" style="height: 240px; overflow: hidden;">
                            <img src="<%= fixImg(dest.cover_image) %>" class="w-100 h-100" style="object-fit: cover; transition: transform 0.5s;" alt="<%= dest.name %>">
                            
                            <!-- Custom type tag -->
                            <div class="position-absolute top-0 start-0 m-3">
                                <span class="badge bg-success bg-opacity-25 text-white border border-success border-opacity-50 rounded-pill px-3 py-2 text-uppercase fw-bold" style="font-size: 0.65rem; backdrop-filter: blur(8px);">
                                    <%= dest.type === 'temple' ? 'Tâm linh' : (dest.type === 'park' ? 'Sinh thái' : 'Làng nghề') %>
                                </span>
                            </div>

                            <!-- Rewards Point Tag -->
                            <div class="position-absolute bottom-0 end-0 m-3">
                                <span class="badge bg-dark bg-opacity-80 text-warning rounded-pill px-3 py-2 fw-bold" style="font-size: 0.68rem; backdrop-filter: blur(8px);">
                                    <i class="bi bi-gift-fill me-1"></i>+<%= dest.points %> ĐIỂM
                                </span>
                            </div>
                        </div>

                        <!-- Card Body Details -->
                        <div class="card-body p-4 d-flex flex-column justify-content-between">
                            <div>
                                <h5 class="fw-black text-dark mb-2" style="font-size: 1.15rem; font-family: 'Inter', sans-serif;"><%= dest.name %></h5>
                                
                                <div class="d-flex align-items-center gap-3 text-muted mb-3" style="font-size: 0.78rem;">
                                    <span><i class="bi bi-clock-fill text-success me-1"></i><%= dest.open_hours || '07:00 - 18:00' %></span>
                                    <span><i class="bi bi-geo-alt-fill text-danger me-1"></i>Bình Lợi</span>
                                </div>

                                <p class="text-muted mb-0 line-clamp-3 small" style="line-height: 1.6;"><%= dest.short_desc || dest.highlight %></p>
                            </div>

                            <!-- Footer Action Link -->
                            <div class="mt-4 pt-3 border-top border-light d-flex justify-content-between align-items-center">
                                <span class="text-primary small fw-bold">Chi tiết hành trình</span>
                                <i class="bi bi-arrow-right-circle-fill text-primary fs-5"></i>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
            <% }) %>
        </div>

        <!-- Empty Result Fallback -->
        <% if (destinations.length === 0) { %>
        <div class="card border-0 shadow-sm rounded-4 p-5 text-center bg-white reveal-up">
            <i class="bi bi-compass-fill display-1 text-muted opacity-25 mb-3 d-block"></i>
            <h4 class="fw-bold text-dark">Không tìm thấy địa điểm nào phù hợp</h4>
            <p class="text-muted small mb-4">Vui lòng thử lại với từ khóa khác hoặc xóa bớt các tiêu chí lọc.</p>
            <a href="/explore" class="btn btn-primary-bl rounded-pill px-4 py-2 fw-bold small">XÓA BỘ LỌC & XEM TẤT CẢ</a>
        </div>
        <% } %>

        <!-- Pagination Section -->
        <% if (destinations.length > 0) { %>
        <div class="mt-5 pt-4 border-top">
            <% 
            let queryParts = [];
            if (currentType) queryParts.push(`type=${currentType}`);
            if (currentSeason) queryParts.push(`season=${currentSeason}`);
            if (searchQuery) queryParts.push(`q=${encodeURIComponent(searchQuery)}`);
            let paginationUrl = '/explore' + (queryParts.length > 0 ? '?' + queryParts.join('&') : '');
            %>
            <%- include('../partials/pagination', { pagination: pagination, paginationUrl: paginationUrl }) %>
        </div>
        <% } %>
    </div>
</section>

<style>
    .destination-card-custom:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 30px rgba(0,0,0,0.08) !important;
    }
    .destination-card-custom:hover img {
        transform: scale(1.06);
    }
</style>
