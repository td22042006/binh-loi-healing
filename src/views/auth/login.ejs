<section class="site-section d-flex align-items-center" style="min-height: 80vh;">
    <div class="container-site">
        <div class="row justify-content-center w-100 m-0">
            <div class="col-12 col-sm-10 col-md-8 col-lg-5 col-xl-4">
                <div class="card-bl p-4 p-md-5 shadow-lg border-0 animate__animated animate__fadeIn">
                    <div class="text-center mb-4">
                        <img src="<%= baseUrl %>/images/hero-1.png" class="rounded-circle mb-3 shadow-sm" style="width: 70px; height: 70px; object-fit: cover;">
                        <h4 class="fw-black text-primary mb-1">Bình Lợi Healing</h4>
                        <p class="text-muted small">Đăng nhập để nhận Passport du lịch số</p>
                    </div>

                    <% if (error) { %>
                        <div class="alert alert-danger x-small py-2"><%= error %></div>
                    <% } %>

                    <form action="<%= baseUrl %>/auth/login" method="POST" class="mb-3">
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Email</label>
                            <input type="email" name="email" class="form-control rounded-pill px-3 py-2" placeholder="email@example.com" required>
                        </div>
                        <div class="mb-4">
                            <label class="form-label small fw-bold">Mật khẩu</label>
                            <input type="password" name="password" class="form-control rounded-pill px-3 py-2" placeholder="••••••••" required>
                        </div>
                        <button type="submit" class="btn btn-primary-bl w-100 py-2 rounded-pill fw-bold">Đăng nhập</button>
                    </form>

                    <div class="text-center position-relative mb-4">
                        <hr class="opacity-10">
                        <span class="position-absolute top-50 start-50 translate-middle bg-white px-2 text-muted x-small">Hoặc tiếp tục với</span>
                    </div>

                    <div class="row g-2 mb-4">
                        <div class="col-6">
                            <button class="btn btn-outline-bl btn-sm w-100 rounded-pill" onclick="alert('Google Login đang kết nối...')">
                                <i class="bi bi-google me-1"></i> Google
                            </button>
                        </div>
                        <div class="col-6">
                            <button class="btn btn-outline-bl btn-sm w-100 rounded-pill" onclick="alert('Facebook Login đang kết nối...')">
                                <i class="bi bi-facebook me-1"></i> Facebook
                            </button>
                        </div>
                    </div>

                    <div class="text-center pt-3 border-top mt-2">
                        <p class="small text-muted mb-0">Chưa có tài khoản? <a href="#" class="text-primary fw-bold text-decoration-none">Đăng ký ngay</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
