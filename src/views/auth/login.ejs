<section class="auth-page-glass">
    <!-- Background Elements -->
    <div class="auth-bg-image"></div>
    <div class="auth-overlay"></div>
    
    <!-- Floating Orbs -->
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>

    <div class="container d-flex align-items-center justify-content-center min-vh-100 position-relative z-index-1">
        <div class="auth-glass-box shadow-premium p-4 p-md-5">
            
            <!-- Branding -->
            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center bg-white rounded-circle shadow-sm p-3 mb-3" style="width: 80px; height: 80px;">
                    <img src="<%= baseUrl %>/images/logo.png" alt="Logo" class="w-100 h-100 object-fit-contain">
                </div>
                <h3 class="fw-black text-white letter-spacing-sm">BÌNH LỢI HEALING</h3>
                <p class="text-white-50 small mb-0">Hệ sinh thái Du lịch Trải nghiệm số</p>
            </div>

            <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert alert-danger bg-danger bg-opacity-25 text-white border-0 rounded-4 small text-center mb-4 backdrop-blur-md">
                    <i class="bi bi-exclamation-circle me-1"></i> <%= error %>
                </div>
            <% } %>

            <!-- Real OAuth One Click Login Zone -->
            <div class="one-click-zone mb-4">
                <a href="<%= baseUrl %>/auth/google" class="btn btn-glass-social w-100 rounded-pill mb-3 position-relative overflow-hidden text-decoration-none">
                    <div class="d-flex align-items-center justify-content-center gap-3 position-relative z-index-1">
                        <img src="https://cdn-icons-png.flaticon.com/512/300/300221.png" alt="Google" width="24" height="24">
                        <span class="fw-bold">Tiếp tục với Google</span>
                    </div>
                </a>
                <a href="<%= baseUrl %>/auth/facebook" class="btn btn-glass-social w-100 rounded-pill position-relative overflow-hidden text-decoration-none">
                    <div class="d-flex align-items-center justify-content-center gap-3 position-relative z-index-1">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/b/b8/2021_Facebook_icon.svg/2048px-2021_Facebook_icon.svg.png" alt="Facebook" width="24" height="24">
                        <span class="fw-bold">Tiếp tục với Facebook</span>
                    </div>
                </a>
            </div>

            <div class="d-flex align-items-center mb-4">
                <hr class="flex-grow-1 border-white opacity-25">
                <span class="px-3 text-white-50 x-small text-uppercase tracking-widest">Hoặc dùng Email</span>
                <hr class="flex-grow-1 border-white opacity-25">
            </div>

            <!-- Standard Form -->
            <form action="<%= baseUrl %>/auth/login" method="POST">
                <div class="form-floating mb-3">
                    <input type="email" name="email" class="form-control form-control-glass rounded-4" id="floatingEmail" placeholder="name@example.com" required>
                    <label for="floatingEmail" class="text-white-50">Email / Số điện thoại</label>
                </div>
                <div class="form-floating mb-4">
                    <input type="password" name="password" class="form-control form-control-glass rounded-4" id="floatingPassword" placeholder="Password" required>
                    <label for="floatingPassword" class="text-white-50">Mật khẩu / OTP</label>
                </div>
                
                <div class="d-flex justify-content-between align-items-center mb-4 text-white-50 small">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="rememberMe" checked>
                        <label class="form-check-label" for="rememberMe">Ghi nhớ đăng nhập</label>
                    </div>
                    <a href="#" class="text-white text-decoration-none fw-bold">Quên mật khẩu?</a>
                </div>

                <button type="submit" class="btn btn-primary-bl w-100 py-3 rounded-pill fw-black text-uppercase shadow-lg">
                    Đăng nhập hệ thống
                </button>
            </form>

            <div class="text-center mt-4">
                <span class="text-white-50 small">Chưa có tài khoản?</span>
                <a href="#" class="text-white fw-bold ms-1 text-decoration-none">Đăng ký ngay</a>
            </div>
        </div>
    </div>
</section>

<!-- No longer need the fake mock processing script -->

<style>
/* Glassmorphism Auth UI */
.auth-page-glass {
    position: relative;
    overflow: hidden;
    background-color: #1a1a2e;
}

.auth-bg-image {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background-image: url('/images/hero-1.png');
    background-size: cover;
    background-position: center;
    filter: blur(8px) brightness(0.8);
    transform: scale(1.05); /* hide blurred edges */
    z-index: 0;
}

.auth-overlay {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: linear-gradient(135deg, rgba(20, 40, 20, 0.6) 0%, rgba(10, 20, 30, 0.8) 100%);
    z-index: 1;
}

.orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    z-index: 2;
    animation: float 10s ease-in-out infinite alternate;
}

.orb-1 {
    top: -10%; left: -10%;
    width: 400px; height: 400px;
    background: rgba(103, 178, 111, 0.4);
}

.orb-2 {
    bottom: -10%; right: -10%;
    width: 300px; height: 300px;
    background: rgba(200, 169, 110, 0.4);
    animation-delay: -5s;
}

@keyframes float {
    0% { transform: translate(0, 0); }
    100% { transform: translate(50px, 50px); }
}

.z-index-1 { z-index: 10; }

.auth-glass-box {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 30px;
    width: 100%;
    max-width: 450px;
    position: relative;
    overflow: hidden;
}

/* Shine effect */
.auth-glass-box::before {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 50%; height: 100%;
    background: linear-gradient(to right, rgba(255,255,255,0) 0%, rgba(255,255,255,0.1) 50%, rgba(255,255,255,0) 100%);
    transform: skewX(-20deg);
    animation: shine 6s infinite;
}

@keyframes shine {
    0% { left: -100%; }
    20% { left: 200%; }
    100% { left: 200%; }
}

.btn-glass-social {
    background: rgba(255, 255, 255, 0.9);
    color: #333;
    border: 1px solid rgba(255,255,255,0.5);
    padding: 14px 20px;
    transition: all 0.3s;
}

.btn-glass-social:hover {
    background: #fff;
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
}

.form-control-glass {
    background: rgba(0, 0, 0, 0.2) !important;
    border: 1px solid rgba(255, 255, 255, 0.1) !important;
    color: white !important;
}

.form-control-glass:focus {
    background: rgba(0, 0, 0, 0.3) !important;
    border-color: rgba(255, 255, 255, 0.3) !important;
    box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.05) !important;
}

.form-control-glass::placeholder { color: transparent; }

/* Customizing Form Floating label for dark background */
.form-floating > .form-control-glass:focus ~ label,
.form-floating > .form-control-glass:not(:placeholder-shown) ~ label {
    color: rgba(255, 255, 255, 0.8) !important;
    transform: scale(0.85) translateY(-0.5rem) translateX(0.15rem);
    background-color: transparent !important;
}
.form-floating > label {
    padding-left: 1.25rem;
}

@media (max-width: 575.98px) {
    .auth-glass-box {
        border-radius: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        border: none;
        background: rgba(255, 255, 255, 0.05);
    }
}
</style>
