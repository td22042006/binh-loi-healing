<section class="auth-page-fix">
    <div class="auth-box">
        <div class="auth-header">
            <img src="<%= baseUrl %>/images/logo.png" alt="Logo">
            <h2>Bình Lợi Healing</h2>
            <p>Đăng nhập để nhận Passport số</p>
        </div>

        <% if (error) { %>
            <div class="auth-alert"><%= error %></div>
        <% } %>

        <form action="<%= baseUrl %>/auth/login" method="POST">
            <div class="auth-input-group">
                <label>Email</label>
                <input type="email" name="email" placeholder="email@example.com" required>
            </div>
            <div class="auth-input-group">
                <label>Mật khẩu</label>
                <input type="password" name="password" placeholder="••••••••" required>
            </div>
            <button type="submit" class="auth-submit">Đăng nhập</button>
        </form>

        <div class="auth-divider">
            <span>Hoặc đăng nhập với</span>
        </div>

        <div class="auth-social">
            <button onclick="handleGoogleLogin()" class="btn-google">
                <i class="bi bi-google"></i> Google
            </button>
            <button onclick="alert('Facebook Login coming soon...')" class="btn-facebook">
                <i class="bi bi-facebook"></i> Facebook
            </button>
        </div>

        <script src="https://accounts.google.com/gsi/client" async defer></script>
        <script>
            function handleGoogleLogin() {
                // In a real production app, you'd use the Google Identity Services SDK here
                // For this demo, we'll simulate the successful response and redirect
                const mockData = {
                    platform: 'google',
                    email: 'visitor@gmail.com',
                    name: 'Guest User',
                    avatar: 'https://lh3.googleusercontent.com/a/ACg8ocL...',
                    id: 'google-123'
                };
                
                fetch('/auth/social', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(mockData)
                }).then(r => r.json()).then(data => {
                    if(data.success) window.location.href = data.redirect;
                });
            }
        </script>

        <div class="auth-footer">
            Chưa có tài khoản? <a href="#">Đăng ký</a>
        </div>
    </div>
</section>

<style>
.auth-page-fix {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f8f9fa;
    padding: 20px;
}
.auth-box {
    background: #fff;
    width: 100%;
    max-width: 400px;
    padding: 40px 30px;
    border-radius: 20px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.05);
    border: 1px solid #eee;
}
.auth-header { text-align: center; margin-bottom: 30px; }
.auth-header img { height: 60px; margin-bottom: 15px; }
.auth-header h2 { font-weight: 800; color: #5c8a5e; margin-bottom: 5px; font-size: 1.5rem; }
.auth-header p { color: #666; font-size: 0.9rem; }

.auth-alert { 
    background: #fff5f5; color: #e53e3e; padding: 10px; border-radius: 10px; 
    font-size: 0.85rem; text-align: center; margin-bottom: 20px; border: 1px solid #feb2b2;
}

.auth-input-group { margin-bottom: 20px; }
.auth-input-group label { display: block; font-weight: 700; font-size: 0.8rem; margin-bottom: 8px; color: #444; }
.auth-input-group input { 
    width: 100%; padding: 12px 15px; border-radius: 12px; border: 1px solid #ddd; 
    font-size: 0.95rem; outline: none; transition: border 0.3s;
}
.auth-input-group input:focus { border-color: #5c8a5e; }

.auth-submit { 
    width: 100%; padding: 12px; border-radius: 12px; border: none; 
    background: #5c8a5e; color: #fff; font-weight: 700; cursor: pointer; transition: 0.3s;
}
.auth-submit:hover { background: #4a6d4b; }

.auth-divider { position: relative; text-align: center; margin: 30px 0; }
.auth-divider::before { content: ""; position: absolute; top: 50%; left: 0; width: 100%; height: 1px; background: #eee; }
.auth-divider span { position: relative; background: #fff; padding: 0 15px; color: #999; font-size: 0.75rem; }

.auth-social { display: flex; gap: 15px; margin-bottom: 30px; }
.auth-social button { 
    flex: 1; padding: 12px; border-radius: 12px; border: 1px solid #eee; 
    background: #fff; font-size: 0.9rem; cursor: pointer; transition: 0.3s;
    display: flex; align-items: center; justify-content: center; gap: 10px;
    font-weight: 700;
}
.btn-google { color: #db4437; border-color: #fbd5d2 !important; }
.btn-google:hover { background: #fdf2f1 !important; }
.btn-facebook { color: #4267b2; border-color: #d1d9eb !important; }
.btn-facebook:hover { background: #f0f2f5 !important; }

.auth-footer { text-align: center; font-size: 0.85rem; color: #666; }
.auth-footer a { color: #5c8a5e; font-weight: 700; text-decoration: none; }

@media (max-width: 450px) {
    .auth-box { padding: 30px 20px; border-radius: 0; box-shadow: none; border: none; max-width: 100%; height: 100%; }
    .auth-page-fix { padding: 0; background: #fff; }
}
</style>
