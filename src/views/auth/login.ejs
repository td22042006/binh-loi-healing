<section class="auth-section min-vh-100 d-flex align-items-center position-relative overflow-hidden py-5">
    <!-- Cinematic Background -->
    <div class="position-absolute top-0 start-0 w-100 h-100" style="background: url('/images/hero-3.png') center/cover; z-index: 0; filter: brightness(0.4);"></div>

    <div class="container position-relative z-index-10">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-8">
                
                <div class="text-center mb-4 reveal-up">
                    <img src="/images/logo.png" alt="Logo" height="60" class="mb-3" onerror="this.style.display='none'">
                    <h2 class="text-white fw-black tracking-widest text-uppercase">Bình Lợi Healing</h2>
                    <p class="text-white-50 small">Khởi đầu hành trình chữa lành của bạn</p>
                </div>

                <div class="card-bl border-0 shadow-premium rounded-5 overflow-hidden bg-white bg-opacity-10 backdrop-blur-lg reveal-up" style="transition-delay: 0.1s">
                    <div class="p-4 p-md-5">
                        
                        <!-- Social Logins (Primary) -->
                        <div class="row g-2 mb-4">
                            <div class="col-6">
                                <a href="/auth/google" class="btn btn-light w-100 rounded-pill shadow-sm py-2 d-flex align-items-center justify-content-center gap-2">
                                    <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" height="20" alt="Google">
                                    <span class="fw-bold text-dark small">Google</span>
                                </a>
                            </div>
                            <div class="col-6">
                                <a href="/auth/facebook" class="btn btn-primary w-100 rounded-pill shadow-sm py-2 border-0 d-flex align-items-center justify-content-center gap-2" style="background-color: #1877F2;">
                                    <i class="bi bi-facebook fs-5"></i>
                                    <span class="fw-bold small">Facebook</span>
                                </a>
                            </div>
                        </div>

                        <div class="d-flex align-items-center mb-4 mt-2">
                            <div class="flex-grow-1 border-bottom border-white border-opacity-25"></div>
                            <span class="px-3 text-white-50 small x-small text-uppercase tracking-widest">Hoặc dùng Email</span>
                            <div class="flex-grow-1 border-bottom border-white border-opacity-25"></div>
                        </div>

                        <!-- Tabs -->
                        <ul class="nav nav-pills nav-fill gap-2 p-1 bg-white bg-opacity-25 rounded-pill mb-4" id="authTabs" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active rounded-pill text-white fw-bold" id="login-tab" data-bs-toggle="tab" data-bs-target="#login-pane" type="button" role="tab">Đăng Nhập</button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link rounded-pill text-white fw-bold" id="register-tab" data-bs-toggle="tab" data-bs-target="#register-pane" type="button" role="tab">Đăng Ký</button>
                            </li>
                        </ul>

                        <% if (typeof error !== 'undefined' && error) { %>
                            <div class="alert alert-danger bg-danger bg-opacity-25 text-white border-0 rounded-4 small text-center mb-4 animate__animated animate__shakeX">
                                <i class="bi bi-exclamation-triangle-fill me-1"></i> <%= error %>
                            </div>
                        <% } %>

                        <div class="tab-content" id="authTabsContent">
                            <!-- Login Form -->
                            <div class="tab-pane fade show active" id="login-pane" role="tabpanel" tabindex="0">
                                <form action="/auth/login" method="POST">
                                    <div class="form-floating mb-3">
                                        <input type="email" class="form-control bg-white bg-opacity-25 border-0 text-white rounded-4" id="loginEmail" name="email" placeholder="name@example.com" required>
                                        <label for="loginEmail" class="text-white-50">Email của bạn</label>
                                    </div>
                                    <div class="form-floating mb-4">
                                        <input type="password" class="form-control bg-white bg-opacity-25 border-0 text-white rounded-4" id="loginPassword" name="password" placeholder="Password" required>
                                        <label for="loginPassword" class="text-white-50">Mật khẩu</label>
                                    </div>
                                    <button type="submit" class="btn btn-primary-bl w-100 rounded-pill py-3 fw-bold shadow-sm text-uppercase tracking-widest mb-3">ĐĂNG NHẬP BẰNG EMAIL</button>
                                </form>
                            </div>

                            <!-- Register Form -->
                            <div class="tab-pane fade" id="register-pane" role="tabpanel" tabindex="0">
                                <form action="/auth/register" method="POST">
                                    <div class="form-floating mb-3">
                                        <input type="text" class="form-control bg-white bg-opacity-25 border-0 text-white rounded-4" id="regName" name="fullName" placeholder="Họ và tên" required>
                                        <label for="regName" class="text-white-50">Họ và tên</label>
                                    </div>
                                    <div class="form-floating mb-3">
                                        <input type="email" class="form-control bg-white bg-opacity-25 border-0 text-white rounded-4" id="regEmail" name="email" placeholder="name@example.com" required>
                                        <label for="regEmail" class="text-white-50">Email</label>
                                    </div>
                                    <div class="form-floating mb-4">
                                        <input type="password" class="form-control bg-white bg-opacity-25 border-0 text-white rounded-4" id="regPassword" name="password" placeholder="Password" required minlength="6">
                                        <label for="regPassword" class="text-white-50">Mật khẩu (tối thiểu 6 ký tự)</label>
                                    </div>
                                    <button type="submit" class="btn btn-success w-100 rounded-pill py-3 fw-bold shadow-sm text-uppercase tracking-widest mb-3">TẠO TÀI KHOẢN</button>
                                </form>
                            </div>
                        </div>

                        <!-- DEV BYPASS (The ultimate fallback) -->
                        <div class="text-center border-top border-white border-opacity-25 pt-3 mt-3">
                            <form action="/auth/bypass" method="POST">
                                <button type="submit" class="btn btn-sm btn-outline-light rounded-pill opacity-50 hover-opacity-100 transition-all">
                                    <i class="bi bi-rocket-takeoff-fill me-1"></i> Bỏ qua Đăng nhập (Vào thẳng bằng quyền Quản trị)
                                </button>
                            </form>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        gsap.from('.reveal-up', { opacity: 0, y: 30, stagger: 0.1, duration: 0.8, ease: 'power2.out' });
        
        // Form styling focus
        document.querySelectorAll('.form-control').forEach(input => {
            input.addEventListener('focus', () => {
                input.classList.remove('bg-opacity-25');
                input.classList.add('bg-opacity-100', 'text-dark');
            });
            input.addEventListener('blur', () => {
                if(!input.value) {
                    input.classList.add('bg-opacity-25');
                    input.classList.remove('bg-opacity-100', 'text-dark');
                }
            });
        });
    });
</script>

<style>
    .backdrop-blur-lg { backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.1); }
    .nav-pills .nav-link.active { background-color: var(--v5-primary); }
    .form-floating > label { color: rgba(255,255,255,0.6); }
    .form-control:focus { box-shadow: 0 0 0 0.25rem rgba(255,255,255,0.2); }
    .hover-opacity-100:hover { opacity: 1 !important; background: rgba(255,255,255,0.1); }
    .tracking-widest { letter-spacing: 2px; }
</style>
