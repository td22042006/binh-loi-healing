<section class="auth-section min-vh-100 d-flex align-items-center position-relative overflow-hidden py-5">
    <!-- Cinematic Background -->
    <div class="position-absolute top-0 start-0 w-100 h-100" style="background: url('<%= settings.login_bg || '/images/hero-1.png' %>') center/cover; z-index: 0; filter: brightness(0.4);"></div>

    <div class="container position-relative z-index-10">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-8">
                
                <div class="text-center mb-4 reveal-up">
                    <img src="/images/logo.png" alt="Logo" height="60" class="mb-3" onerror="this.style.display='none'">
                    <h2 class="text-white fw-black tracking-widest text-uppercase">Bình Lợi Healing</h2>
                    <p class="text-white-50 small">Khởi đầu hành trình chữa lành của bạn</p>
                </div>

                <div class="auth-card border-0 shadow-premium rounded-5 overflow-hidden reveal-up" style="transition-delay: 0.1s">
                    <div class="p-4 p-md-5">
                        
                        <!-- Social Logins (Primary) -->
                        <div class="row g-2 mb-4">
                            <div class="col-<%= (typeof facebookConfigured !== 'undefined' && facebookConfigured) ? '6' : '12' %>">
                                <a href="/auth/google" class="btn btn-light w-100 rounded-pill shadow-sm py-2 d-flex align-items-center justify-content-center gap-2">
                                    <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" height="20" alt="Google">
                                    <span class="fw-bold text-dark small">Đăng nhập Google</span>
                                </a>
                            </div>
                            <% if (typeof facebookConfigured !== 'undefined' && facebookConfigured) { %>
                            <div class="col-6">
                                <a href="/auth/facebook" class="btn btn-primary w-100 rounded-pill shadow-sm py-2 border-0 d-flex align-items-center justify-content-center gap-2" style="background-color: #1877F2;">
                                    <i class="bi bi-facebook fs-5"></i>
                                    <span class="fw-bold small">Facebook</span>
                                </a>
                            </div>
                            <% } %>
                        </div>

                        <div class="d-flex align-items-center mb-4 mt-2">
                            <div class="flex-grow-1" style="border-bottom: 1px solid rgba(255,255,255,0.2);"></div>
                            <span class="px-3 small x-small text-uppercase tracking-widest" style="color: rgba(255,255,255,0.5);">Hoặc</span>
                            <div class="flex-grow-1" style="border-bottom: 1px solid rgba(255,255,255,0.2);"></div>
                        </div>

                        <!-- Tabs -->
                        <ul class="nav nav-pills nav-fill gap-2 p-1 rounded-pill mb-4" id="authTabs" role="tablist" style="background: rgba(255,255,255,0.15);">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active rounded-pill text-white fw-bold" id="login-tab" data-bs-toggle="tab" data-bs-target="#login-pane" type="button" role="tab">Đăng Nhập</button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link rounded-pill text-white fw-bold" id="register-tab" data-bs-toggle="tab" data-bs-target="#register-pane" type="button" role="tab">Đăng Ký</button>
                            </li>
                        </ul>

                        <% if (typeof error !== 'undefined' && error) { %>
                            <div class="alert alert-danger bg-danger bg-opacity-25 text-white border-0 rounded-4 small text-center mb-4 animate__animated animate__shakeX">
                                <i class="bi bi-exclamation-triangle-fill me-1"></i> <%= error %>
                            </div>
                        <% } %>

                        <div class="tab-content" id="authTabsContent">
                            <!-- Login Form -->
                            <div class="tab-pane fade show active" id="login-pane" role="tabpanel" tabindex="0">
                                <form action="/auth/login" method="POST">
                                    <div class="mb-3">
                                        <label for="loginEmail" class="form-label small fw-bold text-white">Email hoặc Số điện thoại</label>
                                        <input type="text" class="form-control auth-input" id="loginEmail" name="email" placeholder="name@example.com hoặc 0901234567" required autocomplete="username">
                                    </div>
                                    <div class="mb-4">
                                        <label for="loginPassword" class="form-label small fw-bold text-white">Mật khẩu</label>
                                        <div class="position-relative">
                                            <input type="password" class="form-control auth-input pe-5" id="loginPassword" name="password" placeholder="Nhập mật khẩu" required autocomplete="current-password">
                                            <button type="button" class="btn btn-sm position-absolute top-50 end-0 translate-middle-y me-2 p-0 border-0" onclick="togglePwd('loginPassword', this)" style="background: none;">
                                                <i class="bi bi-eye text-white fs-5"></i>
                                            </button>
                                        </div>
                                    </div>
                                    <button type="submit" class="btn btn-primary-bl w-100 rounded-pill py-3 fw-bold shadow-sm text-uppercase tracking-widest mb-3">ĐĂNG NHẬP</button>
                                </form>
                            </div>

                            <!-- Register Form -->
                            <div class="tab-pane fade" id="register-pane" role="tabpanel" tabindex="0">
                                <form id="registerForm" action="/auth/register" method="POST" onsubmit="handleRegistrationSubmit(event)">
                                    <div class="mb-3">
                                        <label for="regName" class="form-label small fw-bold text-white">Họ và tên</label>
                                        <input type="text" class="form-control auth-input" id="regName" name="fullName" placeholder="Nguyễn Văn A" required>
                                    </div>
                                    <div class="mb-3">
                                        <label for="regPhone" class="form-label small fw-bold text-white">Số điện thoại</label>
                                        <input type="tel" class="form-control auth-input" id="regPhone" name="phone" placeholder="0901234567" required pattern="[0-9]{10,11}" title="Số điện thoại 10-11 chữ số">
                                    </div>
                                    <div class="mb-4">
                                        <label for="regPassword" class="form-label small fw-bold text-white">Mật khẩu (tối thiểu 6 ký tự)</label>
                                        <div class="position-relative">
                                            <input type="password" class="form-control auth-input pe-5" id="regPassword" name="password" placeholder="••••••" required minlength="6">
                                            <button type="button" class="btn btn-sm position-absolute top-50 end-0 translate-middle-y me-2 p-0 border-0" onclick="togglePwd('regPassword', this)" style="background: none;">
                                                <i class="bi bi-eye text-white opacity-50 fs-5"></i>
                                            </button>
                                        </div>
                                    </div>
                                    <button type="submit" class="btn btn-success w-100 rounded-pill py-3 fw-bold shadow-sm text-uppercase tracking-widest mb-3">TẠO TÀI KHOẢN</button>
                                </form>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- SMS OTP Verification Modal -->
<div class="modal fade" id="otpModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 420px;">
        <div class="modal-content border-0 rounded-4 shadow-premium bg-dark text-white p-4" style="border: 1px solid rgba(255,255,255,0.1) !important;">
            <div class="text-center mb-4">
                <div class="bg-success bg-opacity-25 text-success rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                    <i class="bi bi-shield-lock-fill fs-3"></i>
                </div>
                <h4 class="fw-black mb-1">Xác thực OTP</h4>
                <p class="text-white-50 small mb-0">Mã OTP xác thực đã được gửi qua tin nhắn SMS tới số điện thoại của bạn.</p>
                <div class="badge bg-light text-dark rounded-pill px-3 py-2 mt-3 fw-bold text-uppercase x-small" style="letter-spacing: 1px;">
                    Nhập mã: <span class="text-success">1234</span> để xác nhận
                </div>
            </div>
            
            <div class="mb-4">
                <div class="d-flex justify-content-center gap-2" id="otpInputContainer">
                    <input type="text" maxlength="1" class="form-control text-center fs-2 fw-bold text-white rounded-3 shadow-none otp-box" style="width: 50px; height: 60px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);" onkeyup="moveOtpFocus(this, 'otp2')" id="otp1">
                    <input type="text" maxlength="1" class="form-control text-center fs-2 fw-bold text-white rounded-3 shadow-none otp-box" style="width: 50px; height: 60px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);" onkeyup="moveOtpFocus(this, 'otp3')" id="otp2">
                    <input type="text" maxlength="1" class="form-control text-center fs-2 fw-bold text-white rounded-3 shadow-none otp-box" style="width: 50px; height: 60px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);" onkeyup="moveOtpFocus(this, 'otp4')" id="otp3">
                    <input type="text" maxlength="1" class="form-control text-center fs-2 fw-bold text-white rounded-3 shadow-none otp-box" style="width: 50px; height: 60px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);" onkeyup="moveOtpFocus(this, null)" id="otp4">
                </div>
                <div class="alert alert-danger bg-danger bg-opacity-25 text-white border-0 rounded-3 mt-3 py-2 px-3 small text-center d-none" id="otpErrorAlert">
                    Mã xác thực OTP không chính xác. Vui lòng thử lại!
                </div>
            </div>

            <div class="d-grid gap-2">
                <button type="button" class="btn btn-success rounded-pill py-3 fw-bold text-uppercase tracking-widest" onclick="verifyOtpCode()">XÁC NHẬN KÍCH HOẠT</button>
                <button type="button" class="btn btn-link text-white-50 text-decoration-none small text-center" data-bs-dismiss="modal">Hủy bỏ</button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        gsap.from('.reveal-up', { opacity: 0, y: 30, stagger: 0.1, duration: 0.8, ease: 'power2.out' });
    });

    let otpModalInstance = null;

    function handleRegistrationSubmit(event) {
        event.preventDefault();
        
        // Show OTP Modal
        if (!otpModalInstance) {
            otpModalInstance = new bootstrap.Modal(document.getElementById('otpModal'));
        }
        
        // Reset Inputs
        document.querySelectorAll('.otp-box').forEach(el => el.value = '');
        document.getElementById('otpErrorAlert').classList.add('d-none');
        
        otpModalInstance.show();
        setTimeout(() => document.getElementById('otp1').focus(), 500);
    }

    function moveOtpFocus(current, nextId) {
        if (current.value.length === 1 && nextId) {
            document.getElementById(nextId).focus();
        }
    }

    function verifyOtpCode() {
        const o1 = document.getElementById('otp1').value;
        const o2 = document.getElementById('otp2').value;
        const o3 = document.getElementById('otp3').value;
        const o4 = document.getElementById('otp4').value;
        
        const code = o1 + o2 + o3 + o4;
        
        if (code === '1234') {
            otpModalInstance.hide();
            // Programmatically submit form
            document.getElementById('registerForm').submit();
        } else {
            const err = document.getElementById('otpErrorAlert');
            err.classList.remove('d-none');
            // Shake modal
            gsap.to('#otpModal .modal-content', { x: 10, duration: 0.05, yoyo: true, repeat: 5 });
        }
    }

    function togglePwd(inputId, btn) {
        const input = document.getElementById(inputId);
        const icon = btn.querySelector('i');
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.replace('bi-eye', 'bi-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.replace('bi-eye-slash', 'bi-eye');
        }
    }
</script>

<style>
    .auth-card { 
        background: rgba(0,0,0,0.45); 
        backdrop-filter: blur(20px); 
        -webkit-backdrop-filter: blur(20px); 
        border: 1px solid rgba(255,255,255,0.1); 
    }
    .auth-input {
        background: rgba(255,255,255,0.15) !important;
        border: 1px solid rgba(255,255,255,0.25) !important;
        color: #fff !important;
        border-radius: 12px !important;
        padding: 14px 18px !important;
        font-size: 0.95rem;
        font-weight: 500;
    }
    .auth-input::placeholder { color: rgba(255,255,255,0.55) !important; }
    .auth-input:focus { 
        background: rgba(255,255,255,0.22) !important; 
        border-color: rgba(255,255,255,0.4) !important; 
        box-shadow: 0 0 0 0.2rem rgba(255,255,255,0.12) !important;
        color: #fff !important;
    }
    .nav-pills .nav-link.active { background-color: var(--primary); }
    .tracking-widest { letter-spacing: 2px; }
    .z-index-10 { z-index: 10; }
</style>
