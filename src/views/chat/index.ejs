<!-- Vibrant Chat Dashboard — Connected in Nature -->
<div class="widget-card p-0 overflow-hidden border-0 shadow-2xl" style="height: calc(100vh - 160px); border-radius: 30px;">
    <div class="d-flex h-100">
        <!-- Vibrant Inner Sidebar -->
        <div class="d-none d-lg-flex flex-column" style="width: 280px; background: var(--grad-main); border-right: 1px solid rgba(255,255,255,0.05);">
            <div class="p-4 border-bottom border-white border-opacity-10">
                <h5 class="fw-black text-white mb-0 font-display">Cộng đồng</h5>
                <span class="x-small text-warning fw-bold tracking-widest uppercase">BÌNH LỢI HEALING</span>
            </div>
            
            <div class="p-3 overflow-auto flex-grow-1 custom-scrollbar">
                <div class="nav flex-column gap-2 mb-5">
                    <a href="#" class="nav-link active p-3 rounded-4 glass-item d-flex align-items-center gap-3 text-white fw-bold shadow-sm">
                        <div class="bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 32px; height: 32px;">
                            <i class="bi bi-hash fs-5"></i>
                        </div>
                        Chung
                    </a>
                    <a href="#" class="nav-link p-3 rounded-4 d-flex align-items-center gap-3 text-white opacity-50 hover-lift">
                        <div class="bg-white bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                            <i class="bi bi-hash fs-5"></i>
                        </div>
                        Lễ hội
                    </a>
                    <a href="#" class="nav-link p-3 rounded-4 d-flex align-items-center gap-3 text-white opacity-50 hover-lift">
                        <div class="bg-white bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                            <i class="bi bi-hash fs-5"></i>
                        </div>
                        Mua sắm
                    </a>
                </div>
                
                <div class="px-3 mb-3 x-small text-white opacity-50 text-uppercase tracking-widest fw-black">DU KHÁCH ONLINE (12)</div>
                <div class="d-flex flex-column gap-3 px-2">
                    <% [1,2,3].forEach(i => { %>
                    <div class="d-flex align-items-center gap-3 hover-lift cursor-pointer">
                        <div class="position-relative">
                            <img src="/images/default-avatar.png" class="rounded-circle border border-2 border-white border-opacity-20 shadow-sm" style="width: 36px; height: 36px; object-fit: cover;">
                            <span class="position-absolute bottom-0 end-0 bg-success border border-white rounded-circle shadow-sm" style="width: 10px; height: 10px;"></span>
                        </div>
                        <div class="overflow-hidden">
                            <span class="d-block fw-bold text-white small text-truncate">Du khách <%= i %></span>
                            <span class="d-block x-small text-white opacity-50">Đang hoạt động</span>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>
        </div>

        <!-- Vibrant Chat Area -->
        <div class="flex-grow-1 d-flex flex-column bg-white">
            <!-- Chat Header -->
            <div class="p-4 border-bottom d-flex justify-content-between align-items-center shadow-sm" style="z-index: 10;">
                <div class="d-flex align-items-center gap-3">
                    <div class="d-lg-none p-2 rounded-circle bg-light me-2"><i class="bi bi-list fs-4"></i></div>
                    <div class="bg-primary-50 p-2 rounded-circle text-primary">
                        <i class="bi bi-hash fs-4"></i>
                    </div>
                    <div>
                        <h6 class="fw-black mb-0">Phòng Chung</h6>
                        <span class="text-success x-small fw-bold"><i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i> 12 du khách trực tuyến</span>
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-light rounded-circle shadow-sm" style="width: 40px; height: 40px;"><i class="bi bi-search"></i></button>
                    <button class="btn btn-light rounded-circle shadow-sm" style="width: 40px; height: 40px;"><i class="bi bi-gear-fill"></i></button>
                </div>
            </div>

            <!-- Vibrant Message Bubbles -->
            <div id="chat-messages-vibrant" class="flex-grow-1 p-4 overflow-auto custom-scrollbar d-flex flex-column gap-4" style="background: #f8fafc;">
                <!-- System Message -->
                <div class="text-center my-3">
                    <span class="px-3 py-1 bg-white rounded-pill x-small fw-bold text-muted border shadow-sm">Bắt đầu phiên thảo luận hành trình</span>
                </div>

                <!-- Received -->
                <div class="d-flex gap-3">
                    <img src="/images/default-avatar.png" class="rounded-circle shadow-sm" style="width: 40px; height: 40px;">
                    <div style="max-width: 70%;">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="fw-black small text-primary">Admin</span>
                            <span class="text-muted" style="font-size: 0.65rem;">HÔM NAY 08:30</span>
                        </div>
                        <div class="p-3 rounded-4 shadow-sm bg-white" style="border-top-left-radius: 0; line-height: 1.5;">
                            Chào mừng mọi người đến với Bình Lợi Healing! Mọi người đã chọn được Vibe cho hành trình hôm nay chưa?
                        </div>
                    </div>
                </div>

                <!-- Sent (Self) -->
                <div class="d-flex flex-row-reverse gap-3">
                    <img src="<%= user ? user.avatar : '/images/default-avatar.png' %>" class="rounded-circle shadow-sm border border-2 border-warning" style="width: 40px; height: 40px;">
                    <div class="text-end" style="max-width: 70%;">
                        <div class="d-flex flex-row-reverse align-items-center gap-2 mb-2">
                            <span class="fw-black small text-primary">Tôi</span>
                            <span class="text-muted" style="font-size: 0.65rem;">08:32</span>
                        </div>
                        <div class="p-3 rounded-4 shadow-lg text-white" style="background: var(--grad-main); border-top-right-radius: 0; line-height: 1.5;">
                            Tôi vừa check-in tại Vườn Mai Vàng, khung cảnh thật sự tuyệt vời! 🌿✨
                        </div>
                    </div>
                </div>
            </div>

            <!-- Vibrant Input Area -->
            <div class="p-4 bg-white border-top shadow-lg">
                <form id="chatFormVibrant" class="d-flex gap-3 align-items-center">
                    <button type="button" class="btn btn-light rounded-circle shadow-sm" style="width: 46px; height: 46px;"><i class="bi bi-plus-lg fs-5"></i></button>
                    <div class="flex-grow-1 position-relative">
                        <input type="text" id="chatInputVibrant" 
                               class="form-control rounded-pill border-0 px-4 py-3 bg-light shadow-none fs-6" 
                               placeholder="Gửi tin nhắn tới #Chung..." 
                               style="background: #f1f5f9 !important;">
                        <div class="position-absolute end-0 top-50 translate-middle-y pe-3">
                            <i class="bi bi-emoji-smile text-muted cursor-pointer fs-5"></i>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-premium rounded-circle shadow-lg d-flex align-items-center justify-content-center" 
                            style="width: 50px; height: 50px; background: var(--grad-main); color: white;">
                        <i class="bi bi-send-fill fs-5"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
