<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="glass-panel d-flex flex-column" style="height: 600px; border-radius: var(--radius-lg); overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.05); background: #ffffff;">
                <!-- Header -->
                <div class="p-3 text-white border-0 d-flex justify-content-between align-items-center" style="background: linear-gradient(135deg, #922724 0%, #b83330 100%);">
                    <div class="d-flex align-items-center gap-3">
                        <img src="<%= fixImg(settings.brand_logo, '/images/logo.png') %>" class="rounded-circle shadow-sm" style="width: 40px; height: 40px; border: 2px solid rgba(255,255,255,0.2); object-fit: cover;" onerror="this.src='/images/logo.png'">
                        <div>
                            <h6 class="fw-bold mb-0">Hỗ trợ Bình Lợi Healing</h6>
                            <small class="opacity-75" style="font-size: 11px;"><i class="bi bi-circle-fill text-success me-1" style="font-size: 8px;"></i> Ban Quản Trị</small>
                        </div>
                    </div>
                </div>

                <!-- Messages Body -->
                <div class="flex-grow-1 p-4 overflow-auto" id="chat-messages" style="background: #f8faf9;">
                    <!-- Dynamically loaded messages -->
                </div>

                <!-- Input Footer -->
                <div class="p-3 border-top bg-white">
                    <form id="chat-form" class="d-flex gap-2 align-items-center">
                        <input type="text" class="form-control rounded-pill border-0 bg-light px-4" style="height: 44px; font-size: 0.9rem;" placeholder="Nhập tin nhắn..." id="chat-input" required autocomplete="off">
                        <button type="submit" class="btn btn-danger rounded-circle p-2 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 44px; height: 44px; background-color: var(--primary) !important; border: none;">
                            <i class="bi bi-send-fill text-white"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let chatInterval = null;
    let lastMessageCount = -1;

    async function loadChatMessages() {
        try {
            const res = await axios.get('/api/get-messages');
            if (res.data.success) {
                const messages = res.data.data;
                if (messages.length === lastMessageCount) return;
                lastMessageCount = messages.length;

                const container = document.getElementById('chat-messages');
                let html = `
                    <div class="text-center mb-3">
                        <span class="badge bg-white text-muted shadow-sm px-3 py-2 rounded-pill small" style="font-size: 11px;">
                            Bắt đầu cuộc trò chuyện hỗ trợ trực tuyến
                        </span>
                    </div>
                    <div class="message-received mb-3 d-flex gap-2 align-items-end">
                        <img src="<%= fixImg(settings.brand_logo, '/images/logo.png') %>" class="rounded-circle shadow-sm" style="width: 32px; height: 32px; object-fit: cover;" onerror="this.src='/images/logo.png'">
                        <div class="p-2 px-3 rounded-4 bg-white text-dark shadow-sm" style="max-width: 75%; font-size: 0.88rem; line-height: 1.5; border-bottom-left-radius: 4px !important;">
                            Xin chào! Chúng tôi là Ban Quản Trị Bình Lợi Healing. Bạn cần hỗ trợ thông tin gì vui lòng gửi tin nhắn tại đây nhé!
                        </div>
                    </div>
                `;
                
                const currentSessionId = window.CURRENT_SESSION_ID;
                
                messages.forEach(msg => {
                    const isMe = msg.sender_uuid && String(msg.sender_uuid) === String(currentSessionId);
                    if (isMe) {
                        html += `
                            <div class="message-sent mb-3 d-flex justify-content-end">
                                <div class="p-2 px-3 rounded-4 text-white shadow-sm" style="max-width: 75%; font-size: 0.88rem; line-height: 1.5; background-color: var(--primary) !important; border-bottom-right-radius: 4px !important;">
                                    ${escapeHtml(msg.message)}
                                </div>
                            </div>
                        `;
                    } else {
                        html += `
                            <div class="message-received mb-3 d-flex gap-2 align-items-end">
                                <img src="<%= fixImg(settings.brand_logo, '/images/logo.png') %>" class="rounded-circle shadow-sm" style="width: 32px; height: 32px; object-fit: cover;" onerror="this.src='/images/logo.png'">
                                <div class="p-2 px-3 rounded-4 bg-white text-dark shadow-sm" style="max-width: 75%; font-size: 0.88rem; line-height: 1.5; border-bottom-left-radius: 4px !important;">
                                    ${escapeHtml(msg.message)}
                                </div>
                            </div>
                        `;
                    }
                });
                
                container.innerHTML = html;
                container.scrollTop = container.scrollHeight;
            }
        } catch (e) {
            console.error('Error loading chat messages:', e);
        }
    }

    async function sendMessage(e) {
        e.preventDefault();
        const input = document.getElementById('chat-input');
        const msg = input.value.trim();
        if (!msg) return;

        input.value = '';
        
        try {
            const res = await axios.post('/api/send-message', { message: msg });
            if (res.data.success) {
                loadChatMessages();
            }
        } catch (e) {
            console.error('Error sending message:', e);
        }
    }

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.innerText = text;
        return div.innerHTML;
    }

    document.getElementById('chat-form').addEventListener('submit', sendMessage);

    // Initial load and start interval
    loadChatMessages();
    chatInterval = setInterval(loadChatMessages, 5000);
</script>
