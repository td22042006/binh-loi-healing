<!-- Profile Dashboard — Show All Features -->
<div class="row g-4">
    <!-- Left: Profile Summary -->
    <div class="col-lg-4">
        <div class="widget-card text-center">
            <div class="position-relative d-inline-block mb-4">
                <img src="<%= user.avatar || '/images/default-avatar.png' %>" class="rounded-circle border border-4 border-white shadow-lg" style="width: 120px; height: 120px; object-fit: cover;">
                <button class="btn btn-sm btn-primary-bl rounded-circle position-absolute bottom-0 end-0" style="width: 32px; height: 32px;"><i class="bi bi-camera"></i></button>
            </div>
            <h5 class="fw-black mb-1"><%= user.full_name %></h5>
            <p class="text-muted small mb-4"><%= user.email %></p>
            
            <div class="d-flex flex-column gap-2">
                <div class="p-3 rounded-4 bg-light d-flex justify-content-between align-items-center">
                    <span class="x-small fw-bold text-muted">ID DU KHÁCH</span>
                    <span class="fw-bold text-primary">#<%= user.id %></span>
                </div>
                <div class="p-3 rounded-4 bg-light d-flex justify-content-between align-items-center">
                    <span class="x-small fw-bold text-muted">HÀNH TRÌNH</span>
                    <span class="fw-bold text-primary">Cấp độ <%= Math.floor((user.total_points || 0) / 100) + 1 %></span>
                </div>
            </div>
            <hr class="my-4 opacity-10">
            <a href="/auth/logout" class="btn btn-outline-danger btn-sm w-100 rounded-pill">Đăng xuất tài khoản</a>
        </div>
    </div>

    <!-- Right: Settings Area -->
    <div class="col-lg-8">
        <div class="widget-card">
            <h5 class="fw-bold mb-4">Cài đặt tài khoản</h5>
            
            <ul class="nav nav-pills gap-2 mb-4 p-1 rounded-pill bg-light" style="width: fit-content;">
                <li class="nav-item">
                    <a class="nav-link active rounded-pill px-4 small fw-bold" data-bs-toggle="pill" href="#tab-info">Thông tin</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link rounded-pill px-4 small fw-bold" data-bs-toggle="pill" href="#tab-security">Bảo mật</a>
                </li>
            </ul>

            <div class="tab-content">
                <!-- Info Tab -->
                <div class="tab-pane fade show active" id="tab-info">
                    <form action="/profile/update" method="POST">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label x-small fw-bold">HỌ VÀ TÊN</label>
                                <input type="text" name="full_name" class="form-control rounded-pill bg-light border-0 px-3" value="<%= user.full_name %>">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label x-small fw-bold">EMAIL</label>
                                <input type="email" class="form-control rounded-pill bg-light border-0 px-3" value="<%= user.email %>" disabled>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label x-small fw-bold">SỐ ĐIỆN THOẠI</label>
                                <input type="tel" name="phone" class="form-control rounded-pill bg-light border-0 px-3" value="<%= user.phone %>">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label x-small fw-bold">NGÀY SINH</label>
                                <input type="date" name="birthday" class="form-control rounded-pill bg-light border-0 px-3" value="<%= user.birthday %>">
                            </div>
                            <div class="col-12">
                                <label class="form-label x-small fw-bold">GIỚI THIỆU BẢN THÂN</label>
                                <textarea name="bio" class="form-control rounded-4 bg-light border-0 px-3 py-2" rows="3"><%= user.bio %></textarea>
                            </div>
                        </div>
                        <div class="mt-4 pt-3 border-top">
                            <button type="submit" class="btn btn-primary-bl rounded-pill px-5 fw-bold">Cập nhật thông tin</button>
                        </div>
                    </form>
                </div>

                <!-- Security Tab -->
                <div class="tab-pane fade" id="tab-security">
                    <form action="/profile/password" method="POST">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label x-small fw-bold">MẬT KHẨU HIỆN TẠI</label>
                                <input type="password" name="old_password" class="form-control rounded-pill bg-light border-0 px-3">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label x-small fw-bold">MẬT KHẨU MỚI</label>
                                <input type="password" name="new_password" class="form-control rounded-pill bg-light border-0 px-3">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label x-small fw-bold">XÁC NHẬN MẬT KHẨU MỚI</label>
                                <input type="password" name="confirm_password" class="form-control rounded-pill bg-light border-0 px-3">
                            </div>
                        </div>
                        <div class="mt-4 pt-3 border-top">
                            <button type="submit" class="btn btn-primary-bl rounded-pill px-5 fw-bold">Đổi mật khẩu</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
