<style>
/* ============================================================
   PROFILE EDIT — Premium Light Theme
   ============================================================ */
.edit-profile-section {
    margin-top: 90px;
    padding: 3rem 0 5rem;
    background: var(--bg, #fafbf9);
    min-height: 100vh;
}
.edit-profile-card {
    background: var(--surface, #ffffff);
    border-radius: var(--radius-2xl, 32px);
    border: 1px solid var(--border-light, #f0f2ef);
    box-shadow: var(--shadow-xl, 0 24px 64px rgba(0,0,0,0.1));
    overflow: hidden;
    position: relative;
}
.edit-profile-header {
    background: linear-gradient(135deg, var(--primary-green-dark) 0%, var(--primary-green) 100%);
    padding: 2.5rem 2rem;
    color: #ffffff;
    text-align: center;
    position: relative;
}
.edit-profile-header::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 80% 20%, rgba(240, 165, 0, 0.15) 0%, transparent 60%);
    pointer-events: none;
}
.edit-profile-body {
    padding: 3rem 2.5rem 3.5rem;
}
.input-premium {
    background-color: var(--surface-alt, #f5f7f4) !important;
    border: 1.5px solid var(--border, #e8ece9) !important;
    color: var(--text, #1a1a1a) !important;
    padding: 12px 18px !important;
    border-radius: var(--radius-md, 12px) !important;
    font-size: 0.95rem;
    transition: all 0.25s ease !important;
}
.input-premium:focus {
    background-color: var(--surface, #ffffff) !important;
    border-color: var(--primary-green) !important;
    box-shadow: 0 0 0 4px rgba(30, 90, 62, 0.15) !important;
}
.form-label-premium {
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 6px;
}
.btn-save-profile {
    padding: 14px;
    border-radius: var(--radius-full, 9999px);
    border: none;
    background: linear-gradient(135deg, var(--primary-green) 0%, var(--primary-green-light) 100%);
    color: #ffffff;
    font-weight: 800;
    font-size: 0.9rem;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    box-shadow: 0 8px 24px rgba(30, 90, 62, 0.2);
    transition: all 0.3s var(--ease-out);
}
.btn-save-profile:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(30, 90, 62, 0.35);
}
.avatar-edit-wrapper {
    position: relative;
    display: inline-block;
    padding: 6px;
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-light) 100%);
    border-radius: 50%;
    box-shadow: var(--shadow-md);
}
</style>

<section class="edit-profile-section">
    <div class="container" style="max-width: 680px;">
        <div class="edit-profile-card">
            
            <!-- Header -->
            <div class="edit-profile-header">
                <h3 class="fw-bold mb-1 font-display" style="letter-spacing: -0.02em;"><i class="bi bi-person-gear me-2 text-warning"></i>HỒ SƠ DU KHÁCH</h3>
                <p class="mb-0 text-white-50 small">Cập nhật thông tin cá nhân của bạn tại hệ thống du lịch chữa lành</p>
            </div>

            <!-- Body -->
            <div class="edit-profile-body">
                <form id="editProfileForm">
                    
                    <!-- Avatar Upload -->
                    <div class="text-center mb-5">
                        <div class="avatar-edit-wrapper">
                            <img id="avatar_preview" src="<%= profileUser.avatar || '/images/default-avatar.png' %>" class="rounded-circle border border-4 border-white" 
                                 style="width: 120px; height: 120px; object-fit: cover;">
                            <button type="button" class="btn btn-primary rounded-circle position-absolute bottom-0 end-0 p-2 shadow-lg d-flex align-items-center justify-content-center" 
                                    style="width: 38px; height: 38px; background: var(--primary); border: 2px solid white;"
                                    onclick="document.getElementById('avatar_file').click()">
                                <i class="bi bi-camera-fill fs-6 text-white"></i>
                            </button>
                            <input type="file" id="avatar_file" class="d-none" accept="image/*" onchange="uploadAvatar(this)">
                        </div>
                        <input type="hidden" name="avatar" id="avatar_url" value="<%= profileUser.avatar || '' %>">
                        <div class="text-muted mt-2 x-small">Click biểu tượng camera để thay đổi hình đại diện</div>
                    </div>

                    <!-- Fields -->
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label-premium"><i class="bi bi-person-fill text-success"></i>Họ và tên</label>
                            <input type="text" class="form-control input-premium" name="full_name" value="<%= profileUser.full_name || '' %>" required>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label-premium"><i class="bi bi-telephone-fill text-danger"></i>Số điện thoại</label>
                            <input type="tel" class="form-control input-premium" name="phone" value="<%= profileUser.phone || '' %>" placeholder="09xxxxxxxx">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label-premium"><i class="bi bi-geo-alt-fill text-primary"></i>Thành phố</label>
                            <input type="text" class="form-control input-premium" name="city" value="<%= profileUser.city || '' %>" placeholder="TP.HCM">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label-premium"><i class="bi bi-heart-pulse-fill text-warning"></i>Sở thích du lịch</label>
                            <input type="text" class="form-control input-premium" name="preferences" value="<%= profileUser.preferences || '' %>" placeholder="Thiền, Sinh thái, Ẩm thực...">
                        </div>

                        <div class="col-12">
                            <label class="form-label-premium"><i class="bi bi-compass-fill text-info"></i>Phong cách trải nghiệm</label>
                            <select class="form-select input-premium" name="travel_style">
                                <option value="healing" <%= profileUser.travel_style === 'healing' ? 'selected' : '' %>>🧘 Healing & Chữa lành</option>
                                <option value="tamlinh" <%= profileUser.travel_style === 'tamlinh' ? 'selected' : '' %>>🕉️ Tâm linh & Chiêm bái</option>
                                <option value="sinhthai" <%= profileUser.travel_style === 'sinhthai' ? 'selected' : '' %>>🌿 Du lịch sinh thái miệt vườn</option>
                                <option value="checkin" <%= profileUser.travel_style === 'checkin' ? 'selected' : '' %>>📸 Check-in & Khám phá phong cảnh</option>
                                <option value="giadinh" <%= profileUser.travel_style === 'giadinh' ? 'selected' : '' %>>👨‍👩‍👧 Trải nghiệm gia đình</option>
                            </select>
                        </div>
                    </div>

                    <div class="mt-5">
                        <button type="submit" class="btn btn-save-profile w-100" id="btnSave">
                            <i class="bi bi-check-circle me-2"></i>Lưu thay đổi hồ sơ
                        </button>
                    </div>
                </form>

                <div id="saveResult" class="mt-4 d-none"></div>
                
                <div class="text-center mt-4">
                    <a href="/profile" style="color: var(--text-secondary); font-weight: 700; font-size: 0.9rem; text-decoration: none;" class="transition-all" onmouseover="this.style.color='var(--primary)'" onmouseout="this.style.color='var(--text-secondary)'">
                        <i class="bi bi-arrow-left me-2"></i>Quay lại Hồ sơ
                    </a>
                </div>
            </div>
            
        </div>
    </div>
</section>

<script>
async function uploadAvatar(input) {
    if (!input.files || !input.files[0]) return;
    
    const formData = new FormData();
    formData.append('image', input.files[0]);
    
    const btn = input.previousElementSibling;
    const oldHtml = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
    
    try {
        const res = await axios.post('/api/upload', formData, {
            headers: { 'Content-Type': 'multipart/form-data' }
        });
        
        if (res.data.success) {
            document.getElementById('avatar_url').value = res.data.url;
            document.getElementById('avatar_preview').src = res.data.url;
        }
    } catch (err) {
        alert('Lỗi tải ảnh: ' + (err.response?.data?.message || err.message));
    } finally {
        btn.disabled = false;
        btn.innerHTML = oldHtml;
    }
}

document.getElementById('editProfileForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('btnSave');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang lưu...';

    try {
        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData);
        const res = await axios.post('/profile/update', data);
        
        const resultEl = document.getElementById('saveResult');
        resultEl.classList.remove('d-none');
        resultEl.innerHTML = `<div class="alert alert-success rounded-4 border-0 shadow-sm"><i class="bi bi-check-circle-fill me-2 text-success"></i>${res.data.message}</div>`;
        btn.innerHTML = '<i class="bi bi-check-circle me-2"></i>Đã lưu thành công!';
        
        setTimeout(() => {
            window.location.href = '/profile';
        }, 1000);
    } catch (err) {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-check-circle me-2"></i>Lưu thay đổi hồ sơ';
        alert('Lỗi: ' + (err.response?.data?.message || err.message));
    }
});
</script>
