<!-- Festivals Dashboard — Show All Features -->
<div class="row g-4">
    <!-- Left: Festival List -->
    <div class="col-lg-8">
        <div class="widget-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold mb-0">Lễ hội & Sự kiện Văn hóa</h5>
                <span class="badge-nature"><%= festivals.length %> Sự kiện</span>
            </div>

            <div class="d-flex flex-column gap-4">
                <% festivals.forEach(f => { %>
                <div class="card-heal p-0 overflow-hidden">
                    <div class="row g-0">
                        <div class="col-md-4">
                            <div class="h-100" style="min-height: 160px;">
                                <img src="<%= fixImg(f.image) %>" class="w-100 h-100 object-fit-cover">
                            </div>
                        </div>
                        <div class="col-md-8 p-4">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h6 class="fw-bold mb-0 fs-5"><%= f.name %></h6>
                                <span class="badge-gold"><%= new Date(f.date).toLocaleDateString('vi-VN') %></span>
                            </div>
                            <p class="text-muted small mb-3 line-clamp-2"><%= f.description %></p>
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="x-small text-muted"><i class="bi bi-geo-alt me-1"></i><%= f.location || 'Bình Lợi' %></span>
                                <a href="/festivals/<%= f.id %>" class="btn btn-primary-bl btn-sm rounded-pill px-4">Đăng ký tham gia</a>
                            </div>
                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
        </div>
    </div>

    <!-- Right: Countdown & Stats -->
    <div class="col-lg-4">
        <!-- Next Event Countdown -->
        <% if (festivals.length > 0) { %>
        <div class="widget-card mb-4 text-center" style="background: var(--grad-nature); color: white; border: none;">
            <h6 class="fw-bold mb-3 opacity-75">SỰ KIỆN SẮP TỚI</h6>
            <h5 class="fw-black mb-3"><%= festivals[0].name %></h5>
            <div class="d-flex justify-content-center gap-3 mb-4">
                <div class="p-2 rounded-3 bg-white bg-opacity-10" style="min-width: 60px;">
                    <div class="fw-black fs-4" id="cd-days">--</div>
                    <span class="x-small opacity-50">Ngày</span>
                </div>
                <div class="p-2 rounded-3 bg-white bg-opacity-10" style="min-width: 60px;">
                    <div class="fw-black fs-4" id="cd-hours">--</div>
                    <span class="x-small opacity-50">Giờ</span>
                </div>
            </div>
            <p class="x-small mb-0 opacity-75">Hãy chuẩn bị tinh thần để hòa mình vào không khí lễ hội!</p>
        </div>
        <% } %>

        <!-- Cultural Facts Widget -->
        <div class="widget-card">
            <h6 class="fw-bold mb-3 d-flex align-items-center gap-2">
                <i class="bi bi-book text-primary"></i> Bạn có biết?
            </h6>
            <div class="p-3 rounded-4" style="background: var(--surface-alt);">
                <p class="x-small mb-0 text-muted" style="line-height: 1.6;">
                    Làng Bình Lợi nổi tiếng với truyền thống hiếu học và nghề trồng Mai vàng lớn nhất TP.HCM. Các lễ hội tại đây thường gắn liền với lòng biết ơn thiên nhiên và tổ tiên.
                </p>
            </div>
            <hr class="my-3 opacity-10">
            <div class="d-flex align-items-center gap-2 x-small fw-bold text-primary">
                <i class="bi bi-info-circle"></i> Xem thêm di tích lịch sử
            </div>
        </div>
    </div>
</div>

<script>
    // Simple Countdown logic
    <% if (festivals.length > 0) { %>
    const eventDate = new Date('<%= festivals[0].date %>').getTime();
    setInterval(() => {
        const now = new Date().getTime();
        const diff = eventDate - now;
        if (diff > 0) {
            document.getElementById('cd-days').innerText = Math.floor(diff / (1000 * 60 * 60 * 24));
            document.getElementById('cd-hours').innerText = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        }
    }, 1000);
    <% } %>
</script>
