                            if (se.icon_color === 'warning') colorStyle = 'background: rgba(240, 165, 0, 0.2); color: #ffc847 !important; border: 1px solid rgba(240, 165, 0, 0.4);';
                            if (se.icon_color === 'danger') colorStyle = 'background: rgba(239, 68, 68, 0.2); color: #fca5a5 !important; border: 1px solid rgba(239, 68, 68, 0.4);';
                            if (se.icon_color === 'info') colorStyle = 'background: rgba(59, 130, 246, 0.2); color: #93c5fd !important; border: 1px solid rgba(59, 130, 246, 0.4);';
