<!-- HERO: Full Viewport Cinematic -->
<section class="hero-cinematic position-relative animate__animated animate__fadeIn" style="background: url('<%= settings.hero_image || '/images/hero-1.png' %>') center/cover no-repeat; height: 100vh; min-height: 600px;">
    <div class="hero-overlay position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(to bottom, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.7) 100%);"></div>
    
    <div class="hero-content text-center px-3" style="max-width: 900px; margin: 0 auto;">
        <span class="badge bg-success bg-opacity-25 text-white border border-success border-opacity-50 rounded-pill px-3 py-2 mb-3 text-uppercase fw-bold shadow-sm" style="letter-spacing: 2px; font-size: 0.75rem;">
            <i class="bi bi-compass-fill me-1"></i> BÌNH LỢI HEALING EXPERIENCE
        </span>
        <h1 class="hero-title reveal-up fw-black text-white display-3 mb-3" style="letter-spacing: -1px; text-shadow: 0 4px 15px rgba(0,0,0,0.3);"><%= season.title %></h1>
        <p class="hero-desc reveal-up text-white-50 lead mb-4 mx-auto" style="max-width: 650px;">
            Khám phá Miền Tây ngay giữa lòng Sài Sông — Hệ sinh thái du lịch chữa lành thông minh giúp bạn tìm lại sự tĩnh lặng và năng lượng tích cực từ thiên nhiên.
        </p>
        <div class="d-flex justify-content-center reveal-up">
            <a href="/journey" class="btn btn-primary-bl btn-lg px-5 py-3 rounded-pill fw-bold text-uppercase tracking-widest shadow-premium">
                BẮT ĐẦU HÀNH TRÌNH CHỮA LÀNH <i class="bi bi-arrow-right ms-2"></i>
            </a>
        </div>
    </div>
    
    <!-- Scroll indicator -->
    <div class="position-absolute bottom-0 start-50 translate-middle-x mb-4 text-white animate-pulse" style="z-index: 10;">
        <i class="bi bi-chevron-double-down fs-4 opacity-50"></i>
    </div>
</section>

<!-- STATS: Real Data from Analytics -->
