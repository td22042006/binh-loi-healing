                                <div class="d-flex align-items-center gap-2" style="color: rgba(255, 255, 255, 0.95);">
                                    <i class="bi bi-geo-alt-fill text-danger fs-5"></i> 
                                    <span class="fw-bold"><%= nextEvent.location %></span>
                                </div>
                                <div class="d-flex align-items-center gap-2 mt-1" style="color: rgba(255, 255, 255, 0.95);">
                                    <i class="bi bi-calendar-event text-warning fs-5" style="color: #ffc847 !important;"></i> 
                                    <span><%= new Date(nextEvent.event_date).toLocaleDateString('vi-VN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
                                </div>
                            </div>
                        </div>
