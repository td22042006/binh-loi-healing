                            <h6 class="text-white fw-bold mb-1" style="font-size: 0.95rem;"><%= se.title %></h6>
                            <p class="mb-0 x-small" style="line-height: 1.5; color: rgba(255, 255, 255, 0.8);"><%= se.description %></p>
