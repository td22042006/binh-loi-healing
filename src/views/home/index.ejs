<!-- Floating buttons removed — QR in bottom center, Chat via menu -->

<!-- Global Chat Modal -->
<div class="modal fade" id="globalChatModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm modal-dialog-scrollable" style="max-width: 400px;">
        <div class="modal-content border-0 rounded-4 shadow-premium overflow-hidden">
            <div class="modal-header bg-dark text-white border-0 p-3">
                <div class="d-flex align-items-center gap-2">
                    <img src="/images/logo.png" height="30" onerror="this.style.display='none'">
                    <div>
                        <h6 class="modal-title fw-bold mb-0">Hỗ trợ Bình Lợi</h6>
                        <small class="opacity-50 x-small text-uppercase">Phản hồi bởi Ban Quản Trị</small>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-3 bg-light" style="height: 400px;">
                <div id="global-chat-history" class="overflow-auto h-100">
                    <div class="text-center mb-4"><span class="badge bg-white text-muted rounded-pill shadow-sm py-1 px-3 x-small">Hôm nay</span></div>
                    <div class="d-flex justify-content-start mb-3">
                        <div class="p-3 rounded-4 small shadow-sm bg-white text-dark" style="max-width: 85%; line-height: 1.5;">
                            Chào mừng bạn đến với <strong>Bình Lợi Healing</strong>! 🌿<br><br>
                            Ban quản trị xã luôn sẵn sàng giải đáp mọi thắc mắc của bạn về hành trình khám phá.
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 bg-white p-2">
                <div class="input-group">
                    <input type="text" id="global-chat-input" class="form-control border-0 bg-light rounded-pill ps-4 py-2 small" placeholder="Nhập câu hỏi..." onkeypress="if(event.key === 'Enter') sendGlobalChat()">
                    <button class="btn btn-primary-bl rounded-circle ms-2 p-0 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;" onclick="sendGlobalChat()">
                        <i class="bi bi-send-fill" style="font-size: 0.8rem;"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.getElementById('globalChatModal').addEventListener('show.bs.modal', fetchGlobalMessages);

async function fetchGlobalMessages() {
    try {
        const res = await axios.get('/api/get-messages');
        if (res.data.success) {
            const history = document.getElementById('global-chat-history');
            let html = `
                <div class="text-center mb-4"><span class="badge bg-white text-muted rounded-pill shadow-sm py-1 px-3 x-small">Hôm nay</span></div>
                <div class="d-flex justify-content-start mb-3">
                    <div class="p-3 rounded-4 small shadow-sm bg-white text-dark" style="max-width: 85%; line-height: 1.5;">
                        Chào mừng bạn đến với <strong>Bình Lợi Healing</strong>! 🌿<br><br>
                        Ban quản trị xã luôn sẵn sàng giải đáp mọi thắc mắc.
                    </div>
                </div>
            `;
            res.data.data.forEach(msg => {
                const isMe = msg.sender_uuid === (document.cookie.split('session_uuid=')[1]?.split(';')[0]);
                html += `
                    <div class="d-flex ${isMe ? 'justify-content-end' : 'justify-content-start'} mb-3">
                        <div class="p-3 rounded-4 small shadow-sm ${isMe ? 'bg-primary text-white' : 'bg-white text-dark'}" style="max-width: 85%;">
                            ${msg.message}
                        </div>
                    </div>
                `;
            });
            history.innerHTML = html;
            history.scrollTop = history.scrollHeight;
        }
    } catch (err) { console.error('Fetch error:', err); }
}

async function sendGlobalChat() {
    const input = document.getElementById('global-chat-input');
    const message = input.value.trim();
    if (!message) return;
    input.value = '';
    const history = document.getElementById('global-chat-history');
    history.insertAdjacentHTML('beforeend', `
        <div class="d-flex justify-content-end mb-3">
            <div class="p-3 rounded-4 small shadow-sm bg-primary text-white" style="max-width: 85%;">${message}</div>
        </div>
    `);
    history.scrollTop = history.scrollHeight;
    try { await axios.post('/api/send-message', { message }); } catch (err) { alert('Lỗi: ' + (err.response?.data?.message || err.message)); }
}
</script>

<% if (nextEvent) { %>
<script>
    const festivalDate = new Date("<%= festival.date instanceof Date ? festival.date.toISOString() : festival.date %>").getTime();
    const timer = setInterval(function() {
        const now = new Date().getTime();
        const distance = festivalDate - now;
        if (distance < 0) {
            clearInterval(timer);
            document.getElementById("countdown").innerHTML = '<span class="fw-bold fs-5" style="color: #ffc847 !important; text-shadow: 0 1px 3px rgba(0,0,0,0.5);">SỰ KIỆN ĐANG DIỄN RA!</span>';
            return;
        }
        document.getElementById("days").innerHTML = String(Math.floor(distance / (1000 * 60 * 60 * 24))).padStart(2, '0');
        document.getElementById("hours").innerHTML = String(Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60))).padStart(2, '0');
        document.getElementById("mins").innerHTML = String(Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60))).padStart(2, '0');
    }, 1000);
</script>
<% } %>
