<!-- ============================================
     HOMEPAGE — Bình Lợi Healing v7
     ============================================ -->

<!-- HERO: Full Viewport Cinematic -->
<section class="hero-cinematic position-relative" style="background: url('<%= settings.hero_image || '/images/hero-1.png' %>') center/cover no-repeat;">
    <div class="hero-overlay position-absolute top-0 start-0 w-100 h-100" style="background: rgba(0,0,0,0.3);"></div>
    
    <div class="hero-content text-center">
        <div class="hero-slogan reveal-up"><%= season.type.toUpperCase() %> EXPERIENCE</div>
        <h1 class="hero-title reveal-up"><%= season.title %></h1>
        <p class="hero-desc reveal-up">
            Khám phá Miền Tây ngay giữa lòng Sài Gòn — Hệ sinh thái du lịch số thông minh kết nối bạn với thiên nhiên, văn hóa và con người Bình Lợi.
        </p>
        <div class="d-flex gap-3 justify-content-center flex-wrap reveal-up">
            <a href="/explore" class="btn btn-premium btn-lg">Khám phá địa điểm <i class="bi bi-arrow-right ms-2"></i></a>
            <a href="/journey" class="btn btn-gold btn-lg">Tạo hành trình</a>
        </div>
    </div>
    
    <!-- Scroll indicator -->
    <div class="position-absolute bottom-0 start-50 translate-middle-x mb-4 text-white animate-pulse" style="z-index: 10;">
        <i class="bi bi-chevron-double-down fs-4 opacity-50"></i>
    </div>
</section>

<!-- STATS: Real Data from Analytics -->
<section class="position-relative" style="z-index: 20; margin-top: -48px;">
    <div class="container">
        <div class="card-glass p-4 p-md-5">
            <div class="row g-4">
                <div class="col-6 col-md-3">
                    <div class="text-center">
                        <div class="stat-value font-display fw-black" style="color: var(--accent);"><%= stats.pageViews.toLocaleString() %></div>
                        <div class="stat-label text-muted" style="font-size: 0.78rem; font-weight: 600; letter-spacing: 1px;">LƯỢT XEM TRANG</div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="text-center">
                        <div class="stat-value font-display fw-black" style="color: var(--accent);"><%= stats.visitors.toLocaleString() %></div>
                        <div class="stat-label text-muted" style="font-size: 0.78rem; font-weight: 600; letter-spacing: 1px;">DU KHÁCH TRUY CẬP</div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="text-center">
                        <div class="stat-value font-display fw-black" style="color: var(--accent);"><%= stats.checkins.toLocaleString() %></div>
                        <div class="stat-label text-muted" style="font-size: 0.78rem; font-weight: 600; letter-spacing: 1px;">LƯỢT CHECK-IN</div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="text-center">
                        <div class="stat-value font-display fw-black" style="color: var(--accent);"><%= stats.destinations %></div>
                        <div class="stat-label text-muted" style="font-size: 0.78rem; font-weight: 600; letter-spacing: 1px;">ĐIỂM ĐẾN</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- DESTINATIONS: Bento Grid -->
<section class="py-5 mt-4">
    <div class="container py-5">
        <div class="row align-items-end mb-5">
            <div class="col-md-8 reveal-up">
                <span class="section-label">MUST-VISIT</span>
                <h2 class="section-title">Điểm dừng chân trọng tâm</h2>
                <p class="section-desc">Từ vườn mai cổ thụ đến xưởng nhang trăm tuổi, mỗi địa điểm là một câu chuyện chữa lành.</p>
            </div>
            <div class="col-md-4 text-md-end reveal-up">
                <a href="/explore" class="btn btn-ghost">Xem tất cả <i class="bi bi-arrow-right ms-1"></i></a>
            </div>
        </div>
        
        <div class="row g-4">
            <% featured.forEach((dest, i) => { %>
            <div class="col-md-<%= i < 2 ? '6' : '4' %> reveal-up">
                <a href="/explore/<%= dest.slug %>" class="text-decoration-none">
                    <div class="card-heal h-100" style="background: none !important; box-shadow: none !important;">
                        <div class="card-img position-relative" style="height: <%= i < 2 ? '360px' : '280px' %>;">
                            <img src="<%= fixImg(dest.cover_image) %>" alt="<%= dest.name %>">
                            <div class="position-absolute bottom-0 start-0 w-100 p-4" style="background: linear-gradient(to top, rgba(0,0,0,0.7), transparent); z-index: 5;">
                                <span class="badge-nature mb-2 d-inline-block"><%= dest.type %></span>
                                <h4 class="text-white fw-bold mb-1 font-display"><%= dest.name %></h4>
                                <p class="text-white opacity-75 mb-0 line-clamp-1" style="font-size: 0.85rem;"><%= dest.short_desc || dest.short_description %></p>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
            <% }) %>
        </div>
    </div>
</section>

<!-- EVENTS & SEASONAL (from DB — admin managed) -->
<section class="py-5" style="background: var(--grad-dark);">
    <div class="container py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-6 reveal-up">
                <% if (nextEvent) { %>
                <div class="p-5 rounded-2xl position-relative overflow-hidden" style="background: var(--grad-nature);">
                    <div class="position-relative" style="z-index: 5;">
                        <span class="badge-gold mb-3 d-inline-block">Sự kiện nổi bật</span>
                        <h2 class="text-white fw-black mb-3 font-display" style="font-size: 2rem; line-height: 1.15;"><%= nextEvent.title %></h2>
                        <p class="text-white opacity-75 mb-4" style="font-size: 0.9rem;"><%= nextEvent.description %></p>
                        <div id="countdown" class="d-flex gap-3 mb-4 flex-wrap">
                            <div class="text-center px-3 py-2 rounded-xl" style="background: rgba(255,255,255,0.12); min-width: 72px;">
                                <h3 class="fw-black text-white mb-0" id="days">00</h3>
                                <small class="text-white opacity-50" style="font-size: 0.7rem;">Ngày</small>
                            </div>
                            <div class="text-center px-3 py-2 rounded-xl" style="background: rgba(255,255,255,0.12); min-width: 72px;">
                                <h3 class="fw-black text-white mb-0" id="hours">00</h3>
                                <small class="text-white opacity-50" style="font-size: 0.7rem;">Giờ</small>
                            </div>
                            <div class="text-center px-3 py-2 rounded-xl" style="background: rgba(255,255,255,0.12); min-width: 72px;">
                                <h3 class="fw-black text-white mb-0" id="mins">00</h3>
                                <small class="text-white opacity-50" style="font-size: 0.7rem;">Phút</small>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-2 text-white opacity-60" style="font-size: 0.85rem;">
                            <i class="bi bi-geo-alt-fill"></i> <%= nextEvent.location %>
                        </div>
                    </div>
                </div>
                <% } else { %>
                <div class="p-5 rounded-2xl text-center" style="background: rgba(255,255,255,0.05);">
                    <i class="bi bi-calendar-event display-3 text-white opacity-25 mb-3 d-block"></i>
                    <h4 class="text-white opacity-50">Chưa có sự kiện nổi bật</h4>
                    <p class="text-white opacity-30 small">Quản trị viên có thể thêm sự kiện từ Admin Panel.</p>
                </div>
                <% } %>
            </div>
            <div class="col-lg-6 reveal-up">
                <span class="section-label text-white opacity-50">SEASONAL EXPERIENCE</span>
                <h2 class="text-white fw-black mb-4 font-display" style="font-size: 2rem;">Trải nghiệm theo mùa</h2>
                <p class="text-white opacity-60 mb-4">Mỗi mùa tại Bình Lợi mang một sắc thái riêng biệt.</p>
                <div class="d-flex flex-column gap-3">
                    <% seasonalExperiences.forEach(se => { %>
                    <div class="d-flex gap-3 align-items-start p-3 rounded-xl" style="background: rgba(255,255,255,0.06); transition: background 0.3s;" onmouseover="this.style.background='rgba(255,255,255,0.12)'" onmouseout="this.style.background='rgba(255,255,255,0.06)'">
                        <div class="rounded-lg d-flex align-items-center justify-content-center flex-shrink-0" style="width: 44px; height: 44px; background: rgba(255,255,255,0.1);">
                            <i class="bi <%= se.icon %> text-<%= se.icon_color %>"></i>
                        </div>
                        <div>
                            <h6 class="text-white fw-bold mb-1" style="font-size: 0.9rem;"><%= se.title %></h6>
                            <p class="text-white opacity-50 mb-0" style="font-size: 0.82rem;"><%= se.description %></p>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- SOCIAL FEED: Real Reviews from Community -->
<% if (socialFeed.length > 0) { %>
<section class="py-5">
    <div class="container py-5">
        <div class="text-center mb-5 reveal-up">
            <span class="section-label">LIVE FROM BÌNH LỢI</span>
            <h2 class="section-title mx-auto" style="max-width: 500px;">Khoảnh khắc Chữa lành</h2>
            <p class="section-desc mx-auto">Câu chuyện thật, hình ảnh thật từ cộng đồng du khách.</p>
        </div>
        
        <div class="row g-4 mb-5">
            <% socialFeed.forEach((item, index) => { %>
            <div class="col-md-4 reveal-up">
                <div class="card-heal h-100">
                    <% if (item.image) { %>
                    <div class="card-img position-relative" style="height: 420px;">
                        <img src="<%= fixImg(item.image) %>" alt="Moment">
                        <div class="position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(180deg, transparent 40%, rgba(0,0,0,0.8) 100%); z-index: 2;"></div>
                        <div class="position-absolute top-0 end-0 m-3" style="z-index: 5;">
                            <span class="glass-dark text-white px-3 py-1 rounded-pill d-flex align-items-center gap-1" style="font-size: 0.78rem; backdrop-filter: blur(10px);">
                                <i class="bi bi-heart-fill text-danger"></i> <%= item.likes %>
                            </span>
                        </div>
                        <div class="position-absolute bottom-0 start-0 w-100 p-4 text-white" style="z-index: 5;">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <img src="<%= item.avatar %>" class="rounded-circle" style="width: 36px; height: 36px; object-fit: cover; border: 2px solid rgba(255,255,255,0.4);">
                                <div>
                                    <span class="fw-bold d-block" style="font-size: 0.85rem;"><%= item.user %></span>
                                    <span class="opacity-60 d-block" style="font-size: 0.7rem;"><%= item.time %></span>
                                </div>
                            </div>
                            <p class="mb-2 line-clamp-2" style="font-size: 0.85rem; opacity: 0.9;"><%= item.text %></p>
                            <span class="opacity-50" style="font-size: 0.75rem;"><i class="bi bi-geo-alt-fill me-1"></i><%= item.location %></span>
                        </div>
                    </div>
                    <% } else { %>
                    <div class="card-glass p-4">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <img src="<%= item.avatar %>" class="rounded-circle" style="width: 48px; height: 48px; object-fit: cover; border: 2px solid var(--primary-50);">
                            <div>
                                <span class="fw-bold d-block text-dark"><%= item.user %></span>
                                <span class="opacity-60 d-block small"><%= item.time %></span>
                            </div>
                        </div>
                        <p class="mb-3 line-clamp-4 text-dark" style="font-style: italic;">"<%= item.text %>"</p>
                        <div class="d-flex justify-content-between align-items-center mt-auto">
                            <span class="small text-muted"><i class="bi bi-geo-alt-fill me-1"></i><%= item.location %></span>
                            <span class="badge bg-light text-danger"><i class="bi bi-heart-fill me-1"></i><%= item.likes %></span>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>
            <% }) %>
        </div>
        
        <div class="text-center reveal-up">
            <a href="/reviews" class="btn btn-premium">Chia sẻ khoảnh khắc của bạn <i class="bi bi-arrow-right ms-2"></i></a>
        </div>
    </div>
</section>
<% } %>

<!-- FLOATING ACTION BUTTONS — Arranged vertically -->
<div class="position-fixed d-flex flex-column gap-2 align-items-end" style="bottom: 24px; right: 24px; z-index: 1050;">
    <a href="/checkin" class="btn btn-warning rounded-circle shadow-lg p-0 d-flex align-items-center justify-content-center" 
        style="width: 50px; height: 50px;" title="Quét QR">
        <i class="bi bi-qr-code-scan fs-5"></i>
    </a>
    <button class="btn btn-primary-bl rounded-circle shadow-lg p-0 d-flex align-items-center justify-content-center" 
            style="width: 56px; height: 56px; border: 2px solid rgba(255,255,255,0.2);" 
            data-bs-toggle="modal" data-bs-target="#globalChatModal" title="Nhắn tin">
        <i class="bi bi-chat-heart-fill fs-4"></i>
    </button>
</div>

<!-- Global Chat Modal -->
<div class="modal fade" id="globalChatModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm modal-dialog-scrollable" style="max-width: 400px;">
        <div class="modal-content border-0 rounded-4 shadow-premium overflow-hidden">
            <div class="modal-header bg-dark text-white border-0 p-3">
                <div class="d-flex align-items-center gap-2">
                    <img src="/images/logo.png" height="30" onerror="this.style.display='none'">
                    <div>
                        <h6 class="modal-title fw-bold mb-0">Hỗ trợ Bình Lợi</h6>
                        <small class="opacity-50 x-small text-uppercase">Phản hồi bởi Ban Quản Trị</small>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-3 bg-light" style="height: 400px;">
                <div id="global-chat-history" class="overflow-auto h-100">
                    <div class="text-center mb-4"><span class="badge bg-white text-muted rounded-pill shadow-sm py-1 px-3 x-small">Hôm nay</span></div>
                    <div class="d-flex justify-content-start mb-3">
                        <div class="p-3 rounded-4 small shadow-sm bg-white text-dark" style="max-width: 85%; line-height: 1.5;">
                            Chào mừng bạn đến với <strong>Bình Lợi Healing</strong>! 🌿<br><br>
                            Ban quản trị xã luôn sẵn sàng giải đáp mọi thắc mắc của bạn về hành trình khám phá.
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 bg-white p-2">
                <div class="input-group">
                    <input type="text" id="global-chat-input" class="form-control border-0 bg-light rounded-pill ps-4 py-2 small" placeholder="Nhập câu hỏi..." onkeypress="if(event.key === 'Enter') sendGlobalChat()">
                    <button class="btn btn-primary-bl rounded-circle ms-2 p-0 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;" onclick="sendGlobalChat()">
                        <i class="bi bi-send-fill" style="font-size: 0.8rem;"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.getElementById('globalChatModal').addEventListener('show.bs.modal', fetchGlobalMessages);

async function fetchGlobalMessages() {
    try {
        const res = await axios.get('/api/get-messages');
        if (res.data.success) {
            const history = document.getElementById('global-chat-history');
            let html = `
                <div class="text-center mb-4"><span class="badge bg-white text-muted rounded-pill shadow-sm py-1 px-3 x-small">Hôm nay</span></div>
                <div class="d-flex justify-content-start mb-3">
                    <div class="p-3 rounded-4 small shadow-sm bg-white text-dark" style="max-width: 85%; line-height: 1.5;">
                        Chào mừng bạn đến với <strong>Bình Lợi Healing</strong>! 🌿<br><br>
                        Ban quản trị xã luôn sẵn sàng giải đáp mọi thắc mắc.
                    </div>
                </div>
            `;
            res.data.data.forEach(msg => {
                const isMe = msg.sender_uuid === (document.cookie.split('session_uuid=')[1]?.split(';')[0]);
                html += `
                    <div class="d-flex ${isMe ? 'justify-content-end' : 'justify-content-start'} mb-3">
                        <div class="p-3 rounded-4 small shadow-sm ${isMe ? 'bg-primary text-white' : 'bg-white text-dark'}" style="max-width: 85%;">
                            ${msg.message}
                        </div>
                    </div>
                `;
            });
            history.innerHTML = html;
            history.scrollTop = history.scrollHeight;
        }
    } catch (err) { console.error('Fetch error:', err); }
}

async function sendGlobalChat() {
    const input = document.getElementById('global-chat-input');
    const message = input.value.trim();
    if (!message) return;
    input.value = '';
    const history = document.getElementById('global-chat-history');
    history.insertAdjacentHTML('beforeend', `
        <div class="d-flex justify-content-end mb-3">
            <div class="p-3 rounded-4 small shadow-sm bg-primary text-white" style="max-width: 85%;">${message}</div>
        </div>
    `);
    history.scrollTop = history.scrollHeight;
    try { await axios.post('/api/send-message', { message }); } catch (err) { alert('Lỗi: ' + (err.response?.data?.message || err.message)); }
}
</script>

<!-- COUNTDOWN SCRIPT -->
<% if (nextEvent) { %>
<script>
    const festivalDate = new Date("<%= festival.date %>").getTime();
    const timer = setInterval(function() {
        const now = new Date().getTime();
        const distance = festivalDate - now;
        if (distance < 0) {
            clearInterval(timer);
            document.getElementById("countdown").innerHTML = '<span class="text-warning fw-bold">SỰ KIỆN ĐANG DIỄN RA!</span>';
            return;
        }
        document.getElementById("days").innerHTML = Math.floor(distance / (1000 * 60 * 60 * 24));
        document.getElementById("hours").innerHTML = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        document.getElementById("mins").innerHTML = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
    }, 1000);
</script>
<% } %>
