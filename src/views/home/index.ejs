<!-- HERO: Full-Width Background with Left-Aligned Text -->
<section class="hero-fullwidth">
    <img src="/images/hero-bg.jpg" alt="Bình Lợi" class="hero-bg" onerror="this.src='/images/hero-1.png'">
    <div class="hero-overlay-gradient"></div>
    <div class="hero-inner">
        <div class="container">
            <div class="row">
                <div class="col-lg-7 reveal-up">
                    <p class="hero-kham-pha">KHÁM PHÁ</p>
                    <h1 class="hero-binh-loi">BÌNH LỢI</h1>
                    <p class="hero-subtitle-line">
                        Miền Tây giữa lòng Sài Gòn — nơi thiên nhiên, văn hóa 
                        và bình yên hòa quyện, chữa lành tâm hồn bạn.
                    </p>
                    <div class="d-flex gap-3 flex-wrap">
                        <a href="/explore" class="btn-hero-explore">
