</section>

<!-- EVENTS & SEASONAL (Premium responsive styling) -->
<section class="py-5 position-relative" style="background: linear-gradient(135deg, #091f15 0%, #040e0a 100%); overflow: hidden;">
    <!-- Ambient glowing blur effects for modern premium styling -->
    <div class="position-absolute rounded-circle bg-success opacity-10" style="width: 300px; height: 300px; top: -100px; right: -50px; filter: blur(100px); pointer-events: none;"></div>
    <div class="position-absolute rounded-circle bg-warning opacity-10" style="width: 250px; height: 250px; bottom: -80px; left: -50px; filter: blur(80px); pointer-events: none;"></div>

    <div class="container py-5 position-relative" style="z-index: 2;">
        <div class="row align-items-center g-5">
            <div class="col-lg-6 reveal-up">
                <% if (nextEvent) { %>
                <div class="card border-0 rounded-4 overflow-hidden position-relative shadow-premium hover-lift h-100" 
                     style="min-height: 480px; transition: all 0.4s var(--ease-out); <% if (nextEvent.image) { %>background: url('<%= fixImg(nextEvent.image) %>') center/cover no-repeat;<% } else { %>background: linear-gradient(135deg, #10331e 0%, #06170e 100%); border: 1px solid rgba(45, 122, 74, 0.25);<% } %>">
                    
                    <!-- Gradient overlay to guarantee full contrast for text readability -->
                    <div class="position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(to bottom, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.85) 100%); z-index: 1;"></div>
                    
                    <div class="card-body p-4 p-md-5 d-flex flex-column justify-content-between position-relative h-100" style="z-index: 5; min-height: 480px;">
                        <div>
                            <span class="badge rounded-pill px-3 py-2 mb-3 text-uppercase fw-bold x-small" 
                                  style="background: rgba(240, 165, 0, 0.2); color: #ffc847; border: 1px solid rgba(240, 165, 0, 0.4); letter-spacing: 1.5px;">
                                <i class="bi bi-star-fill me-1"></i> Sự kiện nổi bật
                            </span>
                            
                            <h2 class="text-white fw-black mb-3 font-display text-shadow-md" style="font-size: 2.2rem; line-height: 1.2;">
                                <%= nextEvent.title %>
                            </h2>
                            
                            <p class="mb-4" style="color: rgba(255, 255, 255, 0.88); font-size: 0.95rem; line-height: 1.6; text-shadow: 0 1px 3px rgba(0,0,0,0.5);">
                                <%= nextEvent.description %>
                            </p>
                        </div>
                        
                        <div>
                            <!-- Countdown -->
                            <div id="countdown" class="d-flex gap-2 gap-sm-3 mb-4 flex-wrap">
