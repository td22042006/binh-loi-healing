                </div>
                <% } else { %>
                <div class="p-5 rounded-4 text-center border border-secondary border-opacity-25 shadow-premium" style="background: rgba(255,255,255,0.02); backdrop-filter: blur(5px);">
                    <i class="bi bi-calendar-event display-4 text-white opacity-25 mb-3 d-block"></i>
                    <h4 class="text-white fw-bold">Chưa có sự kiện nổi bật sắp diễn ra</h4>
                    <p class="small mb-0" style="color: rgba(255, 255, 255, 0.7);">Hệ thống sẽ cập nhật tự động khi có sự kiện từ quản trị viên.</p>
                </div>
                <% } %>
            </div>
            
            <div class="col-lg-6 reveal-up">
                <span class="badge rounded-pill px-3 py-2 mb-3 text-uppercase fw-bold x-small" style="background: rgba(45, 200, 100, 0.15); color: #4ade80 !important; border: 1px solid rgba(45, 200, 100, 0.3); letter-spacing: 1px;">
                    <i class="bi bi-calendar3 me-1"></i> Trải nghiệm bốn mùa
                </span>
                <h2 class="text-white fw-black mb-4 font-display" style="font-size: 2.2rem; line-height: 1.2;">Trải nghiệm theo mùa độc đáo</h2>
                <p class="mb-4" style="line-height: 1.7; color: rgba(255, 255, 255, 0.85); font-size: 1rem;">Mỗi mùa tại Bình Lợi đều được lập trình với các workshop, lễ hội và danh mục trải nghiệm độc nhất vô nhị để chữa lành tâm hồn bạn.</p>
                
                <div class="d-flex flex-column gap-3">
                    <% seasonalExperiences.forEach(se => { %>
