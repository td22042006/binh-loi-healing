<!-- Hero Section: Contained Card Style -->
<section class="py-5 bg-light">
    <div class="container py-lg-5">
        <div class="card border-0 shadow-lg overflow-hidden rounded-5 position-relative" style="min-height: 600px;">
            <div class="hero-overlay position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(to right, rgba(0,0,0,0.8), rgba(0,0,0,0.2)); z-index: 5;"></div>
            <img src="/images/hero-1.png" class="position-absolute top-0 start-0 w-100 h-100 object-fit-cover" alt="Bình Lợi Panorama">
            
            <div class="card-body h-100 position-relative d-flex align-items-center p-5 p-lg-5" style="z-index: 10;">
                <div class="col-lg-7 text-white animate__animated animate__fadeInLeft">
                    <span class="badge bg-warning text-dark fw-bold mb-3 px-3 py-2 text-uppercase">Khám phá Bình Lợi</span>
                    <h1 class="display-2 fw-bold mb-4" style="font-family: 'Playfair Display', serif;">Bình Lợi – Miền Tây<br>giữa lòng Sài Gòn</h1>
                    <p class="lead opacity-75 mb-5">
                        Trải nghiệm bản sắc văn hóa - sinh thái tại cửa ngõ thành phố.<br>
                        Nơi những hành trình chữa lành tâm hồn bắt đầu.
                    </p>
                    <div class="d-flex gap-3 flex-wrap">
                        <a href="/onboarding" class="btn btn-primary btn-lg px-5 rounded-pill shadow-lg py-3 fw-bold">
                            BẮT ĐẦU HÀNH TRÌNH ➔
                        </a>
                        <a href="/map" class="btn btn-outline-light btn-lg px-4 rounded-pill py-3 fw-bold">
                            Xem bản đồ
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Community Stats in Cards -->
<section class="pb-5 bg-light">
    <div class="container">
        <div class="row g-4 justify-content-center">
            <div class="col-md-4 col-lg-3">
                <div class="card border-0 shadow-sm rounded-4 p-4 text-center h-100">
                    <h2 class="display-6 fw-bold text-primary mb-0"><%= stats.checkins.toLocaleString() %>+</h2>
                    <p class="text-muted small text-uppercase fw-bold mb-0">Check-ins</p>
                </div>
            </div>
            <div class="col-md-4 col-lg-3">
                <div class="card border-0 shadow-sm rounded-4 p-4 text-center h-100">
                    <h2 class="display-6 fw-bold text-primary mb-0"><%= stats.destinations %></h2>
                    <p class="text-muted small text-uppercase fw-bold mb-0">Địa điểm</p>
                </div>
            </div>
            <div class="col-md-4 col-lg-3">
                <div class="card border-0 shadow-sm rounded-4 p-4 text-center h-100">
                    <h2 class="display-6 fw-bold text-primary mb-0"><%= stats.reviews.toLocaleString() %></h2>
                    <p class="text-muted small text-uppercase fw-bold mb-0">Đánh giá</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Section 1: Overview in Card -->
<section id="about" class="py-5 bg-white">
    <div class="container py-5">
        <div class="card border-0 bg-light rounded-5 overflow-hidden shadow-sm">
            <div class="row g-0 align-items-center">
                <div class="col-lg-6">
                    <div class="p-5 p-lg-5">
                        <span class="badge bg-white text-primary border px-3 py-2 mb-3">01. TỔNG QUAN</span>
                        <h2 class="display-5 fw-bold mb-4" style="color: var(--v5-primary); font-family: 'Playfair Display', serif;">Vùng đất di sản bản địa</h2>
                        <p class="lead text-muted mb-4">Xã Bình Lợi với diện tích <strong>54,18 km²</strong>, là lá phổi xanh tiềm năng bậc nhất tại cửa ngõ TP.HCM.</p>
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="p-3 bg-white rounded-3 border-start border-primary border-4">
                                    <h4 class="fw-bold mb-0 text-primary">54.18</h4>
                                    <p class="small text-muted mb-0">Km² Diện tích</p>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="p-3 bg-white rounded-3 border-start border-primary border-4">
                                    <h4 class="fw-bold mb-0 text-primary">47k+</h4>
                                    <p class="small text-muted mb-0">Cư dân</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 h-100">
                    <img src="/images/hero-2.png" class="w-100 h-100 object-fit-cover" style="min-height: 400px;" alt="Bình Lợi Landscape">
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Seasonal Recommendations -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="row mb-5 align-items-center">
            <div class="col-md-8 text-center text-md-start">
                <h2 class="display-5 fw-bold" style="font-family: 'Playfair Display', serif;">Gợi ý cho bạn mùa này</h2>
                <p class="text-muted mb-0">Dành cho: <span class="badge bg-warning text-dark rounded-pill"><%= seasonName %></span></p>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                <a href="/destinations" class="btn btn-outline-primary rounded-pill px-4">Tất cả điểm đến</a>
            </div>
        </div>

        <div class="row g-4">
            <% featured.forEach(dest => { %>
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden card-hover">
                        <img src="<%= fixImg(dest.cover_image) %>" class="card-img-top" style="height: 220px; object-fit: cover;" alt="<%= dest.name %>">
                        <div class="card-body p-4">
                            <span class="badge bg-light text-primary mb-2"><%= dest.type %></span>
                            <h5 class="fw-bold mb-3"><%= dest.name %></h5>
                            <p class="text-muted small text-truncate-2 mb-0"><%= dest.short_desc %></p>
                            <a href="/explore/<%= dest.slug %>" class="btn btn-link text-primary p-0 mt-3 text-decoration-none fw-bold">Khám phá ➔</a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</section>

<!-- CTA Card -->
<section class="py-5 bg-white">
    <div class="container py-4">
        <div class="card border-0 bg-primary text-white p-5 rounded-5 shadow-lg text-center overflow-hidden position-relative">
            <div class="position-relative" style="z-index: 10;">
                <h2 class="display-4 fw-bold mb-4" style="font-family: 'Playfair Display', serif;">Bắt đầu hành trình của bạn</h2>
                <p class="lead mb-5 opacity-75">Tham gia cùng cộng đồng khám phá Bình Lợi ngay hôm nay.</p>
                <a href="/onboarding" class="btn btn-light btn-lg px-5 py-3 rounded-pill fw-bold text-primary">KHÁM PHÁ NGAY 🚀</a>
            </div>
        </div>
    </div>
</section>

<style>
    .rounded-5 { border-radius: 2rem !important; }
    .card-hover { transition: all 0.3s ease; }
    .card-hover:hover { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(0,0,0,0.1) !important; }
    .text-truncate-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>
