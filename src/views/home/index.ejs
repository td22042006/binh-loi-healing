        <div class="row align-items-end mb-5">
            <div class="col-md-8 reveal-up">
                <span class="why-visit-label">ĐIỂM ĐẾN NỔI BẬT</span>
                <h2 class="why-visit-title">TOP <span>ĐỊA ĐIỂM</span></h2>
                <p class="text-secondary" style="max-width: 500px;">Mỗi địa điểm đều được chọn lọc kỹ lưỡng, đảm bảo tính thẩm mỹ, văn hóa và bình yên chữa lành.</p>
            </div>
            <div class="col-md-4 text-md-end reveal-up">
                <a href="/explore" class="btn-community" style="background: var(--primary-green);">
                    XEM TẤT CẢ <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
        
        <div class="row g-4">
            <% featured.slice(0, 4).forEach((dest, i) => { %>
            <div class="col-md-6 col-lg-3 reveal-up">
                <a href="/explore/<%= dest.slug %>" class="top-dest-card d-block">
                    <img src="<%= fixImg(dest.cover_image) %>" alt="<%= dest.name %>">
                    <div class="dest-overlay"></div>
                    <div class="dest-number">0<%= i + 1 %></div>
                    <div class="dest-info">
                        <h4><%= dest.name %></h4>
                        <p class="line-clamp-2"><%= dest.short_desc || dest.short_description %></p>
                        <span class="view-more">View more <i class="bi bi-arrow-right"></i></span>
                    </div>
                </a>
            </div>
            <% }) %>
        </div>
    </div>
</section>

<!-- MAP SECTION: "Bản đồ du lịch - KHÁM PHÁ BÌNH LỢI" -->
<section class="section-map">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-5 map-content reveal-up">
                <span class="map-label">BẢN ĐỒ DU LỊCH</span>
                <h2 class="map-title">KHÁM PHÁ <span>BÌNH LỢI</span></h2>
                <p style="color: rgba(255,255,255,0.6); line-height: 1.8; font-size: 0.95rem; margin-bottom: 36px; max-width: 400px;">
                    Xem bản đồ tương tác để khám phá tất cả địa điểm, lộ trình di chuyển 
                    và thông tin chi tiết về từng điểm đến tại Bình Lợi.
                </p>
                <a href="/map" class="btn-open-map">
                    <i class="bi bi-map"></i> MỞ BẢN ĐỒ
                </a>
            </div>
            <div class="col-lg-7 reveal-up">
                <div class="map-placeholder">
                    <i class="bi bi-map"></i>
