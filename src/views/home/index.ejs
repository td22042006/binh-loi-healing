                    <div>
                        <div class="stat-value font-display fw-black text-primary fs-2"><%= stats.visitors.toLocaleString() %></div>
                        <div class="stat-label text-muted x-small fw-bold text-uppercase" style="letter-spacing: 1px;">KHÁCH TRUY CẬP THỰC</div>
                    </div>
                </div>
                <div class="col-6 col-md-3 border-end-md">
                    <div>
                        <div class="stat-value font-display fw-black text-primary fs-2"><%= stats.checkins.toLocaleString() %></div>
                        <div class="stat-label text-muted x-small fw-bold text-uppercase" style="letter-spacing: 1px;">LƯỢT CHECK-IN THÀNH CÔNG</div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
