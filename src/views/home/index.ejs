<script>
    // Countdown Logic
    const festivalDate = new Date("<%= festival.date %>").getTime();
    const timer = setInterval(function() {
        const now = new Date().getTime();
        const distance = festivalDate - now;
        
        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        
        document.getElementById("days").innerHTML = days;
        document.getElementById("hours").innerHTML = hours;
        document.getElementById("mins").innerHTML = minutes;
        
        if (distance < 0) {
            clearInterval(timer);
            document.getElementById("countdown").innerHTML = "SỰ KIỆN ĐANG DIỄN RA";
        }
    }, 1000);

    // Navbar Scroll Effect
    window.addEventListener('scroll', function() {
        if (window.scrollY > 50) {
            document.querySelector('.navbar-premium').classList.add('scrolled');
        } else {
            document.querySelector('.navbar-premium').classList.remove('scrolled');
        }
    });
</script>

<style>
    .transition-all { transition: all 0.5s ease; }
    .card-healing:hover img { transform: scale(1.1); }
</style>
