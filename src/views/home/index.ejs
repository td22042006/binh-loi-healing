                                    <h3 class="fw-black text-warning mb-0 fs-2" style="color: #ffc847 !important;" id="days">00</h3>
                                    <small class="x-small text-uppercase fw-bold" style="font-size: 0.65rem; color: rgba(255, 255, 255, 0.7) !important;">Ngày</small>
                                </div>
                                <div class="text-center px-3 py-2 rounded-3 border" style="background: rgba(255, 255, 255, 0.08); border-color: rgba(255, 255, 255, 0.15) !important; min-width: 75px; backdrop-filter: blur(5px);">
                                    <h3 class="fw-black text-warning mb-0 fs-2" style="color: #ffc847 !important;" id="hours">00</h3>
                                    <small class="x-small text-uppercase fw-bold" style="font-size: 0.65rem; color: rgba(255, 255, 255, 0.7) !important;">Giờ</small>
                                </div>
                                <div class="text-center px-3 py-2 rounded-3 border" style="background: rgba(255, 255, 255, 0.08); border-color: rgba(255, 255, 255, 0.15) !important; min-width: 75px; backdrop-filter: blur(5px);">
                                    <h3 class="fw-black text-warning mb-0 fs-2" style="color: #ffc847 !important;" id="mins">00</h3>
                                    <small class="x-small text-uppercase fw-bold" style="font-size: 0.65rem; color: rgba(255, 255, 255, 0.7) !important;">Phút</small>
                                </div>
                            </div>
                            
