<section class="hero-cinematic">
    <video autoplay muted loop playsinline class="hero-video-bg">
        <source src="<%= season.video %>" type="video/mp4">
    </video>
    <div class="hero-overlay"></div>
    
    <div class="hero-content">
        <h6 class="hero-subtitle" data-aos="fade-down" data-aos-delay="200"><%= season.slogan %></h6>
        <h1 class="hero-title" data-aos="zoom-out" data-aos-delay="400"><%= season.title %></h1>
        <p class="lead mb-5 opacity-75" data-aos="fade-up" data-aos-delay="600">Khám phá vẻ đẹp bản địa, hòa mình vào thiên nhiên và chữa lành tâm hồn tại mảnh đất Bình Lợi bình yên.</p>
        <div data-aos="fade-up" data-aos-delay="800">
            <a href="/onboarding" class="btn btn-cinematic me-3">Bắt đầu hành trình</a>
            <a href="#explore" class="btn btn-outline-light rounded-pill px-5 py-3 fw-bold">Tìm hiểu thêm</a>
        </div>
    </div>
    
    <div class="position-absolute bottom-0 start-50 translate-middle-x pb-4">
        <div class="scroll-indicator">
            <div class="mouse"></div>
            <p class="x-small text-uppercase mt-2 opacity-50">Cuộn để khám phá</p>
        </div>
    </div>
</section>

<!-- Stats Section (Glassmorphism) -->
<section class="container position-relative" style="margin-top: -60px; z-index: 10;">
    <div class="glass-card p-4 p-md-5">
        <div class="row text-center g-4">
            <div class="col-6 col-md-3" data-aos="fade-up">
                <h2 class="fw-black mb-0"><%= stats.visitors.toLocaleString() %>+</h2>
                <p class="text-muted small text-uppercase fw-bold">Du khách</p>
            </div>
            <div class="col-6 col-md-3" data-aos="fade-up" data-aos-delay="100">
                <h2 class="fw-black mb-0"><%= stats.checkins.toLocaleString() %>+</h2>
                <p class="text-muted small text-uppercase fw-bold">Check-ins</p>
            </div>
            <div class="col-6 col-md-3" data-aos="fade-up" data-aos-delay="200">
                <h2 class="fw-black mb-0"><%= stats.destinations %></h2>
                <p class="text-muted small text-uppercase fw-bold">Điểm đến</p>
            </div>
            <div class="col-6 col-md-3" data-aos="fade-up" data-aos-delay="300">
                <h2 class="fw-black mb-0"><%= stats.communities %>+</h2>
                <p class="text-muted small text-uppercase fw-bold">Cộng đồng</p>
            </div>
        </div>
    </div>
</section>

<!-- Featured Destinations -->
<section id="explore" class="py-100 container">
    <div class="d-flex justify-content-between align-items-end mb-5">
        <div data-aos="fade-right">
            <h6 class="text-primary text-uppercase fw-bold tracking-widest mb-2">Khám phá</h6>
            <h2 class="display-4 fw-black">Địa điểm nổi bật</h2>
        </div>
        <a href="/explore" class="btn btn-link text-primary fw-bold text-decoration-none" data-aos="fade-left">Xem tất cả <i class="bi bi-arrow-right"></i></a>
    </div>

    <div class="row g-4">
        <% featured.forEach((dest, index) => { %>
        <div class="col-md-4" data-aos="fade-up" data-aos-delay="<%= index * 100 %>">
            <div class="glass-card overflow-hidden h-100">
                <div class="position-relative">
                    <img src="<%= fixImg(dest.cover_image) %>" class="w-100 object-fit-cover" style="height: 300px;">
                    <div class="position-absolute top-0 end-0 p-3">
                        <span class="badge glass-nav text-dark px-3 py-2 rounded-pill shadow-sm"><%= dest.category_name || 'Địa điểm' %></span>
                    </div>
                </div>
                <div class="p-4">
                    <h3 class="h4 mb-3"><%= dest.name %></h3>
                    <p class="text-muted small line-clamp-3 mb-4"><%= dest.description %></p>
                    <a href="/explore/<%= dest.slug %>" class="btn btn-outline-primary rounded-pill w-100 fw-bold">Khám phá ngay</a>
                </div>
            </div>
        </div>
        <% }) %>
    </div>
</section>

<!-- Seasonal Experience Section -->
<section class="py-100" style="background: var(--color-primary); color: white;">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6" data-aos="fade-right">
                <span class="badge bg-white text-primary px-3 py-2 rounded-pill mb-4 fw-bold">CHIẾN DỊCH <%= season.type.toUpperCase() %></span>
                <h2 class="display-3 mb-4"><%= season.title %></h2>
                <p class="lead opacity-75 mb-5">Hành trình trải nghiệm Bình Lợi không chỉ là tham quan, mà là sự hòa quyện giữa con người và hơi thở của thiên nhiên theo từng mùa trong năm.</p>
                
                <div class="glass-card p-4 bg-white bg-opacity-10 border-0 mb-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="icon-box bg-white text-primary rounded-circle" style="width: 50px; height: 50px; display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-calendar-event fs-4"></i>
                        </div>
                        <div>
                            <h6 class="mb-1 fw-bold">Sự kiện sắp tới: <%= festival.name %></h6>
                            <p class="mb-0 small opacity-75"><%= festival.location %> • <%= new Date(festival.date).toLocaleDateString('vi-VN') %></p>
                        </div>
                    </div>
                </div>
                
                <a href="/festivals" class="btn btn-white rounded-pill px-5 py-3 fw-bold mt-3" style="background: white; color: var(--color-primary);">Tham gia ngay</a>
            </div>
            <div class="col-lg-6" data-aos="fade-left">
                <div class="position-relative">
                    <img src="/images/hero-2.png" class="img-fluid rounded-4 shadow-lg" alt="Bình Lợi">
                    <div class="position-absolute -bottom-10 -left-10 glass-card p-4 d-none d-md-block" style="background: rgba(255,255,255,0.9); color: var(--color-text);">
                        <div class="d-flex align-items-center gap-3">
                            <i class="bi bi-quote fs-1 text-primary"></i>
                            <p class="mb-0 italic fw-medium">"Bình từ tâm - Lợi từ tầm"<br><small class="text-muted">- Triết lý Bình Lợi Healing</small></p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Social moments -->
<section class="py-100 container">
    <div class="text-center mb-5" data-aos="fade-up">
        <h6 class="text-primary text-uppercase fw-bold tracking-widest mb-2">Cộng đồng</h6>
        <h2 class="display-4 fw-black">Khoảnh khắc Bình Lợi</h2>
    </div>

    <div class="row g-4">
        <% socialFeed.forEach((post, index) => { %>
        <div class="col-md-3" data-aos="fade-up" data-aos-delay="<%= index * 100 %>">
            <div class="glass-card p-0 overflow-hidden h-100 shadow-sm border-0">
                <img src="<%= post.image %>" class="w-100 object-fit-cover" style="height: 250px;">
                <div class="p-3">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <img src="<%= post.avatar %>" class="rounded-circle" style="width: 30px; height: 30px; object-fit: cover;">
                        <span class="fw-bold small"><%= post.user %></span>
                    </div>
                    <p class="small text-muted line-clamp-2 mb-0"><%= post.text %></p>
                </div>
            </div>
        </div>
        <% }) %>
    </div>
</section>

<style>
    .py-100 { padding: 100px 0; }
    
    .scroll-indicator .mouse {
        width: 25px;
        height: 40px;
        border: 2px solid rgba(255,255,255,0.5);
        border-radius: 20px;
        margin: 0 auto;
        position: relative;
    }
    
    .scroll-indicator .mouse::after {
        content: '';
        width: 4px;
        height: 8px;
        background: white;
        position: absolute;
        top: 8px;
        left: 50%;
        transform: translateX(-50%);
        border-radius: 2px;
        animation: scroll-wheel 1.5s infinite;
    }
    
    @keyframes scroll-wheel {
        0% { opacity: 1; transform: translateX(-50%) translateY(0); }
        100% { opacity: 0; transform: translateX(-50%) translateY(15px); }
    }
    
    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
