<!-- Hero Section: Immersive (Restored) -->
<section class="hero-immersive position-relative overflow-hidden vh-100 bg-dark">
    <div class="hero-overlay position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.7)); z-index: 5;"></div>
    <img src="/images/hero-1.png" class="w-100 h-100 object-fit-cover animate__animated animate__zoomIn" alt="Bình Lợi Panorama">
    <div class="container h-100 position-relative d-flex align-items-center justify-content-center text-center text-white" style="z-index: 10;">
        <div class="animate__animated animate__fadeInUp col-lg-8">
            <span class="text-warning fw-bold mb-3 d-block text-uppercase" style="letter-spacing: 2px;">BÌNH LỢI — TP. HỒ CHÍ MINH</span>
            <h1 class="display-1 fw-bold mb-4" style="font-family: 'Playfair Display', serif;">Bình Lợi – Miền Tây<br>giữa lòng Sài Gòn</h1>
            <p class="lead opacity-75 mb-5 mx-auto">
                Khám phá bản sắc văn hóa - sinh thái tại cửa ngõ ngoại thành,<br>
                nơi truyền thống làng nghề hòa quyện cùng công nghệ số.
            </p>
            <div class="d-flex gap-3 justify-content-center flex-wrap">
                <a href="/onboarding" class="btn btn-primary btn-lg px-5 rounded-pill shadow-lg py-3 fw-bold">BẮT ĐẦU HÀNH TRÌNH ➔</a>
                <a href="/map" class="btn btn-outline-light btn-lg px-5 rounded-pill shadow-lg py-3 fw-bold">Xem bản đồ</a>
            </div>
        </div>
    </div>
</section>

<!-- Stats Float -->
<section class="bg-white py-5 shadow-sm position-relative rounded-top-5 mt-n5" style="z-index: 20; border-radius: 40px 40px 0 0 !important;">
    <div class="container">
        <div class="row g-4 text-center">
            <div class="col-md-4"><div class="p-3"><h2 class="display-5 fw-bold text-primary mb-0"><%= stats.checkins.toLocaleString() %>+</h2><p class="text-muted small text-uppercase fw-bold mb-0">Check-in</p></div></div>
            <div class="col-md-4 border-start border-end"><div class="p-3"><h2 class="display-5 fw-bold text-primary mb-0"><%= stats.destinations %></h2><p class="text-muted small text-uppercase fw-bold mb-0">Điểm đến</p></div></div>
            <div class="col-md-4"><div class="p-3"><h2 class="display-5 fw-bold text-primary mb-0"><%= stats.reviews.toLocaleString() %></h2><p class="text-muted small text-uppercase fw-bold mb-0">Đánh giá</p></div></div>
        </div>
    </div>
</section>

<!-- 01. TỔNG QUAN -->
<section class="py-5 bg-white"><div class="container py-5"><div class="row align-items-center g-5">
    <div class="col-lg-6">
        <span class="badge bg-light text-primary border px-3 py-2 mb-3">01. TỔNG QUAN ĐỊA PHƯƠNG</span>
        <h2 class="display-4 fw-bold mb-4" style="color: var(--v5-primary); font-family: 'Playfair Display', serif;">Vùng đất của di sản bản địa</h2>
        <p class="lead text-muted mb-4">Xã Bình Lợi sở hữu diện tích khoảng <strong>54,18 km²</strong>, là lá phổi xanh tiềm năng bậc nhất cửa ngõ Sài Gòn.</p>
        <div class="row g-3"><div class="col-6"><div class="p-3 bg-light rounded-3 border-start border-primary border-4"><h4 class="fw-bold mb-0">54.18</h4><p class="small text-muted mb-0">Km² Diện tích</p></div></div>
        <div class="col-6"><div class="p-3 bg-light rounded-3 border-start border-primary border-4"><h4 class="fw-bold mb-0">47k+</h4><p class="small text-muted mb-0">Cư dân</p></div></div></div>
    </div>
    <div class="col-lg-6"><img src="/images/hero-2.png" class="img-fluid rounded-4 shadow-lg" alt="Bình Lợi Overview"></div>
</div></div></section>

<!-- 02. HẠT NHÂN KẾT NỐI -->
<section class="py-5 bg-dark text-white"><div class="container py-5"><div class="row align-items-center g-5">
    <div class="col-lg-6 order-2 order-lg-1"><img src="/images/hero-1.png" class="img-fluid rounded-4 shadow-lg" alt="Láng Le Hub"></div>
    <div class="col-lg-6 order-1 order-lg-2">
        <span class="text-warning fw-bold mb-2 d-block">02. HẠT NHÂN KẾT NỐI</span>
        <h2 class="display-4 fw-bold mb-4" style="font-family: 'Playfair Display', serif;">Công viên Văn hóa Láng Le</h2>
        <p class="lead opacity-75 mb-4">Điểm hội tụ các giá trị lịch sử và là trung tâm kết nối mọi hành trình làng nghề.</p>
        <div class="d-flex gap-3 mb-3"><div class="bg-primary p-2 rounded-3" style="width:40px;height:40px;"><i class="bi bi-geo-fill"></i></div><p class="mb-0">Vị trí chiến lược, điểm xuất phát lý tưởng.</p></div>
        <div class="d-flex gap-3"><div class="bg-primary p-2 rounded-3" style="width:40px;height:40px;"><i class="bi bi-people-fill"></i></div><p class="mb-0">Nơi lưu giữ hồn cốt văn hóa cộng đồng đặc trưng.</p></div>
    </div>
</div></div></section>

