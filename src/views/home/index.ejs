                         style="background: rgba(255, 255, 255, 0.03); border-color: rgba(255, 255, 255, 0.06) !important; transition: all 0.3s;" 
                         onmouseover="this.style.background='rgba(255, 255, 255, 0.08)'; this.style.borderColor='rgba(255, 255, 255, 0.12)';" 
