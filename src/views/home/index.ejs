            </div>
            <div class="col-md-4 text-md-end reveal-up">
                <a href="/explore" class="btn btn-outline-primary rounded-pill px-4 py-2 fw-bold small">Xem tất cả địa điểm <i class="bi bi-arrow-right ms-1"></i></a>
            </div>
        </div>
        
        <div class="row g-4">
            <% featured.forEach((dest, i) => { %>
