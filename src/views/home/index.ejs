<!-- STAMP COLLECTION: "BỘ SƯU TẬP CỦA BẠN" -->
<section class="section-stamps">
    <div class="container">
        <div class="text-center mb-5 reveal-up">
            <span class="why-visit-label">BỘ SƯU TẬP CỦA BẠN</span>
            <h2 class="why-visit-title" style="max-width: 500px; margin: 0 auto;">Thu thập tem <span>Bình Lợi</span></h2>
        </div>

        <!-- Progress -->
        <div class="stamp-progress reveal-up" style="max-width: 500px; margin: 0 auto 40px;">
            <div class="progress-ring">
                <div class="inner">3/6</div>
            </div>
            <div>
                <div class="fw-bold" style="font-size: 1rem; color: var(--text);">Tiến trình thu thập</div>
                <div style="font-size: 0.82rem; color: var(--text-secondary);">3/6 địa điểm đã check-in. Hoàn thành để nhận phần thưởng!</div>
            </div>
        </div>

        <!-- Stamp Grid -->
        <div class="row g-3 justify-content-center" style="max-width: 800px; margin: 0 auto;">
            <% 
            const stampDestinations = featured.slice(0, 6);
            const stampIcons = ['bi-tree', 'bi-flower1', 'bi-houses', 'bi-bookmark-star', 'bi-building', 'bi-water'];
            stampDestinations.forEach((dest, i) => { 
            %>
            <div class="col-4 col-md-2 reveal-up">
                <div class="stamp-slot <%= i < 3 ? 'collected' : '' %>">
                    <div class="stamp-icon <%= i < 3 ? 'active' : 'inactive' %>">
                        <i class="bi <%= stampIcons[i] || 'bi-geo-alt' %>"></i>
                    </div>
                    <span class="stamp-name"><%= dest.name.length > 20 ? dest.name.substring(0, 18) + '...' : dest.name %></span>
                </div>
            </div>
            <% }) %>
        </div>
    </div>
</section>

