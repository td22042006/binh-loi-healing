<!-- Hero Section: Cinematic & Immersive -->
<section class="hero-cinematic position-relative bg-dark">
    <!-- Background Video with Fallback -->
    <video autoplay muted loop playsinline class="hero-video-bg" poster="/images/hero-1.png">
        <source src="<%= season.video %>" type="video/mp4">
        <!-- Fallback Image if Video fails -->
        <img src="/images/hero-1.png" class="w-100 h-100 object-fit-cover" alt="Bình Lợi Hero">
    </video>
    
    <div class="hero-overlay position-absolute top-0 start-0 w-100 h-100 dark-overlay" style="z-index: 5;"></div>
    
    <div class="container h-100 position-relative d-flex align-items-center justify-content-center text-center text-white" style="z-index: 10;">
        <div class="animate__animated animate__fadeInUp col-lg-10">
            <div class="hero-slogan mb-3 reveal-up"><%= season.type.toUpperCase() %> EXPERIENCE</div>
            <h1 class="hero-title fw-bold mb-4 reveal-up" style="font-family: var(--font-heading);">
                <%= season.title %>
            </h1>
            <p class="lead opacity-75 mb-5 mx-auto fs-4 reveal-up" style="max-width: 800px;">
                Bình Lợi – Vùng đất "Bình từ tâm, Lợi từ tầm". Khám phá Miền Tây ngay giữa lòng Sài Gòn với hệ sinh thái du lịch số thông minh.
            </p>
            <div class="d-flex gap-4 justify-content-center flex-wrap reveal-up">
                <a href="/onboarding" class="btn btn-premium btn-lg shadow-lg">KHÁM PHÁ NGAY ➔</a>
                <a href="/festivals" class="btn btn-mai btn-lg px-5 fw-bold shadow-lg">Hội Xuân 2026</a>
            </div>
        </div>
    </div>
    
    <!-- Scroll Indicator -->
    <div class="position-absolute bottom-0 start-50 translate-middle-x mb-5 text-white opacity-50 animate__animated animate__bounce animate__infinite" style="z-index: 10;">
        <i class="bi bi-chevron-double-down fs-2"></i>
    </div>
</section>

<!-- Stats Section: Floating Counter -->
<section class="position-relative" style="z-index: 20; margin-top: -60px;">
    <div class="container">
        <div class="glass-panel p-5">
            <div class="row g-4 text-center">
                <div class="col-md-3">
                    <h2 class="display-5 fw-bold text-primary mb-1"><%= stats.checkins.toLocaleString() %>+</h2>
                    <p class="text-muted small text-uppercase fw-bold mb-0">Lượt Check-in</p>
                </div>
                <div class="col-md-3 border-start">
                    <h2 class="display-5 fw-bold text-primary mb-1"><%= stats.visitors.toLocaleString() %>+</h2>
                    <p class="text-muted small text-uppercase fw-bold mb-0">Du khách</p>
                </div>
                <div class="col-md-3 border-start">
                    <h2 class="display-5 fw-bold text-primary mb-1"><%= stats.destinations %></h2>
                    <p class="text-muted small text-uppercase fw-bold mb-0">Điểm đến</p>
                </div>
                <div class="col-md-3 border-start">
                    <h2 class="display-5 fw-bold text-primary mb-1"><%= stats.communities %></h2>
                    <p class="text-muted small text-uppercase fw-bold mb-0">Làng nghề</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Festival Countdown: Smart Engagement -->
<section class="py-5 bg-white overflow-hidden">
    <div class="container py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="p-5 rounded-5 shadow-lg position-relative overflow-hidden" style="background: linear-gradient(135deg, #1a4d2e, #4f6f52);">
                    <div class="position-relative" style="z-index: 5;">
                        <span class="text-warning fw-bold text-uppercase d-block mb-3">Sự kiện nổi bật</span>
                        <h2 class="display-4 text-white fw-bold mb-4"><%= festival.name %></h2>
                        <div id="countdown" class="d-flex gap-3 mb-5">
                            <div class="bg-white bg-opacity-10 rounded-4 p-3 text-white text-center" style="min-width: 80px;">
                                <h3 class="fw-bold mb-0" id="days">00</h3><small class="opacity-50">Ngày</small>
                            </div>
                            <div class="bg-white bg-opacity-10 rounded-4 p-3 text-white text-center" style="min-width: 80px;">
                                <h3 class="fw-bold mb-0" id="hours">00</h3><small class="opacity-50">Giờ</small>
                            </div>
                            <div class="bg-white bg-opacity-10 rounded-4 p-3 text-white text-center" style="min-width: 80px;">
                                <h3 class="fw-bold mb-0" id="mins">00</h3><small class="opacity-50">Phút</small>
                            </div>
                        </div>
                        <a href="/festivals" class="btn btn-warning btn-lg rounded-pill px-5 fw-bold shadow-sm">Đăng ký tham gia ngay</a>
                    </div>
                    <i class="bi bi-calendar-event position-absolute bottom-0 end-0 text-white opacity-10" style="font-size: 15rem; transform: translate(20%, 20%);"></i>
                </div>
            </div>
            <div class="col-lg-6">
                <span class="text-primary fw-bold mb-2 d-block">SEASONAL EXPERIENCE</span>
                <h2 class="display-4 fw-bold mb-4" style="color: var(--v5-primary);">Trải nghiệm theo mùa</h2>
                <p class="lead text-muted mb-4">Mỗi mùa tại Bình Lợi mang một sắc thái riêng biệt, từ sắc vàng rực rỡ của rừng Mai đến vẻ đẹp yên bình của những đêm thả hoa đăng.</p>
                <div class="list-group list-group-flush">
                    <div class="list-group-item bg-transparent border-0 px-0 py-3 d-flex gap-3 align-items-start">
                        <div class="bg-warning text-dark rounded-circle p-2"><i class="bi bi-flower1"></i></div>
                        <div><h5 class="fw-bold mb-1">Đông Xuân: Mai Vàng Khoe Sắc</h5><p class="small text-muted mb-0">Khám phá làng nghề truyền thống và xin lộc đầu năm tại chùa Thanh Tâm.</p></div>
                    </div>
                    <div class="list-group-item bg-transparent border-0 px-0 py-3 d-flex gap-3 align-items-start">
                        <div class="bg-success text-white rounded-circle p-2"><i class="bi bi-bicycle"></i></div>
                        <div><h5 class="fw-bold mb-1">Mùa Hạ: Miệt Vườn Xanh Mát</h5><p class="small text-muted mb-0">Đạp xe xuyên rừng phòng hộ, trải nghiệm hái dừa và làm nông dân thực thụ.</p></div>
                    </div>
                    <div class="list-group-item bg-transparent border-0 px-0 py-3 d-flex gap-3 align-items-start">
                        <div class="bg-danger text-white rounded-circle p-2"><i class="bi bi-stars"></i></div>
                        <div><h5 class="fw-bold mb-1">Thu Đông: Đêm Hoa Đăng Chữa Lành</h5><p class="small text-muted mb-0">Trải nghiệm Acoustic bên hồ, thả hoa đăng cầu bình an và thiền định.</p></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Trending Check-in: Social Wall -->
<section class="py-5 bg-light overflow-hidden">
    <div class="container py-5">
        <div class="text-center mb-5 reveal-up">
            <span class="text-primary fw-bold mb-2 d-block text-uppercase tracking-widest" style="font-size: 0.8rem;">Live from Bình Lợi</span>
            <h2 class="display-4 fw-black mb-3">Khoảnh khắc Chữa lành</h2>
            <p class="text-muted mx-auto" style="max-width: 600px;">Những câu chuyện thật, hình ảnh thật được cộng đồng du khách chia sẻ trực tiếp từ hành trình khám phá.</p>
        </div>
        
        <div class="row g-4 mb-5">
            <% socialFeed.forEach((item, index) => { %>
            <div class="col-md-4 reveal-up">
                <div class="social-card h-100 shadow-premium rounded-5 overflow-hidden bg-white">
                    <div class="social-img-wrapper position-relative" style="height: 450px;">
                        <img src="<%= fixImg(item.image) %>" class="w-100 h-100 object-fit-cover transition-all" alt="Moment">
                        <div class="social-overlay"></div>
                        <div class="position-absolute top-0 end-0 m-3" style="z-index: 10;">
                            <span class="badge glass-panel text-white border-0"><i class="bi bi-heart-fill text-danger me-1"></i> <%= item.likes %></span>
                        </div>
                        <div class="position-absolute bottom-0 start-0 w-100 p-4 text-white" style="z-index: 10;">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <img src="<%= item.avatar %>" class="rounded-circle border border-2 border-white shadow-sm" style="width: 40px; height: 40px;">
                                <div>
                                    <h6 class="mb-0 fw-bold">@<%= item.user.toLowerCase().replace(' ', '') %></h6>
                                    <small class="opacity-75"><%= item.time %></small>
                                </div>
                            </div>
                            <p class="small mb-2 line-clamp-3"><%= item.text %></p>
                            <div class="d-flex align-items-center gap-1 x-small text-secondary">
                                <i class="bi bi-geo-alt-fill"></i> <%= item.location %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>
        
        <div class="text-center reveal-up">
            <button class="btn btn-premium btn-lg rounded-pill px-5 shadow-lg">CHIA SẺ KHOẢNH KHẮC CỦA BẠN</button>
        </div>
    </div>
</section>

<style>
.social-card { transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1); }
.social-card:hover { transform: translateY(-15px); }
.social-img-wrapper:hover img { transform: scale(1.1); }
.social-overlay {
    position: absolute;
    bottom: 0; left: 0; width: 100%; height: 60%;
    background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
    z-index: 5;
}
.tracking-widest { letter-spacing: 3px; }
.shadow-premium { box-shadow: 0 20px 40px rgba(0,0,0,0.1); }
</style>

<!-- Destinations Section -->
