<!-- HERO: 2-Column Layout with Quick Info Card -->
<section class="hero-new" style="<% if (settings.hero_image && settings.hero_image !== '/images/hero-1.png' && settings.hero_image !== 'undefined') { %>background: linear-gradient(rgba(213, 210, 201, 0.85), rgba(213, 210, 201, 0.9)), url('<%= fixImg(settings.hero_image) %>') center/cover no-repeat;<% } else { %>background: #d5d2c9;<% } %>">
    <div class="container">
        <div class="row align-items-start g-5">
            <div class="col-lg-7 reveal-up">
                <h1 class="hero-brand-title"><%= season.title || 'BÌNH LỢI' %></h1>
                <div class="hero-title-line"></div>
                <p class="hero-tagline">KHÁM PHÁ MIỀN TÂY GIỮA LÒNG SÀI GÒN</p>
                <p class="text-secondary mb-4" style="max-width: 520px; line-height: 1.8; font-size: 0.95rem;">
                    Bình Lợi là vùng đất yên bình, nổi bật với làng mai, làng nhang và 
                    những không gian văn hóa truyền thống, mang đến một trải 
                    nghiệm gần gũi và đậm chất địa phương.
                </p>
                <div class="d-flex gap-3 flex-wrap">
                    <a href="/explore" class="btn-explore-new">
                        <i class="bi bi-geo-alt"></i> EXPLORE LOCATIONS
                    </a>
                    <a href="/map" class="btn-map-new">
                        VIEW MAP <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
            <div class="col-lg-5 reveal-up">
                <div class="quick-info-card">
                    <h5 class="qi-title">THÔNG TIN NHANH</h5>
                    <table class="quick-info-table">
                        <tr>
                            <td class="qi-label">VỊ TRÍ:</td>
                            <td class="qi-value">Huyện Bình Chánh, TP.HCM</td>
                        </tr>
                        <tr>
                            <td class="qi-label">ĐẶC SẢN:</td>
                            <td class="qi-value accent">Mai Vàng, Nhang Thơm, Cá Koi</td>
                        </tr>
                        <tr>
                            <td class="qi-label">KHÔNG GIAN:</td>
                            <td class="qi-value">Miệt vườn sinh thái, tâm linh</td>
                        </tr>
                        <tr>
                            <td class="qi-label">CÁCH TRUNG TÂM:</td>
                            <td class="qi-value">Khoảng 20km (45-60 phút)</td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- STATS: Dark Section with Impressive Numbers and Wave Separators -->
<section class="stats-dark">
    <!-- Top Wave divider (white wave curving into the dark section) -->
    <div class="position-absolute top-0 start-0 w-100 overflow-hidden" style="height: 60px; pointer-events: none; z-index: 2;">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 60" preserveAspectRatio="none" style="width: 100%; height: 100%; display: block;">
            <path d="M0,0 C480,50 960,50 1440,0 L1440,60 L0,60 Z" fill="#ffffff"></path>
        </svg>
    </div>

    <div class="container py-4">
        <h2 class="stats-heading text-center">NHỮNG CON SỐ ẤN TƯỢNG</h2>
        <div class="row g-4 text-center">
            <div class="col-6 col-md-3">
                <div class="stat-item-dark">
                    <div class="stat-number"><%= stats.checkins > 0 ? stats.checkins.toLocaleString() : '28000' %>+</div>
                    <div class="stat-text">LƯỢT CHECK-IN</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-item-dark">
                    <div class="stat-number"><%= stats.destinations %>+</div>
                    <div class="stat-text">ĐỊA ĐIỂM TRỌNG TÂM</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-item-dark">
                    <div class="stat-number"><%= stats.workshopCount || '50' %>+</div>
                    <div class="stat-text">WORKSHOP ĐÃ TỔ CHỨC</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-item-dark">
                    <div class="stat-number"><%= stats.avgRating || '4.9' %>/5</div>
                    <div class="stat-text">ĐÁNH GIÁ TRUNG BÌNH</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bottom Wave divider (white wave curving out of the dark section) -->
    <div class="position-absolute bottom-0 start-0 w-100 overflow-hidden" style="height: 60px; pointer-events: none; z-index: 2;">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 60" preserveAspectRatio="none" style="width: 100%; height: 100%; display: block;">
            <path d="M0,60 C480,10 960,10 1440,60 L1440,0 L0,0 Z" fill="#ffffff"></path>
        </svg>
    </div>
</section>

<!-- DESTINATIONS: Equal Bento Grid -->
<section class="py-5 mt-4">
    <div class="container py-5">
        <div class="row align-items-end mb-5">
            <div class="col-md-8 reveal-up">
                <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 mb-2 fw-bold text-uppercase x-small" style="letter-spacing: 1px;">MUST-VISIT</span>
                <h2 class="fw-black text-dark mb-1 letter-spacing-sm">Điểm dừng chân trọng tâm</h2>
                <p class="text-muted">Mỗi địa điểm đều được chọn lọc kỹ lưỡng, đảm bảo tính thẩm mỹ, văn hóa và bình yên chữa lành.</p>
            </div>
            <div class="col-md-4 text-md-end reveal-up">
                <a href="/explore" class="btn btn-view-all-dest rounded-pill px-4 py-2 fw-bold">XEM TẤT CẢ ĐỊA ĐIỂM <i class="bi bi-arrow-right ms-1"></i></a>
            </div>
        </div>
        
        <div class="row g-4">
            <% featured.forEach((dest, i) => { %>
            <div class="col-md-6 col-lg-4 reveal-up">
                <a href="/explore/<%= dest.slug %>" class="text-decoration-none card-heal-wrapper">
                    <div class="card border-0 shadow-sm rounded-4 overflow-hidden position-relative hover-lift" style="height: 340px; transition: all 0.3s ease;">
                        <img src="<%= fixImg(dest.cover_image) %>" alt="<%= dest.name %>" class="w-100 h-100" style="object-fit: cover; transition: transform 0.5s ease;">
                        <div class="position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.2) 60%, transparent 100%); z-index: 2;"></div>
                        
                        <div class="position-absolute bottom-0 start-0 w-100 p-4" style="z-index: 5;">
                            <span class="badge-dest-type mb-2 d-inline-block"><%= dest.type %></span>
                            <h5 class="text-white font-black mb-1 font-display" style="font-size: 1.2rem;"><%= dest.name %></h5>
                            <p class="text-white-50 mb-0 line-clamp-2" style="font-size: 0.8rem; line-height: 1.5;"><%= dest.short_desc || dest.short_description %></p>
                        </div>
                    </div>
                </a>
            </div>
            <% }) %>
        </div>
    </div>
</section>

<!-- EVENTS & SEASONAL (Bright and modern styling) -->
<section class="py-5 position-relative" style="background: linear-gradient(135deg, var(--primary-50) 0%, #ffffff 100%); border-top: 1px solid var(--border-light); border-bottom: 1px solid var(--border-light); overflow: hidden;">
    <div class="container py-5 position-relative" style="z-index: 2;">
        <div class="row align-items-center g-5">
            <div class="col-lg-6 reveal-up">
                <% if (nextEvent) { %>
                <div class="card border-0 rounded-4 overflow-hidden position-relative shadow-premium hover-lift h-100" 
                     style="min-height: 480px; transition: all 0.4s var(--ease-out); background: linear-gradient(135deg, #0d2315 0%, #06120b 100%); border: 1px solid rgba(45, 122, 74, 0.15);">
                    
                    <!-- Gradient overlay for text readability -->
                    <div class="position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.75) 100%); z-index: 1;"></div>
                    
                    <div class="card-body p-4 p-md-5 d-flex flex-column justify-content-between position-relative h-100" style="z-index: 5; min-height: 480px;">
                        <div>
                            <span class="badge rounded-pill px-3 py-2 mb-3 text-uppercase fw-bold x-small" 
                                  style="background: rgba(255, 255, 255, 0.08); color: rgba(255, 255, 255, 0.9); border: 1px solid rgba(255, 255, 255, 0.15); letter-spacing: 1px;">
                                <i class="bi bi-star-fill me-1" style="color: #ffc847;"></i> Sự kiện nổi bật
                            </span>
                            
                            <h2 class="text-white font-black mb-3 font-display" style="font-size: 2.2rem; line-height: 1.2;">
                                <%= nextEvent.title %>
                            </h2>
                            
                            <p class="mb-4" style="color: rgba(255, 255, 255, 0.7); font-size: 0.95rem; line-height: 1.6;">
                                <%= nextEvent.description %>
                            </p>
                        </div>
                        
                        <div>
                            <!-- Event status label -->
                            <div class="mb-4">
                                <span class="font-extrabold text-uppercase x-small" style="color: #ffc847; letter-spacing: 1.5px;">
                                    SỰ KIỆN ĐANG DIỄN RA!
                                </span>
                            </div>
                            
                            <div class="d-flex flex-column gap-2" style="font-size: 0.9rem;">
                                <div class="d-flex align-items-center gap-2" style="color: rgba(255, 255, 255, 0.95);">
                                    <i class="bi bi-geo-alt-fill text-danger fs-5"></i> 
                                    <span class="fw-bold"><%= nextEvent.location %></span>
                                </div>
                                <div class="d-flex align-items-center gap-2 mt-1" style="color: rgba(255, 255, 255, 0.95);">
                                    <i class="bi bi-calendar-event text-warning fs-5" style="color: #ffc847 !important;"></i> 
                                    <span>lúc <%= new Date(nextEvent.event_date).toLocaleDateString('vi-VN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <% } else { %>
                <div class="p-5 rounded-4 text-center border shadow-sm" style="background: #ffffff; border-color: var(--border) !important;">
                    <i class="bi bi-calendar-event display-4 text-success opacity-25 mb-3 d-block"></i>
                    <h4 class="text-dark fw-bold">Chưa có sự kiện nổi bật sắp diễn ra</h4>
                    <p class="small mb-0 text-muted">Hệ thống sẽ cập nhật tự động khi có sự kiện từ quản trị viên.</p>
                </div>
                <% } %>
            </div>
            
            <div class="col-lg-6 reveal-up">
                <span class="badge rounded-pill px-3 py-2 mb-3 text-uppercase fw-bold x-small" style="background: var(--primary-100); color: var(--primary); border: 1px solid var(--primary-200); letter-spacing: 1px;">
                    <i class="bi bi-calendar3 me-1"></i> Trải nghiệm bốn mùa
                </span>
                <h2 class="text-dark font-black mb-4 font-display" style="font-size: 2.2rem; line-height: 1.2;">Trải nghiệm theo mùa độc đáo</h2>
                <p class="mb-4 text-secondary" style="line-height: 1.7; font-size: 1rem;">Mỗi mùa tại Bình Lợi đều được lập trình với các workshop, lễ hội và danh mục trải nghiệm độc nhất vô nhị để chữa lành tâm hồn bạn.</p>
                
                <div class="d-flex flex-column gap-3">
                    <% seasonalExperiences.forEach(se => { %>
                    <div class="d-flex gap-3 align-items-center p-3 rounded-4 border" 
                         style="background: #ffffff; border-color: var(--border) !important; transition: all 0.3s;" 
                         onmouseover="this.style.background='var(--primary-50)'; this.style.borderColor='var(--primary-200)';" 
                         onmouseout="this.style.background='#ffffff'; this.style.borderColor='var(--border)';" >
                        <% 
                            let colorStyle = 'background: rgba(45, 122, 74, 0.1); color: var(--primary) !important; border: 1px solid rgba(45, 122, 74, 0.2);';
                            if (se.icon_color === 'warning') colorStyle = 'background: rgba(240, 165, 0, 0.1); color: var(--accent-dark) !important; border: 1px solid rgba(240, 165, 0, 0.2);';
                            if (se.icon_color === 'danger') colorStyle = 'background: rgba(239, 68, 68, 0.1); color: var(--danger) !important; border: 1px solid rgba(239, 68, 68, 0.2);';
                            if (se.icon_color === 'info') colorStyle = 'background: rgba(59, 130, 246, 0.1); color: var(--info) !important; border: 1px solid rgba(59, 130, 246, 0.2);';
                        %>
                        <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 48px; height: 48px; <%= colorStyle %>">
                            <i class="bi <%= se.icon %> fs-5"></i>
                        </div>
                        <div>
                            <h6 class="text-dark font-extrabold mb-1" style="font-size: 0.95rem;"><%= se.title %></h6>
                            <p class="mb-0 x-small text-secondary" style="line-height: 1.5;"><%= se.description %></p>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>
</section>

