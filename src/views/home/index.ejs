<!-- ============================================
     HOMEPAGE — Bình Lợi Healing v6
     ============================================ -->

<!-- HERO: Full Viewport Cinematic -->
<section class="hero-cinematic position-relative">
    <video autoplay muted loop playsinline class="hero-video-bg" poster="/images/hero-1.png">
        <source src="<%= season.video %>" type="video/mp4">
    </video>
    <div class="hero-overlay position-absolute top-0 start-0 w-100 h-100"></div>
    
    <div class="hero-content text-center">
        <div class="hero-slogan reveal-up"><%= season.type.toUpperCase() %> EXPERIENCE</div>
        <h1 class="hero-title reveal-up"><%= season.title %></h1>
        <p class="hero-desc reveal-up">
            Khám phá Miền Tây ngay giữa lòng Sài Gòn — Hệ sinh thái du lịch số thông minh kết nối bạn với thiên nhiên, văn hóa và con người Bình Lợi.
        </p>
        <div class="d-flex gap-3 justify-content-center flex-wrap reveal-up">
            <a href="/onboarding" class="btn btn-premium btn-lg">Khám phá ngay <i class="bi bi-arrow-right ms-2"></i></a>
            <a href="/festivals" class="btn btn-gold btn-lg">Hội Xuân 2026</a>
        </div>
    </div>
    
    <!-- Scroll indicator -->
    <div class="position-absolute bottom-0 start-50 translate-middle-x mb-4 text-white animate-pulse" style="z-index: 10;">
        <i class="bi bi-chevron-double-down fs-4 opacity-50"></i>
    </div>
</section>

<!-- STATS: Floating Glass -->
<section class="position-relative" style="z-index: 20; margin-top: -48px;">
    <div class="container">
        <div class="card-glass p-4 p-md-5">
            <div class="row g-4">
                <div class="col-6 col-md-3">
                    <div class="text-center">
                        <div class="stat-value font-display fw-black" style="color: var(--primary);"><%= stats.checkins.toLocaleString() %>+</div>
                        <div class="stat-label text-muted" style="font-size: 0.78rem; font-weight: 600; letter-spacing: 1px;">LƯỢT CHECK-IN</div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="text-center">
                        <div class="stat-value font-display fw-black" style="color: var(--primary);"><%= stats.visitors.toLocaleString() %>+</div>
                        <div class="stat-label text-muted" style="font-size: 0.78rem; font-weight: 600; letter-spacing: 1px;">DU KHÁCH</div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="text-center">
                        <div class="stat-value font-display fw-black" style="color: var(--primary);"><%= stats.destinations %></div>
                        <div class="stat-label text-muted" style="font-size: 0.78rem; font-weight: 600; letter-spacing: 1px;">ĐIỂM ĐẾN</div>
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="text-center">
                        <div class="stat-value font-display fw-black" style="color: var(--primary);"><%= stats.communities %></div>
                        <div class="stat-label text-muted" style="font-size: 0.78rem; font-weight: 600; letter-spacing: 1px;">LÀNG NGHỀ</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- DESTINATIONS: Bento Grid -->
<section class="py-5 mt-4">
    <div class="container py-5">
        <div class="row align-items-end mb-5">
            <div class="col-md-8 reveal-up">
                <span class="section-label">MUST-VISIT</span>
                <h2 class="section-title">Điểm dừng chân trọng tâm</h2>
                <p class="section-desc">Từ vườn mai cổ thụ đến xưởng nhang trăm tuổi, mỗi địa điểm là một câu chuyện chữa lành.</p>
            </div>
            <div class="col-md-4 text-md-end reveal-up">
                <a href="/explore" class="btn btn-ghost">Xem tất cả <i class="bi bi-arrow-right ms-1"></i></a>
            </div>
        </div>
        
        <div class="row g-4">
            <% featured.forEach((dest, i) => { %>
            <div class="col-md-<%= i === 0 ? '8' : '4' %> reveal-up">
                <a href="/explore/<%= dest.slug %>" class="text-decoration-none">
                    <div class="card-heal h-100">
                        <div class="card-img position-relative" style="height: <%= i === 0 ? '380px' : '280px' %>;">
                            <img src="<%= fixImg(dest.cover_image) %>" alt="<%= dest.name %>">
                            <div class="position-absolute top-0 end-0 m-3" style="z-index: 5;">
                                <span class="badge-gold"><i class="bi bi-star-fill me-1"></i>4.9</span>
                            </div>
                            <div class="position-absolute bottom-0 start-0 w-100 p-4" style="background: linear-gradient(to top, rgba(0,0,0,0.7), transparent); z-index: 5;">
                                <span class="badge-nature mb-2 d-inline-block"><%= dest.type %></span>
                                <h4 class="text-white fw-bold mb-1 font-display"><%= dest.name %></h4>
                                <p class="text-white opacity-75 mb-0 line-clamp-1" style="font-size: 0.85rem;"><%= dest.short_description %></p>
                            </div>
                        </div>
                    </div>
                </a>
            </div>
            <% }) %>
        </div>
    </div>
</section>

<!-- FESTIVAL COUNTDOWN -->
<section class="py-5" style="background: var(--grad-dark);">
    <div class="container py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-6 reveal-up">
                <div class="p-5 rounded-2xl position-relative overflow-hidden" style="background: var(--grad-nature);">
                    <div class="position-relative" style="z-index: 5;">
                        <span class="badge-gold mb-3 d-inline-block">Sự kiện nổi bật</span>
                        <h2 class="text-white fw-black mb-4 font-display" style="font-size: 2.2rem; line-height: 1.15;"><%= festival.name %></h2>
                        <div id="countdown" class="d-flex gap-3 mb-4 flex-wrap">
                            <div class="text-center px-3 py-2 rounded-xl" style="background: rgba(255,255,255,0.12); min-width: 72px;">
                                <h3 class="fw-black text-white mb-0" id="days">00</h3>
                                <small class="text-white opacity-50" style="font-size: 0.7rem;">Ngày</small>
                            </div>
                            <div class="text-center px-3 py-2 rounded-xl" style="background: rgba(255,255,255,0.12); min-width: 72px;">
                                <h3 class="fw-black text-white mb-0" id="hours">00</h3>
                                <small class="text-white opacity-50" style="font-size: 0.7rem;">Giờ</small>
                            </div>
                            <div class="text-center px-3 py-2 rounded-xl" style="background: rgba(255,255,255,0.12); min-width: 72px;">
                                <h3 class="fw-black text-white mb-0" id="mins">00</h3>
                                <small class="text-white opacity-50" style="font-size: 0.7rem;">Phút</small>
                            </div>
                        </div>
                        <a href="/festivals" class="btn btn-gold px-4">Đăng ký tham gia <i class="bi bi-arrow-right ms-1"></i></a>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 reveal-up">
                <span class="section-label text-white opacity-50">SEASONAL EXPERIENCE</span>
                <h2 class="text-white fw-black mb-4 font-display" style="font-size: 2rem;">Trải nghiệm theo mùa</h2>
                <p class="text-white opacity-60 mb-4">Mỗi mùa tại Bình Lợi mang một sắc thái riêng biệt, từ sắc vàng rực rỡ của rừng Mai đến vẻ đẹp yên bình của đêm hoa đăng.</p>
                <div class="d-flex flex-column gap-3">
                    <div class="d-flex gap-3 align-items-start p-3 rounded-xl" style="background: rgba(255,255,255,0.06);">
                        <div class="rounded-lg d-flex align-items-center justify-content-center flex-shrink-0" style="width: 44px; height: 44px; background: rgba(255,193,7,0.15);"><i class="bi bi-flower1 text-warning"></i></div>
                        <div><h6 class="text-white fw-bold mb-1" style="font-size: 0.9rem;">Đông Xuân: Mai Vàng Khoe Sắc</h6><p class="text-white opacity-50 mb-0" style="font-size: 0.82rem;">Làng nghề truyền thống và xin lộc đầu năm.</p></div>
                    </div>
                    <div class="d-flex gap-3 align-items-start p-3 rounded-xl" style="background: rgba(255,255,255,0.06);">
                        <div class="rounded-lg d-flex align-items-center justify-content-center flex-shrink-0" style="width: 44px; height: 44px; background: rgba(16,185,129,0.15);"><i class="bi bi-bicycle text-success"></i></div>
                        <div><h6 class="text-white fw-bold mb-1" style="font-size: 0.9rem;">Mùa Hạ: Miệt Vườn Xanh Mát</h6><p class="text-white opacity-50 mb-0" style="font-size: 0.82rem;">Đạp xe xuyên rừng, trải nghiệm hái dừa.</p></div>
                    </div>
                    <div class="d-flex gap-3 align-items-start p-3 rounded-xl" style="background: rgba(255,255,255,0.06);">
                        <div class="rounded-lg d-flex align-items-center justify-content-center flex-shrink-0" style="width: 44px; height: 44px; background: rgba(239,68,68,0.15);"><i class="bi bi-stars text-danger"></i></div>
                        <div><h6 class="text-white fw-bold mb-1" style="font-size: 0.9rem;">Thu Đông: Đêm Hoa Đăng Chữa Lành</h6><p class="text-white opacity-50 mb-0" style="font-size: 0.82rem;">Acoustic bên hồ, thả hoa đăng cầu bình an.</p></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- SOCIAL FEED: Healing Moments -->
<section class="py-5">
    <div class="container py-5">
        <div class="text-center mb-5 reveal-up">
            <span class="section-label">LIVE FROM BÌNH LỢI</span>
            <h2 class="section-title mx-auto" style="max-width: 500px;">Khoảnh khắc Chữa lành</h2>
            <p class="section-desc mx-auto">Câu chuyện thật, hình ảnh thật từ cộng đồng du khách.</p>
        </div>
        
        <div class="row g-4 mb-5">
            <% socialFeed.forEach((item, index) => { %>
            <div class="col-md-4 reveal-up">
                <div class="card-heal h-100">
                    <% if (item.image) { %>
                    <div class="card-img position-relative" style="height: 420px;">
                        <img src="<%= fixImg(item.image) %>" alt="Moment">
                        <!-- Overlay gradient -->
                        <div class="position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(180deg, transparent 40%, rgba(0,0,0,0.8) 100%); z-index: 2;"></div>
                        <!-- Like badge -->
                        <div class="position-absolute top-0 end-0 m-3" style="z-index: 5;">
                            <span class="glass-dark text-white px-3 py-1 rounded-pill d-flex align-items-center gap-1" style="font-size: 0.78rem; backdrop-filter: blur(10px);">
                                <i class="bi bi-heart-fill text-danger"></i> <%= item.likes %>
                            </span>
                        </div>
                        <!-- Content -->
                        <div class="position-absolute bottom-0 start-0 w-100 p-4 text-white" style="z-index: 5;">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <img src="<%= item.avatar %>" class="rounded-circle" style="width: 36px; height: 36px; object-fit: cover; border: 2px solid rgba(255,255,255,0.4);">
                                <div>
                                    <span class="fw-bold d-block" style="font-size: 0.85rem;">@<%= item.user.toLowerCase().replace(' ', '') %></span>
                                    <span class="opacity-60 d-block" style="font-size: 0.7rem;"><%= item.time %></span>
                                </div>
                            </div>
                            <p class="mb-2 line-clamp-2" style="font-size: 0.85rem; opacity: 0.9;"><%= item.text %></p>
                            <span class="opacity-50" style="font-size: 0.75rem;"><i class="bi bi-geo-alt-fill me-1"></i><%= item.location %></span>
                        </div>
                    </div>
                    <% } else { %>
                    <div class="card-glass p-4">
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <img src="<%= item.avatar %>" class="rounded-circle" style="width: 48px; height: 48px; object-fit: cover; border: 2px solid var(--primary-50);">
                            <div>
                                <span class="fw-bold d-block text-dark">@<%= item.user.toLowerCase().replace(' ', '') %></span>
                                <span class="opacity-60 d-block small"><%= item.time %></span>
                            </div>
                        </div>
                        <p class="mb-3 line-clamp-4 text-dark" style="font-style: italic;">"<%= item.text %>"</p>
                        <div class="d-flex justify-content-between align-items-center mt-auto">
                            <span class="small text-muted"><i class="bi bi-geo-alt-fill me-1"></i><%= item.location %></span>
                            <span class="badge bg-light text-danger"><i class="bi bi-heart-fill me-1"></i><%= item.likes %></span>
                        </div>
                    </div>
                    <% } %>
                </div>
            </div>
            <% }) %>
        </div>
        
        <div class="text-center reveal-up">
            <a href="/reviews" class="btn btn-premium">Chia sẻ khoảnh khắc của bạn <i class="bi bi-arrow-right ms-2"></i></a>
        </div>
    </div>
</section>

<!-- SMART TECH -->
<section class="py-5" style="background: var(--surface-alt);">
    <div class="container py-5">
        <div class="text-center mb-5 reveal-up">
            <span class="section-label">DIGITAL ECOSYSTEM</span>
            <h2 class="section-title mx-auto">Trải nghiệm số hóa thông minh</h2>
            <p class="section-desc mx-auto">Nâng tầm chuyến đi với hệ sinh thái công nghệ du lịch cộng đồng.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-3 reveal-up">
                <div class="card-stat h-100">
                    <div class="stat-icon" style="background: var(--primary-50); color: var(--primary);"><i class="bi bi-qr-code-scan"></i></div>
                    <h5 class="fw-bold mb-2" style="font-size: 1rem;">Passport Điện Tử</h5>
                    <p class="text-muted mb-0" style="font-size: 0.85rem;">Tích điểm, nhận huy hiệu và stamp số hóa tại mỗi điểm đến.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 reveal-up">
                <div class="card-stat h-100">
                    <div class="stat-icon" style="background: rgba(240,165,0,0.1); color: var(--accent);"><i class="bi bi-headset"></i></div>
                    <h5 class="fw-bold mb-2" style="font-size: 1rem;">Audio Storytelling</h5>
                    <p class="text-muted mb-0" style="font-size: 0.85rem;">Nghe câu chuyện di sản qua QR code thực tế tại hiện trường.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 reveal-up">
                <div class="card-stat h-100">
                    <div class="stat-icon" style="background: rgba(59,130,246,0.1); color: var(--info);"><i class="bi bi-map-fill"></i></div>
                    <h5 class="fw-bold mb-2" style="font-size: 1rem;">Bản Đồ Tương Tác</h5>
                    <p class="text-muted mb-0" style="font-size: 0.85rem;">Định vị thực tế, gợi ý lộ trình tối ưu và tránh đám đông.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 reveal-up">
                <div class="card-stat h-100">
                    <div class="stat-icon" style="background: rgba(16,185,129,0.1); color: var(--success);"><i class="bi bi-chat-dots-fill"></i></div>
                    <h5 class="fw-bold mb-2" style="font-size: 1rem;">Chat Cộng Đồng</h5>
                    <p class="text-muted mb-0" style="font-size: 0.85rem;">Kết nối trực tiếp với người dân và quản lý điểm đến.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- COUNTDOWN SCRIPT -->
<script>
    const festivalDate = new Date("<%= festival.date %>").getTime();
    const timer = setInterval(function() {
        const now = new Date().getTime();
        const distance = festivalDate - now;
        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        document.getElementById("days").innerHTML = days;
        document.getElementById("hours").innerHTML = hours;
        document.getElementById("mins").innerHTML = minutes;
        if (distance < 0) {
            clearInterval(timer);
            document.getElementById("countdown").innerHTML = '<span class="text-warning fw-bold">SỰ KIỆN ĐANG DIỄN RA!</span>';
        }
    }, 1000);
</script>
