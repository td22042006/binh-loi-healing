<!-- Hero Section: Immersive Storytelling -->
<section class="hero-immersive position-relative overflow-hidden vh-100 bg-dark">
    <div class="hero-overlay position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.7)); z-index: 5;"></div>
    <img src="/images/hero-1.png" class="w-100 h-100 object-fit-cover animate__animated animate__zoomIn" alt="Bình Lợi Panorama">
    <div class="container h-100 position-relative d-flex align-items-center justify-content-center text-center text-white" style="z-index: 10;">
        <div class="animate__animated animate__fadeInUp col-lg-8">
            <span class="text-warning fw-bold mb-3 d-block text-uppercase" style="letter-spacing: 2px;">BÌNH LỢI — TP. HỒ CHÍ MINH</span>
            <h1 class="display-1 fw-bold mb-4" style="font-family: 'Playfair Display', serif;">Bình Lợi – Miền Tây<br>giữa lòng Sài Gòn</h1>
            <p class="lead opacity-75 mb-5 mx-auto">
                Khám phá bản sắc văn hóa - sinh thái tại cửa ngõ ngoại thành,<br>
                nơi truyền thống làng nghề hòa quyện cùng công nghệ số.
            </p>
            <div class="d-flex gap-3 justify-content-center flex-wrap">
                <a href="/map" class="btn btn-primary btn-lg px-5 rounded-pill shadow">
                    <i class="bi bi-geo-alt-fill me-2"></i>Bản đồ
                </a>
                <a href="/onboarding" class="btn btn-light btn-lg px-5 rounded-pill shadow">
                    <i class="bi bi-signpost-split-fill me-2"></i>Hành trình
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Community Stats -->
<section class="bg-white py-5 shadow-sm position-relative rounded-top-5 mt-n5" style="z-index: 20; border-radius: 40px 40px 0 0 !important;">
    <div class="container py-4">
        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="p-3">
                    <h2 class="display-5 fw-bold text-primary mb-0"><%= stats.checkins.toLocaleString() %>+</h2>
                    <p class="text-muted small text-uppercase fw-bold mb-0">Lượt Check-in</p>
                </div>
            </div>
            <div class="col-md-4 border-start border-end">
                <div class="p-3">
                    <h2 class="display-5 fw-bold text-primary mb-0"><%= stats.destinations %></h2>
                    <p class="text-muted small text-uppercase fw-bold mb-0">Điểm đến hấp dẫn</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="p-3">
                    <h2 class="display-5 fw-bold text-primary mb-0"><%= stats.reviews.toLocaleString() %></h2>
                    <p class="text-muted small text-uppercase fw-bold mb-0">Đánh giá tin cậy</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Section 1: Overview -->
<section id="about" class="py-5 bg-white">
    <div class="container py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <span class="badge bg-light text-primary border px-3 py-2 mb-3">01. TỔNG QUAN ĐỊA PHƯƠNG</span>
                <h2 class="display-4 fw-bold mb-4" style="color: var(--v5-primary); font-family: 'Playfair Display', serif;">Vùng đất của tiềm năng và di sản</h2>
                <p class="lead text-muted mb-4">Xã Bình Lợi sở hữu quy mô diện tích lớn khoảng <strong>54,18 km²</strong>, là một trong những địa phương có quỹ đất rộng bậc nhất tại TP.HCM.</p>
                <div class="row g-4 mt-2">
                    <div class="col-6">
                        <div class="p-4 border-start border-primary border-4 bg-light rounded-3">
                            <h3 class="fw-bold mb-0">54.18</h3>
                            <p class="small text-muted mb-0">Km² Diện tích</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-4 border-start border-primary border-4 bg-light rounded-3">
                            <h3 class="fw-bold mb-0">47k+</h3>
                            <p class="small text-muted mb-0">Cư dân bản địa</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="position-relative">
                    <div class="card border-0 shadow-lg overflow-hidden rounded-4">
                        <img src="/images/hero-2.png" class="card-img-top" alt="Bình Lợi Landscape">
                    </div>
                    <div class="card bg-white p-4 shadow-lg border-0 rounded-4 position-absolute top-50 start-0 translate-middle-y d-none d-md-block" style="margin-left: -30px; width: 250px;">
                        <h5 class="text-primary fw-bold mb-1">Thiên nhiên an lành</h5>
                        <p class="small text-muted mb-0">Bao quanh bởi hệ thống kênh rạch đặc trưng.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Section 2: Seasonal Recommendations -->
<section class="py-5 bg-light">
    <div class="container py-5">
        <div class="row mb-5 align-items-end">
            <div class="col-md-8 text-center text-md-start">
                <span class="badge bg-primary px-3 py-2 mb-3">✨ KHÁM PHÁ THEO MÙA</span>
                <h2 class="display-4 fw-bold" style="font-family: 'Playfair Display', serif;">Gợi ý cho bạn mùa này</h2>
                <p class="text-muted">Lễ hội đặc sắc: <span class="badge bg-warning text-dark rounded-pill"><%= seasonName %></span></p>
            </div>
            <div class="col-md-4 text-md-end">
                <a href="/destinations" class="btn btn-outline-primary rounded-pill px-4 fw-bold">Xem tất cả địa điểm</a>
            </div>
        </div>

        <div class="row g-4">
            <% featured.forEach(dest => { %>
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden transition-hover">
                        <div class="position-relative">
                            <img src="<%= fixImg(dest.cover_image) %>" class="card-img-top" style="height: 250px; object-fit: cover;" alt="<%= dest.name %>">
                            <span class="badge bg-white text-primary position-absolute top-0 end-0 m-3 shadow-sm">+<%= dest.points %> PTS</span>
                        </div>
                        <div class="card-body p-4 text-center">
                            <span class="badge bg-light text-primary mb-2 border px-2 py-1"><%= dest.type %></span>
                            <h4 class="fw-bold mb-3"><%= dest.name %></h4>
                            <p class="text-muted small text-truncate-2 mb-4"><%= dest.short_desc %></p>
                            <a href="/explore/<%= dest.slug %>" class="btn btn-primary rounded-pill w-100 fw-bold">Khám phá ngay</a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</section>

<!-- Section 3: Smart Tourism -->
<section class="py-5 bg-white">
    <div class="container py-5 text-center">
        <div class="mb-5">
            <h2 class="display-4 fw-bold mb-3" style="font-family: 'Playfair Display', serif;">Du lịch thông minh tại Bình Lợi</h2>
            <p class="text-muted mx-auto" style="max-width: 600px;">Ứng dụng công nghệ số như Bản đồ thông minh, QR kể chuyện giúp nâng cao trải nghiệm cho du khách.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm rounded-4 p-4">
                    <div class="display-4 text-primary mb-3"><i class="bi bi-map-fill"></i></div>
                    <h5 class="fw-bold">Bản đồ tương tác</h5>
                    <p class="small text-muted mb-0">Định vị GPS và gợi ý lộ trình tối ưu dựa trên sở thích cá nhân.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm rounded-4 p-4">
                    <div class="display-4 text-primary mb-3"><i class="bi bi-qr-code-scan"></i></div>
                    <h5 class="fw-bold">QR Kể Chuyện</h5>
                    <p class="small text-muted mb-0">Mỗi điểm đến là một mảnh ghép ký ức được số hóa sinh động.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm rounded-4 p-4">
                    <div class="display-4 text-primary mb-3"><i class="bi bi-award-fill"></i></div>
                    <h5 class="fw-bold">Gamification</h5>
                    <p class="small text-muted mb-0">Thu thập huy hiệu bản sắc khi khám phá đủ các địa danh tại địa phương.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="py-5 bg-primary text-white text-center">
    <div class="container py-5">
        <h2 class="display-3 fw-bold mb-4" style="font-family: 'Playfair Display', serif;">Sẵn sàng khám phá Bình Lợi?</h2>
        <p class="lead mb-5 opacity-75">Hãy để chúng tôi đồng hành cùng bạn trong hành trình chữa lành này.</p>
        <a href="/onboarding" class="btn btn-light btn-lg px-5 rounded-pill fw-bold text-primary shadow-lg py-3">BẮT ĐẦU NGAY 🚀</a>
    </div>
</section>

<style>
    .transition-hover:hover { transform: translateY(-10px); transition: all 0.3s ease; }
    .rounded-top-5 { border-radius: 40px 40px 0 0 !important; }
    .mt-n5 { margin-top: -3rem !important; }
    .text-truncate-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>
