    <div class="row align-items-end mb-5">
        <div class="col-md-8">
            <span class="text-primary fw-bold mb-2 d-block">MUST-VISIT</span>
            <h2 class="display-4 fw-bold" style="font-family: var(--font-heading);">Điểm dừng chân trọng tâm</h2>
