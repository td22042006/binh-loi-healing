<div class="immersive-wizard">
    <!-- BACKGROUND IMAGES LAYER -->
    <div class="wizard-bg-layer">
        <img src="<%= baseUrl %>/images/hero-1.png" class="wizard-bg-image active" id="bg-1">
        <img src="<%= baseUrl %>/images/hero-2.png" class="wizard-bg-image" id="bg-2">
        <img src="<%= baseUrl %>/images/hero-3.png" class="wizard-bg-image" id="bg-3">
    </div>

    <!-- CONTENT LAYER -->
    <div class="wizard-content-layer">
        <form id="onboardingForm" class="w-100">
            
            <!-- STEP 1: MOOD -->
            <div class="immersive-step active" id="step1">
                <div class="mb-2 opacity-50 letter-spacing-lg small">BƯỚC 01 / CẢM XÚC</div>
                <h2 class="immersive-title">Hôm nay bạn muốn<br><span class="text-accent">cảm thấy</span> thế nào?</h2>
                <div class="option-grid-immersive">
                    <div class="immersive-option" onclick="selectMood('an-nhien', this)">🌿 AN NHIÊN</div>
                    <div class="immersive-option" onclick="selectMood('ket-noi', this)">🏺 KẾT NỐI</div>
                    <div class="immersive-option" onclick="selectMood('nang-luong', this)">⚡ NĂNG LƯỢNG</div>
                </div>
                <input type="hidden" name="mood" id="input-mood">
            </div>

            <!-- STEP 2: DURATION -->
            <div class="immersive-step" id="step2">
                <div class="mb-2 opacity-50 letter-spacing-lg small">BƯỚC 02 / THỜI GIAN</div>
                <h2 class="immersive-title">Dành bao lâu cho<br><span class="text-accent">bản thân</span>?</h2>
                <div class="option-grid-immersive">
                    <div class="immersive-option" onclick="selectDuration('half', this)">🌤️ NỬA NGÀY</div>
                    <div class="immersive-option" onclick="selectDuration('full', this)">🌅 CẢ NGÀY</div>
                </div>
                <input type="hidden" name="duration" id="input-duration">
                <div class="mt-5">
                    <button type="button" class="btn btn-link text-white opacity-50" onclick="prevStep(1)">← QUAY LẠI</button>
                </div>
            </div>

            <!-- STEP 3: FINAL -->
            <div class="immersive-step" id="step3">
                <div class="mb-2 opacity-50 letter-spacing-lg small">BƯỚC 03 / KHỞI HÀNH</div>
                <h2 class="immersive-title">Sẵn sàng để<br><span class="text-accent">chữa lành</span>?</h2>
                <p class="lead mb-5 opacity-75">Bình Lợi Healing đã chuẩn bị sẵn sàng lộ trình dành riêng cho bạn.</p>
                <div class="text-center">
                    <button type="submit" class="btn btn-primary-bl btn-lg px-5 py-4 rounded-pill shadow-lg fw-black letter-spacing-lg">
                        BẮT ĐẦU HÀNH TRÌNH ✦
                    </button>
                    <div class="mt-4">
                        <button type="button" class="btn btn-link text-white opacity-50" onclick="prevStep(2)">← THAY ĐỔI LỰA CHỌN</button>
                    </div>
                </div>
            </div>

        </form>
    </div>

    <!-- EXIT BUTTON -->
    <a href="/" class="position-absolute top-0 end-0 m-4 text-white text-decoration-none opacity-50 hover-opacity-100 z-index-50">
        ĐÓNG <i class="bi bi-x-lg ms-2"></i>
    </a>
</div>

<script>
function selectMood(val, el) {
    document.querySelectorAll('#step1 .immersive-option').forEach(o => o.classList.remove('selected'));
    el.classList.add('selected');
    document.getElementById('input-mood').value = val;
    changeBg(2);
    setTimeout(() => nextStep(2), 600);
}

function selectDuration(val, el) {
    document.querySelectorAll('#step2 .immersive-option').forEach(o => o.classList.remove('selected'));
    el.classList.add('selected');
    document.getElementById('input-duration').value = val;
    changeBg(3);
    setTimeout(() => nextStep(3), 600);
}

function nextStep(s) {
    document.querySelectorAll('.immersive-step').forEach(step => step.classList.remove('active'));
    document.getElementById('step' + s).classList.add('active');
}

function prevStep(s) {
    document.querySelectorAll('.immersive-step').forEach(step => step.classList.remove('active'));
    document.getElementById('step' + s).classList.add('active');
    changeBg(s);
}

function changeBg(s) {
    document.querySelectorAll('.wizard-bg-image').forEach(img => img.classList.remove('active'));
    document.getElementById('bg-' + s).classList.add('active');
}

document.getElementById('onboardingForm').addEventListener('submit', function(e) {
    e.preventDefault();
    const btn = e.target.querySelector('button[type="submit"]');
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> ĐANG KHỞI TẠO...';
    btn.disabled = true;

    axios.post(window.APP_CONFIG.apiUrl + '/session', {
        mood: document.getElementById('input-mood').value,
        duration: document.getElementById('input-duration').value,
        interests: ['temple', 'craft', 'nature'] // Default all
    }).then(res => {
        window.location.href = window.APP_CONFIG.baseUrl + '/journey';
    }).catch(err => {
        alert('Có lỗi xảy ra.');
        btn.innerHTML = 'BẮT ĐẦU HÀNH TRÌNH ✦';
        btn.disabled = false;
    });
});
</script>
