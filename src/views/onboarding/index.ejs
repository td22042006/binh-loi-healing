<section class="new-wizard-wrapper">
    <div class="container-custom">
        <div class="text-center mb-5">
            <h1 class="onboard-title">Hôm nay bạn muốn đi kiểu gì?</h1>
            <p class="onboard-subtitle">Chọn vibe cho chuyến hành trình chữa lành của riêng bạn.</p>
        </div>

        <form id="newOnboardingForm">
            <!-- Vibe Selection -->
            <div class="vibe-selection-grid mb-5">
                <div class="vibe-card-new" onclick="selectVibe('chill', this)">
                    <span class="vibe-icon-new">🌿</span>
                    <span class="vibe-name-new">Chill</span>
                </div>
                <div class="vibe-card-new" onclick="selectVibe('peace', this)">
                    <span class="vibe-icon-new">🛕</span>
                    <span class="vibe-name-new">Bình yên</span>
                </div>
                <div class="vibe-card-new" onclick="selectVibe('culture', this)">
                    <span class="vibe-icon-new">🎨</span>
                    <span class="vibe-name-new">Văn hóa</span>
                </div>
                <div class="vibe-card-new" onclick="selectVibe('history', this)">
                    <span class="vibe-icon-new">🏛</span>
                    <span class="vibe-name-new">Lịch sử</span>
                </div>
                <div class="vibe-card-new" onclick="selectVibe('family', this)">
                    <span class="vibe-icon-new">🎉</span>
                    <span class="vibe-name-new">Gia đình</span>
                </div>
            </div>

            <hr class="my-5 opacity-10">

            <!-- Other Options -->
            <div class="row g-4 mb-5">
                <div class="col-md-6">
                    <label class="form-label fw-bold mb-3">Bạn có bao nhiêu thời gian?</label>
                    <select class="form-select form-select-lg rounded-4" name="duration" required>
                        <option value="3h">3-4 Tiếng (Nhanh chóng)</option>
                        <option value="1d" selected>Trọn vẹn 1 ngày</option>
                        <option value="custom">Tự chọn (Khám phá tự do)</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold mb-3">Thời điểm khởi hành?</label>
                    <select class="form-select form-select-lg rounded-4" name="when" required>
                        <option value="now">Ngay bây giờ</option>
                        <option value="weekend">Cuối tuần này</option>
                        <option value="season">Mùa lễ hội</option>
                    </select>
                </div>
            </div>

            <input type="hidden" name="moods" id="moods-input" required>

            <div class="text-center mt-5">
                <button type="submit" class="btn-primary-v5 btn-lg px-5" id="submit-btn">
                    Tạo hành trình của tôi ➔
                </button>
            </div>
        </form>
    </div>
</section>

<script>
    let selectedVibes = [];

    function selectVibe(vibe, el) {
        if (selectedVibes.includes(vibe)) {
            selectedVibes = selectedVibes.filter(v => v !== vibe);
            el.classList.remove('active');
        } else {
            selectedVibes.push(vibe);
            el.classList.add('active');
        }
        document.getElementById('moods-input').value = selectedVibes.join(',');
    }

    document.getElementById('newOnboardingForm').addEventListener('submit', function(e) {
        e.preventDefault();
        const moods = document.getElementById('moods-input').value;
        if (!moods) {
            alert('Vui lòng chọn ít nhất một Vibe!');
            return;
        }

        const btn = document.getElementById('submit-btn');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang tạo...';

        const formData = new FormData(this);
        const data = Object.fromEntries(formData.entries());

        axios.post('/api/session', data)
            .then(res => {
                window.location.href = '/hanh-trinh-cua-toi';
            })
            .catch(err => {
                console.error(err);
                btn.disabled = false;
                btn.innerHTML = 'Thử lại ➔';
            });
    });
</script>