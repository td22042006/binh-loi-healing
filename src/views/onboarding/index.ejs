<!-- Vibrant Onboarding — Choose Your Healing Vibe -->
<div class="row g-4 justify-content-center align-items-center" style="min-height: 85vh;">
    <div class="col-lg-10">
        <div class="text-center mb-5">
            <span class="badge-gold mb-3 px-4 py-2 fs-6 rounded-pill shadow-lg">KHỞI ĐẦU MỚI</span>
            <h1 class="fw-black font-display mb-3" style="font-size: 3.5rem; color: var(--primary); line-height: 1;">Bạn đang tìm kiếm điều gì?</h1>
            <p class="text-muted fs-5 mx-auto" style="max-width: 600px;">Hãy chọn "Vibe" cho hành trình hôm nay của bạn. Chúng tôi sẽ cá nhân hóa mọi địa điểm và trải nghiệm dựa trên cảm xúc của bạn.</p>
        </div>

        <div class="row g-4">
            <% 
               const vibes = [
                   { id: 'healing', name: 'CHỮA LÀNH', desc: 'Zen, Thiền định & Thiên nhiên xanh', icon: 'heart-pulse-fill', color: '#10b981', img: '/images/hero-1.jpg' },
                   { id: 'culture', name: 'VĂN HÓA', desc: 'Làng nghề, Chùa chiền & Lịch sử', icon: 'bank2', color: '#f59e0b', img: '/images/hero-2.jpg' },
                   { id: 'energy', name: 'NĂNG LƯỢNG', desc: 'Đạp xe, Chèo sub & Khám phá', icon: 'lightning-charge-fill', color: '#3b82f6', img: '/images/hero-3.jpg' }
               ];
               vibes.forEach(v => { 
            %>
            <div class="col-md-4">
                <div class="vibe-card position-relative overflow-hidden border-0 shadow-2xl cursor-pointer transition-all" 
                     style="height: 450px; border-radius: 30px; --vibe-color: <%= v.color %>;"
                     onclick="selectVibe('<%= v.id %>')">
                    
                    <img src="<%= v.img %>" class="w-100 h-100 object-fit-cover transition-all vibe-img" style="filter: brightness(0.6);">
                    
                    <!-- Content Overlay -->
                    <div class="position-absolute bottom-0 start-0 w-100 p-4 p-md-5 text-white" style="z-index: 10;">
                        <div class="rounded-circle d-flex align-items-center justify-content-center mb-4 shadow-lg vibe-icon-box" 
                             style="width: 64px; height: 64px; background: white; color: <%= v.color %>;">
                            <i class="bi bi-<%= v.icon %> fs-2"></i>
                        </div>
                        <h2 class="fw-black font-display mb-2 text-white"><%= v.name %></h2>
                        <p class="opacity-75 small mb-0"><%= v.desc %></p>
                    </div>

                    <!-- Selected Indicator -->
                    <div class="position-absolute top-0 end-0 m-4 vibe-check d-none">
                        <i class="bi bi-check-circle-fill text-white fs-1 shadow-lg"></i>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>

        <div class="mt-5 pt-4 text-center">
            <form action="/journey/confirm" method="POST" id="vibeForm">
                <input type="hidden" name="vibe" id="selectedVibeInput">
                <button type="submit" id="continueBtn" class="btn btn-premium px-5 py-3 rounded-pill fs-4 opacity-50 disabled">TIẾP TỤC HÀNH TRÌNH <i class="bi bi-arrow-right-circle-fill ms-2"></i></button>
            </form>
        </div>
    </div>
</div>

<style>
    .vibe-card:hover {
        transform: translateY(-10px) scale(1.02);
    }
    .vibe-card:hover .vibe-img {
        filter: brightness(0.8);
        transform: scale(1.1);
    }
    .vibe-card.selected {
        border: 6px solid var(--vibe-color) !important;
        box-shadow: 0 0 50px var(--vibe-color);
    }
    .vibe-card.selected .vibe-check {
        display: block !important;
    }
    .vibe-card.selected .vibe-icon-box {
        background: var(--vibe-color) !important;
        color: white !important;
    }
    .vibe-icon-box {
        transition: all 0.3s ease;
    }
    .vibe-img {
        transition: all 0.8s cubic-bezier(0.165, 0.84, 0.44, 1);
    }
</style>

<script>
    function selectVibe(id) {
        document.querySelectorAll('.vibe-card').forEach(c => c.classList.remove('selected'));
        const selectedCard = document.querySelector(`[onclick="selectVibe('${id}')"]`);
        selectedCard.classList.add('selected');
        
        document.getElementById('selectedVibeInput').value = id;
        
        const btn = document.getElementById('continueBtn');
        btn.classList.remove('opacity-50', 'disabled');
        
        // Dynamic body background hint
        document.body.style.backgroundColor = selectedCard.style.getPropertyValue('--vibe-color') + '10';
    }
</script>