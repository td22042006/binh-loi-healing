<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

<section class="py-5 bg-light min-vh-100 d-flex align-items-center">
    <div class="container">
        <!-- Header Section -->
        <div class="row justify-content-center mb-5 reveal-up">
            <div class="col-lg-8 text-center">
                <span class="badge bg-primary rounded-pill px-3 py-2 mb-3 text-uppercase fw-bold" style="letter-spacing: 1px;">Step 1: Mood Selection</span>
                <h1 class="display-4 fw-bold mb-3" style="color: var(--v5-primary); font-family: 'Playfair Display', serif;">Hôm nay bạn muốn<br>đi kiểu gì?</h1>
                <p class="lead text-muted">Hãy chọn tâm trạng hiện tại để chúng tôi thiết kế lộ trình chữa lành phù hợp nhất.</p>
            </div>
        </div>

        <form id="eliteOnboardingForm" class="row justify-content-center">
            <div class="col-xl-10">
                <!-- Vibe Grid -->
                <div class="row g-4 mb-5">
                    <div class="col-6 col-md-4 col-lg-2-5">
                        <div class="vibe-card-bs card h-100 border-2 reveal-up text-center p-4 cursor-pointer" onclick="selectVibeBS('chill', this)">
                            <div class="fs-1 mb-2">🌿</div>
                            <h6 class="fw-bold mb-0 text-uppercase small">Sống chậm</h6>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg-2-5">
                        <div class="vibe-card-bs card h-100 border-2 reveal-up text-center p-4 cursor-pointer" onclick="selectVibeBS('peace', this)">
                            <div class="fs-1 mb-2">🛕</div>
                            <h6 class="fw-bold mb-0 text-uppercase small">Tĩnh lặng</h6>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg-2-5">
                        <div class="vibe-card-bs card h-100 border-2 reveal-up text-center p-4 cursor-pointer" onclick="selectVibeBS('culture', this)">
                            <div class="fs-1 mb-2">🎨</div>
                            <h6 class="fw-bold mb-0 text-uppercase small">Khám phá</h6>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg-2-5">
                        <div class="vibe-card-bs card h-100 border-2 reveal-up text-center p-4 cursor-pointer" onclick="selectVibeBS('history', this)">
                            <div class="fs-1 mb-2">🏛</div>
                            <h6 class="fw-bold mb-0 text-uppercase small">Cội nguồn</h6>
                        </div>
                    </div>
                    <div class="col-6 col-md-4 col-lg-2-5">
                        <div class="vibe-card-bs card h-100 border-2 reveal-up text-center p-4 cursor-pointer" onclick="selectVibeBS('family', this)">
                            <div class="fs-1 mb-2">👨‍👩‍👧‍👦</div>
                            <h6 class="fw-bold mb-0 text-uppercase small">Gắn kết</h6>
                        </div>
                    </div>
                </div>

                <!-- Filters -->
                <div class="row g-4 mb-5 reveal-up">
                    <div class="col-md-6">
                        <div class="card p-4 border-0 shadow-sm rounded-4">
                            <label class="form-label fw-bold mb-3"><i class="bi bi-clock me-2"></i>Quy mô hành trình?</label>
                            <select class="form-select form-select-lg border-0 bg-light rounded-3" name="duration" required>
                                <option value="3h">Dạo quanh (3-4 tiếng)</option>
                                <option value="1d" selected>Trọn vẹn 1 ngày</option>
                                <option value="custom">Tự do khám phá</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card p-4 border-0 shadow-sm rounded-4">
                            <label class="form-label fw-bold mb-3"><i class="bi bi-calendar-event me-2"></i>Khởi hành lúc nào?</label>
                            <select class="form-select form-select-lg border-0 bg-light rounded-3" name="when" required>
                                <option value="now">Ngay lúc này</option>
                                <option value="weekend">Cuối tuần tới</option>
                                <option value="season">Mùa lễ hội</option>
                            </select>
                        </div>
                    </div>
                </div>

                <input type="hidden" name="moods" id="moods-input-bs" required>

                <div class="text-center mt-4 reveal-up">
                    <button type="submit" class="btn btn-primary btn-lg px-5 py-3 rounded-pill fw-bold shadow-lg" id="submit-btn-bs">
                        BẮT ĐẦU HÀNH TRÌNH CHỮA LÀNH ➔
                    </button>
                </div>
            </div>
        </form>
    </div>
</section>

<style>
    .vibe-card-bs { transition: all 0.3s ease; border-color: #eee; cursor: pointer; }
    .vibe-card-bs:hover { transform: translateY(-10px); border-color: var(--v5-primary); box-shadow: 0 15px 30px rgba(0,0,0,0.05); }
    .vibe-card-bs.active { border-color: var(--v5-primary); background-color: rgba(92, 138, 94, 0.05); color: var(--v5-primary); }
    .col-lg-2-5 { flex: 0 0 auto; width: 20%; }
    @media (max-width: 992px) { .col-lg-2-5 { width: 33.333%; } }
    @media (max-width: 576px) { .col-lg-2-5 { width: 50%; } }
</style>

<script>
    let selectedVibesBS = [];

    document.addEventListener('DOMContentLoaded', () => {
        gsap.to('.reveal-up', { opacity: 1, y: 0, stagger: 0.15, duration: 1, ease: 'power3.out' });
    });

    function selectVibeBS(vibe, el) {
        if (selectedVibesBS.includes(vibe)) {
            selectedVibesBS = selectedVibesBS.filter(v => v !== vibe);
            el.classList.remove('active');
        } else {
            selectedVibesBS.push(vibe);
            el.classList.add('active');
        }
        document.getElementById('moods-input-bs').value = selectedVibesBS.join(',');
    }

    document.getElementById('eliteOnboardingForm').addEventListener('submit', function(e) {
        e.preventDefault();
        const moods = document.getElementById('moods-input-bs').value;
        if (!moods) {
            alert('Vui lòng chọn ít nhất một tâm trạng!');
            return;
        }

        const btn = document.getElementById('submit-btn-bs');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang phân tích...';

        const formData = new FormData(this);
        const data = Object.fromEntries(formData.entries());

        axios.post('/api/session', data)
            .then(res => {
                window.location.href = '/journey/suggestions';
            })
            .catch(err => {
                console.error(err);
                btn.disabled = false;
                btn.innerHTML = 'Thử lại ➔';
            });
    });
</script>