<div class="container py-5 mt-5">
    <!-- Passport Header -->
    <div class="glass-panel p-5 mb-5 overflow-hidden position-relative reveal-up">
        <div class="row align-items-center position-relative" style="z-index: 5;">
            <div class="col-md-2 text-center mb-4 mb-md-0">
                <img src="<%= user.avatar || 'https://i.pravatar.cc/150?u=' + user.id %>" class="rounded-circle border border-5 border-white shadow-lg animate__animated animate__zoomIn" style="width: 140px; height: 140px; object-fit: cover;">
            </div>
            <div class="col-md-7">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="badge bg-primary px-3 py-2 rounded-pill text-uppercase" style="letter-spacing: 2px; font-size: 10px;">Lvl <%= stats.level %> Explorer</span>
                    <span class="badge bg-mai text-dark px-3 py-2 rounded-pill text-uppercase" style="letter-spacing: 2px; font-size: 10px;">Premium Access</span>
                </div>
                <h1 class="display-3 fw-bold mb-1" style="font-family: var(--font-heading);"><%= user.full_name %></h1>
                <p class="lead text-muted mb-0"><i class="bi bi-geo-alt-fill me-1 text-primary"></i>Người giữ hồn quê Bình Lợi</p>
                <div class="d-flex gap-4 mt-4">
                    <div class="text-start">
                        <h4 class="fw-bold mb-0 text-primary"><%= stats.points.toLocaleString() %></h4>
                        <small class="text-uppercase text-muted fw-bold" style="font-size: 10px;">Reward Points</small>
                    </div>
                    <div class="border-start ps-4 text-start">
                        <h4 class="fw-bold mb-0 text-primary"><%= stats.collected_count %>/<%= stats.total_stamps %></h4>
                        <small class="text-uppercase text-muted fw-bold" style="font-size: 10px;">Stamps Collected</small>
                    </div>
                    <div class="border-start ps-4 text-start">
                        <h4 class="fw-bold mb-0 text-primary"><%= badges.length %></h4>
                        <small class="text-uppercase text-muted fw-bold" style="font-size: 10px;">Badges Earned</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3 text-md-end mt-4 mt-md-0">
                <button class="btn btn-premium rounded-pill px-4" onclick="window.print()">
                    <i class="bi bi-printer me-2"></i>XUẤT PASSPORT
                </button>
            </div>
        </div>
        <i class="bi bi-globe-central-south-asia position-absolute top-50 end-0 text-primary opacity-05" style="font-size: 25rem; transform: translate(30%, -50%);"></i>
    </div>

    <div class="row g-5">
        <!-- Stamp Collection -->
        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-end mb-4 reveal-up">
                <div>
                    <h3 class="fw-bold mb-0" style="font-family: var(--font-heading);">Bộ sưu tập Stamp</h3>
                    <p class="text-muted small mb-0">Quét mã QR tại các điểm đến thực tế để nhận dấu.</p>
                </div>
                <a href="/checkin" class="btn btn-outline-primary btn-sm rounded-pill px-4 fw-bold">QUÉT QR NGAY</a>
            </div>
            
            <div class="row g-4 reveal-up">
                <% stamps.forEach(stamp => { %>
                <div class="col-md-4">
                    <div class="card-healing p-4 text-center <%= stamp.is_collected ? 'border-primary shadow-lg' : 'opacity-40 grayscale border-dashed' %>" style="border: 2px dashed #ccc; transition: all 0.4s ease;">
                        <div class="stamp-icon mb-3">
                            <% if (stamp.is_collected) { %>
                                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center mx-auto shadow-lg animate__animated animate__bounceIn" style="width: 80px; height: 80px; border: 5px double rgba(255,255,255,0.3);">
                                    <i class="bi bi-patch-check-fill fs-2"></i>
                                </div>
                            <% } else { %>
                                <div class="bg-light text-muted rounded-circle d-flex align-items-center justify-content-center mx-auto" style="width: 80px; height: 80px;">
                                    <i class="bi bi-qr-code fs-2"></i>
                                </div>
                            <% } %>
                        </div>
                        <h6 class="fw-bold mb-1"><%= stamp.name %></h6>
                        <p class="small text-muted mb-0">
                            <%= stamp.is_collected ? 'Sưu tập: ' + new Date(stamp.collected_at).toLocaleDateString('vi-VN') : 'Chưa mở khóa' %>
                        </p>
                    </div>
                <% }) %>
                </div>
            </div>
        </div>

        <!-- Sidebar: Missions & Badges -->
        <div class="col-lg-4">
            <!-- Active Missions -->
            <div class="glass-panel p-4 mb-5 reveal-up" style="background: rgba(26, 77, 46, 0.03);">
                <h5 class="fw-bold mb-4 d-flex justify-content-between">
                    Nhiệm vụ đang làm
                    <span class="badge bg-primary rounded-pill"><%= missions.length %></span>
                </h5>
                <div class="d-flex flex-column gap-4">
                    <% missions.forEach(mission => { %>
                    <div>
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="fw-bold mb-0" style="font-size: 14px;"><%= mission.name %></h6>
                            <span class="badge bg-white text-primary border rounded-pill shadow-sm"><%= mission.reward %></span>
                        </div>
                        <p class="small text-muted mb-2"><%= mission.desc %></p>
                        <div class="progress" style="height: 6px; border-radius: 10px;">
                            <div class="progress-bar bg-primary" style="width: <%= mission.progress %>%"></div>
                        </div>
                    </div>
                    <% }) %>
                </div>
            </div>

            <!-- Badges Gallery -->
            <h5 class="fw-bold mb-4 reveal-up">Huy hiệu vinh danh</h5>
            <div class="row g-3 reveal-up">
                <% if (badges && badges.length > 0) { %>
                    <% badges.forEach(ub => { %>
                    <div class="col-4 text-center">
                        <div class="bg-white p-3 rounded-4 shadow-sm mb-2 hover-up">
                            <img src="/images/badge-<%= ub.badge_id || 'default' %>.png" class="img-fluid" onerror="this.src='/images/badge-explorer.png'">
                        </div>
                        <small class="fw-bold d-block text-truncate"><%= ub.badge_name %></small>
                    </div>
                    <% }) %>
                <% } else { %>
                    <div class="col-12 text-center py-4 glass-panel border-dashed">
                        <i class="bi bi-award display-4 text-light mb-2"></i>
                        <p class="small text-muted mb-0">Hãy bắt đầu hành trình đầu tiên để nhận huy hiệu.</p>
                    </div>
                <% } %>
            </div>

            <!-- Reward CTA -->
            <div class="mt-5 p-4 rounded-5 bg-dark text-white shadow-2xl reveal-up position-relative overflow-hidden">
                <div class="position-relative" style="z-index: 5;">
                    <h5 class="fw-bold mb-3">Đổi điểm thưởng</h5>
                    <p class="small opacity-75 mb-4">Sử dụng <%= stats.points %> PTS của bạn để đổi Voucher Workshop hoặc Đặc sản OCOP.</p>
                    <a href="/market" class="btn btn-mai btn-sm w-100 py-2 fw-bold rounded-pill">GHÉ CHỢ OCOP ➔</a>
                </div>
                <i class="bi bi-gift position-absolute bottom-0 end-0 text-white opacity-10" style="font-size: 8rem; transform: translate(20%, 20%);"></i>
            </div>
        </div>
    </div>
</div>

<style>
    .opacity-40 { opacity: 0.4; }
    .grayscale { filter: grayscale(1); }
    .border-dashed { border: 2px dashed #ddd !important; background: transparent !important; }
    .hover-up { transition: transform 0.3s ease; }
    .hover-up:hover { transform: translateY(-5px); }
    @media print {
        .navbar, .btn-premium, .fab-qr, .mobile-nav { display: none !important; }
        .glass-panel { border: 1px solid #000; box-shadow: none; backdrop-filter: none; }
    }
</style>
