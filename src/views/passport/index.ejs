<section class="passport-page min-vh-100 py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-10">
                <!-- Passport Cover / Identity Card -->
                <div class="passport-card shadow-premium rounded-5 overflow-hidden position-relative mb-5">
                    <div class="passport-header p-4 p-md-5 text-white d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-4">
                        <div class="d-flex align-items-center gap-4">
                            <div class="passport-avatar-wrapper">
                                <img src="<%= user.avatar || '/images/default-avatar.png' %>" class="passport-avatar" alt="Avatar">
                                <div class="level-badge"><%= level %></div>
                            </div>
                            <div>
                                <h2 class="fw-black mb-1 text-uppercase letter-spacing-sm"><%= user.full_name %></h2>
                                <p class="mb-0 opacity-75 fw-bold"><i class="bi bi-shield-check me-2"></i>Du khách hạng <%= level > 5 ? 'Elite' : 'Premium' %></p>
                                <div class="passport-id mt-2 x-small opacity-50"><%= passportNum %></div>
                            </div>
                        </div>
                        <div class="text-md-end">
                            <div class="xp-label mb-1 x-small text-uppercase tracking-widest fw-bold opacity-75">Tiến trình Level</div>
                            <div class="progress bg-white bg-opacity-20 rounded-pill mb-1" style="height: 10px; width: 200px;">
                                <div class="progress-bar bg-warning" style="width: <%= progress %>%"></div>
                            </div>
                            <div class="x-small fw-bold text-white-50"><%= xp %> / <%= nextLevelXp %> XP</div>
                        </div>
                    </div>

                    <div class="passport-body bg-white p-4 p-md-5">
                        <div class="row g-4">
                            <!-- Left: Stats & QR -->
                            <div class="col-lg-4 border-end-md">
                                <div class="text-center mb-4">
                                    <div class="bg-light p-3 rounded-4 d-inline-block mb-3">
                                        <img src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=<%= user.id %>" class="img-fluid" alt="QR ID">
                                    </div>
                                    <h6 class="fw-bold mb-1">MÃ ĐỊNH DANH DU KHÁCH</h6>
                                    <p class="x-small text-muted mb-0">Quét tại các điểm check-in để tích điểm</p>
                                </div>

                                <div class="stats-grid row g-2">
                                    <div class="col-6">
                                        <div class="stat-item p-3 bg-light rounded-4 text-center">
                                            <div class="h3 fw-black text-primary mb-0"><%= history.length %></div>
                                            <div class="x-small text-muted text-uppercase fw-bold">Điểm đến</div>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="stat-item p-3 bg-light rounded-4 text-center">
                                            <div class="h3 fw-black text-success mb-0"><%= unlockedBadges.length %></div>
                                            <div class="x-small text-muted text-uppercase fw-bold">Huy hiệu</div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Right: Badges & Rewards -->
                            <div class="col-lg-8 ps-lg-5">
                                <h5 class="fw-black mb-4 d-flex align-items-center gap-2">
                                    <i class="bi bi-award-fill text-warning"></i> BỘ SƯU TẬP HUY HIỆU
                                </h5>
                                                   <% allBadges.forEach(badge => { 
                                        const isUnlocked = unlockedBadges.some(ub => ub.id === badge.id);
                                    %>
                                        <div class="col-md-4 col-6">
                                            <div class="badge-card p-3 rounded-4 text-center h-100 <%= isUnlocked ? 'unlocked' : 'locked' %>">
                                                <div class="badge-icon mb-2">
                                                    <span class="fs-1"><%= badge.icon || '🏆' %></span>
                                                </div>
                                                <h6 class="small fw-bold mb-1"><%= badge.name %></h6>
                                                <div class="x-small opacity-75"><%= isUnlocked ? 'Đã nhận' : 'Chưa mở' %></div>
                                            </div>
                                        </div>
                                    <% }) %>
                                </div>
                                
                                <div class="mt-5 p-4 bg-primary bg-opacity-10 border border-primary border-opacity-25 rounded-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="fs-1">🎁</div>
                                        <div>
                                            <h6 class="fw-black mb-1">ƯU ĐÃI THÀNH VIÊN</h6>
                                            <p class="small text-muted mb-0">Bạn đang được giảm giá 5% khi mua sắm tại Chợ OCOP Bình Lợi.</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
 
                <!-- Activity Timeline -->
                <div class="timeline-section">
                    <h4 class="fw-black mb-4 px-3">LỊCH SỬ HÀNH TRÌNH</h4>
                    <div class="card-bl p-4 p-md-5 rounded-5 shadow-sm bg-white border-0">
                        <% if (history.length > 0) { %>
                            <div class="journey-timeline">
                                <% history.forEach((entry, idx) => { %>
                                    <div class="timeline-row d-flex gap-4 mb-4">
                                        <div class="time-col text-end pt-2" style="width: 80px;">
                                            <div class="fw-bold text-dark small"><%= new Date(entry.created_at).toLocaleTimeString('vi-VN', {hour: '2-digit', minute:'2-digit'}) %></div>
                                            <div class="x-small text-muted"><%= new Date(entry.created_at).toLocaleDateString('vi-VN') %></div>
                                        </div>
                                        <div class="icon-col position-relative">
                                            <div class="timeline-dot bg-primary shadow-sm"></div>
                                            <% if (idx < history.length - 1) { %><div class="timeline-line"></div><% } %>
                                        </div>
                                        <div class="content-col bg-light p-3 rounded-4 flex-grow-1">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <h6 class="fw-bold mb-0 text-primary"><%= entry.name %></h6>
                                                <span class="badge bg-white text-success border border-success border-opacity-25 small">+<%= entry.dest_points || 50 %> XP</span>
                                            </div>
                                            <p class="x-small text-muted mb-0 mt-1">Đã hoàn thành check-in tại địa điểm.</p>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } else { %>
                            <div class="text-center py-5">
                                <i class="bi bi-compass display-1 text-muted opacity-25"></i>
                                <p class="mt-3 text-muted">Hành trình của bạn đang chờ bắt đầu...</p>
                                <a href="/explore" class="btn btn-primary-bl rounded-pill px-5 mt-3">BẮT ĐẦU NGAY</a>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .passport-page { background: #f0f2f5; }
    .passport-card { border: none; }
    .passport-header { background: linear-gradient(135deg, #1a4d2e 0%, #34a853 100%); }
    .passport-avatar-wrapper { position: relative; }
    .passport-avatar { width: 100px; height: 100px; border-radius: 25px; border: 4px solid rgba(255,255,255,0.3); object-fit: cover; }
    .level-badge { position: absolute; bottom: -10px; right: -10px; background: #ffc107; color: #000; width: 35px; height: 35px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 900; border: 3px solid #fff; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
    
    .badge-card { transition: all 0.3s; border: 1px solid #eee; }
    .badge-card.unlocked { background: #f8fff9; border-color: #d1e7dd; }
    .badge-card.locked { opacity: 0.5; filter: grayscale(1); background: #f8f9fa; }
    .badge-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.05); }

    .timeline-dot { width: 16px; height: 16px; border-radius: 50%; border: 4px solid #fff; z-index: 2; position: relative; margin-top: 10px; }
    .timeline-line { position: absolute; top: 20px; bottom: -20px; left: 7px; width: 2px; background: #dee2e6; z-index: 1; }
    
    .border-end-md { border-right: 1px solid #eee; }
    @media (max-width: 991.98px) { .border-end-md { border-right: none; border-bottom: 1px solid #eee; padding-bottom: 2rem; margin-bottom: 2rem; } }
</style>
