<!-- Vibrant Passport Dashboard — Your Digital Soul in Binh Loi -->
<div class="row g-4">
    <!-- Left: The Premium Digital ID -->
    <div class="col-lg-5">
        <div class="widget-card p-0 overflow-hidden border-0 shadow-2xl" 
             style="background: linear-gradient(145deg, #0a2e24 0%, #000000 100%); border-radius: 30px;">
            <div class="p-4 p-md-5 text-white position-relative">
                <!-- Abstract Background Pattern -->
                <div class="position-absolute top-0 end-0 p-3 opacity-10">
                    <i class="bi bi-qr-code-scan" style="font-size: 12rem;"></i>
                </div>
                
                <div class="position-relative" style="z-index: 10;">
                    <div class="d-flex align-items-center gap-4 mb-5">
                        <div class="position-relative">
                            <img src="<%= user.avatar || '/images/default-avatar.png' %>" 
                                 class="rounded-circle border border-4 border-warning shadow-lg" 
                                 style="width: 110px; height: 110px; object-fit: cover;">
                            <div class="position-absolute bottom-0 end-0 bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center border border-3 border-dark" 
                                 style="width: 32px; height: 32px; font-weight: 900; font-size: 0.75rem;">
                                <%= Math.floor((user.total_points || 0) / 100) + 1 %>
                            </div>
                        </div>
                        <div>
                            <span class="badge bg-warning text-dark fw-black mb-2 px-3 rounded-pill" style="font-size: 0.65rem; letter-spacing: 1px;">ELITE EXPLORER</span>
                            <h2 class="fw-black font-display mb-0 text-white" style="font-size: 2.2rem; letter-spacing: -1px;"><%= user.full_name %></h2>
                            <span class="text-white opacity-50 x-small fw-bold">Joined Binh Loi: <%= new Date(user.created_at).getFullYear() %></span>
                        </div>
                    </div>
                    
                    <div class="p-4 rounded-4 mb-5" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1);">
                        <div class="d-flex justify-content-between x-small fw-black mb-2 tracking-widest text-warning">
                            <span>HÀNH TRÌNH CHỮA LÀNH</span>
                            <span><%= user.total_points || 0 %> XP</span>
                        </div>
                        <div class="progress rounded-pill shadow-inner" style="height: 10px; background: rgba(0,0,0,0.4);">
                            <div class="progress-bar rounded-pill shadow-lg" 
                                 style="width: <%= (user.total_points % 100) %>%; background: var(--grad-gold);">
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-end">
                        <div class="text-center p-3 bg-white rounded-4 shadow-2xl" style="width: 120px;">
                            <img src="/api/qr/user/<%= user.id %>" class="w-100 mb-2">
                            <span class="text-dark fw-black d-block" style="font-size: 0.6rem;">ID: <%= user.id.toString().padStart(6, '0') %></span>
                        </div>
                        <div class="text-end">
                            <img src="/images/logo.png" style="height: 40px; filter: brightness(10);" class="opacity-25 mb-3">
                            <p class="text-white opacity-50 x-small fw-bold mb-0">BINH LOI HEALING<br>DIGITAL PASSPORT</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="widget-card mt-4 p-4 text-center">
            <h6 class="fw-black mb-3 text-primary text-uppercase tracking-widest" style="font-size: 0.75rem;">CÁC CHỈ SỐ TRẢI NGHIỆM</h6>
            <div class="row g-3">
                <div class="col-4">
                    <div class="p-3 rounded-4 bg-light shadow-sm">
                        <i class="bi bi-geo-fill text-danger d-block fs-4 mb-1"></i>
                        <span class="fw-black d-block fs-5"><%= stamps.length %></span>
                        <span class="text-muted x-small fw-bold">STAMPS</span>
                    </div>
                </div>
                <div class="col-4">
                    <div class="p-3 rounded-4 bg-light shadow-sm">
                        <i class="bi bi-award-fill text-warning d-block fs-4 mb-1"></i>
                        <span class="fw-black d-block fs-5">5</span>
                        <span class="text-muted x-small fw-bold">BADGES</span>
                    </div>
                </div>
                <div class="col-4">
                    <div class="p-3 rounded-4 bg-light shadow-sm">
                        <i class="bi bi-people-fill text-info d-block fs-4 mb-1"></i>
                        <span class="fw-black d-block fs-5">120</span>
                        <span class="text-muted x-small fw-bold">RANK</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: Badges Showcase & History -->
    <div class="col-lg-7">
        <!-- VIBRANT BADGE COLLECTION -->
        <div class="widget-card mb-4 p-4 shadow-xl">
            <h5 class="fw-black font-display mb-4 text-primary">Bộ sưu tập Huy hiệu</h5>
            <div class="row g-4">
                <% 
                   const allBadges = [
                       { id: 1, name: 'Sứ giả Văn hóa', icon: 'bank', color: '#f59e0b', earned: true },
                       { id: 2, name: 'Người yêu Thiên nhiên', icon: 'tree', color: '#10b981', earned: true },
                       { id: 3, name: 'Bậc thầy Nghệ nhân', icon: 'brush', color: '#3b82f6', earned: false },
                       { id: 4, name: 'Chiến thần Check-in', icon: 'camera', color: '#ef4444', earned: true },
                       { id: 5, name: 'Du khách Thân thiện', icon: 'heart', color: '#ec4899', earned: false },
                       { id: 6, name: 'Chuyên gia OCOP', icon: 'bag-check', color: '#8b5cf6', earned: false }
                   ];
                   allBadges.forEach(b => { 
                %>
                <div class="col-4 col-md-3 text-center">
                    <div class="badge-vibrant-wrapper mx-auto mb-3 <%= b.earned ? 'earned' : 'locked' %>" 
                         style="--badge-color: <%= b.color %>; width: 80px; height: 80px;">
                        <i class="bi bi-<%= b.icon %>"></i>
                    </div>
                    <span class="d-block fw-black" style="font-size: 0.75rem; color: <%= b.earned ? 'var(--primary)' : '#cbd5e1' %>;"><%= b.name %></span>
                </div>
                <% }) %>
            </div>
        </div>

        <!-- STAMP HISTORY -->
        <div class="widget-card p-4">
            <h5 class="fw-black font-display mb-4 text-primary">Nhật ký Hành trình</h5>
            <div class="d-flex flex-column gap-3">
                <% stamps.forEach(s => { %>
                <div class="d-flex align-items-center gap-4 p-3 rounded-4 bg-light border-0 shadow-sm hover-lift">
                    <div class="rounded-4 bg-white shadow-sm d-flex align-items-center justify-content-center flex-shrink-0" 
                         style="width: 54px; height: 54px; color: var(--primary);">
                        <i class="bi bi-pin-map-fill fs-4"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h6 class="fw-black mb-1 small text-uppercase tracking-tight"><%= s.dest_name %></h6>
                        <div class="d-flex align-items-center gap-3">
                            <span class="text-muted x-small fw-bold"><i class="bi bi-calendar3 me-1"></i><%= new Date(s.checkin_time).toLocaleDateString('vi-VN') %></span>
                            <span class="badge bg-success bg-opacity-10 text-success fw-black" style="font-size: 0.6rem;">+10 XP</span>
                        </div>
                    </div>
                    <button class="btn btn-ghost btn-sm rounded-circle"><i class="bi bi-share-fill"></i></button>
                </div>
                <% }) %>
                <% if (stamps.length === 0) { %>
                <div class="text-center py-5 opacity-25">
                    <i class="bi bi-journal-x display-4 mb-2 d-block"></i>
                    <p class="fw-bold">Bạn chưa thu thập stamp nào</p>
                </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<style>
    .badge-vibrant-wrapper {
        border-radius: 22px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        position: relative;
    }
    .badge-vibrant-wrapper.earned {
        background: linear-gradient(135deg, var(--badge-color) 0%, #ffffff 150%);
        color: white;
        box-shadow: 0 10px 25px -5px var(--badge-color);
        transform: rotate(-3deg);
    }
    .badge-vibrant-wrapper.locked {
        background: #f1f5f9;
        color: #cbd5e1;
        opacity: 0.5;
        border: 2px dashed #e2e8f0;
    }
    .badge-vibrant-wrapper.earned:hover {
        transform: rotate(0deg) scale(1.1);
        box-shadow: 0 15px 35px -5px var(--badge-color);
    }
</style>
