<!-- Vibrant Community Feed — The Wall of Healing Moments -->
<div class="row g-4 justify-content-center">
    <!-- Center Content: The Wall -->
    <div class="col-lg-7">
        <!-- VIBRANT POST BOX -->
        <% if (user) { %>
        <div class="widget-card mb-4 border-0 shadow-lg" style="background: white;">
            <form id="reviewFormVibrant">
                <div class="d-flex gap-3 mb-3 p-2">
                    <div class="position-relative">
                        <img src="<%= user.avatar || '/images/default-avatar.png' %>" class="rounded-circle border border-2 border-primary" style="width: 50px; height: 50px; object-fit: cover;">
                        <span class="position-absolute bottom-0 end-0 bg-success border border-white rounded-circle" style="width: 12px; height: 12px;"></span>
                    </div>
                    <textarea class="form-control border-0 bg-transparent shadow-none fs-5" name="content" rows="2" placeholder="Chia sẻ khoảnh khắc chữa lành của bạn..." style="resize: none;"></textarea>
                </div>
                <div class="d-flex justify-content-between align-items-center pt-3 border-top px-2 pb-1">
                    <div class="d-flex gap-1">
                        <button type="button" class="btn btn-light rounded-pill px-3 fw-bold small text-primary border-0"><i class="bi bi-image-fill me-2 text-success"></i>Ảnh/Video</button>
                        <button type="button" class="btn btn-light rounded-pill px-3 fw-bold small text-primary border-0"><i class="bi bi-geo-alt-fill me-2 text-danger"></i>Vị trí</button>
                    </div>
                    <button type="submit" class="btn btn-premium rounded-pill px-4 shadow-sm">ĐĂNG BÀI</button>
                </div>
            </form>
        </div>
        <% } %>

        <!-- THE FEED -->
        <div class="d-flex flex-column gap-4">
            <% reviews.forEach((r, i) => { 
                const hasImage = r.image || (i % 2 === 0); // Mocking some images
                const ratingColor = (r.rating >= 4) ? 'var(--accent-gold)' : 'var(--primary)';
            %>
            <div class="widget-card p-0 overflow-hidden border-0 shadow-xl bg-white hover-lift">
                <div class="p-4">
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div class="d-flex align-items-center gap-3">
                            <div class="position-relative">
                                <img src="<%= r.avatar || '/images/default-avatar.png' %>" class="rounded-circle border border-2 border-white shadow-sm" style="width: 48px; height: 48px; object-fit: cover;">
                                <div class="position-absolute bottom-0 end-0 bg-primary text-white rounded-circle d-flex align-items-center justify-content-center border border-white" style="width: 18px; height: 18px; font-size: 0.5rem;">
                                    <i class="bi bi-check-lg"></i>
                                </div>
                            </div>
                            <div>
                                <h6 class="fw-black mb-0" style="font-size: 1rem;"><%= r.full_name %></h6>
                                <span class="text-muted x-small fw-bold opacity-75"><%= new Date(r.created_at).toLocaleDateString('vi-VN') %> • Công khai</span>
                            </div>
                        </div>
                        <div class="dropdown">
                            <button class="btn btn-ghost btn-sm rounded-circle" data-bs-toggle="dropdown"><i class="bi bi-three-dots"></i></button>
                        </div>
                    </div>
                    
                    <p class="mb-4" style="font-size: 1.05rem; line-height: 1.6; color: #374151;"><%= r.content %></p>
                    
                    <% if (hasImage) { %>
                    <div class="rounded-4 overflow-hidden mb-4 shadow-sm" style="height: 350px;">
                        <img src="<%= r.image || '/images/hero-1.png' %>" class="w-100 h-100 object-fit-cover">
                    </div>
                    <% } %>

                    <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                        <div class="d-flex gap-4">
                            <span class="cursor-pointer fw-bold small text-muted hover-lift d-flex align-items-center gap-2">
                                <i class="bi bi-heart-fill text-danger fs-5"></i> <%= r.likes_count || (Math.floor(Math.random()*100)) %>
                            </span>
                            <span class="cursor-pointer fw-bold small text-muted hover-lift d-flex align-items-center gap-2">
                                <i class="bi bi-chat-dots-fill text-primary fs-5"></i> <%= r.comments_count || (Math.floor(Math.random()*20)) %>
                            </span>
                        </div>
                        <div class="text-warning small fw-black bg-warning bg-opacity-10 px-3 py-1 rounded-pill">
                            <% for(let s=0; s<5; s++) { %><i class="bi bi-star-fill <%= s < (r.rating||5) ? '' : 'opacity-25' %>"></i><% } %>
                        </div>
                    </div>
                </div>
            </div>
            <% }) %>
        </div>
    </div>

    <!-- Right Sidebar: Community Spotlight -->
    <div class="col-lg-4">
        <!-- VIBRANT RANKING WIDGET -->
        <div class="widget-card p-4 mb-4 border-0 shadow-lg" style="background: var(--grad-main); color: white;">
            <h5 class="fw-black font-display mb-4 text-white">Top Du khách Elite</h5>
            <div class="d-flex flex-column gap-3">
                <% ['Tuấn Anh', 'Minh Ngọc', 'Hoàng Nam'].forEach((name, i) => { %>
                <div class="d-flex align-items-center justify-content-between p-3 rounded-4 bg-white bg-opacity-10 border border-white border-opacity-10">
                    <div class="d-flex align-items-center gap-3">
                        <span class="fw-black text-warning fs-5">#<%= i+1 %></span>
                        <img src="/images/default-avatar.png" class="rounded-circle border border-2 border-white" style="width: 32px; height: 32px;">
                        <span class="fw-bold small text-white"><%= name %></span>
                    </div>
                    <span class="badge bg-warning text-dark rounded-pill fw-black" style="font-size: 0.6rem;"><%= 500 - (i*50) %> XP</span>
                </div>
                <% }) %>
            </div>
            <button class="btn btn-outline-light btn-sm w-100 rounded-pill mt-4 border-2 fw-bold">XEM BẢNG XẾP HẠNG</button>
        </div>

        <!-- TRENDING HASHTAGS -->
        <div class="widget-card p-4 border-0 shadow-lg">
            <h6 class="fw-black mb-4 text-primary text-uppercase tracking-widest">Chủ đề thịnh hành</h6>
            <div class="d-flex flex-wrap gap-2">
                <span class="badge bg-light text-primary rounded-pill px-3 py-2 fw-bold hover-lift cursor-pointer">#BinhLoiHealing</span>
                <span class="badge bg-light text-primary rounded-pill px-3 py-2 fw-bold hover-lift cursor-pointer">#VườnMaiVàng</span>
                <span class="badge bg-light text-primary rounded-pill px-3 py-2 fw-bold hover-lift cursor-pointer">#XôngTrầm</span>
                <span class="badge bg-light text-primary rounded-pill px-3 py-2 fw-bold hover-lift cursor-pointer">#ZenWalk</span>
                <span class="badge bg-light text-primary rounded-pill px-3 py-2 fw-bold hover-lift cursor-pointer">#OCOP_BinhLoi</span>
            </div>
        </div>
    </div>
</div>
