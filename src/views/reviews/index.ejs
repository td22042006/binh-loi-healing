<!-- Reviews / Community Feed — Chương 5.13 -->
<section class="py-5" style="margin-top: 80px;">
    <div class="container py-4" style="max-width: 720px;">
        <!-- Header -->
        <div class="text-center mb-5 reveal-up">
            <span class="section-label">CỘNG ĐỒNG</span>
            <h2 class="section-title">Chia sẻ Trải nghiệm</h2>
            <p class="section-desc mx-auto">Đọc và chia sẻ những khoảnh khắc chữa lành cùng cộng đồng du khách Bình Lợi.</p>
        </div>

        <!-- Compose Box -->
        <% if (user) { %>
        <div class="card-glass p-4 mb-5 reveal-up">
            <form id="reviewForm">
                <div class="d-flex gap-3 mb-3">
                    <img src="<%= user.avatar || '/images/default-avatar.png' %>" class="rounded-circle flex-shrink-0" style="width: 44px; height: 44px; object-fit: cover; border: 2px solid var(--primary-100);">
                    <div class="flex-grow-1">
                        <textarea class="form-control border-0 bg-transparent shadow-none p-0" rows="3" name="content" placeholder="Chia sẻ trải nghiệm của bạn tại Bình Lợi..." style="resize: none; font-size: 0.95rem;" required></textarea>
                    </div>
                </div>
                <div class="d-flex justify-content-between align-items-center pt-3" style="border-top: 1px solid var(--border-light);">
                    <div class="d-flex gap-2">
                        <select class="form-select form-select-sm border-0 bg-transparent" name="rating" style="width: auto; font-size: 0.82rem; color: var(--text-secondary);">
                            <option value="5">⭐⭐⭐⭐⭐</option>
                            <option value="4">⭐⭐⭐⭐</option>
                            <option value="3">⭐⭐⭐</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary-bl btn-sm rounded-pill px-4">
                        <i class="bi bi-send me-1"></i> Đăng
                    </button>
                </div>
            </form>
        </div>
        <% } %>

        <!-- Reviews Feed -->
        <div class="d-flex flex-column gap-4">
            <% reviews.forEach((r, i) => { %>
            <div class="p-4 rounded-2xl reveal-up" style="background: var(--surface); border: 1px solid var(--border-light); transition: all 0.3s ease;" onmouseover="this.style.borderColor='var(--primary-100)'" onmouseout="this.style.borderColor='var(--border-light)'">
                <!-- Header -->
                <div class="d-flex align-items-center gap-3 mb-3">
                    <img src="<%= r.avatar || '/images/default-avatar.png' %>" class="rounded-circle" style="width: 42px; height: 42px; object-fit: cover;">
                    <div class="flex-grow-1">
                        <span class="fw-bold d-block" style="font-size: 0.9rem;"><%= r.full_name %></span>
                        <span class="text-muted" style="font-size: 0.75rem;">
                            <% if (r.destination_name) { %><i class="bi bi-geo-alt me-1"></i><%= r.destination_name %> · <% } %>
                            <%= new Date(r.created_at).toLocaleDateString('vi-VN') %>
                        </span>
                    </div>
                    <div class="text-warning" style="font-size: 0.75rem;">
                        <% for(let s = 0; s < (r.rating || 5); s++) { %><i class="bi bi-star-fill"></i><% } %>
                    </div>
                </div>
                
                <!-- Content -->
                <p class="mb-3" style="font-size: 0.92rem; line-height: 1.7; color: var(--text);"><%= r.content %></p>
                
                <!-- Actions -->
                <div class="d-flex align-items-center gap-4" style="font-size: 0.82rem; color: var(--text-muted);">
                    <button class="btn btn-sm p-0 border-0 bg-transparent d-flex align-items-center gap-1 like-btn" onclick="likeReview('<%= r.id %>', this)" style="color: var(--text-muted);">
                        <i class="bi bi-heart"></i>
                        <span><%= r.likes_count || 0 %></span>
                    </button>
                    <button class="btn btn-sm p-0 border-0 bg-transparent d-flex align-items-center gap-1" style="color: var(--text-muted);">
                        <i class="bi bi-chat"></i>
                        <span><%= r.comments_count || 0 %></span>
                    </button>
                    <button class="btn btn-sm p-0 border-0 bg-transparent d-flex align-items-center gap-1" style="color: var(--text-muted);">
                        <i class="bi bi-share"></i>
                    </button>
                </div>
            </div>
            <% }) %>
        </div>

        <% if (reviews.length === 0) { %>
        <div class="text-center py-5">
            <i class="bi bi-chat-heart display-1" style="color: var(--border);"></i>
            <p class="text-muted mt-3">Chưa có đánh giá nào. Hãy là người đầu tiên chia sẻ!</p>
        </div>
        <% } %>
    </div>
</section>

<script>
async function likeReview(id, btn) {
    try {
        const res = await axios.post('/api/review/like', { review_id: id });
        if (res.data.success) {
            const icon = btn.querySelector('i');
            const count = btn.querySelector('span');
            icon.classList.toggle('bi-heart');
            icon.classList.toggle('bi-heart-fill');
            btn.style.color = icon.classList.contains('bi-heart-fill') ? 'var(--danger)' : 'var(--text-muted)';
            count.textContent = res.data.likes;
        }
    } catch(e) { console.error(e); }
}

document.getElementById('reviewForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const btn = form.querySelector('button[type="submit"]');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Đang đăng...';
    try {
        const res = await axios.post('/api/review/create', {
            content: form.content.value,
            rating: form.rating.value
        });
        if (res.data.success) location.reload();
        else alert(res.data.message || 'Lỗi');
    } catch(e) {
        alert('Lỗi: ' + (e.response?.data?.message || e.message));
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-send me-1"></i> Đăng';
    }
});
</script>
