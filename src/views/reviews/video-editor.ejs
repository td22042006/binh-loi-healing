<section class="py-5" style="margin-top: 80px; background: #f8faf9; min-vh-100;">
    <div class="container py-4">
        
        <!-- Header -->
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 border-bottom border-secondary border-opacity-30 pb-4">
            <div class="mb-3 mb-md-0">
                <span class="badge bg-danger bg-opacity-25 text-danger text-uppercase fw-bold tracking-widest px-3 py-2 rounded-pill mb-2 border border-danger border-opacity-35" style="letter-spacing: 1.5px; font-size: 0.7rem;">
                    <i class="bi bi-magic me-1"></i> Studio Sáng Tạo Premium
                </span>
                <h1 class="display-5 fw-black text-dark mb-1" style="font-family: 'Inter', sans-serif;">Hành Trình Cảm Giác</h1>
                <p class="text-muted mb-0 small">Biến những bức ảnh check-in mộc mạc thành video kể chuyện nghệ thuật kèm nhạc nền chữa lành.</p>
            </div>
            <a href="/reviews" class="btn btn-outline-dark rounded-pill px-4"><i class="bi bi-arrow-left me-1"></i> Quay lại Cộng đồng</a>
        </div>

        <div class="row g-4">
            <!-- Left Config Panels -->
            <div class="col-lg-7 col-xl-8">
                
                <!-- 1. TEMPLATE SELECTOR -->
                <div class="editor-glass-card p-4 mb-4 animate__animated animate__fadeInUp">
                    <h5 class="fw-bold text-dark mb-3 d-flex align-items-center gap-2">
                        <span class="step-num">1</span>
                        Chọn mẫu video (Thời lượng)
                    </h5>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="template-card template-card-premium rounded-4 p-3 d-block text-center cursor-pointer active" data-duration="15">
                                <input type="radio" name="video_duration" value="15" checked class="d-none">
                                <div class="fs-4 fw-black text-danger mb-1">15 giây</div>
                                <div class="small text-muted" style="font-size: 0.75rem;">Nhịp điệu nhanh (4 ảnh)</div>
                            </label>
                        </div>
                        <div class="col-md-4">
                            <label class="template-card template-card-premium rounded-4 p-3 d-block text-center cursor-pointer" data-duration="20">
                                <input type="radio" name="video_duration" value="20" class="d-none">
                                <div class="fs-4 fw-black text-dark mb-1">20 giây</div>
                                <div class="small text-muted" style="font-size: 0.75rem;">Vừa vặn cảm xúc (4 ảnh)</div>
                            </label>
                        </div>
                        <div class="col-md-4">
                            <label class="template-card template-card-premium rounded-4 p-3 d-block text-center cursor-pointer" data-duration="30">
                                <input type="radio" name="video_duration" value="30" class="d-none">
                                <div class="fs-4 fw-black text-dark mb-1">30 giây</div>
                                <div class="small text-muted" style="font-size: 0.75rem;">Trải nghiệm sâu (5 ảnh)</div>
                            </label>
                        </div>
                    </div>
                </div>

                <!-- 2. UPLOAD ZONE -->
                <div class="editor-glass-card p-4 mb-4 animate__animated animate__fadeInUp" style="animation-delay: 0.1s;">
                    <h5 class="fw-bold text-dark mb-2 d-flex align-items-center gap-2">
                        <span class="step-num">2</span>
                        Tải ảnh lên (Từ 3 - 5 bức ảnh)
                    </h5>
                    <p class="text-muted small mb-3">Tải lên các bức ảnh bạn đã chụp tại Bình Lợi để lấp đầy dòng thời gian cảm xúc.</p>
                    
                    <div id="dropzone" class="dropzone-premium rounded-4 p-4 text-center cursor-pointer transition-all">
                        <div class="py-4">
                            <i class="bi bi-cloud-arrow-up-fill display-4 text-danger mb-3 upload-pulse d-inline-block"></i>
                            <h6 class="fw-bold text-dark mb-1">Kéo và thả ảnh tại đây</h6>
                            <p class="small text-muted mb-3">Hỗ trợ JPG, PNG (tối đa 5 file, mỗi file < 10MB)</p>
                            <input type="file" id="media-files" multiple accept="image/*" class="d-none">
                            <button type="button" class="btn btn-danger rounded-pill px-4 py-2 text-white font-weight-semibold" style="background: var(--primary); border: none; font-size: 0.85rem;" onclick="document.getElementById('media-files').click()">Chọn tệp từ máy</button>
                        </div>
                    </div>

                    <!-- Uploaded Thumbnails Visualizer -->
                    <div id="thumbnails-container" class="row g-2 mt-4 d-none">
                        <!-- Populated by JS -->
                    </div>
                </div>

                <!-- 3. SOUNDSCAPE SELECTOR -->
                <div class="editor-glass-card p-4 mb-4 animate__animated animate__fadeInUp" style="animation-delay: 0.2s;">
                    <h5 class="fw-bold text-dark mb-3 d-flex align-items-center gap-2">
                        <span class="step-num">3</span>
                        Chọn nhạc nền Soundscape (Mood)
                    </h5>
                    <div class="row g-3" id="soundscape-list">
                        <% if (soundscapes && soundscapes.length > 0) { %>
                            <% soundscapes.forEach((sound, index) => { %>
                                <div class="col-md-6">
                                    <div class="sound-card sound-card-premium rounded-4 p-3 d-flex align-items-center justify-content-between cursor-pointer transition-all <%= index === 0 ? 'active' : '' %>" data-audio-url="<%= fixImg(sound.audio_url) %>">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="sound-icon-circle bg-danger bg-opacity-10 text-danger p-2 rounded-circle">
                                                <i class="bi bi-music-note-beamed"></i>
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark" style="font-size: 0.88rem;"><%= sound.name %></div>
                                                <span class="badge bg-danger bg-opacity-20 text-danger text-capitalize border border-danger border-opacity-25" style="font-size: 0.65rem;"><%= sound.mood %></span>
                                            </div>
                                        </div>
                                        <div class="form-check sound-check-container">
                                            <input type="radio" name="soundscape_select" value="<%= sound.id %>" <%= index === 0 ? 'checked' : '' %> class="form-check-input">
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="col-12">
                                <div class="alert alert-warning bg-opacity-10 border-warning text-warning mb-0 small">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i> Chưa có âm thanh mẫu trong DB. Vui lòng thêm trong admin panel.
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>

                <!-- 4. TEXT OVERLAY EDITOR -->
                <div class="editor-glass-card p-4 mb-4 animate__animated animate__fadeInUp" style="animation-delay: 0.3s;">
                    <h5 class="fw-bold text-dark mb-3 d-flex align-items-center gap-2">
                        <span class="step-num">4</span>
                        Biên tập phụ đề (Text Overlay)
                    </h5>
                    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-bold"><i class="bi bi-quote text-danger me-1"></i>Phần mở đầu (Hook Text)</label>
                            <input type="text" id="text-hook" class="form-control premium-input" value="Lạc vào miền xanh Bình Lợi...">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-bold"><i class="bi bi-quote text-danger me-1"></i>Phần trải nghiệm (Immersion Text)</label>
                            <input type="text" id="text-immersion" class="form-control premium-input" value="Hương nhang thơm đưa bước chân tĩnh lặng.">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-bold"><i class="bi bi-quote text-danger me-1"></i>Khoảnh khắc chính (Highlight Text)</label>
                            <input type="text" id="text-highlight" class="form-control premium-input" value="Chữa lành từ những điều mộc mạc nhất.">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted small fw-bold"><i class="bi bi-quote text-danger me-1"></i>Phần kết (Outro / CTA Text)</label>
                            <input type="text" id="text-outro" class="form-control premium-input" value="Nghe Bình Lợi theo cách của bạn.">
                        </div>
                    </div>
                </div>

                <!-- 5. FILTER SELECTOR -->
                <div class="editor-glass-card p-4 mb-4 animate__animated animate__fadeInUp" style="animation-delay: 0.4s;">
                    <h5 class="fw-bold text-dark mb-3 d-flex align-items-center gap-2">
                        <span class="step-num">5</span>
                        Bộ lọc nghệ thuật (Color Preset)
                    </h5>
                    
                    <div class="d-flex flex-wrap gap-2">
                        <button class="btn btn-premium-filter filter-preset active" data-filter="none">
                            <i class="bi bi-droplet-half me-1"></i>Gốc
                        </button>
                        <button class="btn btn-premium-filter filter-preset" data-filter="warm">
                            <i class="bi bi-sun-fill me-1 text-warning"></i>Nắng Ấm
                        </button>
                        <button class="btn btn-premium-filter filter-preset" data-filter="cool">
                            <i class="bi bi-snow2 me-1 text-info"></i>Xanh Mát
                        </button>
                        <button class="btn btn-premium-filter filter-preset" data-filter="vintage">
                            <i class="bi bi-hourglass-split me-1 text-secondary"></i>Cổ Kính
                        </button>
                        <button class="btn btn-premium-filter filter-preset" data-filter="grayscale">
                            <i class="bi bi-circle-half me-1"></i>Trắng Đen
                        </button>
                    </div>
                </div>
            </div>

            <!-- Right Preview & Export Panel -->
            <div class="col-lg-5 col-xl-4">
                <div class="sticky-top" style="top: 100px; z-index: 10;">
                    
                    <!-- Preview Screen (9:16 Mockup Frame) -->
                    <div class="editor-glass-card p-4 text-center overflow-hidden position-relative">
                        <div class="d-flex justify-content-between align-items-center mb-3 px-1 text-muted small">
                            <span class="fw-bold text-uppercase" style="letter-spacing: 0.5px; font-size: 0.72rem;"><i class="bi bi-phone-fill text-danger me-1"></i> Màn hình dọc 9:16</span>
                            <span class="badge bg-dark px-2 py-1 rounded text-white" id="player-time">00:00 / 00:15</span>
                        </div>
                        
                        <!-- Portrait Canvas Inside Premium Phone Frame -->
                        <div class="phone-mockup-premium mx-auto position-relative bg-black rounded-5 shadow-lg border border-4 border-dark overflow-hidden">
                            <!-- Notch/Dynamic Island mockup -->
                            <div class="notch-island"></div>
                            
                            <canvas id="videoCanvas" width="540" height="960" class="w-100 h-100 object-fit-cover"></canvas>
                            
                            <!-- Control Overlays -->
                            <div class="canvas-overlay-center position-absolute top-50 start-50 translate-middle d-flex align-items-center justify-content-center" style="z-index: 20;">
                                <button id="playBtn" class="btn btn-danger play-btn-premium rounded-circle shadow-lg p-0 d-flex align-items-center justify-content-center">
                                    <i class="bi bi-play-fill" style="margin-left: 3px;"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Progress Bar under Canvas -->
                        <div class="progress mt-4 bg-dark rounded-pill" style="height: 6px; border: 1px solid rgba(255,255,255,0.05);">
                            <div id="playProgress" class="progress-bar bg-primary-gradient" role="progressbar" style="width: 0%;"></div>
                        </div>

                        <!-- Export Status Container -->
                        <div id="export-status-panel" class="mt-4 d-none text-start p-3 rounded-4 bg-dark bg-opacity-50 border border-secondary border-opacity-20">
                            <div class="small fw-bold text-danger mb-2 d-flex align-items-center justify-content-between">
                                <span id="export-status-text">Đang kết xuất video...</span>
                                <span class="spinner-border spinner-border-sm"></span>
                            </div>
                            <div class="progress bg-dark rounded-pill" style="height: 12px; border: 1px solid rgba(255,255,255,0.05);">
                                <div id="exportProgress" class="progress-bar progress-bar-striped progress-bar-animated bg-primary-gradient" role="progressbar" style="width: 0%;"></div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-grid gap-3 mt-4">
                            <button id="exportBtn" class="btn btn-danger btn-lg rounded-pill fw-black shadow-lg d-flex align-items-center justify-content-center gap-2 py-3 btn-export-premium" disabled>
                                <i class="bi bi-file-earmark-play-fill fs-5"></i> XUẤT VIDEO TIKTOK (MP4)
                            </button>
                            <div class="text-muted" style="font-size: 0.72rem;"><i class="bi bi-shield-fill-check text-danger"></i> Quá trình kết xuất xử lý 100% trên thiết bị của bạn</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Visual Timeline Preview -->
        <div class="row mt-5">
            <div class="col-12">
                <div class="editor-glass-card p-4">
                    <h5 class="fw-bold text-white mb-3 d-flex align-items-center gap-2">
                        <i class="bi bi-collection-play-fill text-danger"></i> Dòng thời gian phân cảnh (Storyboard timeline)
                    </h5>
                    <div class="row g-3 text-center" id="timeline-slots">
                        <div class="col-3">
                            <div class="timeline-slot-card rounded-4 p-3">
                                <div class="x-small text-muted fw-bold text-uppercase" style="font-size: 0.65rem; letter-spacing: 0.5px;">HOOK (Mở đầu)</div>
                                <div class="timeline-slot-thumb mt-2 rounded-3 border border-secondary border-opacity-30 d-flex align-items-center justify-content-center text-muted" style="height: 80px;">Trống</div>
                                <div class="small text-white-50 mt-2 font-size-xs">0s - 3.75s</div>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="timeline-slot-card rounded-4 p-3">
                                <div class="x-small text-muted fw-bold text-uppercase" style="font-size: 0.65rem; letter-spacing: 0.5px;">IMMERSION (Chi tiết)</div>
                                <div class="timeline-slot-thumb mt-2 rounded-3 border border-secondary border-opacity-30 d-flex align-items-center justify-content-center text-muted" style="height: 80px;">Trống</div>
                                <div class="small text-white-50 mt-2 font-size-xs">3.75s - 7.5s</div>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="timeline-slot-card rounded-4 p-3">
                                <div class="x-small text-muted fw-bold text-uppercase" style="font-size: 0.65rem; letter-spacing: 0.5px;">HIGHLIGHT (Điểm nhấn)</div>
                                <div class="timeline-slot-thumb mt-2 rounded-3 border border-secondary border-opacity-30 d-flex align-items-center justify-content-center text-muted" style="height: 80px;">Trống</div>
                                <div class="small text-white-50 mt-2 font-size-xs">7.5s - 11.25s</div>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="timeline-slot-card rounded-4 p-3">
                                <div class="x-small text-muted fw-bold text-uppercase" style="font-size: 0.65rem; letter-spacing: 0.5px;">OUTRO (Kết thúc)</div>
                                <div class="timeline-slot-thumb mt-2 rounded-3 border border-secondary border-opacity-30 d-flex align-items-center justify-content-center text-muted" style="height: 80px;">Trống</div>
                                <div class="small text-white-50 mt-2 font-size-xs">11.25s - 15s</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
/* Custom premium CSS override for Studio editor */
.editor-glass-card {
    background: #ffffff !important;
    border: 1px solid rgba(0, 0, 0, 0.08) !important;
    backdrop-filter: blur(20px) saturate(120%);
    border-radius: 20px;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.05);
    transition: all 0.3s ease;
}
.step-num {
    background: linear-gradient(135deg, #922724 0%, #6e1d1b 100%);
    color: white;
    width: 26px;
    height: 26px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-size: 0.8rem;
    font-weight: 800;
}
.template-card-premium {
    border: 1.5px dashed rgba(0,0,0,0.15) !important;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    background: #ffffff !important;
}
.template-card-premium:hover {
    border-color: #922724 !important;
    background: rgba(146, 39, 36, 0.05) !important;
    transform: translateY(-2px);
}
.template-card-premium.active {
    border: 2px solid #922724 !important;
    background: rgba(146, 39, 36, 0.15) !important;
    box-shadow: 0 0 15px rgba(146, 39, 36, 0.2);
}
.template-card-premium.active .fs-4 {
    color: #922724 !important;
}

.dropzone-premium {
    border: 2px dashed rgba(0,0,0,0.15) !important;
    background: rgba(0, 0, 0, 0.02) !important;
    transition: all 0.3s ease;
}
.dropzone-premium:hover {
    border-color: #922724 !important;
    background: rgba(146, 39, 36, 0.04) !important;
}
.upload-pulse {
    animation: bouncePulse 2s infinite;
}
@keyframes bouncePulse {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
}

.sound-card-premium {
    border: 1px solid rgba(0,0,0,0.08) !important;
    background: #ffffff !important;
    transition: all 0.3s ease;
}
.sound-card-premium:hover {
    border-color: #922724 !important;
    background: rgba(146, 39, 36, 0.05) !important;
}
.sound-card-premium.active {
    border: 1.5px solid #922724 !important;
    background: rgba(146, 39, 36, 0.12) !important;
    box-shadow: 0 4px 12px rgba(146, 39, 36, 0.1);
}
.sound-icon-circle {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.premium-input {
    background: #ffffff !important;
    border: 1px solid rgba(0,0,0,0.1) !important;
    border-radius: 12px !important;
    color: #333 !important;
    padding: 12px !important;
    font-size: 0.9rem !important;
    transition: all 0.3s ease !important;
}
.premium-input:focus {
    border-color: #922724 !important;
    box-shadow: 0 0 10px rgba(146, 39, 36, 0.25) !important;
    outline: none !important;
}

.btn-premium-filter {
    background: #ffffff !important;
    border: 1px solid rgba(0,0,0,0.1) !important;
    color: #555 !important;
    border-radius: 30px !important;
    padding: 8px 18px !important;
    font-size: 0.85rem !important;
    font-weight: 500 !important;
    transition: all 0.2s ease !important;
}
.btn-premium-filter:hover {
    border-color: #922724 !important;
    background: rgba(146, 39, 36, 0.05) !important;
    color: white !important;
}
.btn-premium-filter.active {
    background: #922724 !important;
    border-color: #922724 !important;
    color: white !important;
    box-shadow: 0 4px 12px rgba(146, 39, 36, 0.3) !important;
}

/* Phone Mockup */
.phone-mockup-premium {
    width: 270px;
    height: 480px;
    border: 8px solid #181a1b !important;
    border-radius: 40px !important;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.2) !important;
    outline: 2px solid rgba(0,0,0,0.05);
}
.notch-island {
    position: absolute;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    width: 70px;
    height: 18px;
    background: #181a1b;
    border-radius: 10px;
    z-index: 30;
}
.play-btn-premium {
    width: 60px;
    height: 60px;
    background: #922724 !important;
    border: none !important;
    font-size: 1.8rem;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
}
.play-btn-premium:hover {
    transform: scale(1.1);
    box-shadow: 0 0 20px rgba(146, 39, 36, 0.5) !important;
}
.bg-primary-gradient {
    background: linear-gradient(90deg, #b03331 0%, #922724 100%) !important;
}

.btn-export-premium {
    background: linear-gradient(135deg, #922724 0%, #6e1d1b 100%) !important;
    border: none !important;
    font-weight: 700 !important;
    letter-spacing: 0.5px !important;
    box-shadow: 0 8px 24px rgba(146, 39, 36, 0.35) !important;
    transition: all 0.3s ease !important;
}
.btn-export-premium:hover:not(:disabled) {
    transform: translateY(-2px) !important;
    box-shadow: 0 12px 30px rgba(146, 39, 36, 0.5) !important;
}
.btn-export-premium:disabled {
    background: #1f2937 !important;
    color: #4b5563 !important;
    box-shadow: none !important;
    border: 1px solid rgba(255,255,255,0.05) !important;
}

.timeline-slot-card {
    background: rgba(0, 0, 0, 0.03) !important;
    border: 1px solid rgba(0,0,0,0.05) !important;
    transition: all 0.3s ease;
}
.timeline-slot-card:hover {
    border-color: rgba(146, 39, 36, 0.3) !important;
    background: rgba(0, 0, 0, 0.35) !important;
}

.btn-premium-outline {
    border: 1.5px solid rgba(0,0,0,0.15) !important;
    color: #333 !important;
    transition: all 0.2s ease;
}
.btn-premium-outline:hover {
    background: white !important;
    color: black !important;
    border-color: white !important;
}
</style>
