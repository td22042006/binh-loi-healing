<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-black mb-0">Quản lý Sản phẩm OCOP</h2>
    <button class="btn btn-premium rounded-pill px-4" onclick="openAddProductModal()">
        <i class="bi bi-plus-lg me-2"></i>THÊM SẢN PHẨM
    </button>
</div>

<%- include('../partials/media_library_modal') %>

<div class="card glass-card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3 border-0">Sản phẩm</th>
                        <th class="py-3 border-0">Danh mục</th>
                        <th class="py-3 border-0">Giá</th>
                        <th class="py-3 border-0">Trạng thái</th>
                        <th class="pe-4 py-3 border-0 text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    <% products.forEach(p => { %>
                    <tr>
                        <td class="ps-4 py-3">
                            <div class="d-flex align-items-center">
                                <img src="<%= p.image_url %>" class="rounded-3 me-3" style="width: 50px; height: 50px; object-fit: cover;" id="img-table-<%= p.id %>">
                                <div>
                                    <h6 class="fw-bold mb-0"><%= p.name %></h6>
                                    <small class="text-muted"><%= p.id.substring(0,8) %></small>
                                </div>
                            </div>
                        </td>
                        <td><span class="badge bg-secondary bg-opacity-10 text-dark"><%= p.category %></span></td>
                        <td><span class="fw-bold text-primary"><%= p.price.toLocaleString() %>đ</span></td>
                        <td>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" <%= p.is_active ? 'checked' : '' %> onchange="toggleProductStatus('<%= p.id %>', this.checked)">
                            </div>
                        </td>
                        <td class="pe-4 text-end">
                            <button class="btn btn-sm btn-light rounded-pill px-3" onclick='editProduct(<%- JSON.stringify(p) %>)'>
                                <i class="bi bi-pencil-square me-1"></i>Sửa
                            </button>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Edit Product Modal -->
<div class="modal fade" id="productModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content glass-card border-0 shadow-lg">
            <div class="modal-header border-bottom border-light p-4">
                <h5 class="modal-title fw-black"><i class="bi bi-bag-plus me-2 text-primary"></i>Thông tin Sản phẩm</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="productForm">
                    <input type="hidden" name="id">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <div class="mb-3">
                                <label class="form-label small fw-bold">Tên sản phẩm</label>
                                <input type="text" class="form-control rounded-3" name="name" required>
                            </div>
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <label class="form-label small fw-bold">Giá bán (VNĐ)</label>
                                    <input type="number" class="form-control rounded-3" name="price" required>
                                </div>
                                <div class="col-6">
                                    <label class="form-label small fw-bold">Danh mục</label>
                                    <input type="text" class="form-control rounded-3" name="category" placeholder="Ví dụ: Nông sản">
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label small fw-bold">Mô tả</label>
                                <textarea class="form-control rounded-3" name="description" rows="3"></textarea>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold">Hình ảnh</label>
                            <div class="card border-0 bg-light rounded-4 overflow-hidden mb-3" style="aspect-ratio: 1; position: relative;">
                                <img id="product-preview" src="/images/placeholder.png" class="w-100 h-100 object-fit-cover">
                                <div class="position-absolute bottom-0 start-0 w-100 p-2" style="background: rgba(0,0,0,0.5);">
                                    <div class="btn-group w-100">
                                        <button type="button" class="btn btn-sm btn-light rounded-start-pill" onclick="openMediaLibrary('image_url')">
                                            THƯ VIỆN
                                        </button>
                                        <button type="button" class="btn btn-sm btn-primary rounded-end-pill" onclick="document.getElementById('directProductUpload').click()">
                                            TẢI LÊN
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <input type="file" id="directProductUpload" class="d-none" accept="image/*" onchange="handleDirectUpload(this)">
                            <input type="hidden" name="image_url" id="image_url_input" onchange="updateProductPreview(this.value)">
                            <div class="form-check form-switch mt-4">
                                <input class="form-check-input" type="checkbox" name="is_active" id="product_is_active" checked>
                                <label class="form-check-label small fw-bold" for="product_is_active">Đang hiển thị</label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-top border-light p-4">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary-bl rounded-pill px-5 fw-bold" onclick="saveProduct()">LƯU SẢN PHẨM</button>
            </div>
        </div>
    </div>
</div>

<script>
    const productModal = new bootstrap.Modal(document.getElementById('productModal'));
    const productForm = document.getElementById('productForm');

    function editProduct(p) {
        productForm.reset();
        productForm.id.value = p.id;
        productForm.name.value = p.name;
        productForm.price.value = p.price;
        productForm.category.value = p.category;
        productForm.description.value = p.description;
        productForm.image_url.value = p.image_url;
        productForm.is_active.checked = p.is_active;
        
        updateProductPreview(p.image_url);
        productModal.show();
    }

    function updateProductPreview(url) {
        document.getElementById('product-preview').src = url || '/images/placeholder.png';
    }

    function previewMedia(name) {
        if (name === 'image_url') {
            updateProductPreview(document.getElementById('image_url_input').value);
        }
    }

    async function saveProduct() {
        const formData = new FormData(productForm);
        const data = Object.fromEntries(formData);
        data.is_active = productForm.is_active.checked ? 1 : 0;

        try {
            const res = await axios.post('/api/admin/update-product', data);
            if (res.data.success) {
                alert(res.data.message);
                location.reload();
            }
        } catch (e) {
            alert('Lỗi: ' + e.message);
        }
    }

    async function handleDirectUpload(input) {
        const file = input.files[0];
        if (!file) return;

        const btn = input.previousElementSibling.querySelector('.btn-primary');
        const originalContent = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

        const formData = new FormData();
        formData.append('file', file);

        try {
            const res = await axios.post('/api/admin/upload?category=products', formData);
            if (res.data.success) {
                const url = res.data.data.url;
                document.getElementById('image_url_input').value = url;
                updateProductPreview(url);
            }
        } catch (err) {
            alert('Lỗi upload: ' + (err.response?.data?.message || err.message));
        } finally {
            btn.disabled = false;
            btn.innerHTML = originalContent;
            input.value = '';
        }
    }
</script>
