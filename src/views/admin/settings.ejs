<!-- Admin Site Settings -->
<style>
.btn-admin-outline {
    border: 1.5px solid var(--admin-primary) !important;
    color: var(--admin-primary) !important;
    background: transparent !important;
    font-weight: 600;
    transition: all 0.2s;
}
.btn-admin-outline:hover {
    background: var(--admin-primary) !important;
    color: #ffffff !important;
}
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1" style="font-family: 'Inter', sans-serif;">Cài đặt Trang web</h4>
        <p class="mb-0" style="color: var(--admin-muted); font-size: 0.85rem;">Thay đổi nội dung hiển thị trên trang chủ và thông tin giới thiệu</p>
    </div>
</div>

<form id="settingsForm" onsubmit="saveSettings(event)">
    <div class="row g-4">
        <!-- Logo & Brand Identity -->
        <div class="col-12">
            <div class="chart-card">
                <h6 class="fw-bold mb-3"><i class="bi bi-palette me-2" style="color: var(--admin-primary);"></i>Logo & Bộ nhận diện Thương hiệu</h6>
                <div class="row g-4 align-items-center">
                    <div class="col-md-3 text-center">
                        <div class="p-3 rounded-4" style="background: var(--admin-surface); border: 2px dashed var(--admin-border);">
                            <img id="logo_preview" src="<%= fixImg(settings.brand_logo, '/images/logo.png') %>" alt="Logo" style="max-height: 100px; max-width: 100%; object-fit: contain;" onerror="this.src='/images/logo.png'">
                            <div class="mt-2">
                                <button type="button" class="btn btn-sm btn-admin-outline rounded-pill" onclick="document.getElementById('logo_file').click()">
                                    <i class="bi bi-upload me-1"></i>Đổi Logo
                                </button>
                                <input type="file" id="logo_file" class="d-none" accept="image/*" onchange="uploadLogo(this)">
                            </div>
                        </div>
                        <input type="hidden" name="brand_logo" id="brand_logo" value="<%= settings.brand_logo || '/images/logo.png' %>">
                    </div>
                    <div class="col-md-9">
                        <div class="mb-3">
                            <label class="form-label small fw-bold" style="color: var(--admin-muted);">Tên thương hiệu</label>
                            <input type="text" name="brand_name" class="form-control admin-input" value="<%= settings.brand_name || 'BÌNH LỢI' %>" placeholder="Tên thương hiệu...">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold" style="color: var(--admin-muted);">Slogan / Khẩu hiệu</label>
                            <input type="text" name="brand_subtext" class="form-control admin-input" value="<%= settings.brand_subtext || 'Chạm vào bình yên' %>" placeholder="Slogan thương hiệu...">
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Hero Section -->
        <div class="col-lg-6">
            <div class="chart-card">
                <h6 class="fw-bold mb-3"><i class="bi bi-image me-2" style="color: var(--admin-accent);"></i>Hero Section (Trang chủ)</h6>
                
                <div class="mb-3">
                    <label class="form-label small fw-bold" style="color: var(--admin-muted);">Tiêu đề chính</label>
                    <input type="text" name="hero_title" class="form-control admin-input" value="<%= settings.hero_title || 'Bình Lợi - Miền Tây giữa lòng Sài Gòn' %>" placeholder="Tiêu đề hero...">
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold" style="color: var(--admin-muted);">Slogan</label>
                    <input type="text" name="hero_slogan" class="form-control admin-input" value="<%= settings.hero_slogan || 'Miệt vườn giữa phố, trải nghiệm bản sắc' %>" placeholder="Slogan...">
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold" style="color: var(--admin-muted);">Ảnh Hero (Trang chủ)</label>
                    <div class="d-flex align-items-center gap-3 mb-2">
                        <img id="hero_preview" src="<%= settings.hero_image || '/images/hero-1.png' %>" class="rounded-3" style="width: 100px; height: 60px; object-fit: cover; border: 1px solid var(--admin-border);">
                        <button type="button" class="btn btn-sm btn-admin-outline rounded-pill" onclick="document.getElementById('hero_file').click()">
                            <i class="bi bi-upload me-1"></i>Chọn ảnh
                        </button>
                        <input type="file" id="hero_file" class="d-none" accept="image/*" onchange="uploadFile(this, 'hero_image', 'hero_preview')">
                    </div>
                    <input type="hidden" name="hero_image" id="hero_image" value="<%= settings.hero_image || '/images/hero-1.png' %>">
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold" style="color: var(--admin-muted);">Background Giới thiệu</label>
                    <div class="d-flex align-items-center gap-3 mb-2">
                        <img id="about_preview" src="<%= settings.about_bg || '/images/nature-bg.jpg' %>" class="rounded-3" style="width: 100px; height: 60px; object-fit: cover; border: 1px solid var(--admin-border);">
                        <button type="button" class="btn btn-sm btn-admin-outline rounded-pill" onclick="document.getElementById('about_file').click()">
                            <i class="bi bi-upload me-1"></i>Chọn ảnh
                        </button>
                        <input type="file" id="about_file" class="d-none" accept="image/*" onchange="uploadFile(this, 'about_bg', 'about_preview')">
                    </div>
                    <input type="hidden" name="about_bg" id="about_bg" value="<%= settings.about_bg || '/images/nature-bg.jpg' %>">
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold" style="color: var(--admin-muted);">Background Đăng nhập</label>
                    <div class="d-flex align-items-center gap-3 mb-2">
                        <img id="login_preview" src="<%= settings.login_bg || '/images/hero-1.png' %>" class="rounded-3" style="width: 100px; height: 60px; object-fit: cover; border: 1px solid var(--admin-border);">
                        <button type="button" class="btn btn-sm btn-admin-outline rounded-pill" onclick="document.getElementById('login_file').click()">
                            <i class="bi bi-upload me-1"></i>Chọn ảnh
                        </button>
                        <input type="file" id="login_file" class="d-none" accept="image/*" onchange="uploadFile(this, 'login_bg', 'login_preview')">
                    </div>
                    <input type="hidden" name="login_bg" id="login_bg" value="<%= settings.login_bg || '/images/hero-1.png' %>">
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold" style="color: var(--admin-muted);">Hình nền trang Khám phá (banner_explore)</label>
                    <div class="d-flex align-items-center gap-3 mb-2">
                        <img id="banner_explore_preview" src="<%= settings.banner_explore || '/images/hero-1.png' %>" class="rounded-3" style="width: 100px; height: 60px; object-fit: cover; border: 1px solid var(--admin-border);">
                        <button type="button" class="btn btn-sm btn-admin-outline rounded-pill" onclick="document.getElementById('banner_explore_file').click()">
                            <i class="bi bi-upload me-1"></i>Chọn ảnh
                        </button>
                        <input type="file" id="banner_explore_file" class="d-none" accept="image/*" onchange="uploadFile(this, 'banner_explore', 'banner_explore_preview')">
                    </div>
                    <input type="hidden" name="banner_explore" id="banner_explore" value="<%= settings.banner_explore || '/images/hero-1.png' %>">
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold" style="color: var(--admin-muted);">Hình nền trang Workshop (banner_workshop)</label>
                    <div class="d-flex align-items-center gap-3 mb-2">
                        <img id="banner_workshop_preview" src="<%= settings.banner_workshop || '/images/hero-2.png' %>" class="rounded-3" style="width: 100px; height: 60px; object-fit: cover; border: 1px solid var(--admin-border);">
                        <button type="button" class="btn btn-sm btn-admin-outline rounded-pill" onclick="document.getElementById('banner_workshop_file').click()">
                            <i class="bi bi-upload me-1"></i>Chọn ảnh
                        </button>
                        <input type="file" id="banner_workshop_file" class="d-none" accept="image/*" onchange="uploadFile(this, 'banner_workshop', 'banner_workshop_preview')">
                    </div>
                    <input type="hidden" name="banner_workshop" id="banner_workshop" value="<%= settings.banner_workshop || '/images/hero-2.png' %>">
                </div>
            </div>
        </div>

        <!-- About Section -->
        <div class="col-lg-6">
            <div class="chart-card mb-4">
                <h6 class="fw-bold mb-3"><i class="bi bi-info-circle me-2" style="color: var(--admin-primary);"></i>Giới thiệu Chung</h6>
                
                <div class="mb-3">
                    <label class="form-label small fw-bold" style="color: var(--admin-muted);">Tên trang web</label>
                    <input type="text" name="site_name" class="form-control admin-input" value="<%= settings.site_name || 'Bình Lợi Healing' %>">
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold" style="color: var(--admin-muted);">Mô tả</label>
                    <textarea name="site_description" class="form-control admin-input" rows="3" placeholder="Mô tả ngắn về trang web..."><%= settings.site_description || 'Nền tảng du lịch chữa lành tại xã Bình Lợi, huyện Bình Chánh, TP.HCM' %></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold" style="color: var(--admin-muted);">Liên hệ</label>
                    <input type="text" name="contact_phone" class="form-control admin-input" value="<%= settings.contact_phone || '' %>" placeholder="Số điện thoại...">
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold" style="color: var(--admin-muted);">Email</label>
                    <input type="email" name="contact_email" class="form-control admin-input" value="<%= settings.contact_email || '' %>" placeholder="email@example.com">
                </div>
            </div>
        </div>

        <!-- Social & SEO -->
        <div class="col-12">
            <div class="chart-card">
                <h6 class="fw-bold mb-3"><i class="bi bi-globe me-2" style="color: #10b981;"></i>Mạng xã hội & SEO</h6>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label small fw-bold" style="color: var(--admin-muted);">Facebook</label>
                        <input type="text" name="social_facebook" class="form-control admin-input" value="<%= settings.social_facebook || '' %>" placeholder="URL Facebook...">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-bold" style="color: var(--admin-muted);">Instagram</label>
                        <input type="text" name="social_instagram" class="form-control admin-input" value="<%= settings.social_instagram || '' %>" placeholder="URL Instagram...">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-bold" style="color: var(--admin-muted);">TikTok</label>
                        <input type="text" name="social_tiktok" class="form-control admin-input" value="<%= settings.social_tiktok || '' %>" placeholder="URL TikTok...">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4 text-end">
        <button type="submit" class="btn px-5 py-2 rounded-pill fw-bold" style="background: var(--admin-primary); color: white;" id="saveBtn">
            <i class="bi bi-check-circle me-2"></i>Lưu Cài Đặt
        </button>
    </div>
</form>

<script>
async function uploadLogo(input) {
    if (!input.files || !input.files[0]) return;
    
    const formData = new FormData();
    formData.append('image', input.files[0]);
    
    const preview = document.getElementById('logo_preview');
    const btn = input.previousElementSibling;
    const oldHtml = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Đang tải...';
    
    try {
        const res = await axios.post('/api/admin/upload-logo', formData, {
            headers: { 'Content-Type': 'multipart/form-data' }
        });
        
        if (res.data.success) {
            preview.src = res.data.url;
            document.getElementById('brand_logo').value = res.data.url;
            btn.innerHTML = '<i class="bi bi-check-circle-fill text-success me-1"></i>Đã tải!';
            
            // Automatically save settings and reload page to apply logo everywhere
            const form = document.getElementById('settingsForm');
            const formData = new FormData(form);
            const data = Object.fromEntries(formData);
            const saveRes = await axios.post('/api/admin/update-settings', data);
            if (saveRes.data.success) {
                window.location.reload();
            }
        }
    } catch (err) {
        alert('Lỗi tải logo: ' + (err.response?.data?.message || err.message));
        btn.innerHTML = oldHtml;
    } finally {
        btn.disabled = false;
    }
}

async function uploadFile(input, targetId, previewId) {
    if (!input.files || !input.files[0]) return;
    
    const formData = new FormData();
    formData.append('image', input.files[0]);
    
    const btn = input.previousElementSibling;
    const oldHtml = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>...';
    
    try {
        const res = await axios.post('/api/upload', formData, {
            headers: { 'Content-Type': 'multipart/form-data' }
        });
        
        if (res.data.success) {
            document.getElementById(targetId).value = res.data.url;
            if (previewId) document.getElementById(previewId).src = res.data.url;
            btn.innerHTML = '<i class="bi bi-check-circle-fill text-success me-1"></i>Xong';
        }
    } catch (err) {
        alert('Lỗi tải ảnh: ' + (err.response?.data?.message || err.message));
        btn.innerHTML = oldHtml;
    } finally {
        btn.disabled = false;
        setTimeout(() => { btn.innerHTML = oldHtml; }, 2000);
    }
}

async function saveSettings(e) {
    e.preventDefault();
    const btn = document.getElementById('saveBtn');
    btn.disabled = true;
    btn.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>Đang lưu...';
    
    try {
        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData);
        const res = await axios.post('/api/admin/update-settings', data);
        if (res.data.success) {
            btn.innerHTML = '<i class="bi bi-check-circle-fill me-2"></i>Đã lưu!';
            btn.style.background = '#10b981';
            setTimeout(() => {
                btn.innerHTML = '<i class="bi bi-check-circle me-2"></i>Lưu Cài Đặt';
                btn.style.background = 'var(--admin-primary)';
                btn.disabled = false;
            }, 2000);
        }
    } catch (err) {
        alert('Lỗi: ' + err.message);
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-check-circle me-2"></i>Lưu Cài Đặt';
    }
}
</script>
