<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-black mb-0">Cấu hình Hệ thống</h2>
    <button type="button" onclick="saveSettings()" class="btn btn-primary rounded-pill px-4 py-2 fw-bold">
        LƯU THAY ĐỔI <i class="bi bi-save ms-2"></i>
    </button>
</div>

<%- include('../partials/media_library_modal') %>

<div class="row g-4">
    <div class="col-lg-12">
        <div class="card glass-card border-0">
            <div class="card-body p-4">
                <form id="settingsForm">
                    <% Object.keys(grouped).forEach(category => { %>
                        <div class="mb-5">
                            <h5 class="text-primary text-uppercase fw-bold tracking-widest mb-4 border-bottom pb-2">
                                <%= category === 'home' ? 'Cấu hình Trang chủ' : (category === 'stats' ? 'Thống kê & Chỉ số' : category.toUpperCase()) %>
                            </h5>
                            <div class="row g-3">
                                <% grouped[category].forEach(setting => { %>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label small fw-bold text-muted text-uppercase"><%= setting.key_name.replace(/_/g, ' ') %></label>
                                        <% if (setting.key_name.includes('video') || setting.key_name.includes('image')) { %>
                                            <div class="input-group">
                                                <input type="text" class="form-control rounded-start-3" name="<%= setting.key_name %>" value="<%= setting.key_value %>">
                                                <button class="btn btn-primary" type="button" onclick="openMediaLibrary('<%= setting.key_name %>')">
                                                    <i class="bi bi-images me-2"></i>Thư viện
                                                </button>
                                                <button class="btn btn-outline-secondary rounded-end-3" type="button" onclick="previewMedia('<%= setting.key_name %>')">Xem</button>
                                            </div>
                                        <% } else { %>
                                            <input type="text" class="form-control rounded-3" name="<%= setting.key_name %>" value="<%= setting.key_value %>">
                                        <% } %>
                                        <div id="preview-<%= setting.key_name %>" class="mt-2 d-none">
                                            <!-- Media Preview will appear here -->
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        </div>
                    <% }) %>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    async function saveSettings() {
        const form = document.getElementById('settingsForm');
        const formData = new FormData(form);
        const data = {};
        formData.forEach((value, key) => { data[key] = value; });

        try {
            const res = await axios.post('/api/admin/update-settings', data);
            if (res.data.success) {
                alert('Đã lưu cấu hình thành công!');
                location.reload();
            }
        } catch (e) {
            alert('Lỗi: ' + e.message);
        }
    }

    function previewMedia(name) {
        const input = document.querySelector(`input[name="${name}"]`);
        const previewDiv = document.getElementById(`preview-${name}`);
        const url = input.value;

        if (url.endsWith('.mp4')) {
            previewDiv.innerHTML = `<video src="${url}" controls class="w-100 rounded-3 mt-2" style="max-height: 200px;"></video>`;
        } else {
            previewDiv.innerHTML = `<img src="${url}" class="w-100 rounded-3 mt-2" style="max-height: 200px; object-fit: cover;">`;
        }
        previewDiv.classList.remove('d-none');
    }
</script>
