<!-- Admin: Reviews & Soundscape Management -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1" style="font-family: 'Inter', sans-serif;">Quản lý Cộng đồng & Soundscape</h4>
        <p class="mb-0" style="color: var(--admin-muted); font-size: 0.85rem;">Duyệt đánh giá từ du khách và quản lý thư viện âm thanh chữa lành.</p>
    </div>
</div>

<!-- Tabs -->
<ul class="nav nav-tabs mb-4 border-bottom border-secondary border-opacity-25" id="communityTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active fw-bold text-dark border-0 bg-transparent position-relative pb-2 me-3" id="reviews-tab" data-bs-toggle="tab" data-bs-target="#reviews-pane" type="button" role="tab" style="outline: none;">
            <i class="bi bi-chat-left-text me-2"></i>Đánh giá từ Du khách
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link fw-bold text-muted border-0 bg-transparent position-relative pb-2" id="soundscapes-tab" data-bs-toggle="tab" data-bs-target="#soundscapes-pane" type="button" role="tab" style="outline: none;">
            <i class="bi bi-music-note-beamed me-2"></i>Âm thanh Soundscape
        </button>
    </li>
</ul>

<div class="tab-content" id="communityTabsContent">
    <!-- Reviews Tab Pane -->
    <div class="tab-pane fade show active" id="reviews-pane" role="tabpanel" tabindex="0">
        <!-- Filter by Destination -->
        <div class="mb-4 d-flex gap-2 flex-wrap">
            <a href="/admin/reviews" class="btn btn-sm <%= !currentDestination ? 'btn-primary' : 'btn-outline-secondary' %> rounded-pill px-3">Tất cả</a>
            <% destinations.forEach(d => { %>
                <a href="/admin/reviews?destination=<%= d.id %>" class="btn btn-sm <%= currentDestination === d.id ? 'btn-primary' : 'btn-outline-secondary' %> rounded-pill px-3"><%= d.name %></a>
            <% }) %>
        </div>

        <!-- Reviews Table -->
        <div class="admin-table">
            <table class="table table-borderless mb-0">
                <thead>
                    <tr>
                        <th>Người dùng</th>
                        <th>Nội dung</th>
                        <th>Địa điểm</th>
                        <th>Đánh giá</th>
                        <th>Likes</th>
                        <th>Ngày đăng</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    <% reviews.forEach(r => { %>
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <img src="<%= r.avatar || '/images/default-avatar.png' %>" class="rounded-circle" style="width: 32px; height: 32px; object-fit: cover;">
                                <span class="small fw-bold"><%= r.full_name %></span>
                            </div>
                        </td>
                        <td style="max-width: 300px;">
                            <p class="small mb-0 text-truncate" style="max-width: 280px;" title="<%= r.content %>"><%= r.content %></p>
                        </td>
                        <td class="small"><%= r.destination_name || r.location_name || '-' %></td>
                        <td>
                            <span class="text-warning small">
                                <% for(let s = 0; s < (r.rating || 5); s++) { %>⭐<% } %>
                            </span>
                        </td>
                        <td class="small"><%= r.likes_count || 0 %></td>
                        <td class="small" style="color: var(--admin-muted);"><%= new Date(r.created_at).toLocaleDateString('vi-VN') %></td>
                        <td>
                            <button class="btn btn-sm btn-outline-danger rounded-pill px-3" onclick="deleteReview('<%= r.id %>')">
                                <i class="bi bi-trash"></i> Xóa
                            </button>
                        </td>
                    </tr>
                    <% }) %>
                    <% if (reviews.length === 0) { %>
                    <tr><td colspan="7" class="text-center py-5 text-muted">Chưa có bài đánh giá nào.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Soundscapes Tab Pane -->
    <div class="tab-pane fade" id="soundscapes-pane" role="tabpanel" tabindex="0">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="fw-bold mb-0">Thư viện Âm thanh Soundscape</h5>
            <button class="btn btn-primary btn-sm rounded-pill px-3 fw-bold" data-bs-toggle="modal" data-bs-target="#soundscapeModal">
                <i class="bi bi-plus-lg me-1"></i>Thêm âm thanh mẫu
            </button>
        </div>

        <!-- Soundscapes Table -->
        <div class="admin-table">
            <table class="table table-borderless mb-0">
                <thead>
                    <tr>
                        <th>Tên âm thanh</th>
                        <th>Chủ đề (Mood)</th>
                        <th>Thời lượng</th>
                        <th>Nghe thử</th>
                        <th>Ngày tạo</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    <% soundscapes.forEach(s => { %>
                    <tr>
                        <td class="fw-bold small"><%= s.name %></td>
                        <td>
                            <% if (s.mood === 'calm') { %>
                                <span class="badge bg-success bg-opacity-15 text-success rounded-pill px-3 py-1">Calm (Yên bình)</span>
                            <% } else if (s.mood === 'wild') { %>
                                <span class="badge bg-warning bg-opacity-15 text-warning rounded-pill px-3 py-1">Wild (Sống động)</span>
                            <% } else { %>
                                <span class="badge bg-dark bg-opacity-15 text-dark rounded-pill px-3 py-1">Night (Đêm tĩnh lặng)</span>
                            <% } %>
                        </td>
                        <td class="small"><%= s.duration_seconds || 0 %> giây</td>
                        <td>
                            <audio src="<%= s.audio_url %>" controls class="my-audio-player" style="max-height: 28px; width: 220px;"></audio>
                        </td>
                        <td class="small" style="color: var(--admin-muted);"><%= new Date(s.created_at).toLocaleDateString('vi-VN') %></td>
                        <td>
                            <button class="btn btn-sm btn-outline-danger rounded-pill px-3" onclick="deleteSoundscape('<%= s.id %>')">
                                <i class="bi bi-trash"></i> Xóa
                            </button>
                        </td>
                    </tr>
                    <% }) %>
                    <% if (soundscapes.length === 0) { %>
                    <tr><td colspan="6" class="text-center py-5 text-muted">Chưa có âm thanh soundscape nào.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add Soundscape Modal -->
<div class="modal fade" id="soundscapeModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4" style="background: var(--admin-surface);">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Thêm Âm Thanh Soundscape</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="soundscapeForm" onsubmit="saveSoundscape(event)">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Tên âm thanh</label>
                        <input type="text" class="form-control admin-input" id="sound_name" name="name" required placeholder="Ví dụ: Tiếng Rừng Tràm Xào Xạc">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Mood (Chủ đề cảm xúc)</label>
                        <select class="form-select admin-input" id="sound_mood" name="mood" required>
                            <option value="calm">Calm - Thư giãn, nhẹ nhàng</option>
                            <option value="wild">Wild - Sôi động, thiên nhiên hoang dã</option>
                            <option value="night">Night - Huyền bí, yên bình ban đêm</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Thời lượng (giây)</label>
                        <input type="number" class="form-control admin-input" id="sound_duration" name="duration_seconds" value="30" min="1" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Tệp âm thanh (MP3/WAV)</label>
                        <input type="file" class="form-control admin-input" id="sound_file" name="audio" accept="audio/*" required>
                        <div class="form-text small">Giới hạn tệp tối đa 25MB.</div>
                    </div>
                    <div class="modal-footer border-0 px-0 pb-0">
                        <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold" id="saveSoundBtn">Lưu lại</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
/* Custom style to make tabs look like modern pills */
#communityTabs .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: var(--admin-primary);
    border-radius: 3px;
}
#communityTabs .nav-link {
    transition: all 0.2s ease-in-out;
}
#communityTabs .nav-link:hover {
    color: var(--admin-primary) !important;
}
</style>

<script>
async function deleteReview(id) {
    if (!confirm('Xóa bài đánh giá này?')) return;
    try {
        const res = await axios.post('/api/admin/delete-review', { id });
        if (res.data.success) location.reload();
        else alert(res.data.message);
    } catch (e) { alert('Lỗi'); }
}

async function saveSoundscape(e) {
    e.preventDefault();
    const btn = document.getElementById('saveSoundBtn');
    const oldHtml = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Đang lưu...';

    const formData = new FormData();
    formData.append('name', document.getElementById('sound_name').value);
    formData.append('mood', document.getElementById('sound_mood').value);
    formData.append('duration_seconds', document.getElementById('sound_duration').value);
    formData.append('audio', document.getElementById('sound_file').files[0]);

    try {
        const res = await axios.post('/api/admin/create-soundscape', formData, {
            headers: { 'Content-Type': 'multipart/form-data' }
        });

        if (res.data.success) {
            alert(res.data.message);
            location.reload();
        } else {
            alert('Lỗi: ' + res.data.message);
            btn.disabled = false;
            btn.innerHTML = oldHtml;
        }
    } catch (err) {
        alert('Lỗi khi tải âm thanh: ' + (err.response?.data?.message || err.message));
        btn.disabled = false;
        btn.innerHTML = oldHtml;
    }
}

async function deleteSoundscape(id) {
    if (!confirm('Bạn có chắc chắn muốn xóa âm thanh soundscape này?')) return;
    try {
        const res = await axios.post('/api/admin/delete-soundscape', { id });
        if (res.data.success) {
            location.reload();
        } else {
            alert('Lỗi: ' + res.data.message);
        }
    } catch (err) {
        alert('Lỗi xóa âm thanh');
    }
}
</script>

