<!-- Admin Destinations Management -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1" style="font-family: 'Outfit', sans-serif;">Quản lý Địa điểm</h4>
        <p class="mb-0" style="color: var(--admin-muted); font-size: 0.85rem;">Bật/tắt và quản lý tất cả địa điểm trên hệ thống</p>
    </div>
</div>

<div class="admin-table">
    <table class="table table-dark table-borderless mb-0">
        <thead><tr>
            <th style="width: 50px;">#</th>
            <th>Địa điểm</th>
            <th>Loại</th>
            <th>Quản lý</th>
            <th>Check-ins</th>
            <th>Trạng thái</th>
            <th>Thao tác</th>
        </tr></thead>
        <tbody>
            <% destinations.forEach((d, i) => { %>
            <tr id="dest-<%= d.id %>">
                <td class="fw-bold" style="color: var(--admin-muted);"><%= i + 1 %></td>
                <td>
                    <div class="d-flex align-items-center gap-3">
                        <img src="/<%= d.cover_image || 'images/placeholder.jpg' %>" class="rounded-3" style="width: 56px; height: 40px; object-fit: cover;">
                        <div>
                            <div class="fw-bold" style="font-size: 0.88rem;"><%= d.name %></div>
                            <div style="font-size: 0.72rem; color: var(--admin-muted);">/<%= d.slug %></div>
                        </div>
                    </div>
                </td>
                <td><span class="badge rounded-pill" style="background: rgba(59,130,246,0.15); color: #3b82f6;"><%= d.type || 'general' %></span></td>
                <td style="font-size: 0.85rem;"><%= d.manager_name || '<span style="color:var(--admin-muted)">Chưa gán</span>' %></td>
                <td class="fw-bold"><%= d.checkin_count %></td>
                <td>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="toggle-<%= d.id %>" <%= d.is_active ? 'checked' : '' %> onchange="toggleDest('<%= d.id %>', this.checked)">
                    </div>
                </td>
                <td>
                    <a href="/manager?dest_id=<%= d.id %>" class="btn btn-sm rounded-pill" style="background: rgba(59,130,246,0.15); color: #3b82f6; font-size: 0.78rem;">
                        <i class="bi bi-pencil me-1"></i>Sửa
                    </a>
                    <a href="/explore/<%= d.slug %>" target="_blank" class="btn btn-sm rounded-pill" style="background: rgba(255,255,255,0.05); color: var(--admin-muted); font-size: 0.78rem;">
                        <i class="bi bi-eye me-1"></i>Xem
                    </a>
                </td>
            </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<script>
async function toggleDest(id, isActive) {
    try {
        const res = await axios.post('/api/admin/toggle-destination', { id, is_active: isActive });
        if (res.data.success) {
            const row = document.getElementById('dest-' + id);
            row.style.opacity = isActive ? '1' : '0.5';
        }
    } catch (err) {
        alert('Lỗi: ' + err.message);
    }
}
</script>
