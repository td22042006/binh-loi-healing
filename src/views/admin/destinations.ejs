<!-- Admin: Destinations Management -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1" style="font-family: 'Times New Roman', Times, serif;">Quản lý Địa điểm</h4>
        <p class="mb-0" style="color: var(--admin-muted); font-size: 0.85rem;">Thêm, sửa, xóa địa điểm du lịch. Thay đổi cập nhật tức thì trên trang chủ.</p>
    </div>
    <button class="btn btn-primary rounded-pill px-4 fw-bold" data-bs-toggle="modal" data-bs-target="#destModal" onclick="openDestForm()">
        <i class="bi bi-plus-lg me-1"></i> Thêm Địa điểm
    </button>
</div>

<!-- Destinations Table -->
<div class="admin-table">
    <table class="table table-borderless mb-0">
        <thead>
            <tr>
                <th>Địa điểm</th>
                <th>Loại</th>
                <th>Điểm thưởng</th>
                <th>Check-ins</th>
                <th>Views</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            <% destinations.forEach(d => { %>
            <tr>
                <td>
                    <div class="d-flex align-items-center gap-2">
                        <img src="<%= d.cover_image && d.cover_image.startsWith('http') ? d.cover_image : '/images/hero-1.png' %>" class="rounded-3" style="width: 48px; height: 48px; object-fit: cover;">
                        <div>
                            <div class="fw-bold small"><%= d.name %></div>
                            <div style="font-size: 0.72rem; color: var(--admin-muted);">/<%= d.slug %></div>
                        </div>
                    </div>
                </td>
                <td><span class="role-badge role-user"><%= d.type %></span></td>
                <td><span class="text-warning"><i class="bi bi-star-fill me-1"></i><%= d.points || 0 %></span></td>
                <td><%= d.checkin_count || 0 %></td>
                <td><%= d.page_views || 0 %></td>
                <td>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" onchange="toggleDest('<%= d.id %>', this.checked)" <%= d.is_active ? 'checked' : '' %>>
                    </div>
                </td>
                <td>
                    <button class="btn btn-sm btn-outline-primary rounded-pill px-3 me-1" onclick="editDest(this)" data-destination="<%= encodeURIComponent(JSON.stringify({id: d.id, name: d.name, slug: d.slug, type: d.type, short_desc: d.short_desc, description: d.description, open_hours: d.open_hours, cost: d.cost, points: d.points, lat: d.lat, lng: d.lng, cover_image: d.cover_image})) %>">
                        <i class="bi bi-pencil"></i>
                    </button>
                    <button class="btn btn-sm btn-outline-danger rounded-pill px-3" onclick="deleteDest('<%= d.id %>', '<%= d.name %>')">
                        <i class="bi bi-trash"></i>
                    </button>
                </td>
            </tr>
            <% }) %>
            <% if (destinations.length === 0) { %>
            <tr><td colspan="7" class="text-center py-5 text-muted">Chưa có địa điểm nào.</td></tr>
            <% } %>
        </tbody>
    </table>
</div>

<!-- Destination Modal -->
<div class="modal fade" id="destModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 rounded-4" style="background: var(--admin-surface);">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="destModalTitle">Thêm Địa điểm</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="destForm">
                    <input type="hidden" id="d_id" name="id">
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label small fw-bold">Tên địa điểm</label>
                            <input type="text" class="form-control admin-input" id="d_name" name="name" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold">Slug (URL)</label>
                            <input type="text" class="form-control admin-input" id="d_slug" name="slug" placeholder="ten-dia-diem">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold">Loại</label>
                            <select class="form-select admin-input" id="d_type" name="type">
                                <option value="nature">Thiên nhiên</option>
                                <option value="temple">Tâm linh</option>
                                <option value="park">Sinh thái</option>
                                <option value="craft">Làng nghề</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold">Điểm thưởng</label>
                            <input type="number" class="form-control admin-input" id="d_points" name="points" value="10">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold">Giờ mở cửa</label>
                            <input type="text" class="form-control admin-input" id="d_open_hours" name="open_hours" placeholder="07:00 - 18:00">
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold">Mô tả ngắn</label>
                            <input type="text" class="form-control admin-input" id="d_short_desc" name="short_desc">
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold">Mô tả chi tiết / Câu chuyện</label>
                            <textarea class="form-control admin-input" id="d_description" name="description" rows="4"></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold">Link Google Maps (Dán link chia sẻ từ Google Maps để tự động lấy tọa độ)</label>
                            <input type="text" class="form-control admin-input" id="d_maps_link" placeholder="Ví dụ: https://maps.app.goo.gl/... hoặc https://www.google.com/maps/place/..." oninput="autoExtractCoords(this.value)">
                            <div id="d_maps_feedback" class="form-text small mt-1 d-none"></div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold">Chi phí</label>
                            <input type="text" class="form-control admin-input" id="d_cost" name="cost" placeholder="Miễn phí">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold">Latitude</label>
                            <input type="text" class="form-control admin-input" id="d_lat" name="lat" placeholder="10.7431">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold">Longitude</label>
                            <input type="text" class="form-control admin-input" id="d_lng" name="lng" placeholder="106.5028">
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold">Ảnh bìa địa điểm</label>
                            <div class="d-flex align-items-center gap-3 mb-2">
                                <img id="d_cover_preview" src="/images/placeholder.jpg" class="rounded-3" style="width: 100px; height: 60px; object-fit: cover; border: 1px solid var(--admin-border);">
                                <button type="button" class="btn btn-sm btn-outline-light rounded-pill px-3" onclick="document.getElementById('d_cover_file').click()">
                                    <i class="bi bi-upload me-1"></i>Upload ảnh bìa
                                </button>
                                <input type="file" id="d_cover_file" class="d-none" accept="image/*" onchange="uploadCoverFile(this)">
                            </div>
                            <input type="hidden" id="d_cover_image" name="cover_image" value="/images/placeholder.jpg">
                        </div>
                        <!-- Manager Account Section (Only shown when adding new destination) -->
                        <div id="managerAccountSection" class="col-12 border-top border-secondary border-opacity-10 pt-3 mt-3">
                            <h6 class="fw-bold mb-3 text-primary"><i class="bi bi-person-badge me-2"></i>Tạo Tài khoản Quản lý Địa điểm</h6>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label small fw-bold">Họ tên người quản lý</label>
                                    <input type="text" class="form-control admin-input" id="d_manager_name" name="manager_name" placeholder="Ví dụ: Nguyễn Văn A">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small fw-bold">Email quản lý (Bắt buộc)</label>
                                    <input type="email" class="form-control admin-input" id="d_manager_email" name="manager_email" placeholder="manager@example.com">
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label small fw-bold">Mật khẩu quản lý (Bắt buộc)</label>
                                    <input type="password" class="form-control admin-input" id="d_manager_password" name="manager_password" placeholder="Tối thiểu 6 ký tự">
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0">
                <button class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Hủy</button>
                <button class="btn btn-primary rounded-pill px-4 fw-bold" onclick="saveDest()">Lưu</button>
            </div>
        </div>
    </div>
</div>

<script>
let editingDest = false;

// Auto slug generation helper
function generateSlug(str) {
    if (!str) return '';
    str = str.toLowerCase();
    str = str.replace(/à|á|ạ|ả|ã|â|ầ|ấ|ậ|ẩ|ẫ|ă|ằ|ắ|ặ|ẳ|ẵ/g, "a");
    str = str.replace(/è|é|ẹ|ẻ|ẽ|ê|ề|ế|ệ|ể|ễ/g, "e");
    str = str.replace(/ì|í|ị|ỉ|ĩ/g, "i");
    str = str.replace(/ò|ó|ọ|ỏ|õ|ô|ồ|ố|ộ|ổ|ỗ|ơ|ờ|ớ|ợ|ở|ỡ/g, "o");
    str = str.replace(/ù|ú|ụ|ủ|ũ|ư|ừ|ứ|ự|ử|ữ/g, "u");
    str = str.replace(/ỳ|ý|ỵ|ỷ|ỹ/g, "y");
    str = str.replace(/đ/g, "d");
    str = str.replace(/[^a-z0-9 -]/g, ''); // Remove special characters
    str = str.trim().replace(/\s+/g, '-'); // Replace spaces with -
    str = str.replace(/-+/g, '-'); // Replace multiple - with single -
    return str;
}

document.getElementById('d_name').addEventListener('input', function() {
    if (!editingDest) {
        document.getElementById('d_slug').value = generateSlug(this.value);
    }
});

async function uploadCoverFile(input) {
    if (!input.files || !input.files[0]) return;
    
    const formData = new FormData();
    formData.append('image', input.files[0]);
    
    const btn = input.previousElementSibling;
    const oldHtml = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>...';
    
    try {
        const res = await axios.post('/api/upload', formData, {
            headers: { 'Content-Type': 'multipart/form-data' }
        });
        
        if (res.data.success) {
            document.getElementById('d_cover_image').value = res.data.url;
            document.getElementById('d_cover_preview').src = res.data.url;
            btn.innerHTML = '<i class="bi bi-check-circle-fill text-success me-1"></i>Xong';
        }
    } catch (err) {
        alert('Lỗi tải ảnh: ' + (err.response?.data?.message || err.message));
        btn.innerHTML = oldHtml;
    } finally {
        btn.disabled = false;
        setTimeout(() => { btn.innerHTML = oldHtml; }, 2000);
    }
}

function openDestForm() {
    editingDest = false;
    document.getElementById('destModalTitle').textContent = 'Thêm Địa điểm';
    document.getElementById('destForm').reset();
    document.getElementById('d_id').value = '';
    document.getElementById('d_cover_image').value = '/images/placeholder.jpg';
    document.getElementById('d_cover_preview').src = '/images/placeholder.jpg';
    document.getElementById('d_maps_link').value = '';
    const feedback = document.getElementById('d_maps_feedback');
    if (feedback) feedback.className = "form-text small mt-1 d-none";
    document.getElementById('managerAccountSection').style.display = 'block';
    document.getElementById('d_manager_email').setAttribute('required', 'required');
    document.getElementById('d_manager_password').setAttribute('required', 'required');
}

function editDest(target) {
    let d = target;
    if (target instanceof HTMLElement) {
        d = JSON.parse(decodeURIComponent(target.getAttribute('data-destination')));
    }
    editingDest = true;
    document.getElementById('destModalTitle').textContent = 'Sửa Địa điểm';
    document.getElementById('d_id').value = d.id;
    document.getElementById('d_name').value = d.name || '';
    document.getElementById('d_slug').value = d.slug || '';
    document.getElementById('d_type').value = d.type || 'nature';
    document.getElementById('d_short_desc').value = d.short_desc || '';
    document.getElementById('d_description').value = d.description || '';
    document.getElementById('d_open_hours').value = d.open_hours || '';
    document.getElementById('d_cost').value = d.cost || '';
    document.getElementById('d_points').value = d.points || 10;
    document.getElementById('d_lat').value = d.lat || '';
    document.getElementById('d_lng').value = d.lng || '';
    
    document.getElementById('d_maps_link').value = d.lat && d.lng ? `https://www.google.com/maps?q=${d.lat},${d.lng}` : '';
    const feedback = document.getElementById('d_maps_feedback');
    if (feedback) feedback.className = "form-text small mt-1 d-none";
    
    const coverUrl = d.cover_image || '/images/placeholder.jpg';
    document.getElementById('d_cover_image').value = coverUrl;
    document.getElementById('d_cover_preview').src = coverUrl;
    
    document.getElementById('managerAccountSection').style.display = 'none';
    document.getElementById('d_manager_email').removeAttribute('required');
    document.getElementById('d_manager_password').removeAttribute('required');
    
    new bootstrap.Modal(document.getElementById('destModal')).show();
}

async function saveDest() {
    const slugVal = document.getElementById('d_slug').value.trim();
    if (slugVal.includes('/') || slugVal.includes('.') || slugVal.includes('http') || slugVal.includes('?')) {
        alert('Slug (URL) chỉ được chứa chữ viết liền không dấu và dấu gạch ngang (ví dụ: cong-vien-lang-le).\nKhông được điền địa chỉ link website hoặc Google Maps vào ô này.');
        return;
    }

    const data = {
        id: document.getElementById('d_id').value,
        name: document.getElementById('d_name').value,
        slug: slugVal || generateSlug(document.getElementById('d_name').value),
        type: document.getElementById('d_type').value,
        short_desc: document.getElementById('d_short_desc').value,
        description: document.getElementById('d_description').value,
        open_hours: document.getElementById('d_open_hours').value,
        cost: document.getElementById('d_cost').value,
        points: parseInt(document.getElementById('d_points').value) || 10,
        lat: document.getElementById('d_lat').value,
        lng: document.getElementById('d_lng').value,
        cover_image: document.getElementById('d_cover_image').value
    };
    
    if (!editingDest) {
        data.manager_name = document.getElementById('d_manager_name').value;
        data.manager_email = document.getElementById('d_manager_email').value;
        data.manager_password = document.getElementById('d_manager_password').value;
    }
    
    const url = editingDest ? '/api/admin/update-destination' : '/api/admin/create-destination';
    try {
        const res = await axios.post(url, data);
        if (res.data.success) { alert(res.data.message); location.reload(); }
        else alert(res.data.message);
    } catch (e) { alert('Lỗi: ' + (e.response?.data?.message || e.message)); }
}

async function toggleDest(id, checked) {
    try {
        await axios.post('/api/admin/toggle-destination', { id, is_active: checked });
    } catch (e) { alert('Lỗi'); location.reload(); }
}

async function deleteDest(id, name) {
    if (!confirm(`Xóa địa điểm "${name}"? Hành động này không thể hoàn tác!`)) return;
    try {
        const res = await axios.post('/api/admin/delete-destination', { id });
        if (res.data.success) location.reload();
        else alert(res.data.message);
    } catch (e) { alert('Lỗi'); }
}

let resolveTimeout = null;

async function autoExtractCoords(url) {
    const feedback = document.getElementById('d_maps_feedback');
    if (!feedback) return;
    feedback.className = "form-text small mt-1 d-none"; // hide first
    
    if (!url) return;
    
    url = url.trim();
    
    // Check if it's a maps link
    if (!url.includes('google.com/maps') && !url.includes('maps.google') && !url.includes('maps.app.goo.gl') && !url.includes('goo.gl/maps') && !url.includes('g.co/maps')) {
        return;
    }
    
    // First, try to extract directly in case it's a full URL
    let coords = extractCoordsFromUrl(url);
    if (coords) {
        document.getElementById('d_lat').value = coords.lat;
        document.getElementById('d_lng').value = coords.lng;
        feedback.className = "form-text small mt-1 text-success";
        feedback.innerHTML = '<i class="bi bi-check-circle-fill me-1"></i>Đã tự động trích xuất tọa độ thành công!';
        return;
    }
    
    // If it's a shortened link, resolve it via server
    if (url.includes('maps.app.goo.gl') || url.includes('goo.gl/maps') || url.includes('g.co/maps') || url.includes('maps.google')) {
        feedback.className = "form-text small mt-1 text-info";
        feedback.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>Đang giải mã liên kết Google Maps...';
        
        // Debounce if needed, or clear existing
        if (resolveTimeout) clearTimeout(resolveTimeout);
        
        resolveTimeout = setTimeout(async () => {
            try {
                const res = await axios.post('/api/admin/resolve-maps-link', { url });
                if (res.data.success && res.data.finalUrl) {
                    const resolvedCoords = extractCoordsFromUrl(res.data.finalUrl);
                    if (resolvedCoords) {
                        document.getElementById('d_lat').value = resolvedCoords.lat;
                        document.getElementById('d_lng').value = resolvedCoords.lng;
                        feedback.className = "form-text small mt-1 text-success";
                        feedback.innerHTML = '<i class="bi bi-check-circle-fill me-1"></i>Đã tự động giải mã và trích xuất tọa độ thành công!';
                    } else {
                        feedback.className = "form-text small mt-1 text-warning";
                        feedback.innerHTML = '<i class="bi bi-exclamation-triangle-fill me-1"></i>Đã giải mã liên kết nhưng không tìm thấy tọa độ. Hãy điền thủ công.';
                    }
                } else {
                    feedback.className = "form-text small mt-1 text-danger";
                    feedback.innerHTML = '<i class="bi bi-exclamation-circle-fill me-1"></i>Lỗi khi giải mã liên kết.';
                }
            } catch (err) {
                feedback.className = "form-text small mt-1 text-danger";
                feedback.innerHTML = '<i class="bi bi-exclamation-circle-fill me-1"></i>Lỗi hệ thống khi giải mã liên kết.';
            }
        }, 500);
    }
}

function extractCoordsFromUrl(url) {
    if (!url) return null;
    
    // 1. Try to find query params like q=lat,lng or query=lat,lng
    const qMatch = url.match(/[?&](q|query)=(-?\d+\.\d+),(-?\d+\.\d+)/);
    if (qMatch) {
        return { lat: qMatch[2], lng: qMatch[3] };
    }
    
    // 2. Try to find the pattern !3d<lat>!4d<lng>
    const markerMatch = url.match(/!3d(-?\d+\.\d+)!4d(-?\d+\.\d+)/);
    if (markerMatch) {
        return { lat: markerMatch[1], lng: markerMatch[2] };
    }
    
    // 3. Try to find @lat,lng
    const atMatch = url.match(/@(-?\d+\.\d+),(-?\d+\.\d+)/);
    if (atMatch) {
        return { lat: atMatch[1], lng: atMatch[2] };
    }

    // 4. Try to find /search/lat,+lng or /search/lat,lng
    const searchMatch = url.match(/\/search\/(-?\d+\.\d+),\+?(-?\d+\.\d+)/);
    if (searchMatch) {
        return { lat: searchMatch[1], lng: searchMatch[2] };
    }
    
    return null;
}
</script>
