<!-- Admin: Users Management -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1" style="font-family: 'Outfit', sans-serif;">Quản lý Người dùng</h4>
        <p class="mb-0" style="color: var(--admin-muted); font-size: 0.85rem;">Tạo, chỉnh sửa và quản lý tài khoản du khách.</p>
    </div>
    <button class="btn btn-primary rounded-pill px-4 fw-bold" data-bs-toggle="modal" data-bs-target="#userModal" onclick="openUserForm()">
        <i class="bi bi-plus-lg me-1"></i> Thêm Người dùng
    </button>
</div>

<!-- Search -->
<div class="mb-4">
    <form method="GET" action="/admin/users" class="d-flex gap-2">
        <input type="text" name="q" class="form-control admin-input" value="<%= searchQuery %>" placeholder="Tìm theo tên, email, SĐT..." style="max-width: 400px;">
        <button type="submit" class="btn btn-outline-primary rounded-pill px-4"><i class="bi bi-search me-1"></i> Tìm</button>
        <% if (searchQuery) { %>
        <a href="/admin/users" class="btn btn-outline-secondary rounded-pill px-3">Xóa lọc</a>
        <% } %>
    </form>
</div>

<!-- Users Table -->
<div class="admin-table">
    <table class="table table-borderless mb-0">
        <thead>
            <tr>
                <th>Người dùng</th>
                <th>SĐT</th>
                <th>Vai trò</th>
                <th>Điểm</th>
                <th>Ngày tạo</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            <% users.forEach(u => { %>
            <tr>
                <td>
                    <div class="d-flex align-items-center gap-2">
                        <img src="<%= u.avatar || '/images/default-avatar.png' %>" class="rounded-circle" style="width: 36px; height: 36px; object-fit: cover;">
                        <div>
                            <div class="fw-bold small"><%= u.full_name %></div>
                            <div style="font-size: 0.72rem; color: var(--admin-muted);"><%= u.email %></div>
                        </div>
                    </div>
                </td>
                <td class="small"><%= u.phone || '-' %></td>
                <td><span class="role-badge role-<%= u.role %>"><%= u.role %></span></td>
                <td><%= u.total_points || 0 %></td>
                <td class="small" style="color: var(--admin-muted);"><%= new Date(u.created_at).toLocaleDateString('vi-VN') %></td>
                <td>
                    <% if (u.is_active !== 0) { %>
                        <span class="badge bg-success bg-opacity-15 text-success rounded-pill px-3 py-1fw-bold">Đã Duyệt</span>
                    <% } else { %>
                        <div class="d-flex flex-column gap-1 align-items-start">
                            <span class="badge bg-warning bg-opacity-15 text-warning rounded-pill px-3 py-1 fw-bold">Chờ Duyệt</span>
                            <button class="btn btn-xs btn-success rounded-pill px-2 py-0 fw-black text-uppercase tracking-wider" style="font-size: 0.65rem;" onclick="approveUserDirectly('<%= u.id %>')">Duyệt ngay</button>
                        </div>
                    <% } %>
                </td>
                <td>
                    <button class="btn btn-sm btn-outline-primary rounded-pill px-3 me-1" onclick='editUser(<%- JSON.stringify({id: u.id, full_name: u.full_name, email: u.email, phone: u.phone, role: u.role, is_active: u.is_active, managed_destination_id: u.managed_destination_id}) %>)'>
                        <i class="bi bi-pencil"></i>
                    </button>
                    <button class="btn btn-sm btn-outline-danger rounded-pill px-3" onclick="deleteUser('<%= u.id %>', '<%= u.full_name %>')">
                        <i class="bi bi-trash"></i>
                    </button>
                </td>
            </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<!-- Pagination -->
<% if (totalPages > 1) { %>
<div class="d-flex justify-content-center mt-4 gap-2">
    <% for (let p = 1; p <= totalPages; p++) { %>
        <a href="/admin/users?page=<%= p %><%= searchQuery ? '&q=' + searchQuery : '' %>" 
           class="btn btn-sm <%= p === currentPage ? 'btn-primary' : 'btn-outline-secondary' %> rounded-pill px-3"><%= p %></a>
    <% } %>
</div>
<% } %>

<!-- User Modal -->
<div class="modal fade" id="userModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4" style="background: var(--admin-surface);">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="userModalTitle">Thêm Người dùng</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="userForm">
                    <input type="hidden" id="u_id" name="id">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Họ và tên</label>
                        <input type="text" class="form-control admin-input" id="u_full_name" name="full_name" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Số điện thoại</label>
                        <input type="tel" class="form-control admin-input" id="u_phone" name="phone">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Email</label>
                        <input type="email" class="form-control admin-input" id="u_email" name="email">
                    </div>
                    <div class="mb-3" id="passwordGroup">
                        <label class="form-label small fw-bold">Mật khẩu</label>
                        <input type="password" class="form-control admin-input" id="u_password" name="password" minlength="6">
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Vai trò</label>
                            <select class="form-select admin-input" id="u_role" name="role">
                                <option value="user">User</option>
                                <option value="manager">Manager (Quản lý)</option>
                                <option value="admin">Admin</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Trạng thái</label>
                            <select class="form-select admin-input" id="u_is_active" name="is_active">
                                <option value="1">Active</option>
                                <option value="0">Inactive</option>
                            </select>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0">
                <button class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Hủy</button>
                <button class="btn btn-primary rounded-pill px-4 fw-bold" onclick="saveUser()">Lưu</button>
            </div>
        </div>
    </div>
</div>

<script>
let editingUser = false;

function openUserForm() {
    editingUser = false;
    document.getElementById('userModalTitle').textContent = 'Thêm Người dùng';
    document.getElementById('userForm').reset();
    document.getElementById('u_id').value = '';
    document.getElementById('passwordGroup').style.display = 'block';
}

function editUser(user) {
    editingUser = true;
    document.getElementById('userModalTitle').textContent = 'Sửa Người dùng';
    document.getElementById('u_id').value = user.id;
    document.getElementById('u_full_name').value = user.full_name;
    document.getElementById('u_email').value = user.email;
    document.getElementById('u_phone').value = user.phone || '';
    document.getElementById('u_role').value = user.role;
    document.getElementById('u_is_active').value = user.is_active !== 0 ? '1' : '0';
    document.getElementById('passwordGroup').style.display = 'none';
    new bootstrap.Modal(document.getElementById('userModal')).show();
}

async function saveUser() {
    const data = {
        id: document.getElementById('u_id').value,
        full_name: document.getElementById('u_full_name').value,
        email: document.getElementById('u_email').value,
        phone: document.getElementById('u_phone').value,
        role: document.getElementById('u_role').value,
        is_active: parseInt(document.getElementById('u_is_active').value),
        password: document.getElementById('u_password')?.value
    };
    
    const url = editingUser ? '/api/admin/update-user' : '/api/admin/create-user';
    try {
        const res = await axios.post(url, data);
        if (res.data.success) { alert(res.data.message); location.reload(); }
        else alert(res.data.message);
    } catch (e) { alert('Lỗi: ' + (e.response?.data?.message || e.message)); }
}

async function deleteUser(id, name) {
    if (!confirm(`Xóa người dùng "${name}"?`)) return;
    try {
        const res = await axios.post('/api/admin/delete-user', { id });
        if (res.data.success) location.reload();
        else alert(res.data.message);
    } catch (e) { alert('Lỗi'); }
}

async function approveUserDirectly(id) {
    try {
        const res = await axios.post('/api/admin/update-user', { id: id, is_active: 1 });
        if (res.data.success) {
            location.reload();
        } else {
            alert(res.data.message);
        }
    } catch (e) {
        alert('Lỗi phê duyệt tài khoản');
    }
}
</script>
