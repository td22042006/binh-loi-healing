<!-- Admin Users Management -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1" style="font-family: 'Outfit', sans-serif;">Quản lý Người dùng</h4>
        <p class="mb-0" style="color: var(--admin-muted); font-size: 0.85rem;">Phân quyền và quản lý tài khoản hệ thống</p>
    </div>
    <form action="/admin/users" method="GET" class="d-flex gap-2">
        <input type="text" name="q" class="form-control admin-input" placeholder="Tìm kiếm..." value="<%= searchQuery %>" style="width: 220px;">
        <button type="submit" class="btn btn-sm rounded-pill px-3" style="background: var(--admin-primary); color: white;"><i class="bi bi-search"></i></button>
    </form>
</div>

<div class="admin-table">
    <table class="table table-dark table-borderless mb-0">
        <thead><tr>
            <th>Người dùng</th>
            <th>Email</th>
            <th>Vai trò</th>
            <th>Địa điểm quản lý</th>
            <th>Điểm</th>
            <th>Ngày tạo</th>
            <th>Thao tác</th>
        </tr></thead>
        <tbody>
            <% users.forEach(u => { %>
            <tr id="user-<%= u.id %>">
                <td>
                    <div class="d-flex align-items-center gap-2">
                        <img src="<%= u.avatar || '/images/default-avatar.png' %>" class="rounded-circle" style="width: 36px; height: 36px; object-fit: cover;">
                        <span class="fw-bold" style="font-size: 0.88rem;"><%= u.full_name %></span>
                    </div>
                </td>
                <td style="font-size: 0.85rem; color: var(--admin-muted);"><%= u.email %></td>
                <td>
                    <select class="form-select form-select-sm admin-input" style="width: 120px; font-size: 0.8rem;" id="role-<%= u.id %>" onchange="updateUser('<%= u.id %>')">
                        <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>Du khách</option>
                        <option value="manager" <%= u.role === 'manager' ? 'selected' : '' %>>Quản lý</option>
                        <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>Admin</option>
                    </select>
                </td>
                <td>
                    <select class="form-select form-select-sm admin-input" style="width: 160px; font-size: 0.8rem;" id="dest-<%= u.id %>" onchange="updateUser('<%= u.id %>')">
                        <option value="">— Không —</option>
                        <% destinations.forEach(d => { %>
                        <option value="<%= d.id %>" <%= u.managed_destination_id === d.id ? 'selected' : '' %>><%= d.name %></option>
                        <% }) %>
                    </select>
                </td>
                <td class="fw-bold"><%= u.total_points || 0 %></td>
                <td style="font-size: 0.82rem; color: var(--admin-muted);"><%= new Date(u.created_at).toLocaleDateString('vi-VN') %></td>
                <td>
                    <button class="btn btn-sm rounded-pill" style="background: rgba(239,68,68,0.15); color: #ef4444; font-size: 0.78rem;" onclick="deleteUser('<%= u.id %>', '<%= u.full_name %>')">
                        <i class="bi bi-trash3"></i>
                    </button>
                </td>
            </tr>
            <% }) %>
        </tbody>
    </table>
</div>

<!-- Pagination -->
<% if (totalPages > 1) { %>
<div class="d-flex justify-content-center mt-4 gap-2">
    <% for (let p = 1; p <= totalPages; p++) { %>
    <a href="/admin/users?page=<%= p %>&q=<%= searchQuery %>" class="btn btn-sm rounded-pill px-3 <%= p === currentPage ? '' : '' %>" style="<%= p === currentPage ? 'background: var(--admin-primary); color: white;' : 'background: var(--admin-surface); color: var(--admin-muted); border: 1px solid var(--admin-border);' %>"><%= p %></a>
    <% } %>
</div>
<% } %>

<script>
async function updateUser(id) {
    const role = document.getElementById('role-' + id).value;
    const dest = document.getElementById('dest-' + id).value;
    try {
        const res = await axios.post('/api/admin/update-user', {
            id, role, managed_destination_id: dest || null
        });
        if (res.data.success) {
            const row = document.getElementById('user-' + id);
            row.style.background = 'rgba(16,185,129,0.08)';
            setTimeout(() => row.style.background = '', 1500);
        }
    } catch (err) {
        alert('Lỗi: ' + err.message);
    }
}

async function deleteUser(id, name) {
    if (!confirm('Bạn chắc chắn muốn xóa "' + name + '"?')) return;
    try {
        const res = await axios.post('/api/admin/delete-user', { id });
        if (res.data.success) {
            document.getElementById('user-' + id).remove();
        } else {
            alert(res.data.message);
        }
    } catch (err) {
        alert('Lỗi: ' + err.message);
    }
}
</script>
