<!-- Admin Dashboard — Real Analytics -->
<div class="mb-4">
    <h4 class="fw-bold mb-1" style="font-family: 'Times New Roman', Times, serif;">Dashboard</h4>
    <p class="mb-0" style="color: var(--admin-muted); font-size: 0.85rem;">Tổng quan hệ thống du lịch Bình Lợi — Dữ liệu thời gian thực.</p>
</div>

<!-- Stats Row -->
<div class="row g-3 mb-4">
    <div class="col-md-3 col-6">
        <div class="stat-card">
            <div class="d-flex align-items-center gap-3">
                <div class="stat-icon" style="background: rgba(59,130,246,0.15); color: #3b82f6;"><i class="bi bi-eye-fill"></i></div>
                <div>
                    <h3><%= stats.pageViews.toLocaleString() %></h3>
                    <small>Lượt xem trang</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="stat-card">
            <div class="d-flex align-items-center gap-3">
                <div class="stat-icon" style="background: rgba(16,185,129,0.15); color: #10b981;"><i class="bi bi-people-fill"></i></div>
                <div>
                    <h3><%= stats.uniqueVisitors.toLocaleString() %></h3>
                    <small>Khách truy cập</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="stat-card">
            <div class="d-flex align-items-center gap-3">
                <div class="stat-icon" style="background: rgba(240,165,0,0.15); color: #f0a500;"><i class="bi bi-geo-alt-fill"></i></div>
                <div>
                    <h3><%= stats.checkins.toLocaleString() %></h3>
                    <small>Lượt Check-in</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="stat-card">
            <div class="d-flex align-items-center gap-3">
                <div class="stat-icon" style="background: rgba(239,68,68,0.15); color: #ef4444;"><i class="bi bi-person-fill"></i></div>
                <div>
                    <h3><%= stats.users.toLocaleString() %></h3>
                    <small>Người dùng</small>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Secondary Stats -->
<div class="row g-3 mb-4">
    <div class="col-md-3 col-6">
        <div class="stat-card">
            <div class="d-flex align-items-center gap-3">
                <div class="stat-icon" style="background: rgba(139,92,246,0.15); color: #8b5cf6;"><i class="bi bi-chat-heart-fill"></i></div>
                <div>
                    <h3><%= stats.reviews %></h3>
                    <small>Bài đánh giá</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="stat-card">
            <div class="d-flex align-items-center gap-3">
                <div class="stat-icon" style="background: rgba(236,72,153,0.15); color: #ec4899;"><i class="bi bi-map-fill"></i></div>
                <div>
                    <h3><%= stats.destinations %></h3>
                    <small>Địa điểm</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="stat-card">
            <div class="d-flex align-items-center gap-3">
                <div class="stat-icon" style="background: rgba(34,211,238,0.15); color: #22d3ee;"><i class="bi bi-palette-fill"></i></div>
                <div>
                    <h3><%= stats.workshops %></h3>
                    <small>Workshop</small>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="stat-card">
            <div class="d-flex align-items-center gap-3">
                <div class="stat-icon" style="background: rgba(251,191,36,0.15); color: #fbbf24;"><i class="bi bi-clock-fill"></i></div>
                <div>
                    <h3><%= stats.avgDuration %>s</h3>
                    <small>TG phản hồi TB</small>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row g-4 mb-4">
    <div class="col-lg-8">
        <div class="chart-card">
            <h6 class="fw-bold mb-3" style="font-family: 'Times New Roman', Times, serif;">Lượt truy cập (14 ngày gần nhất)</h6>
            <canvas id="viewsChart" height="240"></canvas>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="chart-card">
            <h6 class="fw-bold mb-3" style="font-family: 'Times New Roman', Times, serif;">Top Điểm đến</h6>
            <% topDests.forEach((d, i) => { %>
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="d-flex align-items-center gap-2">
                    <span class="badge rounded-pill" style="background: rgba(59,130,246,0.15); color: #3b82f6; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; font-size: 0.7rem;"><%= i + 1 %></span>
                    <span class="small fw-bold"><%= d.name %></span>
                </div>
                <span class="small" style="color: var(--admin-muted);"><%= d.checkin_count %> check-ins</span>
            </div>
            <% }) %>
            <% if (topDests.length === 0) { %>
            <p class="text-center small" style="color: var(--admin-muted);">Chưa có dữ liệu check-in</p>
            <% } %>
        </div>
    </div>
</div>

<!-- Recent Users & Check-in Trends -->
<div class="row g-4">
    <div class="col-lg-6">
        <div class="chart-card">
            <h6 class="fw-bold mb-3" style="font-family: 'Times New Roman', Times, serif;">Check-in theo tháng</h6>
            <canvas id="checkinChart" height="200"></canvas>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="admin-table">
            <div class="p-3 d-flex justify-content-between align-items-center" style="border-bottom: 1px solid var(--admin-border);">
                <h6 class="fw-bold mb-0" style="font-family: 'Times New Roman', Times, serif;">Người dùng mới nhất</h6>
                <a href="/admin/users" class="small" style="color: var(--admin-primary); text-decoration: none;">Xem tất cả →</a>
            </div>
            <table class="table table-borderless mb-0">
                <tbody>
                    <% recentUsers.forEach(u => { %>
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <img src="<%= u.avatar || '/images/default-avatar.png' %>" class="rounded-circle" style="width: 32px; height: 32px; object-fit: cover;">
                                <div>
                                    <div class="small fw-bold"><%= u.full_name %></div>
                                    <div style="font-size: 0.72rem; color: var(--admin-muted);"><%= u.phone || u.email %></div>
                                </div>
                            </div>
                        </td>
                        <td><span class="role-badge role-<%= u.role %>"><%= u.role %></span></td>
                        <td class="small" style="color: var(--admin-muted);"><%= new Date(u.created_at).toLocaleDateString('vi-VN') %></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    // Daily Views Chart
    const dailyData = <%- JSON.stringify(chartData.dailyViews) %>;
    new Chart(document.getElementById('viewsChart'), {
        type: 'line',
        data: {
            labels: dailyData.map(d => { const date = new Date(d.day); return date.getDate() + '/' + (date.getMonth()+1); }),
            datasets: [{
                label: 'Lượt xem',
                data: dailyData.map(d => d.count),
                borderColor: '#3b82f6',
                backgroundColor: 'rgba(59,130,246,0.1)',
                fill: true,
                tension: 0.4,
                borderWidth: 2,
                pointRadius: 3,
                pointBackgroundColor: '#3b82f6'
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#71717a', font: { size: 11 } } },
                y: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#71717a', font: { size: 11 } }, beginAtZero: true }
            }
        }
    });

    // Monthly Check-in Chart
    const monthlyData = <%- JSON.stringify(chartData.monthlyCheckins) %>;
    new Chart(document.getElementById('checkinChart'), {
        type: 'bar',
        data: {
            labels: monthlyData.map(d => d.month),
            datasets: [{
                label: 'Check-ins',
                data: monthlyData.map(d => d.count),
                backgroundColor: 'rgba(240,165,0,0.4)',
                borderColor: '#f0a500',
                borderWidth: 1,
                borderRadius: 8
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { display: false }, ticks: { color: '#71717a', font: { size: 11 } } },
                y: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#71717a', font: { size: 11 } }, beginAtZero: true }
            }
        }
    });
});
</script>
