<!-- Admin Dashboard — Biểu đồ & Thống kê -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1" style="font-family: 'Outfit', sans-serif;">Dashboard</h4>
        <p class="mb-0" style="color: var(--admin-muted); font-size: 0.85rem;">Tổng quan hệ thống Bình Lợi Healing</p>
    </div>
    <span class="badge rounded-pill" style="background: rgba(240,165,0,0.15); color: var(--admin-accent); padding: 8px 16px;">
        <i class="bi bi-shield-check me-1"></i>Quản trị viên Xã
    </span>
</div>

<!-- Stats Grid -->
<div class="row g-3 mb-4">
    <div class="col-6 col-xl-2">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <div class="stat-icon" style="background: rgba(59,130,246,0.15); color: #3b82f6;"><i class="bi bi-people-fill"></i></div>
            </div>
            <h3><%= stats.users %></h3>
            <small>Người dùng</small>
        </div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <div class="stat-icon" style="background: rgba(16,185,129,0.15); color: #10b981;"><i class="bi bi-geo-alt-fill"></i></div>
            </div>
            <h3><%= stats.destinations %></h3>
            <small>Địa điểm</small>
        </div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <div class="stat-icon" style="background: rgba(240,165,0,0.15); color: #f0a500;"><i class="bi bi-qr-code"></i></div>
            </div>
            <h3><%= stats.checkins %></h3>
            <small>Check-ins</small>
        </div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <div class="stat-icon" style="background: rgba(168,85,247,0.15); color: #a855f7;"><i class="bi bi-chat-heart-fill"></i></div>
            </div>
            <h3><%= stats.reviews %></h3>
            <small>Đánh giá</small>
        </div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <div class="stat-icon" style="background: rgba(236,72,153,0.15); color: #ec4899;"><i class="bi bi-palette-fill"></i></div>
            </div>
            <h3><%= stats.workshops %></h3>
            <small>Workshop</small>
        </div>
    </div>
    <div class="col-6 col-xl-2">
        <div class="stat-card">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <div class="stat-icon" style="background: rgba(34,211,238,0.15); color: #22d3ee;"><i class="bi bi-envelope-fill"></i></div>
            </div>
            <h3><%= stats.messages %></h3>
            <small>Tin nhắn</small>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="chart-card">
            <h6 class="fw-bold mb-3"><i class="bi bi-graph-up me-2" style="color: var(--admin-primary);"></i>Lượt truy cập Website (14 ngày)</h6>
            <canvas id="viewsChart" height="100"></canvas>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="chart-card">
            <h6 class="fw-bold mb-3"><i class="bi bi-bar-chart-fill me-2" style="color: #10b981;"></i>Check-in theo tháng</h6>
            <canvas id="checkinChart" height="200"></canvas>
        </div>
    </div>
</div>

<!-- Top Destinations + Recent Users -->
<div class="row g-3">
    <div class="col-lg-5">
        <div class="chart-card">
            <h6 class="fw-bold mb-3"><i class="bi bi-trophy-fill me-2" style="color: var(--admin-accent);"></i>Top Địa điểm</h6>
            <% topDests.forEach((d, i) => { %>
            <div class="d-flex justify-content-between align-items-center py-2 <%= i < topDests.length - 1 ? 'border-bottom' : '' %>" style="border-color: var(--admin-border) !important;">
                <div class="d-flex align-items-center gap-2">
                    <span class="fw-bold" style="color: var(--admin-muted); width: 20px;">#<%= i+1 %></span>
                    <span style="font-size: 0.88rem;"><%= d.name %></span>
                </div>
                <span class="badge rounded-pill" style="background: rgba(16,185,129,0.15); color: #10b981;"><%= d.checkin_count %> check-in</span>
            </div>
            <% }) %>
            <% if (topDests.length === 0) { %>
            <p class="text-center mb-0" style="color: var(--admin-muted); font-size: 0.85rem;">Chưa có dữ liệu</p>
            <% } %>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="admin-table">
            <div class="p-3 d-flex justify-content-between align-items-center">
                <h6 class="fw-bold mb-0"><i class="bi bi-people me-2" style="color: var(--admin-primary);"></i>Người dùng gần đây</h6>
                <a href="/admin/users" style="color: var(--admin-primary); font-size: 0.82rem; text-decoration: none;">Xem tất cả →</a>
            </div>
            <table class="table table-dark table-borderless mb-0">
                <thead><tr>
                    <th>Người dùng</th><th>Vai trò</th><th>Điểm</th><th>Ngày</th>
                </tr></thead>
                <tbody>
                    <% recentUsers.forEach(u => { %>
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <img src="<%= u.avatar || '/images/default-avatar.png' %>" class="rounded-circle" style="width: 32px; height: 32px; object-fit: cover;">
                                <div>
                                    <div class="fw-bold" style="font-size: 0.85rem;"><%= u.full_name %></div>
                                    <div style="font-size: 0.72rem; color: var(--admin-muted);"><%= u.email %></div>
                                </div>
                            </div>
                        </td>
                        <td><span class="role-badge role-<%= u.role %>"><%= u.role %></span></td>
                        <td class="fw-bold"><%= u.points || 0 %></td>
                        <td style="font-size: 0.82rem; color: var(--admin-muted);"><%= new Date(u.created_at).toLocaleDateString('vi-VN') %></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Page Views Chart
    const viewsData = <%- JSON.stringify(chartData.dailyViews) %>;
    const viewsLabels = viewsData.map(d => {
        const date = new Date(d.day);
        return date.getDate() + '/' + (date.getMonth()+1);
    });
    
    new Chart(document.getElementById('viewsChart'), {
        type: 'line',
        data: {
            labels: viewsLabels.length ? viewsLabels : ['Chưa có dữ liệu'],
            datasets: [{
                label: 'Lượt xem',
                data: viewsData.map(d => d.count),
                borderColor: '#3b82f6',
                backgroundColor: 'rgba(59,130,246,0.1)',
                fill: true,
                tension: 0.4,
                pointRadius: 4,
                pointBackgroundColor: '#3b82f6'
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#71717a', font: { size: 11 } } },
                y: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#71717a', font: { size: 11 } }, beginAtZero: true }
            }
        }
    });

    // Check-in Chart
    const checkinData = <%- JSON.stringify(chartData.monthlyCheckins) %>;
    new Chart(document.getElementById('checkinChart'), {
        type: 'bar',
        data: {
            labels: checkinData.map(d => d.month),
            datasets: [{
                label: 'Check-ins',
                data: checkinData.map(d => d.count),
                backgroundColor: '#10b981',
                borderRadius: 8,
                barThickness: 24
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { display: false }, ticks: { color: '#71717a', font: { size: 11 } } },
                y: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#71717a', font: { size: 11 } }, beginAtZero: true }
            }
        }
    });
});
</script>
