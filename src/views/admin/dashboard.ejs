<!-- Admin Dashboard — Professional Show-All -->
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="widget-card text-center py-4" style="background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%); color: white; border: none;">
            <i class="bi bi-people fs-2 opacity-50 mb-2"></i>
            <h3 class="fw-black mb-0"><%= stats.total_users || 0 %></h3>
            <span class="x-small fw-bold opacity-75 text-uppercase tracking-widest">Người dùng</span>
        </div>
    </div>
    <div class="col-md-3">
        <div class="widget-card text-center py-4" style="background: linear-gradient(135deg, #065f46 0%, #10b981 100%); color: white; border: none;">
            <i class="bi bi-geo-alt fs-2 opacity-50 mb-2"></i>
            <h3 class="fw-black mb-0"><%= stats.total_destinations || 0 %></h3>
            <span class="x-small fw-bold opacity-75 text-uppercase tracking-widest">Địa điểm</span>
        </div>
    </div>
    <div class="col-md-3">
        <div class="widget-card text-center py-4" style="background: linear-gradient(135deg, #92400e 0%, #f59e0b 100%); color: white; border: none;">
            <i class="bi bi-palette fs-2 opacity-50 mb-2"></i>
            <h3 class="fw-black mb-0"><%= stats.total_workshops || 0 %></h3>
            <span class="x-small fw-bold opacity-75 text-uppercase tracking-widest">Workshop</span>
        </div>
    </div>
    <div class="col-md-3">
        <div class="widget-card text-center py-4" style="background: linear-gradient(135deg, #991b1b 0%, #ef4444 100%); color: white; border: none;">
            <i class="bi bi-qr-code fs-2 opacity-50 mb-2"></i>
            <h3 class="fw-black mb-0"><%= stats.total_checkins || 0 %></h3>
            <span class="x-small fw-bold opacity-75 text-uppercase tracking-widest">Check-ins</span>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Recent Users Table -->
    <div class="col-lg-8">
        <div class="widget-card">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h6 class="fw-bold mb-0">Người dùng mới đăng ký</h6>
                <button class="btn btn-sm btn-ghost">Xem tất cả</button>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="bg-light">
                        <tr class="x-small fw-bold text-muted text-uppercase tracking-tighter">
                            <th>Người dùng</th>
                            <th>Email</th>
                            <th>Ngày tham gia</th>
                            <th>Vai trò</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody style="font-size: 0.85rem;">
                        <% (recentUsers || []).forEach(u => { %>
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <img src="<%= u.avatar || '/images/default-avatar.png' %>" class="rounded-circle" style="width: 32px; height: 32px; object-fit: cover;">
                                    <span class="fw-bold"><%= u.full_name %></span>
                                </div>
                            </td>
                            <td><%= u.email %></td>
                            <td><%= new Date(u.created_at).toLocaleDateString('vi-VN') %></td>
                            <td><span class="badge rounded-pill bg-<%= u.role === 'admin' ? 'danger' : 'primary' %>" style="font-size: 0.65rem;"><%= u.role %></span></td>
                            <td>
                                <button class="btn btn-sm btn-ghost p-1"><i class="bi bi-pencil-square text-primary"></i></button>
                                <button class="btn btn-sm btn-ghost p-1"><i class="bi bi-trash text-danger"></i></button>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Quick Actions & Alerts -->
    <div class="col-lg-4">
        <div class="widget-card">
            <h6 class="fw-bold mb-4">Tác vụ nhanh</h6>
            <div class="d-grid gap-2">
                <a href="/admin/destinations/create" class="btn btn-outline-primary text-start p-3 rounded-4 d-flex align-items-center justify-content-between">
                    <div>
                        <span class="d-block fw-bold small">Thêm địa điểm mới</span>
                        <span class="text-muted x-small">Tạo nội dung storytelling</span>
                    </div>
                    <i class="bi bi-plus-circle-fill"></i>
                </a>
                <a href="/admin/workshops/create" class="btn btn-outline-warning text-start p-3 rounded-4 d-flex align-items-center justify-content-between">
                    <div>
                        <span class="d-block fw-bold small">Tạo Workshop</span>
                        <span class="text-muted x-small">Quản lý phiên học mới</span>
                    </div>
                    <i class="bi bi-calendar-plus"></i>
                </a>
                <a href="/admin/market/create" class="btn btn-outline-success text-start p-3 rounded-4 d-flex align-items-center justify-content-between">
                    <div>
                        <span class="d-block fw-bold small">Đăng sản phẩm OCOP</span>
                        <span class="text-muted x-small">Quản lý kho hàng</span>
                    </div>
                    <i class="bi bi-box-seam"></i>
                </a>
            </div>
        </div>
    </div>
</div>
