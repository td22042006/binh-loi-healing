<!-- Admin Dashboard — Chương 7 -->
<section class="py-5" style="margin-top: 80px; background: var(--bg); min-height: 100vh;">
    <div class="container-fluid px-4 py-3">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h2 class="fw-black font-display mb-1">Admin Dashboard</h2>
                <p class="text-muted mb-0" style="font-size: 0.88rem;">Tổng quan hệ thống Bình Lợi Healing</p>
            </div>
            <div class="d-flex gap-2">
                <a href="/admin/workshops" class="btn btn-ghost btn-sm rounded-pill px-3"><i class="bi bi-palette me-1"></i>Workshop</a>
                <a href="/admin/reviews" class="btn btn-ghost btn-sm rounded-pill px-3"><i class="bi bi-chat me-1"></i>Đánh giá</a>
                <a href="/admin/users" class="btn btn-primary-bl btn-sm rounded-pill px-3"><i class="bi bi-people me-1"></i>Users</a>
            </div>
        </div>

        <!-- Stats Grid -->
        <div class="row g-4 mb-5">
            <div class="col-md-6 col-xl-3">
                <div class="p-4 rounded-2xl" style="background: var(--grad-nature); color: white;">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="mb-1 opacity-75" style="font-size: 0.82rem;">Tổng người dùng</p>
                            <h2 class="fw-black mb-0 font-display"><%= analytics.totalUsers || 0 %></h2>
                        </div>
                        <div class="rounded-xl p-2" style="background: rgba(255,255,255,0.15);"><i class="bi bi-people-fill fs-4"></i></div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="p-4 rounded-2xl" style="background: var(--surface); border: 1px solid var(--border-light);">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="mb-1 text-muted" style="font-size: 0.82rem;">Tổng check-in</p>
                            <h2 class="fw-black mb-0 font-display" style="color: var(--primary);"><%= analytics.totalCheckins || 0 %></h2>
                        </div>
                        <div class="rounded-xl p-2" style="background: var(--primary-50); color: var(--primary);"><i class="bi bi-geo-alt-fill fs-4"></i></div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="p-4 rounded-2xl" style="background: var(--surface); border: 1px solid var(--border-light);">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="mb-1 text-muted" style="font-size: 0.82rem;">Tổng đánh giá</p>
                            <h2 class="fw-black mb-0 font-display" style="color: var(--accent);"><%= analytics.totalReviews || 0 %></h2>
                        </div>
                        <div class="rounded-xl p-2" style="background: rgba(240,165,0,0.1); color: var(--accent);"><i class="bi bi-chat-heart-fill fs-4"></i></div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-3">
                <div class="p-4 rounded-2xl" style="background: var(--surface); border: 1px solid var(--border-light);">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="mb-1 text-muted" style="font-size: 0.82rem;">Đặt workshop</p>
                            <h2 class="fw-black mb-0 font-display" style="color: var(--info);"><%= analytics.totalBookings || 0 %></h2>
                        </div>
                        <div class="rounded-xl p-2" style="background: rgba(59,130,246,0.1); color: var(--info);"><i class="bi bi-ticket-fill fs-4"></i></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Users Table -->
        <div class="rounded-2xl overflow-hidden" style="background: var(--surface); border: 1px solid var(--border-light);">
            <div class="p-4 d-flex justify-content-between align-items-center" style="border-bottom: 1px solid var(--border-light);">
                <h5 class="fw-bold mb-0"><i class="bi bi-people me-2" style="color: var(--primary);"></i>Người dùng gần đây</h5>
                <a href="/admin/users" class="btn btn-sm btn-ghost rounded-pill px-3">Xem tất cả</a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead><tr style="font-size: 0.78rem; color: var(--text-muted); letter-spacing: 0.5px;">
                        <th class="border-0 py-3 px-4">NGƯỜI DÙNG</th>
                        <th class="border-0 py-3">EMAIL</th>
                        <th class="border-0 py-3">VAI TRÒ</th>
                        <th class="border-0 py-3">ĐIỂM</th>
                        <th class="border-0 py-3">NGÀY THAM GIA</th>
                    </tr></thead>
                    <tbody>
                        <% recentUsers.forEach(u => { %>
                        <tr>
                            <td class="px-4 py-3">
                                <div class="d-flex align-items-center gap-2">
                                    <img src="<%= u.avatar || '/images/default-avatar.png' %>" class="rounded-circle" style="width: 36px; height: 36px; object-fit: cover;">
                                    <span class="fw-bold" style="font-size: 0.88rem;"><%= u.full_name %></span>
                                </div>
                            </td>
                            <td style="font-size: 0.85rem; color: var(--text-secondary);"><%= u.email %></td>
                            <td>
                                <span class="px-2 py-1 rounded-pill" style="font-size: 0.72rem; font-weight: 600; background: <%= u.role === 'admin' ? 'var(--primary-50)' : u.role === 'manager' ? 'rgba(240,165,0,0.1)' : 'var(--surface-alt)' %>; color: <%= u.role === 'admin' ? 'var(--primary)' : u.role === 'manager' ? 'var(--accent-dark)' : 'var(--text-secondary)' %>;">
                                    <%= u.role %>
                                </span>
                            </td>
                            <td class="fw-bold" style="font-size: 0.88rem;"><%= u.total_points || 0 %></td>
                            <td style="font-size: 0.82rem; color: var(--text-muted);"><%= new Date(u.created_at).toLocaleDateString('vi-VN') %></td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
