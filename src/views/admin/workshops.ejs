<% /* Admin Workshops - Chương 7 */ %>
<section class="py-4" style="margin-top: 80px; background: #f8f9fa; min-height: 100vh;">
    <div class="container-fluid px-4">
        <a href="/admin" class="text-decoration-none text-muted small"><i class="bi bi-arrow-left me-1"></i>Dashboard</a>
        <h2 class="fw-black mb-4 mt-1">🎨 Quản lý Workshop</h2>
        <div class="card border-0 shadow-sm rounded-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light"><tr><th>Workshop</th><th>Địa điểm</th><th>Giá</th><th>Lượt đặt</th><th>Rating</th><th>Trạng thái</th></tr></thead>
                    <tbody>
                        <% workshops.forEach(w => { %>
                        <tr>
                            <td class="fw-bold"><%= w.title %></td>
                            <td class="text-muted"><%= w.destination_name || '-' %></td>
                            <td><%= w.price === 0 ? 'Miễn phí' : new Intl.NumberFormat('vi-VN').format(w.price) + 'đ' %></td>
                            <td><span class="badge bg-primary rounded-pill"><%= w.booking_count || 0 %></span></td>
                            <td><% if (w.avg_rating) { %><span class="text-warning"><i class="bi bi-star-fill"></i> <%= parseFloat(w.avg_rating).toFixed(1) %></span><% } else { %>-<% } %></td>
                            <td><span class="badge bg-<%= w.is_active ? 'success' : 'secondary' %> rounded-pill"><%= w.is_active ? 'Active' : 'Inactive' %></span></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
