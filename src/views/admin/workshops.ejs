<!-- Admin Workshops Management -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1" style="font-family: 'Outfit', sans-serif;">Quản lý Workshop</h4>
        <p class="mb-0" style="color: var(--admin-muted); font-size: 0.85rem;">Danh sách tất cả workshop trên hệ thống</p>
    </div>
</div>

<div class="admin-table">
    <table class="table table-dark table-borderless mb-0">
        <thead><tr>
            <th>Workshop</th>
            <th>Địa điểm</th>
            <th>Giá</th>
            <th>Lượt đặt</th>
            <th>Trạng thái</th>
        </tr></thead>
        <tbody>
            <% workshops.forEach(w => { %>
            <tr>
                <td class="fw-bold" style="font-size: 0.88rem;"><%= w.title %></td>
                <td style="font-size: 0.85rem; color: var(--admin-muted);"><%= w.destination_name || 'N/A' %></td>
                <td class="fw-bold" style="color: var(--admin-accent);"><%= w.price ? w.price.toLocaleString() + 'đ' : 'Miễn phí' %></td>
                <td><span class="badge rounded-pill" style="background: rgba(59,130,246,0.15); color: #3b82f6;"><%= w.booking_count %> đặt</span></td>
                <td>
                    <span class="badge rounded-pill" style="background: <%= w.is_active ? 'rgba(16,185,129,0.15)' : 'rgba(239,68,68,0.15)' %>; color: <%= w.is_active ? '#10b981' : '#ef4444' %>;">
                        <%= w.is_active ? 'Hoạt động' : 'Tạm ẩn' %>
                    </span>
                </td>
            </tr>
            <% }) %>
            <% if (workshops.length === 0) { %>
            <tr><td colspan="5" class="text-center py-4" style="color: var(--admin-muted);">Chưa có workshop nào</td></tr>
            <% } %>
        </tbody>
    </table>
</div>
