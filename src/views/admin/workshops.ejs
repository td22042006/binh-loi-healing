<!-- Admin: Workshop Management -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1" style="font-family: 'Outfit', sans-serif;">Quản lý Workshop</h4>
        <p class="mb-0" style="color: var(--admin-muted); font-size: 0.85rem;">Thêm, sửa, xóa workshop trải nghiệm.</p>
    </div>
    <button class="btn btn-primary rounded-pill px-4 fw-bold" data-bs-toggle="modal" data-bs-target="#wsModal" onclick="openWsForm()">
        <i class="bi bi-plus-lg me-1"></i> Thêm Workshop
    </button>
</div>

<!-- Workshops Table -->
<div class="admin-table">
    <table class="table table-borderless mb-0">
        <thead>
            <tr>
                <th>Tên Workshop</th>
                <th>Loại</th>
                <th>Giá</th>
                <th>Thời gian</th>
                <th>Sức chứa</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            <% workshops.forEach(ws => { %>
            <tr>
                <td>
                    <div class="d-flex align-items-center gap-2">
                        <img src="<%= ws.image && ws.image.startsWith('http') ? ws.image : '/images/hero-2.png' %>" class="rounded-3" style="width: 44px; height: 44px; object-fit: cover;">
                        <div>
                            <div class="fw-bold small"><%= ws.title %></div>
                            <div style="font-size: 0.72rem; color: var(--admin-muted);"><%= ws.destination_name || '-' %></div>
                        </div>
                    </div>
                </td>
                <td><span class="role-badge role-user"><%= ws.type %></span></td>
                <td>
                    <% if (ws.price == 0) { %>
                        <span class="text-success small fw-bold">Miễn phí</span>
                    <% } else { %>
                        <span class="small"><%= new Intl.NumberFormat('vi-VN').format(ws.price) %>đ</span>
                    <% } %>
                </td>
                <td class="small"><%= ws.duration || '2 giờ' %></td>
                <td class="small"><%= ws.max_participants || 20 %></td>
                <td>
                    <% if (ws.is_active) { %>
                        <span class="badge bg-success bg-opacity-25 text-success rounded-pill px-3">Active</span>
                    <% } else { %>
                        <span class="badge bg-secondary bg-opacity-25 text-secondary rounded-pill px-3">Ẩn</span>
                    <% } %>
                </td>
                <td>
                    <button class="btn btn-sm btn-outline-primary rounded-pill px-3 me-1" onclick='editWs(<%- JSON.stringify({id: ws.id, title: ws.title, description: ws.description, type: ws.type, price: ws.price, duration: ws.duration, max_participants: ws.max_participants, image: ws.image, is_active: ws.is_active, destination_id: ws.destination_id}) %>)'>
                        <i class="bi bi-pencil"></i>
                    </button>
                    <button class="btn btn-sm btn-outline-danger rounded-pill px-3" onclick="deleteWs('<%= ws.id %>')">
                        <i class="bi bi-trash"></i>
                    </button>
                </td>
            </tr>
            <% }) %>
            <% if (workshops.length === 0) { %>
            <tr><td colspan="7" class="text-center py-5 text-muted">Chưa có workshop nào.</td></tr>
            <% } %>
        </tbody>
    </table>
</div>

<!-- Workshop Modal -->
<div class="modal fade" id="wsModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 rounded-4" style="background: var(--admin-surface);">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="wsModalTitle">Thêm Workshop</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="wsForm">
                    <input type="hidden" id="ws_id" name="id">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label small fw-bold">Tên workshop</label>
                            <input type="text" class="form-control admin-input" id="ws_title" name="title" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold">Mô tả</label>
                            <textarea class="form-control admin-input" id="ws_description" name="description" rows="3"></textarea>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold">Loại</label>
                            <select class="form-select admin-input" id="ws_type" name="type">
                                <option value="craft">Làm Nhang</option>
                                <option value="mai">Chăm Mai</option>
                                <option value="meditation">Thiền Healing</option>
                                <option value="food">Bánh Dân Gian</option>
                                <option value="eco">Sinh Thái</option>
                                <option value="culture">Văn Hóa</option>
                                <option value="other">Khác</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold">Giá (VNĐ)</label>
                            <input type="number" class="form-control admin-input" id="ws_price" name="price" value="0">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold">Thời gian</label>
                            <input type="text" class="form-control admin-input" id="ws_duration" name="duration" value="2 giờ">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Sức chứa</label>
                            <input type="number" class="form-control admin-input" id="ws_max" name="max_participants" value="20">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Thuộc địa điểm</label>
                            <select class="form-select admin-input" id="ws_dest" name="destination_id">
                                <option value="">-- Không --</option>
                                <% destinations.forEach(d => { %>
                                    <option value="<%= d.id %>"><%= d.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label small fw-bold">Link ảnh</label>
                            <input type="text" class="form-control admin-input" id="ws_image" name="image" placeholder="https://...">
                        </div>
                        <div class="col-md-6">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" id="ws_is_active" name="is_active" checked>
                                <label class="form-check-label small" for="ws_is_active">Hoạt động</label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0">
                <button class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Hủy</button>
                <button class="btn btn-primary rounded-pill px-4 fw-bold" onclick="saveWs()">Lưu</button>
            </div>
        </div>
    </div>
</div>

<script>
let editingWs = false;

function openWsForm() {
    editingWs = false;
    document.getElementById('wsModalTitle').textContent = 'Thêm Workshop';
    document.getElementById('wsForm').reset();
    document.getElementById('ws_id').value = '';
    document.getElementById('ws_is_active').checked = true;
}

function editWs(ws) {
    editingWs = true;
    document.getElementById('wsModalTitle').textContent = 'Sửa Workshop';
    document.getElementById('ws_id').value = ws.id;
    document.getElementById('ws_title').value = ws.title || '';
    document.getElementById('ws_description').value = ws.description || '';
    document.getElementById('ws_type').value = ws.type || 'craft';
    document.getElementById('ws_price').value = ws.price || 0;
    document.getElementById('ws_duration').value = ws.duration || '2 giờ';
    document.getElementById('ws_max').value = ws.max_participants || 20;
    document.getElementById('ws_image').value = ws.image || '';
    document.getElementById('ws_dest').value = ws.destination_id || '';
    document.getElementById('ws_is_active').checked = ws.is_active;
    new bootstrap.Modal(document.getElementById('wsModal')).show();
}

async function saveWs() {
    const data = {
        id: document.getElementById('ws_id').value,
        title: document.getElementById('ws_title').value,
        description: document.getElementById('ws_description').value,
        type: document.getElementById('ws_type').value,
        price: parseInt(document.getElementById('ws_price').value) || 0,
        duration: document.getElementById('ws_duration').value,
        max_participants: parseInt(document.getElementById('ws_max').value) || 20,
        image: document.getElementById('ws_image').value,
        destination_id: document.getElementById('ws_dest').value,
        is_active: document.getElementById('ws_is_active').checked
    };
    
    const url = editingWs ? '/api/admin/update-workshop' : '/api/admin/create-workshop';
    try {
        const res = await axios.post(url, data);
        if (res.data.success) { alert(res.data.message); location.reload(); }
        else alert(res.data.message);
    } catch (e) { alert('Lỗi: ' + (e.response?.data?.message || e.message)); }
}

async function deleteWs(id) {
    if (!confirm('Xóa workshop này?')) return;
    try {
        const res = await axios.post('/api/admin/delete-workshop', { id });
        if (res.data.success) location.reload();
        else alert(res.data.message);
    } catch (e) { alert('Lỗi'); }
}
</script>
