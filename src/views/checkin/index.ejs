<section class="py-5" style="margin-top: 80px; background: #f8faf9;">
    <div class="container py-4" style="max-width: 700px;">
        <div class="text-center mb-5 reveal-up">
            <span class="badge rounded-pill px-3 py-2 mb-3 text-uppercase fw-bold x-small" style="background: var(--primary-100); color: var(--primary); border: 1px solid var(--primary-200); letter-spacing: 1px;">
                <i class="bi bi-qr-code-scan me-1"></i> Xác thực hành trình
            </span>
            <h2 class="fw-black text-dark mb-2 font-display" style="font-size: 2rem;">Check-in & Xác nhận</h2>
            <p class="text-muted mx-auto" style="max-width: 500px; font-size: 0.92rem;">Quét mã QR tại địa điểm hoặc sử dụng GPS để xác nhận bạn đã đến nơi.</p>
        </div>

        <!-- QR Scanner Card -->
        <div class="card border-0 shadow-premium rounded-4 overflow-hidden mb-4 reveal-up">
            <div class="p-3 text-white d-flex align-items-center gap-2" style="background: linear-gradient(135deg, #922724 0%, #b83330 100%);">
                <i class="bi bi-qr-code-scan fs-4"></i>
                <div>
                    <h6 class="fw-bold mb-0" style="font-size: 0.95rem;">Quét mã QR tại điểm</h6>
                    <small class="opacity-75" style="font-size: 0.72rem;">Hướng camera vào mã QR được in tại địa điểm</small>
                </div>
            </div>
            <div class="p-4">
                <!-- Camera Preview Area -->
                <div id="qr-scanner-area" style="width: 100%; border-radius: 12px; overflow: hidden; background: #1a1a2e; min-height: 300px; position: relative;">
                    <!-- Loading placeholder while camera initializes -->
                    <div id="camera-loading" class="d-flex flex-column align-items-center justify-content-center text-white" style="min-height: 300px;">
                        <div class="spinner-border text-light mb-3" role="status" style="width: 3rem; height: 3rem;">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="small opacity-75 mb-1">Đang mở camera...</p>
                        <p class="x-small opacity-50 mb-0">Vui lòng cho phép truy cập khi được hỏi</p>
                    </div>
                    <!-- html5-qrcode will render inside this div -->
                    <div id="reader" style="width: 100%; display: none;"></div>
                </div>
                <div id="qr-result" class="mt-3"></div>
            </div>
        </div>

        <!-- GPS Status Card -->
        <div id="gps-card" class="card border-0 shadow-sm rounded-4 p-4 text-center reveal-up bg-white">
            <div class="d-flex align-items-center justify-content-center gap-2 mb-2">
                <i class="bi bi-geo-alt-fill text-muted fs-4"></i>
                <h6 class="fw-bold mb-0 text-muted">Định vị GPS</h6>
            </div>
            <p id="location-status" class="small text-muted mb-0">
                <i class="bi bi-info-circle me-1"></i> Quét mã QR trước, hệ thống sẽ tự động kiểm tra GPS sau.
            </p>
            <% if (dest) { %>
            <button id="btn-gps-check" class="btn rounded-pill px-4 py-2 fw-bold text-white mt-3" style="background: var(--primary);" onclick="doGpsCheckin()">
                <i class="bi bi-pin-map-fill me-1"></i> Xác nhận vị trí tại "<%= dest.name %>"
            </button>
            <% } %>
        </div>
    </div>
</section>

<!-- Success Modal -->
<div class="modal fade" id="checkinSuccessModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-premium overflow-hidden">
            <div class="position-relative">
                <img id="modal-img" src="" class="w-100" style="height: 220px; object-fit: cover;">
                <div class="position-absolute top-0 end-0 m-3">
                    <button type="button" class="btn-close btn-close-white bg-dark p-2 rounded-circle" data-bs-dismiss="modal"></button>
                </div>
                <div class="position-absolute bottom-0 start-0 w-100 p-4" style="background: linear-gradient(to top, rgba(0,0,0,0.85), transparent);">
                    <span class="badge bg-success rounded-pill px-3 py-2 mb-2 fw-bold"><i class="bi bi-check-circle-fill me-1"></i> Check-in thành công!</span>
                    <h4 id="modal-title" class="text-white fw-black mb-0"></h4>
                </div>
            </div>
            <div class="modal-body p-4 text-center">
                <div id="modal-points" class="mb-3"></div>
                <p id="modal-story" class="text-muted small mb-4" style="line-height: 1.7;"></p>
                <div class="d-flex gap-2 justify-content-center flex-wrap">
                    <a href="/profile" class="btn rounded-pill px-4 py-2 fw-bold text-white" style="background: var(--primary);">
                        <i class="bi bi-trophy me-1"></i> Xem huy hiệu
                    </a>
                    <button class="btn btn-outline-secondary rounded-pill px-4 py-2 fw-bold" data-bs-dismiss="modal">
                        Tiếp tục khám phá
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // ========== GPS (thu thập ngầm, KHÔNG hiện trạng thái) ==========
    let userLat = null;
    let userLng = null;
    let gpsReady = false;

    // Chỉ lấy GPS ngầm, không cập nhật UI
    if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(
            function(pos) {
                userLat = pos.coords.latitude;
                userLng = pos.coords.longitude;
                gpsReady = true;
                console.log('GPS ready:', userLat, userLng);
            },
            function(err) {
                console.warn('GPS pre-fetch error (OK, will retry after scan):', err.message);
            },
            { enableHighAccuracy: true, timeout: 10000, maximumAge: 60000 }
        );
    }

    // ========== QR Scanner ==========
    let scannerStopped = false;
    let html5QrCode = null;

    function showCameraError(errorMsg) {
        document.getElementById('camera-loading').style.display = 'none';
        document.getElementById('qr-scanner-area').innerHTML = 
            '<div class="p-4 text-center d-flex flex-column align-items-center justify-content-center" style="min-height: 300px; color: #fff;">' +
                '<i class="bi bi-camera-video-off fs-1 mb-3" style="color: #ff6b6b;"></i>' +
                '<h6 class="fw-bold mb-2" style="color: #ff6b6b;">Không mở được Camera</h6>' +
                '<p class="small mb-3 opacity-75" style="max-width: 300px; line-height: 1.6; color: #ccc;">' +
                    (errorMsg || 'Vui lòng cho phép truy cập Camera trong cài đặt trình duyệt, sau đó tải lại trang.') +
                '</p>' +
                '<button class="btn btn-sm btn-outline-light rounded-pill px-4" onclick="location.reload()">' +
                    '<i class="bi bi-arrow-clockwise me-1"></i> Thử lại' +
                '</button>' +
            '</div>';
    }

    function startScanner() {
        // Kiểm tra trình duyệt hỗ trợ camera
        if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
            showCameraError('Trình duyệt của bạn không hỗ trợ truy cập camera. Hãy mở trang này bằng Chrome hoặc Safari.');
            return;
        }

        // Bước 1: Xin quyền camera từ trình duyệt (hiện hộp thoại native)
        navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } })
            .then(function(stream) {
                // Quyền đã được cấp! Dừng stream test ngay
                stream.getTracks().forEach(function(track) { track.stop(); });
                
                // Bước 2: Khởi động QR scanner
                document.getElementById('camera-loading').style.display = 'none';
                document.getElementById('reader').style.display = 'block';
                
                html5QrCode = new Html5Qrcode('reader');
                html5QrCode.start(
                    { facingMode: 'environment' },
                    { fps: 10, qrbox: { width: 250, height: 250 }, aspectRatio: 1.0 },
                    onScanSuccess,
                    function() {} // ignore scan errors (no QR found yet)
                ).catch(function(err) {
                    console.error('Html5Qrcode start failed:', err);
                    showCameraError('Không thể khởi động scanner. Vui lòng tải lại trang.');
                });
            })
            .catch(function(err) {
                console.error('Camera permission error:', err);
                var msg = 'Vui lòng cho phép truy cập Camera khi trình duyệt hỏi.';
                if (err.name === 'NotAllowedError') {
                    msg = 'Bạn đã từ chối quyền Camera. Vui lòng vào Cài đặt trình duyệt → Quyền riêng tư → Camera → cho phép trang này, sau đó tải lại.';
                } else if (err.name === 'NotFoundError') {
                    msg = 'Không tìm thấy camera trên thiết bị này.';
                } else if (err.name === 'NotReadableError') {
                    msg = 'Camera đang được sử dụng bởi ứng dụng khác. Hãy đóng app khác và thử lại.';
                } else if (err.name === 'OverconstrainedError') {
                    msg = 'Không tìm thấy camera phù hợp. Đang thử camera trước...';
                    // Thử lại với camera trước (fallback)
                    navigator.mediaDevices.getUserMedia({ video: true })
                        .then(function(stream) {
                            stream.getTracks().forEach(function(t) { t.stop(); });
                            document.getElementById('camera-loading').style.display = 'none';
                            document.getElementById('reader').style.display = 'block';
                            html5QrCode = new Html5Qrcode('reader');
                            html5QrCode.start(
                                { facingMode: 'user' },
                                { fps: 10, qrbox: { width: 250, height: 250 } },
                                onScanSuccess,
                                function() {}
                            ).catch(function(e) { showCameraError('Không thể mở camera.'); });
                        })
                        .catch(function() { showCameraError(msg); });
                    return;
                }
                showCameraError(msg);
            });
    }

    function onScanSuccess(decodedText) {
        if (scannerStopped) return;
        scannerStopped = true;

        // Dừng camera ngay
        if (html5QrCode) {
            html5QrCode.stop().catch(function() {});
        }

        // Hiện trạng thái đang xử lý
        document.getElementById('qr-result').innerHTML = 
            '<div class="d-flex align-items-center gap-2 p-3 rounded-3" style="background: rgba(146,39,36,0.08); border: 1px solid rgba(146,39,36,0.15);">' +
                '<div class="spinner-border spinner-border-sm" role="status" style="color: var(--primary);"></div>' +
                '<span class="fw-bold small" style="color: var(--primary);">Đã quét thành công! Đang xác thực vị trí GPS...</span>' +
            '</div>';

        // Cập nhật GPS card
        document.getElementById('location-status').innerHTML = 
            '<span class="text-primary"><i class="bi bi-hourglass-split me-1"></i> Đang lấy tọa độ GPS...</span>';

        // Trích slug từ nội dung QR
        var slug = decodedText.trim();
        if (slug.indexOf('slug=') !== -1) {
            var match = slug.match(/slug=([^&]+)/);
            if (match) slug = match[1];
        } else if (slug.indexOf('/explore/') !== -1) {
            slug = slug.split('/explore/').pop().split('?')[0].split('#')[0];
        } else if (slug.indexOf('/') !== -1) {
            var parts = slug.split('/').filter(function(s) { return s; });
            slug = parts[parts.length - 1] || slug;
        }
        try { slug = decodeURIComponent(slug); } catch(e) {}

        // GPS check + checkin
        if (gpsReady && userLat !== null) {
            updateGpsStatus(userLat, userLng);
            doCheckin(slug, 'qr', userLat, userLng);
        } else {
            // GPS chưa sẵn sàng, xin lại
            if (!navigator.geolocation) {
                gpsError('Thiết bị không hỗ trợ GPS.');
                return;
            }
            navigator.geolocation.getCurrentPosition(
                function(pos) {
                    userLat = pos.coords.latitude;
                    userLng = pos.coords.longitude;
                    gpsReady = true;
                    updateGpsStatus(userLat, userLng);
                    doCheckin(slug, 'qr', userLat, userLng);
                },
                function(err) {
                    gpsError('Không lấy được vị trí GPS. ' + err.message);
                },
                { enableHighAccuracy: true, timeout: 15000, maximumAge: 0 }
            );
        }
    }

    function updateGpsStatus(lat, lng) {
        document.getElementById('location-status').innerHTML = 
            '<span class="text-success"><i class="bi bi-check-circle-fill me-1"></i> GPS: ' + 
            lat.toFixed(6) + ', ' + lng.toFixed(6) + '</span>';
    }

    function gpsError(msg) {
        document.getElementById('location-status').innerHTML = 
            '<span class="text-danger"><i class="bi bi-exclamation-triangle me-1"></i> ' + msg + '</span>';
        document.getElementById('qr-result').innerHTML = 
            '<div class="alert alert-warning rounded-3">' +
                '<i class="bi bi-exclamation-triangle me-1"></i> QR đã quét nhưng không xác định được GPS.<br>' +
                '<small>Vui lòng cho phép truy cập vị trí và tải lại trang.</small>' +
            '</div>' +
            '<button class="btn btn-sm btn-outline-primary rounded-pill mt-2" onclick="location.reload()">' +
                '<i class="bi bi-arrow-clockwise me-1"></i> Thử lại</button>';
    }

    // ========== GPS-only Checkin (khi có slug từ URL) ==========
    <% if (dest) { %>
    window.doGpsCheckin = function() {
        var btn = document.getElementById('btn-gps-check');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang xác thực...';

        if (gpsReady && userLat !== null) {
            updateGpsStatus(userLat, userLng);
            doCheckin('<%= slug %>', 'gps', userLat, userLng);
        } else {
            navigator.geolocation.getCurrentPosition(
                function(pos) {
                    userLat = pos.coords.latitude;
                    userLng = pos.coords.longitude;
                    updateGpsStatus(userLat, userLng);
                    doCheckin('<%= slug %>', 'gps', userLat, userLng);
                },
                function(err) {
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-pin-map-fill me-1"></i> Xác nhận vị trí';
                    alert('Không thể lấy vị trí GPS. Vui lòng cho phép quyền truy cập vị trí.');
                },
                { enableHighAccuracy: true, timeout: 15000, maximumAge: 0 }
            );
        }
    };
    <% } %>

    // ========== Core Checkin API ==========
    function doCheckin(slug, method, lat, lng) {
        if (!slug) {
            document.getElementById('qr-result').innerHTML = 
                '<div class="alert alert-warning rounded-3">Mã QR không hợp lệ. Vui lòng quét lại.</div>';
            return;
        }

        axios.post('/api/checkin', { slug: slug, method: method, lat: lat, lng: lng })
            .then(function(res) {
                if (res.data.success) {
                    if (typeof confetti === 'function') {
                        confetti({ particleCount: 200, spread: 120, origin: { y: 0.6 } });
                    }

                    var dest = res.data.destination;
                    document.getElementById('modal-title').innerText = dest.name;
                    
                    var imgSrc = dest.cover_image || '/images/hero-1.png';
                    if (imgSrc && imgSrc.indexOf('http') !== 0 && imgSrc.indexOf('data:') !== 0 && imgSrc.indexOf('/') !== 0) {
                        imgSrc = '/' + imgSrc;
                    }
                    document.getElementById('modal-img').src = imgSrc;
                    document.getElementById('modal-story').innerText = dest.story || dest.highlight || 'Chào mừng bạn đã đến với địa điểm này!';
                    document.getElementById('modal-points').innerHTML = 
                        '<div class="d-inline-flex align-items-center gap-2 px-4 py-2 rounded-pill" style="background: rgba(146,39,36,0.08); border: 1px solid rgba(146,39,36,0.15);">' +
                            '<i class="bi bi-star-fill text-warning"></i>' +
                            '<span class="fw-bold" style="color: var(--primary);">+' + res.data.points_earned + ' điểm thưởng</span>' +
                        '</div>';

                    document.getElementById('qr-result').innerHTML = 
                        '<div class="d-flex align-items-center gap-2 p-3 rounded-3 bg-success bg-opacity-10 border border-success border-opacity-25">' +
                            '<i class="bi bi-check-circle-fill text-success fs-4"></i>' +
                            '<div>' +
                                '<span class="fw-bold text-success d-block">Check-in thành công!</span>' +
                                '<small class="text-muted">Địa điểm: ' + dest.name + '</small>' +
                            '</div>' +
                        '</div>';

                    new bootstrap.Modal(document.getElementById('checkinSuccessModal')).show();
                } else {
                    showCheckinError(res.data.message);
                }
            })
            .catch(function(err) {
                showCheckinError((err.response && err.response.data && err.response.data.message) || err.message);
            });
    }

    function showCheckinError(message) {
        document.getElementById('qr-result').innerHTML = 
            '<div class="alert alert-danger rounded-3 d-flex align-items-start gap-2">' +
                '<i class="bi bi-exclamation-triangle-fill mt-1"></i>' +
                '<div>' +
                    '<strong>Check-in thất bại</strong><br>' +
                    '<small>' + message + '</small>' +
                '</div>' +
            '</div>' +
            '<button class="btn btn-sm btn-outline-primary rounded-pill mt-2" onclick="location.reload()">' +
                '<i class="bi bi-arrow-clockwise me-1"></i> Quét lại</button>';
        var btn = document.getElementById('btn-gps-check');
        if (btn) {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-pin-map-fill me-1"></i> Xác nhận vị trí';
        }
    }

    // ========== Khởi động Scanner ==========
    startScanner();
});
</script>
