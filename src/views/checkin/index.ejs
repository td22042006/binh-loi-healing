<style>
/* Corner borders for QR placeholder */
.qr-placeholder-frame {
    transition: all 0.3s ease;
}
.corner-border {
    position: absolute;
    width: 24px;
    height: 24px;
    border-color: #922724;
    border-style: solid;
    border-width: 0;
}
.top-left { top: -3px; left: -3px; border-top-width: 4px; border-left-width: 4px; border-top-left-radius: 12px; }
.top-right { top: -3px; right: -3px; border-top-width: 4px; border-right-width: 4px; border-top-right-radius: 12px; }
.bottom-left { bottom: -3px; left: -3px; border-bottom-width: 4px; border-left-width: 4px; border-bottom-left-radius: 12px; }
.bottom-right { bottom: -3px; right: -3px; border-bottom-width: 4px; border-right-width: 4px; border-bottom-right-radius: 12px; }

/* Laser scanner effect */
.scanner-laser {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(to right, transparent, #b83330, #e11d48, #b83330, transparent);
    box-shadow: 0 0 10px #f43f5e;
    z-index: 10;
    animation: scan 2s linear infinite;
}
@keyframes scan {
    0% { top: 0%; }
    50% { top: 100%; }
    100% { top: 0%; }
}

/* Custom styling for html5-qrcode video element */
#reader video {
    object-fit: cover !important;
    border-radius: 14px;
}
</style>

<section class="py-5" style="margin-top: 80px; background: #f8faf9;">
    <div class="container py-4" style="max-width: 700px;">
        <div class="text-center mb-5 reveal-up">
            <span class="badge rounded-pill px-3 py-2 mb-3 text-uppercase fw-bold x-small" style="background: var(--primary-100); color: var(--primary); border: 1px solid var(--primary-200); letter-spacing: 1px;">
                <i class="bi bi-qr-code-scan me-1"></i> Xác thực hành trình
            </span>
            <h2 class="fw-black text-dark mb-2 font-display" style="font-size: 2rem;">Check-in & Xác nhận</h2>
            <p class="text-muted mx-auto" style="max-width: 500px; font-size: 0.92rem;">Quét mã QR tại địa điểm hoặc sử dụng GPS để xác nhận bạn đã đến nơi.</p>
        </div>

        <!-- QR Scanner Card -->
        <div class="card border-0 shadow-premium rounded-4 overflow-hidden mb-4 reveal-up">
            <div class="p-3 text-white d-flex align-items-center justify-content-between gap-2" style="background: linear-gradient(135deg, #922724 0%, #b83330 100%);">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-qr-code-scan fs-4"></i>
                    <div>
                        <h6 class="fw-bold mb-0" style="font-size: 0.95rem;">Quét mã QR tại điểm</h6>
                        <small id="scanner-subtitle" class="opacity-75" style="font-size: 0.72rem;">Nhấn nút để khởi động camera</small>
                    </div>
                </div>
                <button id="btn-stop-camera" class="btn btn-sm btn-outline-light rounded-pill px-3 d-none animate__animated animate__fadeIn" onclick="stopScanner()">
                    <i class="bi bi-camera-video-off me-1"></i> Tắt Camera
                </button>
            </div>
            <div class="p-4">
                <!-- Camera Preview Area -->
                <div id="qr-scanner-area" style="width: 100%; border-radius: 16px; overflow: hidden; background: #0f172a; min-height: 320px; position: relative; border: 2px solid #e2e8f0; display: flex; align-items: center; justify-content: center;">
                    
                    <!-- Intro Screen before scanner starts -->
                    <div id="scanner-intro" class="d-flex flex-column align-items-center justify-content-center text-center p-4 w-100" style="min-height: 320px;">
                        <div class="qr-placeholder-frame mb-4 d-flex align-items-center justify-content-center position-relative" style="width: 130px; height: 130px; border: 2px dashed #cbd5e1; border-radius: 16px; background: rgba(255,255,255,0.03);">
                            <i class="bi bi-qr-code-scan text-muted" style="font-size: 3.5rem; color: #64748b !important;"></i>
                            <div class="corner-border top-left"></div>
                            <div class="corner-border top-right"></div>
                            <div class="corner-border bottom-left"></div>
                            <div class="corner-border bottom-right"></div>
                        </div>
                        <h6 class="fw-bold text-dark mb-2">Sẵn sàng quét QR Code</h6>
                        <p class="text-muted small mb-4 px-3" style="max-width: 340px; line-height: 1.5;">Vui lòng mở camera để quét mã QR check-in tại các địa điểm tham quan.</p>
                        <button id="btn-start-scanner" class="btn rounded-pill px-4 py-2 text-white fw-bold shadow" style="background: var(--primary); transition: all 0.3s;" onclick="startScanner()">
                            <i class="bi bi-camera-fill me-1"></i> Bật Camera Quét Mã
                        </button>
                    </div>

                    <!-- Loading placeholder while camera initializes -->
                    <div id="camera-loading" class="d-flex flex-column align-items-center justify-content-center text-white d-none w-100" style="min-height: 320px;">
                        <div class="spinner-border text-danger mb-3" role="status" style="width: 2.5rem; height: 2.5rem;">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="small text-white-50 mb-1">Đang khởi động camera...</p>
                        <p class="x-small text-white-50 opacity-75 mb-0">Vui lòng chọn "Cho phép" khi trình duyệt hỏi.</p>
                    </div>
                    
                    <!-- html5-qrcode will render inside this div -->
                    <div id="reader" style="width: 100%; display: none; position: relative;"></div>
                    
                    <!-- Scanner Laser Overlay for visual feedback -->
                    <div id="scanner-laser" class="scanner-laser d-none"></div>
                </div>
                <div id="qr-result" class="mt-3"></div>
            </div>
        </div>

        <!-- GPS Status Card -->
        <div id="gps-card" class="card border-0 shadow-sm rounded-4 p-4 text-center reveal-up bg-white">
            <div class="d-flex align-items-center justify-content-center gap-2 mb-2">
                <i class="bi bi-geo-alt-fill text-muted fs-4"></i>
                <h6 class="fw-bold mb-0 text-muted">Định vị GPS</h6>
            </div>
            <p id="location-status" class="small text-muted mb-0">
                <i class="bi bi-info-circle me-1"></i> Quét mã QR trước, hệ thống sẽ tự động xác minh GPS của bạn sau.
            </p>
            <% if (dest) { %>
            <button id="btn-gps-check" class="btn rounded-pill px-4 py-2 fw-bold text-white mt-3" style="background: var(--primary);" onclick="doGpsCheckin()">
                <i class="bi bi-pin-map-fill me-1"></i> Xác nhận vị trí tại "<%= dest.name %>"
            </button>
            <% } %>
        </div>
    </div>
</section>

<!-- Success Modal -->
<div class="modal fade" id="checkinSuccessModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-premium overflow-hidden">
            <div class="position-relative">
                <img id="modal-img" src="" class="w-100" style="height: 220px; object-fit: cover;">
                <div class="position-absolute top-0 end-0 m-3">
                    <button type="button" class="btn-close btn-close-white bg-dark p-2 rounded-circle" data-bs-dismiss="modal"></button>
                </div>
                <div class="position-absolute bottom-0 start-0 w-100 p-4" style="background: linear-gradient(to top, rgba(0,0,0,0.85), transparent);">
                    <span class="badge bg-success rounded-pill px-3 py-2 mb-2 fw-bold"><i class="bi bi-check-circle-fill me-1"></i> Check-in thành công!</span>
                    <h4 id="modal-title" class="text-white fw-black mb-0 font-display"></h4>
                </div>
            </div>
            <div class="modal-body p-4 text-center">
                <div id="modal-points" class="mb-3"></div>
                <p id="modal-story" class="text-muted small mb-4" style="line-height: 1.7;"></p>
                <div class="d-flex gap-2 justify-content-center flex-wrap">
                    <a href="/profile" class="btn rounded-pill px-4 py-2 fw-bold text-white" style="background: var(--primary);">
                        <i class="bi bi-trophy me-1"></i> Xem huy hiệu
                    </a>
                    <button class="btn btn-outline-secondary rounded-pill px-4 py-2 fw-bold" data-bs-dismiss="modal">
                        Tiếp tục hành trình
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    let userLat = null;
    let userLng = null;
    let gpsReady = false;
    let html5QrCode = null;
    let scannerStopped = false;

    // Custom Camera Error handling
    function showCameraError(errorMsg) {
        document.getElementById('camera-loading').classList.add('d-none');
        document.getElementById('scanner-intro').classList.add('d-none');
        document.getElementById('btn-stop-camera').classList.add('d-none');
        document.getElementById('scanner-laser').classList.add('d-none');
        
        document.getElementById('qr-scanner-area').innerHTML = 
            '<div class="p-4 text-center d-flex flex-column align-items-center justify-content-center" style="min-height: 320px; color: #fff; width: 100%;">' +
                '<i class="bi bi-camera-video-off fs-1 mb-3" style="color: #ff6b6b;"></i>' +
                '<h6 class="fw-bold mb-2" style="color: #ff6b6b;">Lỗi truy cập Camera</h6>' +
                '<p class="small mb-3 opacity-75 text-light px-3" style="max-width: 320px; line-height: 1.6;">' +
                    (errorMsg || 'Vui lòng cho phép quyền truy cập Camera trong cài đặt trình duyệt để tiếp tục quét mã QR.') +
                '</p>' +
                '<button class="btn btn-sm btn-outline-light rounded-pill px-4" onclick="location.reload()">' +
                    '<i class="bi bi-arrow-clockwise me-1"></i> Tải lại trang' +
                '</button>' +
            '</div>';
    }

    // Step 1: When user clicks "Bật Camera Quét Mã", get GPS FIRST
    window.startScanner = function() {
        // Update UI to show GPS is being requested
        document.getElementById('scanner-intro').classList.add('d-none');
        document.getElementById('camera-loading').classList.remove('d-none');
        document.getElementById('scanner-subtitle').innerText = "Đang yêu cầu quyền định vị GPS...";
        
        document.getElementById('location-status').innerHTML = 
            '<span class="text-primary"><i class="bi bi-hourglass-split me-1"></i> Đang yêu cầu quyền định vị GPS từ thiết bị...</span>';

        // Check if GPS is available
        if (!navigator.geolocation) {
            showGpsRequired('Thiết bị của bạn không hỗ trợ định vị GPS.');
            return;
        }

        // Request GPS permission FIRST
        navigator.geolocation.getCurrentPosition(
            function(pos) {
                userLat = pos.coords.latitude;
                userLng = pos.coords.longitude;
                gpsReady = true;

                document.getElementById('location-status').innerHTML = 
                    '<span class="text-success"><i class="bi bi-check-circle-fill me-1"></i> GPS đã sẵn sàng</span>';

                // GPS OK -> now start camera
                startCameraAfterGps();
            },
            function(err) {
                console.error("GPS error:", err);
                showGpsRequired('Vui lòng bật Định vị (GPS) trên thiết bị và cho phép quyền vị trí cho trình duyệt để quét mã QR.');
            },
            { enableHighAccuracy: true, timeout: 15000, maximumAge: 0 }
        );
    };

    // Show GPS required error in the scanner area
    function showGpsRequired(msg) {
        document.getElementById('camera-loading').classList.add('d-none');
        document.getElementById('scanner-intro').classList.add('d-none');
        
        document.getElementById('qr-scanner-area').innerHTML = 
            '<div class="p-4 text-center d-flex flex-column align-items-center justify-content-center" style="min-height: 320px; color: #fff; width: 100%;">' +
                '<i class="bi bi-geo-alt-fill fs-1 mb-3" style="color: #fbbf24;"></i>' +
                '<h6 class="fw-bold mb-2" style="color: #fbbf24;">Cần bật Định vị GPS</h6>' +
                '<p class="small mb-3 opacity-75 text-light px-3" style="max-width: 340px; line-height: 1.6;">' +
                    msg +
                '</p>' +
                '<button class="btn btn-sm btn-outline-light rounded-pill px-4" onclick="location.reload()">' +
                    '<i class="bi bi-arrow-clockwise me-1"></i> Thử lại' +
                '</button>' +
            '</div>';

        document.getElementById('location-status').innerHTML = 
            '<span class="text-danger"><i class="bi bi-exclamation-triangle-fill me-1"></i> Chưa bật định vị GPS</span>';
    }

    // Step 2: Start camera AFTER GPS is confirmed
    function startCameraAfterGps() {
        document.getElementById('scanner-subtitle').innerText = "Đang kết nối camera...";

        if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
            showCameraError('Trình duyệt của bạn không hỗ trợ camera. Vui lòng mở trang này trên Chrome hoặc Safari.');
            return;
        }

        navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } })
            .then(function(stream) {
                stream.getTracks().forEach(function(track) { track.stop(); });
                
                document.getElementById('camera-loading').classList.add('d-none');
                document.getElementById('reader').style.display = 'block';
                document.getElementById('btn-stop-camera').classList.remove('d-none');
                document.getElementById('scanner-laser').classList.remove('d-none');
                document.getElementById('scanner-subtitle').innerText = "Vui lòng hướng camera vào mã QR";
                
                scannerStopped = false;
                html5QrCode = new Html5Qrcode('reader');
                html5QrCode.start(
                    { facingMode: 'environment' },
                    { 
                        fps: 10, 
                        qrbox: function(width, height) {
                            var size = Math.min(width, height) * 0.7;
                            return { width: size, height: size };
                        }, 
                        aspectRatio: 1.0 
                    },
                    onScanSuccess,
                    function() {}
                ).catch(function(err) {
                    console.error('Html5Qrcode start failed:', err);
                    showCameraError('Không thể khởi động camera. Vui lòng tải lại trang.');
                });
            })
            .catch(function(err) {
                console.error('Camera access error:', err);
                var msg = 'Vui lòng chấp nhận quyền truy cập camera khi trình duyệt yêu cầu.';
                if (err.name === 'NotAllowedError') {
                    msg = 'Bạn đã chặn quyền camera. Hãy vào Cài đặt trình duyệt → Quyền riêng tư → cho phép trang web này sử dụng camera.';
                } else if (err.name === 'NotFoundError') {
                    msg = 'Không tìm thấy camera trên thiết bị của bạn.';
                }
                showCameraError(msg);
            });
    }

    // Stop Scanner function
    window.stopScanner = function() {
        if (html5QrCode) {
            html5QrCode.stop().then(function() {
                document.getElementById('reader').style.display = 'none';
                document.getElementById('btn-stop-camera').classList.add('d-none');
                document.getElementById('scanner-laser').classList.add('d-none');
                document.getElementById('scanner-intro').classList.remove('d-none');
                document.getElementById('scanner-subtitle').innerText = "Nhấn nút để khởi động camera";
            }).catch(function(e) {
                console.error("Stop camera error:", e);
            });
        }
    };

    // Successful QR Scan Handler - GPS already acquired at this point
    function onScanSuccess(decodedText) {
        if (scannerStopped) return;
        scannerStopped = true;

        // Turn off camera & laser overlay
        document.getElementById('btn-stop-camera').classList.add('d-none');
        document.getElementById('scanner-laser').classList.add('d-none');
        document.getElementById('scanner-subtitle').innerText = "Đang xác thực...";
        if (html5QrCode) {
            html5QrCode.stop().catch(function() {});
        }

        // Show verifying status
        document.getElementById('qr-result').innerHTML = 
            '<div class="d-flex align-items-center gap-2 p-3 rounded-3" style="background: rgba(146,39,36,0.08); border: 1px solid rgba(146,39,36,0.15);">' +
                '<div class="spinner-border spinner-border-sm" role="status" style="color: var(--primary);"></div>' +
                '<span class="fw-bold small" style="color: var(--primary);">Đang đối chiếu vị trí GPS...</span>' +
            '</div>';
        
        document.getElementById('location-status').innerHTML = 
            '<span class="text-primary"><i class="bi bi-hourglass-split me-1"></i> Đang đối chiếu vị trí...</span>';

        // Parse destination slug from QR data
        var slug = decodedText.trim();
        if (slug.indexOf('slug=') !== -1) {
            var match = slug.match(/slug=([^&]+)/);
            if (match) slug = match[1];
        } else if (slug.indexOf('/explore/') !== -1) {
            slug = slug.split('/explore/').pop().split('?')[0].split('#')[0];
        } else if (slug.indexOf('/checkin') !== -1) {
            var match2 = slug.match(/slug=([^&]+)/);
            if (match2) slug = match2[1];
        } else if (slug.indexOf('/') !== -1) {
            var parts = slug.split('/').filter(function(s) { return s; });
            slug = parts[parts.length - 1] || slug;
        }
        try { slug = decodeURIComponent(slug); } catch(e) {}
        if (slug.endsWith('/')) slug = slug.slice(0, -1);
        slug = slug.split('?')[0].split('#')[0].trim();

        // Re-fetch fresh GPS coordinates right before submitting
        if (navigator.geolocation && gpsReady) {
            navigator.geolocation.getCurrentPosition(
                function(pos) {
                    userLat = pos.coords.latitude;
                    userLng = pos.coords.longitude;
                    doCheckin(slug, 'qr', userLat, userLng);
                },
                function(err) {
                    // Use previously acquired GPS coordinates
                    doCheckin(slug, 'qr', userLat, userLng);
                },
                { enableHighAccuracy: true, timeout: 8000, maximumAge: 0 }
            );
        } else {
            showCheckinError('Không thiết lập được GPS');
        }
    }

    // GPS-only Checkin button click handler (for checkin links with slug in URL)
    <% if (dest) { %>
    window.doGpsCheckin = function() {
        var btn = document.getElementById('btn-gps-check');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Đang xác định vị trí GPS...';

        document.getElementById('location-status').innerHTML = 
            '<span class="text-primary"><i class="bi bi-hourglass-split me-1"></i> Đang lấy tọa độ vị trí của bạn...</span>';

        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(
                function(pos) {
                    userLat = pos.coords.latitude;
                    userLng = pos.coords.longitude;
                    gpsReady = true;
                    document.getElementById('location-status').innerHTML = 
                        '<span class="text-success"><i class="bi bi-check-circle-fill me-1"></i> GPS đã sẵn sàng</span>';
                    doCheckin('<%= slug %>', 'gps', userLat, userLng);
                },
                function(err) {
                    console.error("GPS manual error:", err);
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-pin-map-fill me-1"></i> Xác nhận vị trí';
                    showCheckinError('Không lấy được vị trí GPS');
                },
                { enableHighAccuracy: true, timeout: 15000, maximumAge: 0 }
            );
        } else {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-pin-map-fill me-1"></i> Xác nhận vị trí';
            showCheckinError('Thiết bị không hỗ trợ định vị');
        }
    };
    <% } %>

    // Core Checkin API Submission
    function doCheckin(slug, method, lat, lng) {
        if (!slug || lat === null || lng === null) {
            showCheckinError('Thiếu thông tin vị trí hoặc địa điểm');
            return;
        }

        axios.post('/api/checkin', { slug: slug, method: method, lat: lat, lng: lng })
            .then(function(res) {
                if (res.data.success) {
                    if (typeof confetti === 'function') {
                        confetti({ particleCount: 200, spread: 120, origin: { y: 0.6 } });
                    }

                    var dest = res.data.destination;
                    document.getElementById('modal-title').innerText = dest.name;
                    
                    var imgSrc = dest.cover_image || '/images/hero-1.png';
                    if (imgSrc && imgSrc.indexOf('http') !== 0 && imgSrc.indexOf('data:') !== 0 && imgSrc.indexOf('/') !== 0) {
                        imgSrc = '/' + imgSrc;
                    }
                    document.getElementById('modal-img').src = imgSrc;
                    document.getElementById('modal-story').innerText = dest.story || dest.highlight || 'Cảm ơn bạn đã ghé thăm Bình Lợi!';
                    document.getElementById('modal-points').innerHTML = 
                        '<div class="d-inline-flex align-items-center gap-2 px-4 py-2 rounded-pill" style="background: rgba(146,39,36,0.08); border: 1px solid rgba(146,39,36,0.15);">' +
                            '<i class="bi bi-star-fill text-warning animate__animated animate__bounceIn"></i>' +
                            '<span class="fw-bold text-danger">+' + res.data.points_earned + ' điểm thưởng</span>' +
                        '</div>';

                    document.getElementById('qr-result').innerHTML = 
                        '<div class="d-flex align-items-center gap-2 p-3 rounded-3 bg-success bg-opacity-10 border border-success border-opacity-25">' +
                            '<i class="bi bi-check-circle-fill text-success fs-4"></i>' +
                            '<div>' +
                                '<span class="fw-bold text-success d-block">Xác thực vị trí thành công!</span>' +
                                '<small class="text-muted">Điểm đến: ' + dest.name + '</small>' +
                            '</div>' +
                        '</div>';

                    document.getElementById('location-status').innerHTML = 
                        '<span class="text-success"><i class="bi bi-check-circle-fill me-1"></i> GPS hợp lệ</span>';

                    var successModal = new bootstrap.Modal(document.getElementById('checkinSuccessModal'));
                    successModal.show();
                } else {
                    showCheckinError(res.data.message, res.data.error_type);
                }
            })
            .catch(function(err) {
                var msg = 'Xác thực thất bại';
                var type = '';
                if (err.response && err.response.data) {
                    msg = err.response.data.message || msg;
                    type = err.response.data.error_type || type;
                }
                showCheckinError(msg, type);
            });
    }

    // Display simple error message - only "Xác thực thất bại" + descriptive message
    function showCheckinError(msg, type) {
        msg = msg || 'Xác thực thất bại';
        document.getElementById('qr-result').innerHTML = 
            '<div class="alert alert-danger rounded-3 mt-2 p-3 text-center">' +
                '<i class="bi bi-exclamation-triangle-fill fs-4 d-block mb-2"></i>' +
                '<strong class="fs-6 d-block mb-1">Xác thực thất bại</strong>' +
                '<span class="small opacity-90">' + msg + '</span>' +
            '</div>' +
            '<button class="btn btn-sm btn-outline-danger rounded-pill mt-2" onclick="location.reload()">' +
                '<i class="bi bi-arrow-clockwise me-1"></i> Quét lại</button>';
        
        // Update location status based on error type
        if (type === 'OUT_OF_RADIUS') {
            document.getElementById('location-status').innerHTML = 
                '<span class="text-danger"><i class="bi bi-x-circle-fill me-1"></i> Nằm ngoài bán kính địa điểm</span>';
        } else if (type === 'ALREADY_CHECKED_IN') {
            document.getElementById('location-status').innerHTML = 
                '<span class="text-warning"><i class="bi bi-exclamation-circle-fill me-1"></i> Đã xác thực địa điểm này</span>';
        } else {
            document.getElementById('location-status').innerHTML = 
                '<span class="text-danger"><i class="bi bi-exclamation-triangle-fill me-1"></i> ' + msg + '</span>';
        }
        
        var btn = document.getElementById('btn-gps-check');
        if (btn) {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-pin-map-fill me-1"></i> Xác nhận vị trí';
        }
    }
});
</script>

