<section class="site-section">
    <div class="container-site">
        <div class="text-center mb-5 animate__animated animate__fadeIn">
            <span class="text-primary fw-bold mb-2 d-block">XÁC THỰC HÀNH TRÌNH</span>
            <h2 class="display-text">Check-in & Lưu niệm</h2>
            <p class="text-muted mx-auto" style="max-width: 600px;">Sử dụng QR Code hoặc vị trí GPS để xác nhận điểm đến và nhận huy hiệu.</p>
        </div>

        <div class="row g-4 justify-content-center">
            <div class="col-md-6">
                <!-- QR Scanner Card -->
                <div class="card-bl p-4 shadow-lg mb-4 text-center">
                    <h5 class="mb-4"><i class="bi bi-qr-code-scan me-2 text-primary"></i> Quét mã QR tại điểm</h5>
                    <div id="reader" style="width: 100%; border-radius: 12px; overflow: hidden; background: #eee;"></div>
                    <div id="qr-result" class="mt-3"></div>
                </div>

                <!-- GPS Status Card -->
                <div class="card-bl p-4 shadow-sm text-center">
                    <h5><i class="bi bi-geo-alt me-2 text-secondary"></i> Định vị GPS</h5>
                    <p id="location-status" class="small text-muted mb-3">Đang kiểm tra vị trí...</p>
                    <button id="btn-gps-check" class="btn btn-outline-bl btn-sm">Xác nhận bằng vị trí</button>
                </div>
            </div>

            <div class="col-md-6">
                <!-- Frame Preview -->
                <div class="card-bl p-4 shadow-lg h-100">
                    <h5 class="mb-4 text-center">Khung ảnh lưu niệm BND</h5>
                    <div class="photo-frame-container position-relative overflow-hidden rounded-4 border">
                        <img src="<%= baseUrl %>/images/hero-2.png" class="w-100" alt="Preview">
                        <!-- Frame Overlays -->
                        <div class="frame-overlay frame-mai animate__animated animate__fadeIn">
                            <span class="badge bg-secondary text-dark position-absolute bottom-0 start-0 m-3 shadow">#BinhLoiHealing 🌿</span>
                            <div class="position-absolute top-0 end-0 m-3">
                                <span class="display-6">🌼</span>
                            </div>
                        </div>
                    </div>
                    <div class="mt-4 text-center">
                        <p class="small text-muted">Hệ thống khung ảnh (frame) được thiết kế dựa trên bộ nhận diện thương hiệu (mai vàng, nhang, sông nước).</p>
                        <button class="btn btn-primary-bl w-100" onclick="alert('Chức năng chụp ảnh với khung đang được tích hợp camera...')">Chụp ảnh lưu niệm 📸</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
.photo-frame-container::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    border: 15px solid rgba(200, 169, 110, 0.2);
    pointer-events: none;
}
.frame-mai {
    pointer-events: none;
}
</style>

<script src="https://unpkg.com/html5-qrcode"></script>
<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.5.1/dist/confetti.browser.min.js"></script>

<script>
// QR Scanner Logic
function onScanSuccess(decodedText, decodedResult) {
    document.getElementById('qr-result').innerHTML = `<div class="alert alert-success">Đã quét: ${decodedText}</div>`;
    // decodedText is usually the slug or URL. We need the slug.
    let slug = decodedText;
    if (decodedText.includes('/')) {
        slug = decodedText.split('/').pop();
    }
    verifyCheckin(slug, 'qr');
}

let html5QrcodeScanner = new Html5QrcodeScanner("reader", { fps: 10, qrbox: 250 });
html5QrcodeScanner.render(onScanSuccess);

// GPS Logic
document.getElementById('btn-gps-check').addEventListener('click', () => {
    if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(pos => {
            document.getElementById('location-status').innerHTML = `Tọa độ: ${pos.coords.latitude.toFixed(4)}, ${pos.coords.longitude.toFixed(4)}`;
            verifyCheckin('<%= slug || "" %>', 'gps', pos.coords.latitude, pos.coords.longitude);
        });
    } else {
        alert("Trình duyệt không hỗ trợ định vị.");
    }
});

function verifyCheckin(slug, method, lat = null, lng = null) {
    if (!slug) {
        alert("Thiếu thông tin địa điểm để check-in.");
        return;
    }
    
    axios.post(window.APP_CONFIG.apiUrl + '/checkin', {
        slug: slug,
        method: method,
        lat: lat,
        lng: lng
    }).then(res => {
        if (res.data.success) {
            confetti({ particleCount: 100, spread: 70, origin: { y: 0.6 } });
            alert('Check-in thành công! Bạn nhận được ' + res.data.points_earned + ' điểm.');
            window.location.href = window.APP_CONFIG.baseUrl + '/summary';
        } else {
            alert('Thất bại: ' + res.data.message);
        }
    }).catch(err => {
        alert('Lỗi: ' + (err.response?.data?.message || err.message));
    });
}
</script>
