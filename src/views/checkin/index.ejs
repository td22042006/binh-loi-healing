<!-- Vibrant Check-in — The Gate to Your Rewards -->
<div class="row g-4 justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="col-lg-6 text-center">
        <div class="widget-card p-5 border-0 shadow-2xl position-relative overflow-hidden" 
             style="background: var(--grad-main); border-radius: 40px; color: white;">
            
            <!-- Background Decoration -->
            <div class="position-absolute top-0 start-0 w-100 h-100 opacity-10" 
                 style="background-image: radial-gradient(circle at 20% 20%, white 0%, transparent 50%), radial-gradient(circle at 80% 80%, var(--accent-gold) 0%, transparent 50%);"></div>

            <div class="position-relative" style="z-index: 10;">
                <div class="rounded-pill bg-warning text-dark d-inline-block px-4 py-2 fw-black mb-4 shadow-lg" style="font-size: 0.75rem; letter-spacing: 2px;">
                    SCAN & COLLECT XP
                </div>
                
                <h1 class="fw-black font-display mb-3 text-white" style="font-size: 3rem; line-height: 1;">Xác thực Hành trình</h1>
                <p class="opacity-75 mb-5 mx-auto px-lg-5" style="max-width: 450px;">Hãy đưa camera vào mã QR tại điểm đến để tích lũy Stamp và nhận ngay 10 XP vào Passport của bạn.</p>

                <!-- VIBRANT SCANNER BOX -->
                <div class="position-relative mx-auto mb-5" style="width: 280px; height: 280px;">
                    <!-- Decorative Corners -->
                    <div class="position-absolute top-0 start-0 p-3 border-top border-start border-4 border-warning rounded-4" style="width: 60px; height: 60px;"></div>
                    <div class="position-absolute top-0 end-0 p-3 border-top border-end border-4 border-warning rounded-4" style="width: 60px; height: 60px;"></div>
                    <div class="position-absolute bottom-0 start-0 p-3 border-bottom border-start border-4 border-warning rounded-4" style="width: 60px; height: 60px;"></div>
                    <div class="position-absolute bottom-0 end-0 p-3 border-bottom border-end border-4 border-warning rounded-4" style="width: 60px; height: 60px;"></div>
                    
                    <div class="w-100 h-100 bg-white bg-opacity-10 backdrop-blur-md rounded-4 d-flex align-items-center justify-content-center overflow-hidden border border-white border-opacity-20 shadow-inner">
                        <div id="reader" class="w-100 h-100"></div>
                        <!-- Laser Animation -->
                        <div class="position-absolute w-100 bg-warning opacity-50 shadow-lg laser-line" style="height: 2px; top: 0; left: 0; box-shadow: 0 0 15px var(--accent-gold); z-index: 100;"></div>
                        <i class="bi bi-qr-code text-white opacity-25" style="font-size: 8rem;"></i>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-4">
                        <div class="p-3 rounded-4 bg-white bg-opacity-10 border border-white border-opacity-10 shadow-sm">
                            <i class="bi bi-lightning-charge-fill text-warning d-block fs-3 mb-1"></i>
                            <span class="fw-black d-block text-white">+10 XP</span>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="p-3 rounded-4 bg-white bg-opacity-10 border border-white border-opacity-10 shadow-sm">
                            <i class="bi bi-pin-map-fill text-danger d-block fs-3 mb-1"></i>
                            <span class="fw-black d-block text-white">+1 STAMP</span>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="p-3 rounded-4 bg-white bg-opacity-10 border border-white border-opacity-10 shadow-sm">
                            <i class="bi bi-gift-fill text-info d-block fs-3 mb-1"></i>
                            <span class="fw-black d-block text-white">REWARDS</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <p class="text-muted small mt-4 fw-bold">Gặp khó khăn khi quét mã? <a href="#" class="text-primary text-decoration-none">Nhập mã điểm đến bằng tay</a></p>
    </div>
</div>

<style>
    .laser-line {
        animation: scanMove 3s infinite cubic-bezier(0.4, 0, 0.2, 1);
    }
    @keyframes scanMove {
        0%, 100% { top: 0; opacity: 0; }
        5% { opacity: 1; }
        50% { top: 100%; opacity: 1; }
        95% { opacity: 1; }
        100% { top: 100%; opacity: 0; }
    }
    .shadow-2xl {
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    }
</style>

<script src="https://unpkg.com/html5-qrcode"></script>
<script>
    const html5QrCode = new Html5Qrcode("reader");
    const config = { fps: 10, qrbox: { width: 250, height: 250 } };

    html5QrCode.start({ facingMode: "environment" }, config, (decodedText) => {
        // Handle successful scan
        window.location.href = `/api/checkin?code=${decodedText}`;
    });
</script>
