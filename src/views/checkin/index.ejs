<section class="site-section">
    <div class="container-site">
        <div class="text-center mb-5 animate__animated animate__fadeIn">
            <span class="text-primary fw-bold mb-2 d-block">XÁC THỰC HÀNH TRÌNH</span>
            <h2 class="display-text">Check-in & Xác nhận</h2>
            <p class="text-muted mx-auto" style="max-width: 600px;">Sử dụng QR Code hoặc vị trí GPS để xác nhận điểm đến và nhận huy hiệu.</p>
        </div>

        <div class="row g-4 justify-content-center">
            <div class="col-md-7 col-lg-6">
                <!-- QR Scanner Card -->
                <div class="card-bl p-4 shadow-lg mb-4 text-center">
                    <h5 class="mb-4"><i class="bi bi-qr-code-scan me-2 text-primary"></i> Quét mã QR tại điểm</h5>
                    <div id="reader" style="width: 100%; border-radius: 12px; overflow: hidden; background: #eee;"></div>
                    <div id="qr-result" class="mt-3"></div>
                </div>

                <!-- GPS Status Card -->
                <div class="card-bl p-4 shadow-sm text-center">
                    <h5><i class="bi bi-geo-alt me-2 text-secondary"></i> Định vị GPS</h5>
                    <p id="location-status" class="small text-muted mb-3">Đang kiểm tra vị trí...</p>
                    <button id="btn-gps-check" class="btn btn-outline-bl btn-sm rounded-pill px-4">Xác nhận bằng vị trí</button>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Multimedia Portal Modal -->
<div class="modal fade" id="multimediaModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow-lg overflow-hidden">
            <div class="position-relative">
                <img id="modal-img" src="" class="w-100" style="height: 200px; object-fit: cover;">
                <div class="position-absolute top-0 end-0 m-3">
                    <button type="button" class="btn-close btn-close-white bg-dark p-2 rounded-circle" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="position-absolute bottom-0 start-0 w-100 p-3 bg-gradient-dark text-white">
                    <h4 id="modal-title" class="mb-0 fw-bold"></h4>
                </div>
            </div>
            <div class="modal-body p-4 text-center">
                <p id="modal-story" class="text-muted small mb-4" style="line-height: 1.6;"></p>
                <div class="d-grid gap-2">
                    <button class="btn btn-primary-bl rounded-pill" onclick="window.location.href='/profile'">Xem Hồ sơ & Huy hiệu</button>
                    <button class="btn btn-outline-bl rounded-pill" data-bs-dismiss="modal">Tiếp tục khám phá</button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.bg-gradient-dark { background: linear-gradient(to top, rgba(0,0,0,0.8), transparent); }
</style>

<script src="https://unpkg.com/html5-qrcode"></script>
<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.5.1/dist/confetti.browser.min.js"></script>

<script>
// QR Scanner Logic
function onScanSuccess(decodedText, decodedResult) {
    document.getElementById('qr-result').innerHTML = `<div class="alert alert-success">Đã quét thành công! Đang xử lý...</div>`;
    let slug = decodedText;
    if (decodedText.includes('/')) {
        slug = decodedText.split('/').pop();
    }
    verifyCheckin(slug, 'qr');
}

let html5QrcodeScanner = new Html5QrcodeScanner("reader", { fps: 10, qrbox: 250, videoConstraints: { facingMode: "environment" } });
html5QrcodeScanner.render(onScanSuccess);

// GPS Logic
document.getElementById('btn-gps-check').addEventListener('click', () => {
    document.getElementById('location-status').innerHTML = '<i class="bi bi-hourglass-split"></i> Đang xác thực tọa độ...';
    if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(pos => {
            verifyCheckin('<%= slug || "" %>', 'gps', pos.coords.latitude, pos.coords.longitude);
        });
    } else {
        alert("Trình duyệt không hỗ trợ định vị.");
    }
});

function verifyCheckin(slug, method, lat = null, lng = null) {
    if (!slug) {
        alert("Thiếu thông tin địa điểm để check-in.");
        return;
    }
    
    if (method === 'gps' && lat === null) {
        navigator.geolocation.getCurrentPosition(pos => {
            verifyCheckin(slug, 'gps', pos.coords.latitude, pos.coords.longitude);
        });
        return;
    }

    axios.post('/api/checkin', {
        slug: slug,
        method: method,
        lat: lat,
        lng: lng
    }).then(res => {
        if (res.data.success) {
            confetti({ particleCount: 150, spread: 100, origin: { y: 0.7 } });
            showMultimediaPortal(res.data.destination);
        } else {
            alert('Thất bại: ' + res.data.message);
            document.getElementById('location-status').innerHTML = 'Xác thực thất bại. Vui lòng thử lại.';
        }
    }).catch(err => {
        alert('Lỗi: ' + (err.response?.data?.message || err.message));
        document.getElementById('location-status').innerHTML = 'Lỗi kết nối.';
    });
}

function showMultimediaPortal(dest) {
    document.getElementById('modal-title').innerText = dest.name;
    document.getElementById('modal-img').src = '/images/' + (dest.cover_image || 'hero-1.png');
    document.getElementById('modal-story').innerText = dest.story || "Chào mừng bạn đến với địa điểm văn hóa đặc sắc của Bình Lợi.";

    const myModal = new bootstrap.Modal(document.getElementById('multimediaModal'));
    myModal.show();
}
</script>
