# BÌNH LỢI HEALING — Apache Rewrite
Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Bỏ qua các file và thư mục có thật (như public/css/style.css)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Mọi thứ khác vào index.php
    RewriteRule ^(.*)$ index.php?url=$1 [L,QSA]
</IfModule>
